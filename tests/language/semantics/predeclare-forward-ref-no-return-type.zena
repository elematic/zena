// @mode: check
// Mutual recursion: caller → helper → caller, no return type annotations.
// With lazy resolution, this is detected as a cycle and requires annotations.
let caller = (n: i32) => {
  helper(n);
};

let helper = (n: i32) => { // @error: Recursive function requires an explicit return type annotation
  if (n > 0) {
    caller(n - 1);
  }
};
