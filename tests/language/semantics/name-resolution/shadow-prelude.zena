// @mode: check

// Locally defining a class with the same name as a prelude type should shadow it.
class Box<T> {
  var value: T;
  new(value: T) : value = value {}
}

let b1: Box<i32> = new Box<i32>(42);
let b2: Box<i32> = b1;

// Should NOT be the prelude Box, should be the local Box.
// We can check this by making sure it behaves correctly and doesn't get confused.
// Let's also check we can instantiate it with string-convert, etc without issues.
let b3: Box<f32> = new Box<f32>(1.5);
