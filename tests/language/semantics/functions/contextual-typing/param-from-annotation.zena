// @mode: check
// Function parameter types are inferred from the annotation on the variable.
// Note: contextual typing from variable annotations is not yet supported —
// parameters must be explicitly annotated even with a function type annotation.

let f: (a: i32) => i32 = (x: i32) => x + 1;
let r: i32 = f(1);

// With multiple parameters
let add: (a: i32, b: i32) => i32 = (x: i32, y: i32) => x + y;
let s: i32 = add(1, 2);
