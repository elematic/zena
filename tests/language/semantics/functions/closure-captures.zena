// @mode: check
// Closures capture variables from their enclosing scope.

// Capture a single variable
let x: i32 = 10;
let addX = (y: i32): i32 => x + y;
let r: i32 = addX(5);

// Capture multiple variables
let a: i32 = 1;
let b: i32 = 2;
let sum = (): i32 => a + b;
let s: i32 = sum();

// Nested closures
let outer = (x: i32) => {
  let inner = (y: i32): i32 => x + y;
  return inner;
};
