// @mode: check
// Return type is inferred from the function body.

// Expression body: inferred from expression type
let add = (a: i32, b: i32) => a + b;
let r: i32 = add(1, 2);

// Block body: inferred from return statements
let greet = (name: String) => {
  return "Hello, " + name;
};
let s: String = greet("world");

// Inferred void when no return
let log = (msg: String) => {};
