// @mode: check
// Default parameter values: param keeps its declared type (no T | null widening).

// Default value with reference type
let greet = (name: String = "world") => "hello, " + name;
greet("Zena");
greet();

// Default value with primitive type — NOT widened to i32 | null
let inc = (x: i32 = 1) => x + 1;
inc(5);
inc();

// Multiple defaults
let range = (start: i32 = 0, end: i32 = 10) => end - start;
range(1, 5);
range(1);
range();

// Optional (?) without default IS widened to T | null
let maybe = (x?: String) => x;
let r: String | null = maybe();
