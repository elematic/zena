// @mode: check
// Union dedup with function types: identical function signatures in both
// branches should collapse to a single function type.

let pickFn = (x: boolean) => {
  if (x) { return (n: i32) => "pos"; }
  return (n: i32) => "neg";
};

// Both branches return (i32) => String, so the result should be that type.
let result = pickFn(true)(42);
let s: String = result;
