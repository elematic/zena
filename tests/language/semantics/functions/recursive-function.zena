// @mode: check
// Recursive functions require an explicit return type annotation.

// Valid: recursive with return type annotation
let countdown = (n: i32): i32 => if (n > 0) { countdown(n - 1) } else { 0 };
let r: i32 = countdown(5);

// Valid: mutual recursion (both annotated)
let isEven = (n: i32): boolean => if (n == 0) { true } else { isOdd(n - 1) };
let isOdd = (n: i32): boolean => if (n == 0) { false } else { isEven(n - 1) };
