// @mode: check

declare function computeValue(x: i32): i32;
declare function computeValue(x: String, loc: String | null = __LOCATION__): i32;

export let testOverloads = (): void => {
  // Should pick the first overload
  let a: i32 = computeValue(42);
  
  // Should pick the second overload. 
  // The __LOCATION__ default parameter will be injected by the compiler,
  // increasing the arguments length passed to the type checker.
  // This verifies our fix for the 'Index out of bounds' error.
  let b: i32 = computeValue("hello");
};
