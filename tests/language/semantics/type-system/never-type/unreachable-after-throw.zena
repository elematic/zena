// @mode: check
import {Error} from 'zena:error';

// A function annotated `: never` must have a never-typed body.
let fail = (): never => {
  throw new Error("unreachable");
};

// After a throw in one branch, the remaining code is still reachable via
// other paths — but the thrown value is typed `never`.
let safeDiv = (a: i32, b: i32): i32 => {
  if (b == 0) {
    throw new Error("division by zero");
  }
  return a;
};
