// @mode: check

// This test is about plain top-level union algebra only.
// `never` in a direct union is absorbed: `String | never` simplifies to `String`.
// Correlated inline tuple unions like `(true, T) | (false, never)` are handled
// separately by control-flow/pattern narrowing rules.
let test = (x: String | never) => {
  let y: String = x;
};
