// @mode: check

class Box<T> {
  value: T;
  new(this.value);
}

type MyBox<T> = Box<T>;
type StringBox = MyBox<String>;

let b1: MyBox<i32> = new Box(123);
let b2: StringBox = new Box("hello");
let b3: MyBox<String> = new Box("nope");

let b4: MyBox<i32> = new Box("error"); // @error: Type mismatch
