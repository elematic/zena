// @mode: check

// Tests that union types correctly subsume subtypes while preserving nullability,
// ensuring that a union of `Type | null` and `I32` (a subtype of `Type`) results
// in `Type | null`. This correctly causes a type error when assigned to a 
// non-nullable `Type`.
class Type {}
class I32 extends Type {}

let f = (t: Type | null, i32Type: I32, cond: boolean): Type => {
  let r = if (cond) { t } else { i32Type };
  return r; // @error:
};
