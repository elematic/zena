// @mode: check

import { MyMixin } from './lib.zena';

class Applied with MyMixin {
  new();
}

let test = (): void => {
  let c = new Applied();
  let v: i32 = c.mixinMethod();

  // But this should fail, because the method returns i32, not String.
  let s: String = c.mixinMethod(); // @error: Type mismatch
};