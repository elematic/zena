// @mode: check
// Case class: var field has setter, immutable field does not
class Counter(name: string, var count: i32)

let c = new Counter('test', 0);
// Mutable field assignment should work
c.count = 1;
// Immutable field: name has no setter, so assigning through member expression
// will go through the fields path (allowed until immutable-fields branch lands)
let n: string = c.name;
