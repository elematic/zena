// @mode: check
// Generic type argument inference with wrong type should produce error.

class Box<T> {
  value: T;
  new(this.value);
}

class Wrapper<T> {
  inner: Box<T>;
  new(this.inner);
}

// Inferred T = i32, so value should be i32.
let b = new Box(42);
let wrong: String = b.value; // @error: Type mismatch

// Inferred T = i32 from Box<i32>, so inner.value should be i32.
let b2 = new Box<i32>(10);
let w = new Wrapper(b2);
let bad: String = w.inner.value; // @error: Type mismatch
