// @mode: check
interface Identifiable {
  getId(): i32;
}

class Logger<T extends Identifiable> {
  logId(item: T): i32 {
    return item.getId();
  }
}

class User implements Identifiable {
  getId(): i32 { return 1; }
}

class BadUser {}

let l = new Logger<User>();
let id: i32 = l.logId(new User());
let bad = new Logger<BadUser>(); // @error: does not satisfy constraint
