// @mode: check
// Nested generic inference: infer T from Box<T> against Box<i32>.

class Box<T> {
  value: T;
  new(this.value);
}

class Wrapper<T> {
  inner: Box<T>;
  new(this.inner);
}

// T should be inferred as i32 from Box<i32> argument.
let b1 = new Box<i32>(42);
let w1 = new Wrapper(b1);
let v1: i32 = w1.inner.value;

// T should be inferred as String from Box<String> argument.
let b2 = new Box<String>("hello");
let w2 = new Wrapper(b2);
let v2: String = w2.inner.value;
