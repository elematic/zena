// @mode: check
// @result: 1

sealed class Node {
  case ClassType
  case MixinType
  case InterfaceType
  case TypeAliasType
  case OtherType
}

type GenericNamedType = ClassType | MixinType | InterfaceType | TypeAliasType;

let check = (t: GenericNamedType): i32 => {
  return match (t) {
    case ClassType {}: 1
    case MixinType {}: 2
    case InterfaceType {}: 3
    case TypeAliasType {}: 4
  };
};

export let main = (): i32 => {
  return check(new ClassType());
};
