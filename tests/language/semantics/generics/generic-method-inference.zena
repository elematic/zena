// @mode: check

// Tests generic type argument inference from closure bodies passed to 
// generic method calls, including proper return type inference for block bodies
// and argument adaptation.
class Seq<T> {
  map<U>(f: (item: T) => U): Seq<U> {
    return this as any as Seq<U>;
  }
}

class Type {}
class ErrorType extends Type {}

let f = (seq: Seq<String>): Seq<Type> => {
  return seq.map((item) => {
    return if (item == "error") {
      new ErrorType() as Type;
    } else {
      new Type();
    };
  });
};
