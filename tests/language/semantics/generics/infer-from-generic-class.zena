// @mode: check
// Nested generic inference: infer T from Pair<T, U> against Pair<i32, String>.

class Pair<A, B> {
  first: A;
  second: B;
  new(this.first, this.second);
}

class Holder<A, B> {
  pair: Pair<A, B>;
  new(this.pair);
}

// A and B should be inferred from Pair<i32, String>.
let p = new Pair<i32, String>(1, "hello");
let h = new Holder(p);
let v1: i32 = h.pair.first;
let v2: String = h.pair.second;
