// @mode: check

export let main = (cond: boolean): void => {
  var out = "str";
  var num = 0;

  // The condition evaluates to a union of string | number implicitly inside
  // an ExpressionStatement. It shouldn't trigger "cannot mix primitive and
  // reference types" because it's a void context, so the result type is Void.
  if (cond) {
    out = "hello";
  } else {
    num = 42;
  }

  // Same thing here using match
  match (cond) {
    case true: out = "wow"
    case false: num = 1
  };
};
