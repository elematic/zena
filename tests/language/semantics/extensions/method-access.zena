// @mode: check
// Extension class method access: requires cast to extension type

class MyValue {
  new() {}
}

extension class ValueExt on MyValue {
  getValue(): i32 {
    return 42;
  }
}

let testMethodAccess = () => {
  let val: MyValue = new MyValue();
  // Method is only available via the extension type (with cast)
  let result = (val as ValueExt).getValue(); // OK - cast to extension type
};
