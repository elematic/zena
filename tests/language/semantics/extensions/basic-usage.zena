// @mode: check
// Extension class basic usage: static methods, getters, this resolution

class MyArray {
  new() {}
}

extension class ArrayExt on MyArray {
  static new() {}
  length: i32 { get { return 0; } }
}

extension class ArrayTest on MyArray {
  test() {
    let a: MyArray = this; // Should be valid - this resolves to underlying type
  }
}
