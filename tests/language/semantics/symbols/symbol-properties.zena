// @mode: check

symbol mySym;
symbol otherSym;

class MyClass {
  var :mySym: i32;

  new(symVal: i32) {
    this.:mySym = symVal;
  }

  test(): void {
    this.:mySym = 42;
    let x: i32 = this.:mySym;
    
    this.:otherSym = 10; // @error: otherSym
    let y: String = this.:mySym; // @error: mismatch
  }
}

let testOutside = (): void => {
  let m = new MyClass(10);
  let a: i32 = m.:mySym;
  let b = m.:otherSym; // @error: otherSym
};