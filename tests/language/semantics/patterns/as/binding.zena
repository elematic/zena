// @mode: check
// An as-pattern binds the matched value to a name while also destructuring it
sealed class Shape {
  case Circle(radius: i32)
  case Rect(w: i32, h: i32)
}

let s: Shape = new Circle(5);
let r = match (s) {
  case Circle {} as c: c.radius
  case Rect {} as rect: rect.w + rect.h
};
let n: i32 = r;
