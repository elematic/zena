// @mode: check
interface Runnable {
  run(): i32;
}

class Task implements Runnable {
  run(): i32 { return 1; }
}

class Nothing {}

class ImplicitImpl {
  run(): i32 { return 2; }
}

let t: Runnable = new Task();
let nope: Runnable = new Nothing(); // @error: Type mismatch

let t2: Runnable = new ImplicitImpl(); // @error: Type mismatch
