// @mode: check
interface Supplier<T> {
  get(): T;
}

class NumberSupplier implements Supplier<i32> {
  get(): i32 { return 42; }
}

class StringSupplier implements Supplier<String> {
  get(): String { return "hi"; }
}

class BadSupplier implements Supplier<String> {
  get(): i32 { return 42; } // @error: incorrectly implements interface
}
