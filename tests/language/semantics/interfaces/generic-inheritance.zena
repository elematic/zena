// @mode: check

interface Iter<V> {
  next(): V | null;
}

interface StringIter extends Iter<String> {
  peek(): String | null;
}

class MyIter implements StringIter { // @error: incorrectly implements interface
  peek(): String | null { return null; }
  // Returns i32 instead of String
  next(): i32 | null { return null; }
}