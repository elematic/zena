// @mode: check
interface D {
  d(): void;
}
interface B extends D {
  b(): void;
}
interface C extends D {
  c(): void;
}
interface A extends B, C {
  a(): void;
}

class Impl implements A {
  a(): void {}
  b(): void {}
  c(): void {}
  d(): void {}
}

class BadImpl implements A {
  a(): void {}
  b(): void {}
  c(): void {}
  // d(): void {}
} // @error: incorrectly implements interface
