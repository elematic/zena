// @mode: check
// A type parameter can shadow a class name in an outer scope.
class Box {
  value: i32;
  new(value: i32) : value = value {}
}

// Inside this function, 'Box' refers to the type parameter, not the class.
let identity = <Box>(x: Box): Box => x;

// At module scope, 'Box' still refers to the class.
let b: Box = new Box(42);
