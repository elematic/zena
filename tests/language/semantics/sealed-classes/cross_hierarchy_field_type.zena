// @mode: check
// Inline variant field whose type is an inline variant from another sealed class
sealed class Wrapper {
  case Box(content: Item)
}

sealed class Item {
  case Leaf(value: i32)
  case Branch(left: Item, right: Item)
}

// Destructuring Box should resolve `content` as Item (not unknown)
let unwrap = (w: Wrapper): i32 => match (w) {
  case Box {content}: match (content) {
    case Leaf {value}: value
    case Branch {left, right}: 0
  }
};
