// @mode: check
// After a null guard that definitely exits, the variable should be narrowed.

class Wrapper(value: i32)

// Basic null guard with return
let basic = (x: Wrapper | null): i32 => {
  if (x == null) { return 0; }
  // x should be narrowed to Wrapper here
  let w: Wrapper = x;
  return w.value;
};

// Inverse: if x != null exits, x is null after
let inverse = (x: Wrapper | null): i32 => {
  if (x != null) { return x.value; }
  // x should be narrowed to null here
  return 0;
};

// Else branch definitely exits
let elseExit = (x: Wrapper | null): i32 => {
  if (x != null) {
    // x should be narrowed to Wrapper here (already works)
    let w: Wrapper = x;
    return w.value;
  } else {
    return 0;
  }
};
