// @mode: check
// while (x != null) should narrow x to non-null inside the loop body.

class Node {
  value: i32;
  next: Node | null;
  new(this.value, this.next);
}

let sum = (head: Node | null): i32 => {
  var current = head;
  var total = 0;
  while (current != null) {
    // current should be narrowed to Node here
    total += current.value;
    current = current.next;
  }
  return total;
};
