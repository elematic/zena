// @mode: check
// In a match case body the matched variable is narrowed to the matched type
sealed class Shape {
  case Circle(radius: f64)
  case Rect(width: f64, height: f64)
}
let area = (s: Shape): f64 => match (s) {
  case Circle {radius}: radius * radius
  case Rect {width, height}: width * height
};
