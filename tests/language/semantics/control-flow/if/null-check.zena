// @mode: check
// Basic null narrowing: x !== null, null !== x, and x != null
// all narrow the variable to non-null in the truthy branch.

class Node {
  value: i32;
  new(this.value);
}

// !== null narrows to non-null
let withNotEquals = (node: Node | null): i32 => {
  if (node !== null) {
    return node.value;
  }
  return 0;
};

// null !== x also narrows
let withReversed = (node: Node | null): i32 => {
  if (null !== node) {
    return node.value;
  }
  return 0;
};

// != null narrows too
let withLooseNotEquals = (node: Node | null): i32 => {
  if (node != null) {
    return node.value;
  }
  return 0;
};

// Type restores after if block — second check still works
let withRestore = (node: Node | null): i32 => {
  if (node !== null) {
    let v = node.value;
  }
  if (node !== null) {
    let v2 = node.value;
  }
  return 0;
};
