// @mode: check
// Verify that if-expressions narrow types in branches, like if-statements do.

class Wrapper(value: i32)

// != null narrows to non-null in consequent
let basic = (x: Wrapper | null): Wrapper =>
  if (x != null) { x } else { new Wrapper(0) };

// == null narrows to null in consequent, non-null in alternate
let inverse = (x: Wrapper | null): Wrapper =>
  if (x == null) { new Wrapper(0) } else { x };

// is-expression narrowing in if-expression
let isNarrow = (x: Wrapper | null): i32 =>
  if (x is Wrapper) { x.value } else { 0 };
