// @mode: check
// In the else branch of (x == null || y == null), both x and y are non-null.

class Box {
  value: i32;
  new(this.value);
}

let check = (x: Box | null, y: Box | null): i32 => {
  if (x == null || y == null) {
    return 0;
  }
  // Both x and y are narrowed to Box here
  return x.value + y.value;
};

// Single || with null check narrows in else
let single = (x: Box | null): i32 => {
  if (x == null || x.value < 0) {
    return 0;
  }
  return x.value;
};
