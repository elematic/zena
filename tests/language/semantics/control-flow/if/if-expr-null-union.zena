// @mode: check

// Tests that if-expressions correctly compute the union of branch types while
// preserving nullability. The union of `A | null` and `B` (where `B extends A`)
// produces `A | null`, which correctly causes a type error when assigned to a non-nullable `A`.
class A {}
class B extends A {}

let f = (x: A | null, y: B, cond: boolean): A => {
  let result = if (cond) { x } else { y };
  return result; // @error:
};
