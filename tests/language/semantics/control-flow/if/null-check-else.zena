// @mode: check
// In the else branch of !== null, the variable is narrowed to null.
// Accessing a property on null should produce an error.

class Node {
  value: i32;
  new(this.value);
}

// else branch of !== null: node is null
let elseIsNull = (node: Node | null): i32 => {
  if (node !== null) {
    return node.value;
  } else {
    return node.value; // @error: null
  }
};

// == null truthy branch means value IS null
let eqNullTruthy = (node: Node | null): i32 => {
  if (node == null) {
    return node.value; // @error: null
  }
  return 0;
};

// == null else branch means value is NOT null
let eqNullElse = (node: Node | null): i32 => {
  if (node == null) {
    return 0;
  } else {
    return node.value;
  }
};

// === null else branch means value is NOT null
let strictEqElse = (node: Node | null): i32 => {
  if (node === null) {
    return 0;
  } else {
    return node.value;
  }
};
