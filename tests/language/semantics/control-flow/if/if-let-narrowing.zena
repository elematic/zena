// @mode: check
// Inside an if-let body, destructured fields have the narrowed type from the matched variant.

sealed class Option {
  case Some(value: i32)
  case None
}

let opt: Option = new Some(42);
if (let Some {value} = opt) {
  let n: i32 = value;
}

// Nested sealed class — fields from matched variant are accessible
sealed class Result {
  case Ok(data: String)
  case Err(message: String)
}

let r: Result = new Ok("hello");
if (let Ok {data} = r) {
  let s: String = data;
}
