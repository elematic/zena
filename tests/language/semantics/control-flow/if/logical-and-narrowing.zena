// @mode: check
// Logical && should narrow the left side for the right side.

class Box {
  value: i32;
  new(this.value);
}

let check = (x: Box | null): i32 => {
  // After x != null on the left, x should be narrowed to Box on the right.
  if (x != null && x.value > 0) {
    return 1;
  }
  return 0;
};
