// @mode: check
// Warnings for unnecessary ?? and ??= usage.

class Box {
  new() {}
}

// ?? on non-nullable LHS warns
let a: Box = new Box();
let b = a ?? new Box();  // @warning: not nullable

// ??= on non-nullable LHS warns
let withNonNullable = (): void => {
  var x: Box = new Box();
  x ??= new Box();  // @warning: not nullable
};
