// @mode: check
// Equality operators require comparable types.

class Cat {
  name: String;
  new(this.name);
}
class Dog {
  name: String;
  new(this.name);
}

// Same type: always allowed.
let a = 42 == 42;
let b = "hello" != "world";

// Class vs class: allowed (reference equality).
let c1 = new Cat("Whiskers");
let c2 = new Cat("Mittens");
let d1 = new Dog("Rex");
let same = c1 == c2;

// Incompatible types: rejected.
let bad1 = 42 == "hello"; // @error: cannot apply operator
let bad2 = true != 42; // @error: cannot apply operator
