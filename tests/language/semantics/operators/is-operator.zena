// @mode: check
// The `is` operator checks if a value is an instance of a type.

class Animal {
  new() {}
}

class Dog extends Animal {
  new() : super() {}
}

class Cat {
  new() {}
}

// is returns bool
let check = (a: Animal): boolean => a is Dog;

// is works on union types
let checkUnion = (x: Cat | Dog): boolean => x is Cat;

// is works with null
let checkNull = (x: Animal | null): boolean => x is Animal;
