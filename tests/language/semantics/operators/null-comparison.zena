// @mode: check
// Comparing a reference type to null with == and != is valid.

class Loc {
  line: i32;
  new(this.line);
}

// Nullable union compared to null.
let loc: Loc | null = null;
let a = loc != null;
let b = loc == null;

// Null literal on the left side.
let c = null == loc;
let d = null != loc;
