// @mode: check
// Field types are inferred from their initializers when no annotation is given.

class Config {
  var count = 0;
  var label = "default";

  getCount(): i32 { return this.count; }
  getLabel(): String { return this.label; }
}

let c = new Config();
let n: i32 = c.getCount();
let s: String = c.getLabel();
