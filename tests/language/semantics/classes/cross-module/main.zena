// @mode: check

import { MyClass, processClass } from './lib.zena';

let test = (): void => {
  let c = new MyClass(42);
  let explicitlyTyped: MyClass = c;

  // This should correctly type check across modules.
  processClass(explicitlyTyped);

  // But this should fail, because the type isn't String.
  let s: String = explicitlyTyped; // @error: Type mismatch
};