// @mode: check
// Valid method call on a class instance
class Greeter {
  var name: String = "";
  new(name: String) : name = name {}
  greet(): String {
    return "Hello, " + this.name;
  }
  add(a: i32, b: i32): i32 {
    return a + b;
  }
}
let g = new Greeter("world");
let msg = g.greet();
let sum = g.add(1, 2);
