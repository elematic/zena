// @mode: check

class Point {
  x: i32;
  new(this.x);

  operator ==(other: Point): boolean {
    return this.x == other.x;
  }
}

let p1 = new Point(1);
let p2 = new Point(2);

let b1: boolean = p1 == p2;
let b2: boolean = p1 != p2;

let b3 = p1 == 1; // @error: Type mismatch
let b4 = p1 != "hello"; // @error: Type mismatch
