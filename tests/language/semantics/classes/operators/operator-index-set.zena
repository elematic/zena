// @mode: check

class MyArray<T> {
  new();

  operator [](index: i32): T {
    throw new Error("stub");
  }

  operator [](index: i32): T {
    throw new Error("stub");
  }

  operator []=(index: i32, value: T): void {
  }
}

let arr = new MyArray<i32>();

arr[0] = 42;
arr[1] = "string"; // @error: Type mismatch

arr["key"] = 42; // @error: Type mismatch
