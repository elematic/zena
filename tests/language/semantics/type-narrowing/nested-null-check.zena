// @mode: check
// Nested null checks: narrowing multiple nullable variables in sequence.

class Node {
  value: i32;
  next: Node | null;
  new(this.value, this.next);
}

let process = (node: Node | null): i32 => {
  if (node !== null) {
    let v = node.value;
    let next = node.next;
    if (next !== null) {
      return next.value;
    }
  }
  return 0;
};
