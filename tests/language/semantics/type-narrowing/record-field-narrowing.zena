// @mode: check
// Record fields can be narrowed after null checks (records are immutable).

class Container {
  value: i32;
  new(this.value);
}

// Record field narrows after null check
let basicRecordNarrowing = (r: {inner: Container | null}): i32 => {
  if (r.inner !== null) {
    return r.inner.value;
  }
  return 0;
};

// Nested record field narrows after null check
let nestedRecordNarrowing = (r: {outer: {inner: Container | null}}): i32 => {
  if (r.outer.inner !== null) {
    return r.outer.inner.value;
  }
  return 0;
};
