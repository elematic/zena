// @mode: check
// Narrowing after `if (x == null) { x = value; }` and `x ??= value`.
// Both patterns guarantee x is non-null afterward.

import {HashSet} from 'zena:set';

// Pattern 1: if (x == null) { x = value; }
let withIfAssign = (): void => {
  var x: HashSet<String> | null = null;
  if (x == null) {
    x = new HashSet<String>();
  }
  // x should be narrowed to HashSet<String> here — no cast needed.
  x.add("hello");
};

// Pattern 2: x ??= value
let withNullishAssign = (): void => {
  var x: HashSet<String> | null = null;
  x ??= new HashSet<String>();
  // x should be narrowed to HashSet<String> here — no cast needed.
  x.add("hello");
};
