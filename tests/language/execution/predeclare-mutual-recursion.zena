// @mode: run
// @result: 1
// Mutual recursion: isEven/isOdd with fully annotated types.
let isEven = (n: i32): boolean => {
  if (n == 0) { return true; }
  return isOdd(n - 1);
};

let isOdd = (n: i32): boolean => {
  if (n == 0) { return false; }
  return isEven(n - 1);
};

export let main = () => {
  if (isEven(10)) { return 1; }
  return 0;
};
