// @mode: run
// @result: true
class Point(x: i32, y: i32)

export let main = (): boolean => {
  let a = new Point(1, 2);
  let b = new Point(1, 2);
  let c = new Point(3, 4);
  // Same points should have the same hash code
  // Different points should (likely) have different hash codes
  return a.hashCode() == b.hashCode() && a.hashCode() != c.hashCode();
};
