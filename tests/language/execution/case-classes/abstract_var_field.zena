// @mode: run
// @result: 999
// Abstract var field allows writing through base type
abstract class Node {
  abstract var loc: i32;
}
class Binary extends Node {
  var loc: i32;
  left: i32;
  right: i32;
  new(left: i32, right: i32, loc: i32) : left = left, right = right, loc = loc, super() {}
}

let setLoc = (n: Node, v: i32): void => { n.loc = v; };
let getLoc = (n: Node): i32 => n.loc;

export let main = (): i32 => {
  let b: Node = new Binary(10, 20, 100);
  setLoc(b, 999);
  return getLoc(b);
};
