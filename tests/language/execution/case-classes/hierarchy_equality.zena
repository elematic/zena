// @mode: run
// @result: 1
// Case class equality with sealed variants: same-type same-fields
// are equal, same-type different-fields are not equal.
// Case classes use sub final so ref.test is an exact type check.
sealed class Shape {
  case Circle(radius: i32)
  case Square(side: i32)
}

export let main = (): i32 => {
  let c1 = new Circle(5);
  let c2 = new Circle(5);
  let c3 = new Circle(10);
  let s = new Square(5);

  // Same class, same fields -> equal
  let sameEqual = c1 == c2;

  // Same class, different fields -> not equal
  let diffFields = c1 == c3;

  // Square equality
  let squareEqual = s == new Square(5);

  if (sameEqual && !diffFields && squareEqual) {
    return 1;
  }
  return 0;
};
