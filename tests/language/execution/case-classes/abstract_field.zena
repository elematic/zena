// @mode: run
// @result: 300
// Abstract field on abstract class, concrete subclass field satisfies it
abstract class Node {
  abstract loc: i32;
}
class Binary extends Node {
  left: i32;
  right: i32;
  loc: i32;
  new(left: i32, right: i32, loc: i32) : left = left, right = right, loc = loc, super() {}
}
class Literal extends Node {
  value: i32;
  loc: i32;
  new(value: i32, loc: i32) : value = value, loc = loc, super() {}
}

let getLoc = (n: Node): i32 => n.loc;

export let main = (): i32 => {
  let b: Node = new Binary(10, 20, 100);
  let l: Node = new Literal(42, 200);
  return getLoc(b) + getLoc(l);
};
