// @mode: run
// @result: 15
class Counter {
  var #value: i32 = 0;

  new() {}

  add(n: i32): void {
    this.#value += n;
  }

  subtract(n: i32): void {
    this.#value -= n;
  }

  multiply(n: i32): void {
    this.#value *= n;
  }

  getValue(): i32 {
    return this.#value;
  }
}

export let main = (): i32 => {
  let c = new Counter();
  c.add(10);       // 0 + 10 = 10
  c.subtract(3);   // 10 - 3 = 7
  c.add(1);        // 7 + 1 = 8
  c.multiply(2);   // 8 * 2 = 16
  c.subtract(1);   // 16 - 1 = 15
  return c.getValue();
};
