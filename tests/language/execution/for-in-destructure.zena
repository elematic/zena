// @mode: run
// @stdout: found a=1\nfound b=2\ndone

import {HashMap} from 'zena:map';
import {Box} from 'zena:box';

export let main = (): void => {
  let map = new HashMap<String, Box<i32>>();
  map['a'] = new Box(1);
  map['b'] = new Box(2);

  // Destructure MapEntry in for-in loop
  var foundA = false;
  var foundB = false;
  for (let {key, value} in map) {
    if (key == 'a' && value.value == 1) foundA = true;
    if (key == 'b' && value.value == 2) foundB = true;
  }
  if (foundA) console.log('found a=1');
  if (foundB) console.log('found b=2');
  console.log('done');
};
