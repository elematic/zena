// @mode: run
// @stdout: found a\nfound b\ndone

import {HashMap} from 'zena:map';
import {Box} from 'zena:box';

export let main = (): void => {
  let map = new HashMap<String, Box<i32>>();
  map['a'] = new Box(1);
  map['b'] = new Box(2);

  // Iterate directly on the Iterator returned by keys()
  var foundA = false;
  var foundB = false;
  for (let key in map.keys()) {
    if (key == 'a') foundA = true;
    if (key == 'b') foundB = true;
  }
  if (foundA) console.log('found a');
  if (foundB) console.log('found b');
  console.log('done');
};
