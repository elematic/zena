// @mode: run
// @result: 0

var sideEffect = 0;

class Box {
  value: i32 = 0;
  new(v: i32) { this.value = v; }
}

let makeBox = () => {
  sideEffect = 100;
  return new Box(0);
};

export let main = () => {
  let b: Box | null = new Box(42);
  let result = b ?? makeBox();
  return sideEffect;
};
