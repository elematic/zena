// @mode: run
// @result: 1

class Inner {
  value: i32 = 0;
  new(v: i32) { this.value = v; }
}

class Container {
  inner: Inner | null = null;
  new(i: Inner) { this.inner = i; }
}

export let main = () => {
  let c: Container | null = null;
  // If this doesn't short-circuit, accessing c.inner would trap
  let result = c?.inner;
  if (result == null) { return 1; }
  return 0;
};
