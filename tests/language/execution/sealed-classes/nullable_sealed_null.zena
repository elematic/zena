// @mode: run
// @result: 0
// Match on sealed class | null with variant patterns (null)
sealed class Shape {
  case Circle(radius: i32)
  case Rect(w: i32, h: i32)
}

let describe = (s: Shape | null): i32 => match (s) {
  case Circle {}: 1
  case Rect {}: 2
  case _: 0
};

export let main = (): i32 => describe(null);
