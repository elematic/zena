// @mode: run
// @result: 10
// Distributed variants with pattern matching
sealed class Expr {
  case Add, Lit
}

class Add(left: Expr, right: Expr) extends Expr
class Lit(value: i32) extends Expr

let eval = (e: Expr): i32 => match (e) {
  case Lit { value as v }: v
  case Add { left as l, right as r }: eval(l) + eval(r)
};

export let main = (): i32 => {
  let e = new Add(new Lit(3), new Lit(7));
  return eval(e);
};
