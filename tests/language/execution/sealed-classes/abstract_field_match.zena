// @mode: run
// @result: 132
// Abstract field with match destructuring
sealed class Node {
  case Binary, Literal
  abstract loc: i32;
}
class Binary(left: i32, right: i32, loc: i32) extends Node
class Literal(value: i32, loc: i32) extends Node

let getLoc = (n: Node): i32 => match (n) {
  case Binary {loc}: loc
  case Literal {loc}: loc
};

export let main = (): i32 => {
  let b: Node = new Binary(1, 2, 55);
  let l: Node = new Literal(9, 77);
  return getLoc(b) + getLoc(l);
};
