// @mode: run
// @result: 12
// Inline variants match second case
sealed class Shape {
  case Circle(radius: i32)
  case Rect(width: i32, height: i32)
}

export let main = (): i32 => {
  let s: Shape = new Rect(3, 4);
  return match (s) {
    case Circle { radius as r }: r
    case Rect { width as w, height as h }: w * h
  };
};
