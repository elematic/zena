// @mode: run
// @result: 300
// Sealed class with abstract field, case class params satisfy it
sealed class Node {
  case Binary, Literal
  abstract loc: i32;
}
class Binary(left: i32, right: i32, loc: i32) extends Node
class Literal(value: i32, loc: i32) extends Node

let getLoc = (n: Node): i32 => n.loc;

export let main = (): i32 => {
  let b: Node = new Binary(10, 20, 100);
  let l: Node = new Literal(42, 200);
  return getLoc(b) + getLoc(l);
};
