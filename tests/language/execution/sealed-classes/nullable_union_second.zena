// @mode: run
// @result: 120
// Match on X | Y | null union with class patterns (second class)
class A { x: i32; new(this.x); }
class B { y: i32; new(this.y); }

let process = (obj: A | B | null): i32 => match (obj) {
  case A {x}: x
  case B {y}: y + 100
  case _: -1
};

export let main = (): i32 => process(new B(20));
