// @mode: run
// @result: 18
// Multiple abstract fields
sealed class Expr {
  case Num, Add
  abstract line: i32;
  abstract col: i32;
}
class Num(value: i32, line: i32, col: i32) extends Expr
class Add(left: Expr, right: Expr, line: i32, col: i32) extends Expr

let getLine = (e: Expr): i32 => e.line;
let getCol = (e: Expr): i32 => e.col;

export let main = (): i32 => {
  let a: Expr = new Num(10, 1, 5);
  let b: Expr = new Add(a, a, 2, 10);
  return getLine(a) + getCol(a) + getLine(b) + getCol(b);
};
