// @mode: run
// @result: 5
// Inline variants with pattern matching
sealed class Shape {
  case Circle(radius: i32)
  case Rect(width: i32, height: i32)
}

export let main = (): i32 => {
  let s: Shape = new Circle(5);
  return match (s) {
    case Circle { radius as r }: r
    case Rect {}: 0
  };
};
