// @mode: run
// @result: 42
// Destructure a variant field whose type is a variant from another sealed class
sealed class Wrapper {
  case Box(content: Item)
}

sealed class Item {
  case Leaf(value: i32)
  case Branch(left: Item, right: Item)
}

export let main = (): i32 => {
  let w: Wrapper = new Box(new Leaf(42));
  return match (w) {
    case Box {content}: match (content) {
      case Leaf {value}: value
      case Branch {}: 0
    }
  };
};
