// @mode: run
// @result: 110
// Abstract var field on sealed class with mutable case params
sealed class Node {
  case Binary, Literal
  abstract var loc: i32;
}
class Binary(left: i32, right: i32, var loc: i32) extends Node
class Literal(value: i32, var loc: i32) extends Node

let setLoc = (n: Node, v: i32): void => { n.loc = v; };
let getLoc = (n: Node): i32 => n.loc;

export let main = (): i32 => {
  let b: Node = new Binary(10, 20, 100);
  let l: Node = new Literal(42, 200);
  setLoc(b, 50);
  setLoc(l, 60);
  return getLoc(b) + getLoc(l);
};
