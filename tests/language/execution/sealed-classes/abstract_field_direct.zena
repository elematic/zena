// @mode: run
// @result: 300
// Abstract field accessed directly on concrete type
sealed class Node {
  case Binary, Literal
  abstract loc: i32;
}
class Binary(left: i32, right: i32, loc: i32) extends Node
class Literal(value: i32, loc: i32) extends Node

export let main = (): i32 => {
  let b = new Binary(10, 20, 100);
  let l = new Literal(42, 200);
  return b.loc + l.loc;
};
