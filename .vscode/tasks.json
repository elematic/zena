{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch-vscode-extension",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build", "-w", "vscode-zena", "--", "--watch"],
      "problemMatcher": [
        {
          "owner": "wireit",
          "source": "Wireit",
          "severity": "error",
          "pattern": {
            "regexp": ""
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "\\[build\\]",
            "endsPattern": "Watching for file changes"
          }
        },
        "$tsc-watch"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
