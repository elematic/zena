{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Zena Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-zena"
      ],
      "outFiles": ["${workspaceFolder}/packages/vscode-zena/**/*.{js,cjs}"],
      "preLaunchTask": "watch-vscode-extension"
    }
  ]
}
