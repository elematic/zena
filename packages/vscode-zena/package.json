{
  "name": "vscode-zena",
  "displayName": "Zena Language",
  "description": "Language support for the Zena programming language",
  "version": "0.1.0",
  "publisher": "zena-lang",
  "type": "module",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.cjs",
  "activationEvents": [
    "onLanguage:zena"
  ],
  "scripts": {
    "build": "wireit",
    "package": "npm run build && vsce package --no-dependencies",
    "install-ext": "npm run package && code --install-extension vscode-zena-0.1.0.vsix"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:ts",
        "build:lsp"
      ]
    },
    "build:ts": {
      "command": "tsc",
      "files": [
        "src/**/*.{ts,cts}",
        "tsconfig.json"
      ],
      "output": [
        "extension.cjs",
        "extension.cjs.map",
        "lib/"
      ],
      "clean": "if-file-deleted"
    },
    "build:lsp": {
      "command": "node --stack-size=4096 ../cli/lib/cli.js build ../zena-compiler/zena/lsp.zena --target host -o lsp.wasm",
      "files": [
        "../zena-compiler/zena/**/*.zena"
      ],
      "output": [
        "lsp.wasm"
      ],
      "dependencies": [
        "../cli:build"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.115.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "~5.9.3",
    "wireit": "^0.14.4"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "zena",
        "aliases": [
          "Zena",
          "zena"
        ],
        "extensions": [
          ".zena"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "zena.helloWorld",
        "title": "Hello World",
        "category": "Zena"
      }
    ],
    "grammars": [
      {
        "language": "zena",
        "scopeName": "source.zena",
        "path": "./syntaxes/zena.tmLanguage.json"
      },
      {
        "scopeName": "text.html.markdown.zena.codeblock",
        "path": "./syntaxes/zena-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.zena": "zena"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/justinfagnani/zena"
  },
  "license": "MIT",
  "dependencies": {
    "@zena-lang/runtime": "^0.0.1"
  }
}
