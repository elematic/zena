{
  "name": "@zena-lang/zena-compiler",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./zena/*": "./zena/*.zena"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "zena"
  ],
  "scripts": {
    "build": "wireit",
    "build:tests": "wireit",
    "test": "wireit"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:ts",
        "build:tests"
      ]
    },
    "build:ts": {
      "command": "tsc",
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "zena/**/*.zena"
      ],
      "output": [
        "index.{js,d.ts,js.map,d.ts.map}"
      ],
      "clean": "if-file-deleted"
    },
    "build:tests": {
      "command": "node scripts/build-wasi-tests.js",
      "files": [
        "scripts/build-wasi-tests.js",
        "zena/**/*.zena"
      ],
      "output": [
        "zena/out/**/*.wasm"
      ],
      "dependencies": [
        "../cli:build"
      ]
    },
    "test": {
      "command": "node scripts/run-wasmtime.js",
      "files": [
        "scripts/run-wasmtime.js",
        "../../tests/**/*.zena",
        "../../tests/**/*.json"
      ],
      "output": [],
      "dependencies": [
        "build:tests"
      ]
    }
  },
  "devDependencies": {
    "@zena-lang/compiler": "*",
    "typescript": "^5.3.3",
    "wireit": "^0.14.4"
  }
}
