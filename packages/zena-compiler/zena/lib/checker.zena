/**
 * Type checker for the Zena compiler.
 *
 * The checker walks the AST, infers types, validates compatibility,
 * and populates the SemanticModel with type information. The AST is
 * never mutated — all semantic data lives in the SemanticModel.
 *
 * Architecture:
 *
 * Two-phase checking (checkModule):
 *   Phase 1 — Register all declaration signatures: imports, classes,
 *     interfaces, enums, mixins, type aliases, declared functions, and
 *     symbols. After Phase 1, every type identity and member signature
 *     is available for lookup.
 *   Phase 2 — Check all bodies: class method bodies, field initializers,
 *     accessor bodies, variable declarations, expression statements, and
 *     all other non-declaration statements. Interface conformance and
 *     abstract-field validation also run here.
 *   This separation ensures that forward references between classes work:
 *   class A's method can call class B's method even when B is declared
 *   after A, because B's member signatures are registered in Phase 1
 *   before A's method body is checked in Phase 2.
 *
 * Name resolution:
 * - Value names delegate to the scope pass's ReferenceMap
 *   (Identifier → SymbolInfo → binding type). The checker has no value
 *   scope stack.
 * - Binding types are stored in SemanticModel via SymbolInfo.id keys,
 *   set at declaration time and read at reference time.
 * - Type annotation resolution uses the checker's own type-name scope
 *   stack, since the scope pass doesn't record type annotation references.
 * - Built-in types (i32, boolean, etc.) are pre-registered as singletons
 *   in the type-name scope.
 *
 * On-demand type materialization:
 * - Type declarations (classes, interfaces, etc.) are materialized
 *   on demand by resolveTypeName when first referenced, before their
 *   full Phase 1 registration runs.
 *
 * Other:
 * - Narrowing uses SymbolInfo.id keys for identity-based precision.
 * - The checker produces a SemanticModel + diagnostics as output.
 */

import { Array } from 'zena:array';
import { HashMap } from 'zena:map';
import { HashSet } from 'zena:set';
import { parseI32 } from 'zena:string-convert';
import {
  Node, Module, SourceLocation,
  // Expressions
  Expression, Identifier, NumberLiteral, StringLiteral, BooleanLiteral,
  NullLiteral, BinaryExpression, UnaryExpression, AssignmentExpression,
  FunctionExpression, CallExpression, MemberExpression, IndexExpression,
  ThisExpression, SuperExpression, NewExpression, AsExpression, IsExpression,
  ArrayLiteral, RecordLiteral, TupleLiteral, MapLiteral,
  TemplateLiteral, TaggedTemplateExpression, MatchExpression, IfExpression,
  ThrowExpression, TryExpression, RangeExpression, PipelineExpression,
  PipePlaceholder,
  // Statements
  Statement, VariableDeclaration, ExpressionStatement, BlockStatement,
  ReturnStatement, BreakStatement, ContinueStatement, IfStatement,
  WhileStatement, ForStatement, ForInStatement, ClassDeclaration,
  InterfaceDeclaration, EnumDeclaration, MixinDeclaration,
  TypeAliasDeclaration, ImportDeclaration, ExportAllDeclaration,
  ExportFromDeclaration, DeclareFunction, SymbolDeclaration,
  // Patterns
  Pattern, IdentifierPattern, RecordPattern, TuplePattern, AsPattern,
  ClassPattern, LogicalPattern, AssignmentPattern,
  // Type Annotations
  TypeAnnotation, NamedTypeAnnotation, UnionTypeAnnotation,
  FunctionTypeAnnotation, LiteralTypeAnnotation, RecordTypeAnnotation,
  TupleTypeAnnotation, InlineTupleTypeAnnotation, ThisTypeAnnotation,
  // Helpers
  TypeParameter, Parameter, FieldDefinition, MethodDefinition,
  AccessorDeclaration, MatchCase, PropertyAssignment, SpreadElement,
  LetPatternCondition, BindingProperty, PropertySignature, CatchClause,
  CaseClassParam, FieldInitializer, SuperInitializer, EnumMember, MapEntry,
  MethodSignature, AccessorSignature, SetterInfo, SealedVariant
} from './ast.zena';
import {
  Type, I32Type, U32Type, I64Type, U64Type, F32Type, F64Type,
  BooleanType, VoidType, NullType, NeverType, UnknownType, AnyType,
  AnyRefType, EqRefType, ByteArrayType,
  BoolLiteralType, StringLiteralType,
  ArrayType, TupleType as TupleT, InlineTupleType as InlineTupleT,
  UnionType as UnionT, RecordType as RecordT,
  FunctionType, ClassType, InterfaceType, MixinType,
  TypeParameterType, TypeAliasType, SymbolType, ThisType,
  instantiateClassType, instantiateInterfaceType, instantiateMixinType,
  instantiateTypeAliasType, GenericNamedType,
  isNumericType, isIntegerType, isFloatType, is64BitType,
  numericTypeName, isBooleanLike, widenType, baseType,
  promoteNumeric, typeToString
} from './types.zena';
import { SemanticModel } from './semantic-model.zena';
import {
  Diagnostic, DiagnosticBag, DiagnosticCode, DiagnosticSeverity
} from './diagnostics.zena';
import { ScopeResult, SymbolInfo, SymbolId, ModuleExports } from './scope.zena';

/**
 * Internal state for the type checker.
 *
 * Name resolution for values (variables, parameters, functions) is
 * delegated to the scope pass's ReferenceMap. The checker no longer
 * maintains its own value scope stack. Instead:
 *
 *   Declaration time: the checker stores a binding's type in the
 *   SemanticModel via `model.setBindingType(symbolInfo, type)`.
 *
 *   Reference time: an Identifier is resolved through the ReferenceMap
 *   to its SymbolInfo, then `model.getBindingType(info)` recovers the
 *   type. Narrowings are checked first (keyed by SymbolInfo.id).
 *
 * The checker still maintains its own type-name scope stack because
 * the scope pass's ReferenceMap only covers value-namespace identifiers,
 * not type annotations. Type names (i32, MyClass, T, etc.) are resolved
 * through this stack.
 */
class CheckerContext {
  model = new SemanticModel();
  diagnostics: DiagnosticBag;

  /**
   * Type namespace scope stack: maps type names (i32, MyClass, etc.) to Types.
   * The scope pass doesn't record type annotation references in the
   * ReferenceMap, so the checker resolves type names itself.
   */
  #typeScopes = new Array<HashMap<String, Type>>();

  /**
   * Narrowed types (control-flow narrowing) per scope level.
   * Keyed by SymbolInfo.id so narrowing survives across scopes that
   * reference the same binding, and is robust against shadowing.
   * Kept as a stack so narrowings are automatically discarded when
   * their enclosing scope exits.
   */
  #narrowings = new Array<HashMap<SymbolId, Type>>();

  /**
   * The current function's expected return type, or null if not in a function.
   */
  var #returnType?: Type = null;

  /**
   * Inferred return types collected from return statements.
   * Used when a function has no explicit return type annotation.
   */
  var #inferredReturnTypes = new Array<Type>();

  /**
   * Stack of class types being checked. The top is the innermost class.
   * Used by ThisExpression, super resolution, and member access validation.
   */
  #classStack = new Array<ClassType>();

  /**
   * Loop nesting depth (for break/continue validation).
   */
  var #loopDepth = 0;

  /**
   * Pending function declarations indexed by SymbolInfo.id.
   * Populated by a pre-scan in checkModule so that resolveIdentifier
   * can lazily resolve forward-referenced function types from their
   * annotations without waiting for the main pass to reach them.
   */
  #pendingFunctions = new HashMap<SymbolId, Node>();

  /**
   * SymbolInfo IDs currently being lazily resolved.
   * Used for cycle detection: if we re-enter resolution for an ID
   * already in this set, we've found a recursive reference.
   */
  #resolving = new HashSet<SymbolId>();

  /**
   * Pipeline value stack for `|>` operator.
   * `$` placeholder resolves to the top of this stack.
   */
  #pipelineStack = new Array<Type>();

  /**
   * The scope result from name resolution (for reference lookups).
   */
  #scopeResult?: ScopeResult | null;

  /**
   * Type ID counter for generating unique IDs (ClassType, InterfaceType).
   */
  var #nextTypeId = 0;

  /**
   * SymbolInfo IDs currently being materialized (cycle detection).
   * Prevents infinite recursion when type A references type B
   * which references type A. Keyed by SymbolInfo.id rather than
   * name strings, since names only have meaning within a scope.
   */
  #pendingTypes = new HashSet<SymbolId>();

  /**
   * Prelude exports: types available globally from stdlib modules.
   * Populated by the Compiler before checking user modules.
   * Falls back to these when local type lookup fails.
   */
  #preludeTypes = new HashMap<String, Type>();

  /**
   * Prelude value exports: values available globally from stdlib modules.
   */
  #preludeValues = new HashMap<String, Type>();

  /**
   * Dependency exports map: import specifier → ModuleExports.
   * Populated by the compiler so the checker can resolve imported types.
   */
  var #depExports?: HashMap<String, ModuleExports> | null = null;

  /**
   * Dependency semantic models: import specifier → SemanticModel.
   * When provided, the checker can look up actual resolved types from
   * already-checked dependency modules instead of creating empty stubs.
   */
  var #depModels?: HashMap<String, SemanticModel> | null = null;

  /** The file path of the module being checked. */
  #filePath: String;

  emitLocations: boolean;

  new(
      file: String,
      scopeResult: ScopeResult | null,
      depExports: HashMap<String, ModuleExports> | null,
      depModels: HashMap<String, SemanticModel> | null,
      emitLocations: boolean = false)
    : diagnostics = new DiagnosticBag(file),
      #filePath = file,
      #scopeResult = scopeResult,
      #depExports = depExports,
      #depModels = depModels,
      emitLocations = emitLocations {
    
    // Initialize with module-level scope.
    this.#typeScopes.push(new HashMap<String, Type>());
    this.#narrowings.push(new HashMap<SymbolId, Type>());

    // Wire the scope pass's maps into the SemanticModel
    // so consumers have a single object for all queries.
    if (scopeResult != null) {
      let sr = scopeResult as ScopeResult;
      this.model.setReferences(sr.references);
      this.model.setDeclarations(sr.declarations);
    }

    // Pre-register built-in types in the type namespace.
    this.declareBuiltinType("i32", new I32Type());
    this.declareBuiltinType("u32", new U32Type());
    this.declareBuiltinType("i64", new I64Type());
    this.declareBuiltinType("u64", new U64Type());
    this.declareBuiltinType("f32", new F32Type());
    this.declareBuiltinType("f64", new F64Type());
    this.declareBuiltinType("boolean", new BooleanType());
    this.declareBuiltinType("void", new VoidType());
    this.declareBuiltinType("null", new NullType());
    this.declareBuiltinType("never", new NeverType());
  }

  /**
   * Register a built-in type in the type namespace.
   */
  declareBuiltinType(name: String, t: Type): void {
    this.#typeScopes[0][name] = t;
  }

  /**
   * Generate a fresh type ID.
   */
  freshTypeId(): i32 {
    let id = this.#nextTypeId;
    this.#nextTypeId = this.#nextTypeId + 1;
    return id;
  }

  // --- Scope management ---

  /**
   * Push a new scope frame (for type names and narrowings).
   * Value-namespace scoping is handled by the scope pass's ReferenceMap.
   */
  enterScope(): void {
    this.#typeScopes.push(new HashMap<String, Type>());
    this.#narrowings.push(new HashMap<SymbolId, Type>());
  }

  exitScope(): void {
    this.#typeScopes.pop();
    this.#narrowings.pop();
  }

  // --- Value binding (via SemanticModel + SymbolInfo) ---

  /**
   * Store a binding's type in the SemanticModel, keyed by SymbolInfo.
   * Called when processing declarations (VariableDeclaration, parameters).
   */
  declareBinding(info: SymbolInfo, t: Type): void {
    this.model.setBindingType(info, t);
    // Also store on the declaration node for getNodeType() queries.
    if (info.declaration != null) {
      this.model.setNodeType(info.declaration as Node, t);
    }
  }

  /**
   * Resolve an identifier's type via the ReferenceMap.
   * Checks narrowings first, then falls back to the binding type.
   * If no type is stored yet, attempts lazy resolution for function
   * declarations (enabling forward references and self-recursion).
   */
  resolveIdentifier(node: Node): Type | null {
    let info = this.model.resolve(node);
    if (info == null) { return null; }
    let si = info as SymbolInfo;

    // Check narrowings first (innermost to outermost).
    var i = this.#narrowings.length - 1;
    while (i >= 0) {
      if (this.#narrowings[i].has(si.id)) {
        return this.#narrowings[i][si.id];
      }
      i = i - 1;
    }

    // Fall back to the binding type stored by the checker.
    let bt = this.model.getBindingType(si);
    if (bt != null) { return bt as Type; }

    // No type stored yet — attempt lazy resolution for pending functions.
    if (this.#pendingFunctions.has(si.id)) {
      return this.lazyResolveFunction(si, this.#pendingFunctions[si.id]);
    }

    // On-demand: if the declaration is a type (class, interface, mixin,
    // sealed variant), materialize it via resolveTypeName so forward
    // references in the value namespace work.
    // For DeclareFunction, register a placeholder so forward refs don't fail.
    let decl = si.declaration;
    if (decl != null) {
      let declNode = decl as Node;
      var typeName: String | null = null;
      match (declNode) {
        case ClassDeclaration {name}: { typeName = name.name; }
        case InterfaceDeclaration {name}: { typeName = name.name; }
        case MixinDeclaration {name}: { typeName = name.name; }
        case SealedVariant {name}: { typeName = name.name; }
        case DeclareFunction: {
          // Forward reference to a declare function — bind as unknown
          // placeholder; the main pass will replace with the real type.
          this.declareBinding(si, new UnknownType());
          return new UnknownType();
        }
        case _: {}
      }
      if (typeName != null) {
        // resolveTypeName will materialize + declareBinding if needed.
        let t = this.resolveTypeName(typeName as String);
        if (t != null) { return t; }
      }
    }
    return null;
  }

  /**
   * Register a function declaration for lazy resolution.
   * Called during the checkModule pre-scan.
   */
  registerPendingFunction(id: SymbolId, funcExpr: Node): void {
    this.#pendingFunctions[id] = funcExpr;
  }

  /**
   * Lazily resolve a function's type from its annotations or body.
   *
   * If the function is fully annotated (all params + return type),
   * resolves the exact FunctionType from annotations. If it has no
   * return type but is a pure forward reference (no cycle), eagerly
   * checks the function body to infer the type. If it's in a recursive
   * cycle without a return type annotation, reports an error.
   */
  lazyResolveFunction(si: SymbolInfo, funcNode: Node): Type | null {
    match (funcNode) {
      case FunctionExpression {typeParameters, params, returnType, body, loc}: {
        // Check for cycle — if we're already resolving this symbol,
        // it's a recursive reference.
        if (this.#resolving.has(si.id)) {
          // Recursive call. If fully annotated, we can resolve from annotations.
          if (returnType != null) {
            // Resolve from annotations only (no body check needed).
            return this.resolveFunctionFromAnnotations(typeParameters, params, returnType as TypeAnnotation, si);
          } else {
            // Recursive without return type annotation — error.
            this.error(
              "Recursive function requires an explicit return type annotation.",
              DiagnosticCode.TypeMismatch,
              loc
            );
            return new UnknownType();
          }
        }

        // Not a cycle. Mark as resolving.
        this.#resolving.add(si.id);

        let funcType = if (returnType != null) {
          // Fully annotated — resolve from annotations.
          this.resolveFunctionFromAnnotations(typeParameters, params, returnType as TypeAnnotation, si)
        } else {
          // No return type annotation — eagerly check the function body.
          checkFunctionExpression(this, typeParameters, params, null, body, loc, null)
        };

        // Store result so subsequent references find it immediately.
        this.declareBinding(si, funcType);

        // Clean up resolving state.
        this.#resolving.delete(si.id);

        return funcType;
      }
      case _: { return null; }
    }
  }

  /**
   * Resolve a function type from its annotations only (no body check).
   * Used for fully-annotated functions and recursive references.
   */
  resolveFunctionFromAnnotations(
    typeParameters: Array<TypeParameter> | null,
    params: Array<Parameter>,
    returnTypeAnn: TypeAnnotation,
    si: SymbolInfo
  ): Type {
    // Enter a temporary scope for type parameter names.
    this.enterScope();
    var resolvedTypeParams: Array<TypeParameterType> | null = null;
    if (typeParameters != null) {
      let tps = typeParameters as Array<TypeParameter>;
      resolvedTypeParams = new Array<TypeParameterType>();
      var tpi = 0;
      while (tpi < tps.length) {
        let tp = tps[tpi];
        var constraint: Type | null = null;
        if (tp.constraint != null) {
          constraint = resolveTypeAnnotation(this, tp.constraint as TypeAnnotation);
        }
        let tpType = new TypeParameterType(tp.name, constraint, null);
        this.declareTypeName(tp.name, tpType);
        (resolvedTypeParams as Array<TypeParameterType>).push(tpType);
        tpi += 1;
      }
    }

    // Resolve parameter types.
    let paramTypes = new Array<Type>();
    let paramNames = new Array<String>();
    var pi = 0;
    while (pi < params.length) {
      let param = params[pi];
      paramNames.push(param.name.name);
      if (param.typeAnnotation != null) {
        paramTypes.push(resolveTypeAnnotation(this, param.typeAnnotation as TypeAnnotation));
      } else {
        paramTypes.push(new UnknownType());
      }
      pi += 1;
    }

    // Resolve return type.
    let retType = resolveTypeAnnotation(this, returnTypeAnn);

    this.exitScope();

    // Build the FunctionType.
    let funcType = new FunctionType(paramTypes, paramNames, retType);
    if (resolvedTypeParams != null) {
      funcType.typeParameters = resolvedTypeParams;
    }

    return funcType as Type;
  }

  // --- Type name resolution ---

  /**
   * Declare a type name in the current scope.
   */
  declareTypeName(name: String, t: Type): void {
    let top = this.#typeScopes[this.#typeScopes.length - 1];
    top[name] = t;
  }

  /**
   * Declare a type name in the module (outermost) scope. Used for sealed
   * variant types that need to be visible outside the class scope.
   */
  declareModuleTypeName(name: String, t: Type): void {
    this.#typeScopes[0][name] = t;
  }

  /**
   * Resolve a type name: check the checker's type scopes first, then
   * prelude, then fall through to scope analysis for on-demand
   * materialization. When a name is found in scope analysis but not yet
   * materialized, creates the Type from the declaration AST node.
   */
  resolveTypeName(name: String): Type | null {
    // Check local scopes first (innermost to outermost).
    var i = this.#typeScopes.length - 1;
    while (i >= 0) {
      if (this.#typeScopes[i].has(name)) {
        return this.#typeScopes[i][name];
      }
      i = i - 1;
    }
    // Fall back to prelude types.
    if (this.#preludeTypes.has(name)) {
      return this.#preludeTypes[name];
    }
    // On-demand: look up in scope analysis and materialize.
    return this.#materializeFromScope(name);
  }

  /**
   * Look up a type name in scope analysis and materialize a Type object
   * on demand. Returns null if the name doesn't exist in scope analysis.
   * Sets all boolean flags from the AST node at creation time.
   */
  #materializeFromScope(name: String): Type | null {
    if (this.#scopeResult == null) { return null; }
    let sr = this.#scopeResult as ScopeResult;
    let si = sr.rootScope.resolveType(name);
    if (si == null) { return null; }
    let info = si as SymbolInfo;

    // Cycle detection — keyed by SymbolInfo.id, not name.
    if (this.#pendingTypes.has(info.id)) {
      return null;
    }
    this.#pendingTypes.add(info.id);

    let t = this.#materializeType(info);
    if (t != null) {
      let materialized = t as Type;
      this.declareModuleTypeName(name, materialized);
      // Also bind in the value namespace so forward references work.
      // The DeclarationMap records the value-namespace SymbolInfo, so
      // we need to look up via the declaration AST node.
      if (info.declaration != null) {
        let valueInfo = this.model.resolveDeclaration(info.declaration as Node);
        if (valueInfo != null) {
          this.declareBinding(valueInfo as SymbolInfo, materialized);
        }
      }
    }

    this.#pendingTypes.delete(info.id);
    return t;
  }

  /**
   * Create a Type from a SymbolInfo's declaration node.
   * Sets all boolean flags immediately from the AST.
   */
  #materializeType(info: SymbolInfo): Type | null {
    let decl = info.declaration;
    if (decl == null) {
      return null;
    }
    let node = decl as Node;
    match (node) {
      case ClassDeclaration as cd: {
        let ct = new ClassType(this.freshTypeId(), cd.name.name);
        ct.isFinal = cd.isFinal;
        ct.isAbstract = cd.isAbstract;
        ct.isSealed = cd.isSealed;
        if (cd.isSealed) {
          ct.isAbstract = true;
        }
        if (cd.caseParams != null && !cd.isSealed) {
          ct.isFinal = true;
          ct.isCaseClass = true;
        }
        ct.isExtension = cd.isExtension;
        // Pre-register forward variant names for sealed classes.
        if (cd.isSealed && cd.sealedVariants != null) {
          let variants = cd.sealedVariants as Array<SealedVariant>;
          for (let variant in variants) {
            if (variant.params == null) {
              let forwardVariantNames = ct.forwardVariantNames ??= new HashSet<String>();
              forwardVariantNames.add(variant.name.name);
            }
          }
        }
        return ct;
      }
      case InterfaceDeclaration as id: {
        return new InterfaceType(this.freshTypeId(), id.name.name);
      }
      case MixinDeclaration as md: {
        return new MixinType(md.name.name);
      }
      case SealedVariant as sv: {
        let ct = new ClassType(this.freshTypeId(), sv.name.name);
        ct.isCaseClass = true;
        ct.isFinal = true;
        return ct;
      }
      case EnumDeclaration as ed: {
        return new TypeAliasType(ed.name.name, null, new I32Type(), true);
      }
      case TypeAliasDeclaration as ta: {
        this.enterScope();
        let declarationParams = ta.typeParameters;
        var typeParams: Array<TypeParameterType> | null = null;
        if (declarationParams != null) {
          let tempTypeParams = new Array<TypeParameterType>();
          typeParams = tempTypeParams;
          for (let param in declarationParams) {
            let tpType = new TypeParameterType(param.name, null, null);
            tempTypeParams.push(tpType);
            this.declareTypeName(tpType.name, tpType);
          }

          // Resolve constraints
          for (var i = 0; i < declarationParams.length; i += 1) {
            let param = declarationParams[i];
            if (param.constraint != null) {
              tempTypeParams[i].constraint =
                resolveTypeAnnotation(this, param.constraint as TypeAnnotation);
            }
            if (param.defaultType != null) {
              tempTypeParams[i].defaultType =
                resolveTypeAnnotation(this, param.defaultType as TypeAnnotation);
            }
          }
        }
        
        let targetType = resolveTypeAnnotation(this, ta.typeAnnotation);
        this.exitScope();
        
        return new TypeAliasType(ta.name.name, typeParams, targetType, ta.isDistinct);
      }
      case _: {
        return null;
      }
    }
  }

  /**
   * Register a prelude type (available globally without import).
   */
  registerPreludeType(name: String, t: Type): void {
    this.#preludeTypes[name] = t;
  }

  /**
   * Register a prelude value (available globally without import).
   */
  registerPreludeValue(name: String, t: Type): void {
    this.#preludeValues[name] = t;
  }

  /**
   * Resolve a prelude value by name.
   */
  resolvePreludeValue(name: String): Type | null {
    if (this.#preludeValues.has(name)) {
      return this.#preludeValues[name];
    }
    return null;
  }

  /**
   * Resolve a prelude type by name. Used for identity-based type comparisons
   * (e.g. checking if a ClassType is the prelude Array).
   */
  resolvePreludeType(name: String): Type | null {
    if (this.#preludeTypes.has(name)) {
      return this.#preludeTypes[name];
    }
    return null;
  }

  // --- Pipeline ---

  pushPipelineValue(t: Type): void { this.#pipelineStack.push(t); }
  popPipelineValue(): void { this.#pipelineStack.pop(); }
  pipelineValueType: Type | null {
    get {
      if (this.#pipelineStack.length == 0) { return null; }
      return this.#pipelineStack[this.#pipelineStack.length - 1];
    }
  }

  // --- Dependency exports ---

  /**
   * Get the file path of the module being checked.
   */
  filePath: String {
    get { return this.#filePath; }
  }

  /**
   * Get the dependency exports map (import specifier → ModuleExports).
   */
  depExports: HashMap<String, ModuleExports> | null {
    get { return this.#depExports; }
  }

  /**
   * Get the dependency semantic models (import specifier → SemanticModel).
   */
  depModels: HashMap<String, SemanticModel> | null {
    get { return this.#depModels; }
  }

  // --- Return type ---

  returnType: Type | null {
    get { return this.#returnType; }
  }

  setReturnType(t: Type | null): void {
    this.#returnType = t;
  }

  // --- Inferred return types ---

  inferredReturnTypes: Array<Type> {
    get { return this.#inferredReturnTypes; }
  }

  setInferredReturnTypes(a: Array<Type>): void {
    this.#inferredReturnTypes = a;
  }

  addInferredReturnType(t: Type): void {
    this.#inferredReturnTypes.push(t);
  }

  // --- Loop depth ---

  enterLoop(): void { this.#loopDepth = this.#loopDepth + 1; }
  exitLoop(): void { this.#loopDepth = this.#loopDepth - 1; }
  inLoop(): boolean { return this.#loopDepth > 0; }

  // --- Class stack ---

  enterClass(ct: ClassType): void { this.#classStack.push(ct); }
  exitClass(): void { this.#classStack.pop(); }
  currentClass: ClassType | null {
    get {
      if (this.#classStack.length == 0) { return null; }
      return this.#classStack[this.#classStack.length - 1];
    }
  }

  // --- Narrowing ---

  /**
   * Narrow a binding's type within the current scope.
   * Keyed by SymbolInfo.id for identity-based precision.
   */
  narrowBinding(info: SymbolInfo, t: Type): void {
    let top = this.#narrowings[this.#narrowings.length - 1];
    top[info.id] = t;
  }

  // --- Scope result access ---

  scopeResult: ScopeResult | null {
    get { return this.#scopeResult; }
  }

  // --- Error helpers ---

  error(message: String, code: DiagnosticCode, loc: SourceLocation | null): void {
    this.diagnostics.reportError(message, code, loc);
  }

  warning(message: String, code: DiagnosticCode, loc: SourceLocation | null): void {
    this.diagnostics.reportWarning(message, code, loc);
  }
}

/**
 * Register the standard prelude types in a CheckerContext.
 *
 * TEMPORARY SCAFFOLDING — this function should be deleted.
 *
 * The prelude provides fundamental types like String, Array, etc.
 * that are implicitly available in all Zena code without explicit import.
 * Currently these are hardcoded stubs, but the correct approach (already
 * used by the bootstrap compiler) is:
 *
 *   1. Compile the stdlib .zena files through the normal pipeline.
 *   2. Populate prelude types/values from the checked modules' exports.
 *   3. Look up well-known types by canonical module path (e.g.
 *      "String" → zena:string's exports) instead of stub identity.
 *
 * The self-hosted compiler already loads, parses, and scope-analyzes
 * stdlib modules in compile(). What's missing is:
 *   - Remove the `if (file.isStdlib) { continue; }` skip in
 *     checkCompilation() so stdlib modules get type-checked.
 *   - After checking prelude modules, populate #preludeTypes/#preludeValues
 *     from their CheckResult exports instead of these stubs.
 *   - Add a WELL_KNOWN_TYPE_MODULES map for identity-based lookups
 *     (resolvePreludeType("Iterable") → query zena:iterator's exports).
 *
 * The blocker is that the self-hosted checker doesn't yet support all
 * language features used in stdlib (interfaces + implements, extension
 * classes, @intrinsic/@external decorators, operator overloading).
 * As those features land, this function should shrink and eventually
 * disappear. See docs/design/self-hosted-compiler.md §"Prelude: From
 * Stubs to Real Stdlib".
 */
let registerStandardPrelude = (ctx: CheckerContext): void => {
  // String - the fundamental string type
  let stringType = new ClassType(ctx.freshTypeId(), "String");
  // Register operator + for string concatenation.
  let concatParams = new Array<Type>();
  concatParams.push(stringType);
  let concatMethod = new FunctionType(concatParams, null, stringType);
  stringType.methods["+"] = concatMethod;
  // Register operator == for string equality.
  let eqParams = new Array<Type>();
  eqParams.push(stringType);
  let eqRetType: Type = new BooleanType();
  let eqMethod = new FunctionType(eqParams, null, eqRetType);
  stringType.methods["=="] = eqMethod;
  // String members: length getter, startsWith, endsWith, sliceBytes, getByteAt
  stringType.methods["get#length"] = new FunctionType(new Array<Type>(), null, new I32Type());
  let startsWithParams = new Array<Type>();
  startsWithParams.push(stringType);
  stringType.methods["startsWith"] = new FunctionType(startsWithParams, null, new BooleanType());
  let endsWithParams = new Array<Type>();
  endsWithParams.push(stringType);
  stringType.methods["endsWith"] = new FunctionType(endsWithParams, null, new BooleanType());
  let sliceBytesParams = new Array<Type>();
  sliceBytesParams.push(new I32Type());
  sliceBytesParams.push(new I32Type());
  stringType.methods["sliceBytes"] = new FunctionType(sliceBytesParams, null, stringType);
  let getByteAtParams = new Array<Type>();
  getByteAtParams.push(new I32Type());
  stringType.methods["getByteAt"] = new FunctionType(getByteAtParams, null, new I32Type());
  ctx.registerPreludeType("String", stringType);
  ctx.registerPreludeValue("String", stringType);

  // Error - base error type
  let errorType = new ClassType(ctx.freshTypeId(), "Error");
  // Error.message field
  errorType.fields["message"] = stringType;
  // Error constructor: new Error(message: String)
  let errCtorParams = new Array<Type>();
  errCtorParams.push(stringType);
  let errCtorNames = new Array<String>();
  errCtorNames.push("message");
  errorType.constructorType = new FunctionType(errCtorParams, errCtorNames, errorType);
  ctx.registerPreludeType("Error", errorType);
  ctx.registerPreludeValue("Error", errorType);

  // Iterable<T> - the interface for for-in loops
  let iterableType = new InterfaceType(ctx.freshTypeId(), "Iterable");
  let iterableTParam = new TypeParameterType("T", null, null);
  let iterableTParams = new Array<TypeParameterType>();
  iterableTParams.push(iterableTParam);
  iterableType.typeParameters = iterableTParams;
  ctx.registerPreludeType("Iterable", iterableType);

  // FixedArray<T> - fixed-size array
  let fixedArrayType = new ClassType(ctx.freshTypeId(), "FixedArray");
  let fixedArrayTParam = new TypeParameterType("T", null, null);
  let fixedArrayTParams = new Array<TypeParameterType>();
  fixedArrayTParams.push(fixedArrayTParam);
  fixedArrayType.typeParameters = fixedArrayTParams;
  // FixedArray members: length getter, [] indexer, []= setter
  fixedArrayType.methods["get#length"] = new FunctionType(new Array<Type>(), null, new I32Type());
  let faIndexParams = new Array<Type>();
  faIndexParams.push(new I32Type());
  fixedArrayType.methods["[]"] = new FunctionType(faIndexParams, null, fixedArrayTParam);
  let faSetParams = new Array<Type>();
  faSetParams.push(new I32Type());
  faSetParams.push(fixedArrayTParam);
  fixedArrayType.methods["[]="] = new FunctionType(faSetParams, null, new VoidType());
  // push, pop (from GrowableArray trait)
  let faPushParams = new Array<Type>();
  faPushParams.push(fixedArrayTParam);
  fixedArrayType.methods["push"] = new FunctionType(faPushParams, null, new VoidType());
  fixedArrayType.methods["pop"] = new FunctionType(new Array<Type>(), null, fixedArrayTParam);
  // FixedArray<T> implements Iterable<T>
  let faIterableArgs = new Array<Type>();
  faIterableArgs.push(fixedArrayTParam);
  fixedArrayType.implementsList.push(instantiateInterfaceType(iterableType, faIterableArgs));
  ctx.registerPreludeType("FixedArray", fixedArrayType);
  ctx.registerPreludeValue("FixedArray", fixedArrayType);

  // Array<T> - growable array
  let arrayType = new ClassType(ctx.freshTypeId(), "Array");
  let arrayTParam = new TypeParameterType("T", null, null);
  let arrayTParams = new Array<TypeParameterType>();
  arrayTParams.push(arrayTParam);
  arrayType.typeParameters = arrayTParams;
  // Array members: length getter, push, pop, [] indexer, []= setter
  arrayType.methods["get#length"] = new FunctionType(new Array<Type>(), null, new I32Type());
  let aPushParams = new Array<Type>();
  aPushParams.push(arrayTParam);
  arrayType.methods["push"] = new FunctionType(aPushParams, null, new VoidType());
  arrayType.methods["pop"] = new FunctionType(new Array<Type>(), null, arrayTParam);
  let aIndexParams = new Array<Type>();
  aIndexParams.push(new I32Type());
  arrayType.methods["[]"] = new FunctionType(aIndexParams, null, arrayTParam);
  let aSetParams = new Array<Type>();
  aSetParams.push(new I32Type());
  aSetParams.push(arrayTParam);
  arrayType.methods["[]="] = new FunctionType(aSetParams, null, new VoidType());
  // Array constructor: new Array<T>() — capacity param optional, stubbed as zero-arg
  arrayType.constructorType = new FunctionType(new Array<Type>(), null, arrayType);
  // Array<T> implements Iterable<T>
  let aIterableArgs = new Array<Type>();
  aIterableArgs.push(arrayTParam);
  arrayType.implementsList.push(instantiateInterfaceType(iterableType, aIterableArgs));
  ctx.registerPreludeType("Array", arrayType);
  ctx.registerPreludeValue("Array", arrayType);

  // ImmutableArray<T> - immutable array with read-only indexer
  let immArrayType = new ClassType(ctx.freshTypeId(), "ImmutableArray");
  let immArrayTParam = new TypeParameterType("T", null, null);
  let immArrayTParams = new Array<TypeParameterType>();
  immArrayTParams.push(immArrayTParam);
  immArrayType.typeParameters = immArrayTParams;
  // Add read-only indexer ([] but no []=)
  let iaIndexerParams = new Array<Type>();
  iaIndexerParams.push(new I32Type());
  let iaIndexer = new FunctionType(iaIndexerParams, null, stringType);
  immArrayType.methods["[]"] = iaIndexer;
  // Add length getter
  let iaLengthGetter = new FunctionType(new Array<Type>(), null, new I32Type());
  immArrayType.methods["get#length"] = iaLengthGetter;
  // ImmutableArray<T> implements Iterable<T>
  let iaIterableArgs = new Array<Type>();
  iaIterableArgs.push(immArrayTParam);
  immArrayType.implementsList.push(instantiateInterfaceType(iterableType, iaIterableArgs));
  ctx.registerPreludeType("ImmutableArray", immArrayType);

  // TemplateStringsArray - for tagged template literals (immutable)
  let tsArrayType = new ClassType(ctx.freshTypeId(), "TemplateStringsArray");
  // Private fields (stored for private access validation)
  tsArrayType.fields["#strings"] = immArrayType;
  tsArrayType.fields["#raw"] = immArrayType;
  // Add read-only indexer ([] but no []=)
  let tsIndexerParams = new Array<Type>();
  tsIndexerParams.push(new I32Type());
  let tsIndexer = new FunctionType(tsIndexerParams, null, stringType);
  tsArrayType.methods["[]"] = tsIndexer;
  // Add length getter (no setter)
  let tsLengthGetter = new FunctionType(new Array<Type>(), null, new I32Type());
  tsArrayType.methods["get#length"] = tsLengthGetter;
  // Add raw getter (returns ImmutableArray<String>, no setter)
  let tsRawGetter = new FunctionType(new Array<Type>(), null, immArrayType);
  tsArrayType.methods["get#raw"] = tsRawGetter;
  ctx.registerPreludeType("TemplateStringsArray", tsArrayType);

  // Box<T> - optional wrapper
  let boxType = new ClassType(ctx.freshTypeId(), "Box");
  ctx.registerPreludeType("Box", boxType);
  ctx.registerPreludeValue("Box", boxType);

  // Option<T>, Some, None
  let optionType = new ClassType(ctx.freshTypeId(), "Option");
  let someType = new ClassType(ctx.freshTypeId(), "Some");
  let noneType = new ClassType(ctx.freshTypeId(), "None");
  ctx.registerPreludeType("Option", optionType);
  ctx.registerPreludeType("Some", someType);
  ctx.registerPreludeType("None", noneType);

  // Map, HashMap
  let mapType = new InterfaceType(ctx.freshTypeId(), "Map");
  let hashMapType = new ClassType(ctx.freshTypeId(), "HashMap");
  // HashMap<K, V> type parameters
  let hashMapKParam = new TypeParameterType("K", null, null);
  let hashMapVParam = new TypeParameterType("V", null, null);
  let hashMapTParams = new Array<TypeParameterType>();
  hashMapTParams.push(hashMapKParam);
  hashMapTParams.push(hashMapVParam);
  hashMapType.typeParameters = hashMapTParams;
  // HashMap members: get, set, has, delete, size, [], []=, keys, forEach, getOr, find, clear
  let hmGetParams = new Array<Type>();
  hmGetParams.push(hashMapKParam);
  let hmGetRetTypes = new Array<Type>();
  hmGetRetTypes.push(hashMapVParam);
  hmGetRetTypes.push(new BooleanType());
  let hmGetRetType: Type = new InlineTupleT(hmGetRetTypes);
  hashMapType.methods["get"] = new FunctionType(hmGetParams, null, hmGetRetType);
  let hmSetParams = new Array<Type>();
  hmSetParams.push(hashMapKParam);
  hmSetParams.push(hashMapVParam);
  hashMapType.methods["set"] = new FunctionType(hmSetParams, null, new VoidType());
  let hmHasParams = new Array<Type>();
  hmHasParams.push(hashMapKParam);
  hashMapType.methods["has"] = new FunctionType(hmHasParams, null, new BooleanType());
  let hmDeleteParams = new Array<Type>();
  hmDeleteParams.push(hashMapKParam);
  hashMapType.methods["delete"] = new FunctionType(hmDeleteParams, null, new BooleanType());
  hashMapType.methods["get#size"] = new FunctionType(new Array<Type>(), null, new I32Type());
  let hmIndexParams = new Array<Type>();
  hmIndexParams.push(hashMapKParam);
  hashMapType.methods["[]"] = new FunctionType(hmIndexParams, null, hashMapVParam);
  let hmIndexSetParams = new Array<Type>();
  hmIndexSetParams.push(hashMapKParam);
  hmIndexSetParams.push(hashMapVParam);
  hashMapType.methods["[]="] = new FunctionType(hmIndexSetParams, null, new VoidType());
  let hmGetOrParams = new Array<Type>();
  hmGetOrParams.push(hashMapKParam);
  hmGetOrParams.push(hashMapVParam);
  hashMapType.methods["getOr"] = new FunctionType(hmGetOrParams, null, hashMapVParam);
  hashMapType.methods["clear"] = new FunctionType(new Array<Type>(), null, new VoidType());
  let hmForEachCbParams = new Array<Type>();
  hmForEachCbParams.push(hashMapKParam);
  hmForEachCbParams.push(hashMapVParam);
  let hmForEachCbType = new FunctionType(hmForEachCbParams, null, new VoidType());
  let hmForEachParams = new Array<Type>();
  hmForEachParams.push(hmForEachCbType);
  hashMapType.methods["forEach"] = new FunctionType(hmForEachParams, null, new VoidType());
  // HashMap constructor: new HashMap<K, V>()
  hashMapType.constructorType = new FunctionType(new Array<Type>(), null, hashMapType);
  ctx.registerPreludeType("Map", mapType);
  ctx.registerPreludeType("HashMap", hashMapType);
  ctx.registerPreludeValue("HashMap", hashMapType);

  // Set, HashSet
  let setType = new InterfaceType(ctx.freshTypeId(), "Set");
  let hashSetType = new ClassType(ctx.freshTypeId(), "HashSet");
  let hashSetTParam = new TypeParameterType("T", null, null);
  let hashSetTParams = new Array<TypeParameterType>();
  hashSetTParams.push(hashSetTParam);
  hashSetType.typeParameters = hashSetTParams;
  // HashSet members: add, has, delete, clear, size, []
  let hsAddParams = new Array<Type>();
  hsAddParams.push(hashSetTParam);
  hashSetType.methods["add"] = new FunctionType(hsAddParams, null, new BooleanType());
  let hsHasParams = new Array<Type>();
  hsHasParams.push(hashSetTParam);
  hashSetType.methods["has"] = new FunctionType(hsHasParams, null, new BooleanType());
  let hsDeleteParams = new Array<Type>();
  hsDeleteParams.push(hashSetTParam);
  hashSetType.methods["delete"] = new FunctionType(hsDeleteParams, null, new BooleanType());
  hashSetType.methods["clear"] = new FunctionType(new Array<Type>(), null, new VoidType());
  hashSetType.methods["get#size"] = new FunctionType(new Array<Type>(), null, new I32Type());
  let hsIndexParams = new Array<Type>();
  hsIndexParams.push(hashSetTParam);
  hashSetType.methods["[]"] = new FunctionType(hsIndexParams, null, new BooleanType());
  // HashSet constructor: new HashSet<T>()
  hashSetType.constructorType = new FunctionType(new Array<Type>(), null, hashSetType);
  ctx.registerPreludeType("Set", setType);
  ctx.registerPreludeType("HashSet", hashSetType);
  ctx.registerPreludeValue("HashSet", hashSetType);

  // Sequence, MutableSequence
  let seqType = new InterfaceType(ctx.freshTypeId(), "Sequence");
  let mutSeqType = new InterfaceType(ctx.freshTypeId(), "MutableSequence");
  ctx.registerPreludeType("Sequence", seqType);
  ctx.registerPreludeType("MutableSequence", mutSeqType);

  // Range types
  let boundedRangeType = new ClassType(ctx.freshTypeId(), "BoundedRange");
  let fromRangeType = new ClassType(ctx.freshTypeId(), "FromRange");
  let toRangeType = new ClassType(ctx.freshTypeId(), "ToRange");
  let fullRangeType = new ClassType(ctx.freshTypeId(), "FullRange");
  ctx.registerPreludeType("BoundedRange", boundedRangeType);
  ctx.registerPreludeType("FromRange", fromRangeType);
  ctx.registerPreludeType("ToRange", toRangeType);
  ctx.registerPreludeType("FullRange", fullRangeType);

  // console (value only)
  let consoleType = new ClassType(ctx.freshTypeId(), "Console");
  ctx.registerPreludeValue("console", consoleType);
};

// ============================================================================
// Public API
// ============================================================================

/**
 * Result of checking a module.
 */
export class CheckResult(
  model: SemanticModel,
  diagnostics: Array<Diagnostic>
)

/**
 * Check a module AST and produce type information.
 *
 * `scopeResult` is the output of scope analysis for this module.
 * If null, the checker will work without cross-module import info.
 *
 * `depExports` maps import specifiers (as written in source) to the
 * ModuleExports of the resolved dependency module. When provided, the
 * checker resolves imported type and value names from these exports.
 *
 * This version loads the standard prelude types (String, Array, etc.)
 * automatically.
 */
export let checkModule = (ast: Module, scopeResult: ScopeResult | null, depExports: HashMap<String, ModuleExports> | null, depModels: HashMap<String, SemanticModel> | null = null, emitLocations: boolean = false): CheckResult => {
  let ctx = new CheckerContext(ast.path, scopeResult, depExports, depModels, emitLocations);

  // Register standard prelude types.
  registerStandardPrelude(ctx);

  // Pre-pass: index function declarations for lazy resolution.
  // This enables forward references and mutual recursion for annotated functions.
  // Type declarations (classes, interfaces, etc.) are registered eagerly in
  // Phase 1 below, but are also materialized on demand by resolveTypeName when
  // first referenced (e.g. during Phase 1 superclass resolution).
  var fi = 0;
  while (fi < ast.body.length) {
    match (ast.body[fi]) {
      case VariableDeclaration {pattern, init}: {
        match (pattern) {
          case IdentifierPattern as pat: {
            match (init) {
              case FunctionExpression as fe: {
                let info = ctx.model.resolveDeclaration(pat);
                if (info != null) {
                  ctx.registerPendingFunction((info as SymbolInfo).id, fe as Node);
                }
              }
              case _: {}
            }
          }
          case _: {}
        }
      }
      case _: {}
    }
    fi += 1;
  }

  // === Phase 1: Register all declaration signatures ===
  // Process imports and register type declarations (classes, interfaces,
  // enums, mixins, type aliases, declared functions, symbols) so that ALL
  // member signatures are available before any bodies are checked.
  var ri = 0;
  while (ri < ast.body.length) {
    let stmt = ast.body[ri];
    match (stmt) {
      case ImportDeclaration {}: { checkStatement(ctx, stmt); }
      case ClassDeclaration as cd: { registerClassDeclaration(ctx, cd); }
      case InterfaceDeclaration as id: { checkInterfaceDeclaration(ctx, id); }
      case EnumDeclaration as ed: { checkEnumDeclaration(ctx, ed); }
      case MixinDeclaration as md: { checkMixinDeclaration(ctx, md); }
      case TypeAliasDeclaration {name}: {
        ctx.resolveTypeName(name.name);
      }
      case DeclareFunction as df: { checkDeclareFunction(ctx, df); }
      case SymbolDeclaration as sd: { checkSymbolDeclaration(ctx, sd); }
      case _: {} // Non-declaration statements handled in Phase 2.
    }
    ri += 1;
  }

  // === Phase 2: Check all bodies and non-declaration statements ===
  // Class bodies are checked here (after all member signatures exist).
  // Other declarations were fully handled in Phase 1 and are skipped.
  var i = 0;
  while (i < ast.body.length) {
    let stmt = ast.body[i];
    match (stmt) {
      case ClassDeclaration as cd: { checkClassBodies(ctx, cd); }
      // Already fully handled in Phase 1.
      case ImportDeclaration {}: {}
      case InterfaceDeclaration {}: {}
      case EnumDeclaration {}: {}
      case MixinDeclaration {}: {}
      case TypeAliasDeclaration {}: {}
      case DeclareFunction {}: {}
      case SymbolDeclaration {}: {}
      case ExportAllDeclaration {}: {}
      case ExportFromDeclaration {}: {}
      // Everything else: variable declarations, expression statements, etc.
      case _: { checkStatement(ctx, stmt); }
    }
    i += 1;
  }

  // Collect diagnostics from the bag into the model.
  let bagDiags = ctx.diagnostics.diagnostics;
  var j = 0;
  while (j < bagDiags.length) {
    ctx.model.addDiagnostic(bagDiags[j]);
    j = j + 1;
  }

  return new CheckResult(ctx.model, bagDiags);
};

/**
 * Resolve a type annotation AST node to a Type.
 */
let resolveTypeAnnotation = (ctx: CheckerContext, ann: TypeAnnotation): Type => match (ann) {
  case NamedTypeAnnotation {name, typeArguments}: {
    // Look up the name in the type scope.
    let resolved = ctx.resolveTypeName(name);
    if (resolved == null) {
      ctx.error(
        "Type '" + name + "' not found.",
        DiagnosticCode.SymbolNotFound,
        ann.loc
      );
      return new UnknownType();
    }
    
    // Handle generic type arguments
    let resolvedArgs = new Array<Type>();
    var hasTypeArgs = false;
    
    if (typeArguments != null) {
      if (typeArguments.length > 0) {
        hasTypeArgs = true;
        for (let typeArgument in typeArguments) {
          resolvedArgs.push(resolveTypeAnnotation(ctx, typeArgument));
        }
      }
    }
    
    match (resolved as Type) {
      case ClassType as ct: {
        if (ct.typeParameters != null) {
          applyAndCheckTypeArguments(ctx, ct.typeParameters as Array<TypeParameterType>, resolvedArgs, ann.loc);
          return instantiateClassType(ct, resolvedArgs);
        }
      }
      case MixinType as mt: {
        if (mt.typeParameters != null) {
          applyAndCheckTypeArguments(ctx, mt.typeParameters as Array<TypeParameterType>, resolvedArgs, ann.loc);
          return instantiateMixinType(mt, resolvedArgs);
        }
      }
      case InterfaceType as it: {
        if (it.typeParameters != null) {
          applyAndCheckTypeArguments(ctx, it.typeParameters as Array<TypeParameterType>, resolvedArgs, ann.loc);
          return instantiateInterfaceType(it, resolvedArgs);
        }
      }
      case TypeAliasType as tat: {
        if (tat.typeParameters != null) {
          applyAndCheckTypeArguments(ctx, tat.typeParameters as Array<TypeParameterType>, resolvedArgs, ann.loc);
          let target = substituteTypeParams(tat.typeParameters, resolvedArgs, tat.target);
          if (tat.isDistinct) {
            let inst = instantiateTypeAliasType(tat, resolvedArgs);
            inst.target = target;
            return inst;
          }
          return target;
        } else {
          if (hasTypeArgs) {
             ctx.error("Type '" + name + "' is not generic.", DiagnosticCode.TypeMismatch, ann.loc);
          }
          return if (tat.isDistinct) tat else tat.target;
        }
      }
      case _: {
        if (hasTypeArgs) {
           ctx.error("Type '" + name + "' is not generic.", DiagnosticCode.TypeMismatch, ann.loc);
        }
      }
    }
    
    resolved as Type
  }
  case UnionTypeAnnotation {types}: {
    let resolved = new Array<Type>();
    var i = 0;
    while (i < types.length) {
      resolved.push(resolveTypeAnnotation(ctx, types[i]));
      i += 1;
    }
    createUnionType(resolved)
  }
  case FunctionTypeAnnotation {params, returnType}: {
    let paramTypes = new Array<Type>();
    var i = 0;
    while (i < params.length) {
      paramTypes.push(resolveTypeAnnotation(ctx, params[i]));
      i += 1;
    }
    let retType = resolveTypeAnnotation(ctx, returnType);
    new FunctionType(paramTypes, null, retType)
  }
  case LiteralTypeAnnotation {value}: {
    match (value) {
      case BooleanLiteral {value}: new BoolLiteralType(value)
      case NumberLiteral {raw}: {
        // Number literal type — check for decimal point to decide base type.
        // For now, treat as i32.
        new I32Type()
      }
      case StringLiteral {value}: new StringLiteralType(value)
      case NullLiteral {}: new NullType()
      case _: new UnknownType()
    }
  }
  case RecordTypeAnnotation {properties}: {
    let props = new HashMap<String, Type>();
    var optionals: HashSet<String> | null = null;
    for (let prop in properties) {
      props[prop.name.name] = resolveTypeAnnotation(ctx, prop.typeAnnotation);
      if (prop.optional) {
        optionals ??= new HashSet<String>();
        optionals.add(prop.name.name);
      }
    }
    new RecordT(props, optionals)
  }
  case TupleTypeAnnotation {elementTypes}: {
    let elTypes = new Array<Type>();
    var i = 0;
    while (i < elementTypes.length) {
      elTypes.push(resolveTypeAnnotation(ctx, elementTypes[i]));
      i += 1;
    }
    new TupleT(elTypes)
  }
  case InlineTupleTypeAnnotation {elementTypes}: {
    let elTypes = new Array<Type>();
    var i = 0;
    while (i < elementTypes.length) {
      elTypes.push(resolveTypeAnnotation(ctx, elementTypes[i]));
      i += 1;
    }
    new InlineTupleT(elTypes)
  }
  case ThisTypeAnnotation {}: new ThisType()
};

/**
 * Check if an array of types already contains a type equal to target.
 */
let containsType = (types: Array<Type>, target: Type): boolean => {
  var i = 0;
  while (i < types.length) {
    if (typesEqual(types[i], target)) { return true; }
    i += 1;
  }
  return false;
};

/**
 * Create a union type, flattening nested unions and deduplicating.
 */
let createUnionType = (types: Array<Type>): Type => {
  let deduped = new Array<Type>();

  for (let type in types) {
    match (type) {
      case UnionT {types as inner}: {
        for (let innerType in inner) {
          if (!containsType(deduped, innerType)) {
            deduped.push(innerType);
          }
        }
      }
      case NeverType: {}  // Remove never from unions.
      case _: {
        if (!containsType(deduped, type)) {
          deduped.push(type);
        }
      }
    }
  }

  if (deduped.length == 0) { return new NeverType(); }
  if (deduped.length == 1) { return deduped[0]; }
  return new UnionT(deduped);
};

/**
 * Extract the element type from an iterable type for for-in loops.
 * Checks if the type implements Iterable<T> by identity-based comparison
 * against the prelude Iterable interface.
 * Reports an error if the type is not iterable.
 */
let getElementType = (
  ctx: CheckerContext,
  iterableType: Type,
  iterableExpr: Expression
): Type => {
  match (iterableType) {
    case ArrayType {elementType}: {
      return elementType;
    }
    case ClassType as ct: {
      return getElementTypeFromClass(ctx, ct, iterableExpr);
    }
    case InterfaceType as it: {
      let elemType = findIterableInterface(ctx, it);
      if (elemType != null) {
        return elemType as Type;
      }
      ctx.error(
        "Type '" + it.name + "' is not iterable.",
        DiagnosticCode.TypeMismatch,
        iterableExpr.loc
      );
      return new UnknownType();
    }
    case UnknownType: {
      return new UnknownType();
    }
    case _: {
      ctx.error(
        "Type is not iterable.",
        DiagnosticCode.TypeMismatch,
        iterableExpr.loc
      );
      return new UnknownType();
    }
  }
  return new UnknownType();
};

let getElementTypeFromClass = (
  ctx: CheckerContext,
  ct: ClassType,
  iterableExpr: Expression
): Type => {
  // Check if the class implements Iterable<T> (walk implementsList).
  var i = 0;
  while (i < ct.implementsList.length) {
    let iface = ct.implementsList[i];
    let elemType = findIterableInterface(ctx, iface);
    if (elemType != null) {
      let result = elemType as Type;
      return substituteTypeParams(ct.typeParameters, ct.typeArguments, result);
    }
    i += 1;
  }
  // Walk superclass chain.
  if (ct.superType != null) {
    return getElementType(ctx, ct.superType as Type, iterableExpr);
  }
  ctx.error(
    "Type '" + ct.name + "' is not iterable.",
    DiagnosticCode.TypeMismatch,
    iterableExpr.loc
  );
  return new UnknownType();
};

/**
 * Check if an interface type is Iterable<T> or extends Iterable<T>.
 * Uses identity-based comparison against the prelude Iterable type.
 * Returns the element type T if found, null otherwise.
 */
let findIterableInterface = (ctx: CheckerContext, iface: InterfaceType): Type | null => {
  let prelude = ctx.resolvePreludeType("Iterable");
  if (prelude == null) { return null; }
  match (prelude as Type) {
    case InterfaceType as iterableType: {
      // Compare by type id — instantiateInterfaceType preserves the source id.
      let sourceId = if (iface.genericSource != null) {
        (iface.genericSource as InterfaceType).id
      } else {
        iface.id
      };
      if (sourceId == iterableType.id) {
        if (iface.typeArguments != null) {
          let args = iface.typeArguments as Array<Type>;
          if (args.length > 0) { return args[0]; }
        }
        return null;
      }
      // Walk extends list.
      var i = 0;
      while (i < iface.extendsList.length) {
        let result = findIterableInterface(ctx, iface.extendsList[i]);
        if (result != null) { return result; }
        i += 1;
      }
      return null;
    }
    case _: { return null; }
  }
};

/**
 * Substitute type parameters with their corresponding type arguments.
 * typeParams: the type parameter names/types from the generic class
 * typeArgs: the actual type arguments
 * t: the type to substitute within
 */
let substituteTypeParams = (
  typeParams: Array<TypeParameterType> | null,
  typeArgs: Array<Type> | null,
  t: Type
): Type => {
  if (typeParams == null || typeArgs == null) { return t; }
  let params = typeParams as Array<TypeParameterType>;
  let args = typeArgs as Array<Type>;
  let tpLen = params.length;
  let taLen = args.length;

  match (t) {
    case TypeParameterType {name}: {
      // Find the matching type parameter and substitute.
      for (var i = 0; i < tpLen && i < taLen; i += 1) {
        if (params[i].name == name) {
          return args[i];
        }
      }
      // No match found, return original.
      return t;
    }
    case UnionT {types}: {
      let substituted = new Array<Type>();
      for (let t in types) {
        substituted.push(substituteTypeParams(typeParams, typeArgs, t));
      }
      return createUnionType(substituted);
    }
    case ArrayType {elementType}: {
      let subElem = substituteTypeParams(typeParams, typeArgs, elementType);
      return new ArrayType(subElem);
    }
    case TupleT {elementTypes}: {
      let subElems = new Array<Type>();
      for (let elem in elementTypes) {
        subElems.push(substituteTypeParams(typeParams, typeArgs, elem));
      }
      return new TupleT(subElems);
    }
    case InlineTupleT {elementTypes}: {
      let subElems = new Array<Type>();
      for (let elem in elementTypes) {
        subElems.push(substituteTypeParams(typeParams, typeArgs, elem));
      }
      return new InlineTupleT(subElems);
    }
    case RecordT {properties, optionalProperties}: {
      let subProps = new HashMap<String, Type>();
      for (let {key} in properties) {
        subProps[key] = substituteTypeParams(typeParams, typeArgs, properties[key]);
      }
      return new RecordT(subProps, optionalProperties);
    }
    case FunctionType as ft: {
      let subParams = new Array<Type>();
      for (let param in ft.parameters) {
        subParams.push(substituteTypeParams(typeParams, typeArgs, param));
      }
      let subRet = substituteTypeParams(typeParams, typeArgs, ft.returnType);
      return new FunctionType(subParams, ft.parameterNames, subRet);
    }
    case ClassType as ct: {
      if (ct.typeArguments != null) {
        let srcArgs = ct.typeArguments as Array<Type>;
        let subArgs = new Array<Type>();
        var changed = false;
        for (let arg in srcArgs) {
          let sub = substituteTypeParams(typeParams, typeArgs, arg);
          subArgs.push(sub);
          if (!typesEqual(sub, arg)) {
            changed = true;
          }
        }
        if (changed) {
          return instantiateClassType(ct.genericSource ?? ct, subArgs);
        }
      }
      return t;
    }
    case InterfaceType as it: {
      if (it.typeArguments != null) {
        let srcArgs = it.typeArguments as Array<Type>;
        let subArgs = new Array<Type>();
        var changed = false;
        for (let arg in srcArgs) {
          let sub = substituteTypeParams(typeParams, typeArgs, arg);
          subArgs.push(sub);
          if (!typesEqual(sub, arg)) {
            changed = true;
          }
        }
        if (changed) {
          return instantiateInterfaceType(it.genericSource ?? it, subArgs);
        }
      }
      return t;
    }
    case MixinType as mt: {
      if (mt.typeArguments != null) {
        let srcArgs = mt.typeArguments as Array<Type>;
        let subArgs = new Array<Type>();
        var changed = false;
        for (let arg in srcArgs) {
          let sub = substituteTypeParams(typeParams, typeArgs, arg);
          subArgs.push(sub);
          if (!typesEqual(sub, arg)) {
            changed = true;
          }
        }
        if (changed) {
          return instantiateMixinType(mt.genericSource ?? mt, subArgs);
        }
      }
      return t;
    }
    case _: { return t; }
  }
};

/**
 * Applies default type arguments and checks constraints.
 * Modifies `typeArgs` in place if defaults are applied.
 */
let applyAndCheckTypeArguments = (
  ctx: CheckerContext,
  typeParams: Array<TypeParameterType>,
  typeArgs: Array<Type>,
  loc: SourceLocation | null
): void => {
  // Apply defaults if type arguments are missing
  for (var i = typeArgs.length; i < typeParams.length; i += 1) {
    let param = typeParams[i];
    if (param.defaultType != null) {
      typeArgs.push(substituteTypeParams(typeParams, typeArgs, param.defaultType as Type));
    } else {
      ctx.error(
        `Expected ${typeParams.length} type arguments, but got ${i}.`,
        DiagnosticCode.ArgumentCountMismatch,
        loc
      );
      while (typeArgs.length < typeParams.length) {
        typeArgs.push(new UnknownType());
      }
      break;
    }
  }

  if (typeArgs.length > typeParams.length) {
    ctx.error(
      `Expected ${typeParams.length} type arguments, but got ${typeArgs.length}.`,
      DiagnosticCode.ArgumentCountMismatch,
      loc
    );
    // Truncate to avoid issues later
    while (typeArgs.length > typeParams.length) {
      typeArgs.pop();
    }
  }

  // Check constraints
  for (var j = 0; j < typeParams.length && j < typeArgs.length; j += 1) {
    let param = typeParams[j];
    if (param.constraint != null) {
      let expectedConstraint = substituteTypeParams(typeParams, typeArgs, param.constraint as Type);
      if (!isAssignableTo(ctx, typeArgs[j], expectedConstraint)) {
        ctx.error(
          "Type '" + typeToString(typeArgs[j]) + "' does not satisfy constraint '" +
            typeToString(expectedConstraint) + "' for type parameter '" + param.name + "'.",
          DiagnosticCode.TypeMismatch,
          loc
        );
      }
    }
  }
};

/**
 * Infer type arguments from constructor arguments for a generic class.
 * Returns a new ClassType with typeArguments set, or the original if not generic.
 */
let instantiateGenericClass = (
  ctx: CheckerContext,
  ct: ClassType,
  explicitTypeArgs: Array<TypeAnnotation> | null,
  args: Array<Expression>,
  loc: SourceLocation | null
): ClassType => {
  let typeParams = ct.typeParameters;
  if (typeParams == null) { return ct; }
  let params = typeParams as Array<TypeParameterType>;
  if (params.length == 0) { return ct; }

  // If explicit type arguments provided, use those.
  if (explicitTypeArgs != null) {
    let explicit = explicitTypeArgs as Array<TypeAnnotation>;
    let typeArgs = new Array<Type>();
    var i = 0;
    while (i < explicit.length) {
      typeArgs.push(resolveTypeAnnotation(ctx, explicit[i]));
      i += 1;
    }
    applyAndCheckTypeArguments(ctx, params, typeArgs, loc);
    return instantiateClassType(ct, typeArgs);
  }

  // Infer type arguments from constructor arguments.
  let ctorOpt = ct.constructorType;
  if (ctorOpt == null) { return ct; }
  let ctor = ctorOpt as FunctionType;

  // Build a map from type param names to inferred types.
  let inferred = new HashMap<String, Type>();
  var ai = 0;
  while (ai < args.length && ai < ctor.parameters.length) {
    let paramType = ctor.parameters[ai];
    let argType = checkExpression(ctx, args[ai], null);
    inferTypeArg(paramType, argType, inferred);
    ai += 1;
  }

  // Build typeArguments array from inferred map.
  let typeArgs = new Array<Type>();
  var pi = 0;
  while (pi < params.length) {
    let paramName = params[pi].name;
    if (inferred.has(paramName)) {
      typeArgs.push(inferred[paramName]);
    } else {
      // No inference possible; use unknown.
      typeArgs.push(new UnknownType());
    }
    pi += 1;
  }

  // Apply missing default types and check constraints before instantiating.
  applyAndCheckTypeArguments(ctx, params, typeArgs, loc);
  
  // Create instantiated class type using factory function.
  return instantiateClassType(ct, typeArgs);
};

/**
 * Infer a type argument by matching a parameter type against an argument type.
 * paramType: the expected param type (may be TypeParameterType)
 * argType: the actual argument type
 * inferred: map to store inferred type params
 */
let inferTypeArg = (paramType: Type, argType: Type, inferred: HashMap<String, Type>): void => {
  match (paramType) {
    case TypeParameterType {name}: {
      // Direct type parameter — infer from arg type.
      if (!inferred.has(name)) {
        inferred[name] = argType;
      }
    }
    case ArrayType {elementType}: {
      // Array<T> against Array<i32> → infer T = i32.
      match (argType) {
        case ArrayType as argArr: {
          inferTypeArg(elementType, argArr.elementType, inferred);
        }
        case _: {}
      }
    }
    case ClassType as pt: {
      // Box<T> against Box<i32> → infer T = i32.
      match (argType) {
        case ClassType as at: {
          if (pt.id == at.id && pt.typeArguments != null && at.typeArguments != null) {
            let ptArgs = pt.typeArguments as Array<Type>;
            let atArgs = at.typeArguments as Array<Type>;
            var i = 0;
            while (i < ptArgs.length && i < atArgs.length) {
              inferTypeArg(ptArgs[i], atArgs[i], inferred);
              i += 1;
            }
          }
        }
        case _: {}
      }
    }
    case FunctionType as pt: {
      // (T) => U against (i32) => String → infer T = i32, U = String.
      match (argType) {
        case FunctionType as at: {
          var i = 0;
          while (i < pt.parameters.length && i < at.parameters.length) {
            inferTypeArg(pt.parameters[i], at.parameters[i], inferred);
            i += 1;
          }
          inferTypeArg(pt.returnType, at.returnType, inferred);
        }
        case _: {}
      }
    }
    case _: {}
  }
};

/**
 * Check if `source` is assignable to `target`.
 */
/**
 * Check if a ClassType is a specific prelude type by identity (type id comparison).
 * Works for both uninstantiated and instantiated generic types because
 * instantiateClassType preserves the source type's id.
 */
let isPreludeClassType = (ctx: CheckerContext, ct: ClassType, preludeName: String): boolean => {
  let prelude = ctx.resolvePreludeType(preludeName);
  if (prelude == null) { return false; }
  match (prelude as Type) {
    case ClassType as pt: { return ct.id == pt.id; }
    case _: { return false; }
  }
};

let isAssignableTo = (ctx: CheckerContext, source: Type, target: Type): boolean => {
  // Same type (identity check via match).
  if (typesEqual(source, target)) { return true; }

  // `never` is assignable to anything.
  if (source is NeverType) { return true; }

  // Anything is assignable to `unknown` or `any`.
  if (target is UnknownType || target is AnyType) { return true; }

  // `null` is assignable to nullable unions.
  if (source is NullType) {
    match (target) {
      case UnionT {types}: {
        var i = 0;
        while (i < types.length) {
          if (types[i] is NullType) { return true; }
          i += 1;
        }
      }
      case _: {}
    }
    return false;
  }

  // Boolean literal assignable to boolean.
  if (source is BoolLiteralType && target is BooleanType) { return true; }

  // Union source: all members must be assignable to target.
  match (source) {
    case UnionT {types as sourceTypes}: {
      var i = 0;
      while (i < sourceTypes.length) {
        if (!isAssignableTo(ctx, sourceTypes[i], target)) { return false; }
        i += 1;
      }
      return true;
    }
    case _: {}
  }

  // Union target: source must be assignable to at least one member.
  match (target) {
    case UnionT {types as targetTypes}: {
      var i = 0;
      while (i < targetTypes.length) {
        if (isAssignableTo(ctx, source, targetTypes[i])) { return true; }
        i += 1;
      }
      return false;
    }
    case _: {}
  }

  // Numeric: allow implicit widening in some cases.
  // For now, require exact numeric type match (strict).
  // This matches Zena's no-coercion design.

  // Class subtyping: a subclass is assignable to its superclass chain.
  match (source) {
    case ClassType as srcClass: {
      match (target) {
        case ClassType as tgtClass: {
          // Walk the supertype chain.
          var current: ClassType | null = srcClass.superType;
          while (current != null) {
            let cur = current as ClassType;
            if (cur.id == tgtClass.id) { return true; }
            current = cur.superType;
          }
        }
        case _: {}
      }
    }
    case _: {}
  }

  // Record structural assignability: all target properties must exist in source
  // with assignable types.
  match (source) {
    case RecordT {properties as srcProps}: {
      match (target) {
        case RecordT {properties as tgtProps}: {
          let keys = tgtProps.keys();
          while (let (true, key) = keys.next()) {
            if (!srcProps.has(key)) { return false; }
            if (!isAssignableTo(ctx, srcProps[key], tgtProps[key])) { return false; }
          }
          return true;
        }
        case _: {}
      }
    }
    case _: {}
  }

  // ArrayType(elementType) is assignable to Array<T>/FixedArray<T> when elementType assignable to T.
  match (source) {
    case ArrayType {elementType}: {
      match (target) {
        case ClassType as tgtClass: {
          let isArrayLike = isPreludeClassType(ctx, tgtClass, "Array") || isPreludeClassType(ctx, tgtClass, "FixedArray");
          if (isArrayLike && tgtClass.typeArguments != null) {
            let tgtArgs = tgtClass.typeArguments as Array<Type>;
            if (tgtArgs.length > 0) {
              return isAssignableTo(ctx, elementType, tgtArgs[0]);
            }
          }
          // Also match uninstantiated Array/FixedArray (bare type)
          if (isArrayLike) {
            return true;
          }
        }
        case ArrayType {elementType as tgtElem}: {
          return isAssignableTo(ctx, elementType, tgtElem);
        }
        case _: {}
      }
    }
    case _: {}
  }

  return false;
};

/**
 * Check if two type arrays (tuple elements) are structurally equal.
 */
let tupleElementsEqual = (ea: Array<Type>, eb: Array<Type>): boolean => {
  if (ea.length != eb.length) { return false; }
  var i = 0;
  while (i < ea.length) {
    if (!typesEqual(ea[i], eb[i])) { return false; }
    i += 1;
  }
  return true;
};

/**
 * Check if two types are structurally equal.
 */
let typesEqual = (a: Type, b: Type): boolean => {
  // For now, use a simple structural comparison based on type kind.
  // Identity-based comparison will come with interning.
  match (a) {
    case I32Type: b is I32Type
    case U32Type: b is U32Type
    case I64Type: b is I64Type
    case U64Type: b is U64Type
    case F32Type: b is F32Type
    case F64Type: b is F64Type
    case BooleanType: b is BooleanType
    case VoidType: b is VoidType
    case NullType: b is NullType
    case NeverType: b is NeverType
    case UnknownType: b is UnknownType
    case AnyType: b is AnyType
    case AnyRefType: b is AnyRefType
    case EqRefType: b is EqRefType
    case ByteArrayType: b is ByteArrayType
    case BoolLiteralType {value as va}: {
      match (b) {
        case BoolLiteralType {value as vb}: va == vb
        case _: false
      }
    }
    case StringLiteralType {value as va}: {
      match (b) {
        case StringLiteralType {value as vb}: va == vb
        case _: false
      }
    }
    case ClassType as ca: {
      match (b) {
        case ClassType as cb: {
          // Compare canonical base type (follow genericSource chain)
          let baseA = if (ca.genericSource != null) (ca.genericSource as ClassType).id else ca.id;
          let baseB = if (cb.genericSource != null) (cb.genericSource as ClassType).id else cb.id;
          if (baseA != baseB) { return false; }
          // Compare type arguments for generic instantiations
          if (ca.typeArguments == null && cb.typeArguments == null) { return true; }
          if (ca.typeArguments == null || cb.typeArguments == null) { return false; }
          let argsA = ca.typeArguments as Array<Type>;
          let argsB = cb.typeArguments as Array<Type>;
          if (argsA.length != argsB.length) { return false; }
          var i = 0;
          while (i < argsA.length) {
            if (!typesEqual(argsA[i], argsB[i])) { return false; }
            i += 1;
          }
          true
        }
        case _: false
      }
    }
    case InterfaceType as ia: {
      match (b) {
        case InterfaceType as ib: {
          // Compare canonical base type (follow genericSource chain)
          let baseA = if (ia.genericSource != null) (ia.genericSource as InterfaceType).id else ia.id;
          let baseB = if (ib.genericSource != null) (ib.genericSource as InterfaceType).id else ib.id;
          if (baseA != baseB) { return false; }
          // Compare type arguments for generic instantiations
          if (ia.typeArguments == null && ib.typeArguments == null) { return true; }
          if (ia.typeArguments == null || ib.typeArguments == null) { return false; }
          let argsA = ia.typeArguments as Array<Type>;
          let argsB = ib.typeArguments as Array<Type>;
          if (argsA.length != argsB.length) { return false; }
          var i = 0;
          while (i < argsA.length) {
            if (!typesEqual(argsA[i], argsB[i])) { return false; }
            i += 1;
          }
          true
        }
        case _: false
      }
    }
    case TypeParameterType {name as na}: {
      match (b) {
        case TypeParameterType {name as nb}: na == nb
        case _: false
      }
    }
    case ArrayType {elementType as ea}: {
      match (b) {
        case ArrayType {elementType as eb}: typesEqual(ea, eb)
        case _: false
      }
    }
    case TupleT {elementTypes as ea}: {
      match (b) {
        case TupleT {elementTypes as eb}: tupleElementsEqual(ea, eb)
        case _: false
      }
    }
    case InlineTupleT {elementTypes as ea}: {
      match (b) {
        case InlineTupleT {elementTypes as eb}: tupleElementsEqual(ea, eb)
        case _: false
      }
    }
    case FunctionType as fa: {
      match (b) {
        case FunctionType as fb: {
          if (fa.parameters.length != fb.parameters.length) { return false; }
          if (!typesEqual(fa.returnType, fb.returnType)) { return false; }
          var i = 0;
          while (i < fa.parameters.length) {
            if (!typesEqual(fa.parameters[i], fb.parameters[i])) { return false; }
            i += 1;
          }
          true
        }
        case _: false
      }
    }
    case UnionT {types as ua}: {
      match (b) {
        case UnionT {types as ub}: {
          if (ua.length != ub.length) { return false; }
          var i = 0;
          while (i < ua.length) {
            if (!typesEqual(ua[i], ub[i])) { return false; }
            i += 1;
          }
          true
        }
        case _: false
      }
    }
    case RecordT {properties as pa}: {
      match (b) {
        case RecordT {properties as pb}: {
          if (pa.size != pb.size) { return false; }
          let keys = pa.keys();
          while (let (true, key) = keys.next()) {
            if (!pb.has(key)) { return false; }
            if (!typesEqual(pa[key], pb[key])) { return false; }
          }
          true
        }
        case _: false
      }
    }
    case MixinType as ma: {
      match (b) {
        case MixinType as mb: ma.name == mb.name
        case _: false
      }
    }
    case SymbolType as sa: {
      match (b) {
        case SymbolType as sb: sa.id == sb.id
        case _: false
      }
    }
    case ThisType: b is ThisType
    case TypeAliasType as ta: {
      match (b) {
        case TypeAliasType as tb: ta.name == tb.name
        case _: false
      }
    }
  }
};

// ============================================================================
// Control-Flow Narrowing Helpers
// ============================================================================

/**
 * Check if a statement definitely exits (return, break, continue, throw).
 * Used to propagate narrowing past null-guard patterns like:
 *   if (x == null) { return; }
 *   // x is now non-null here
 */
let branchDefinitelyExits = (stmt: Statement): boolean => {
  match (stmt) {
    case ReturnStatement {}: true
    case BreakStatement {}: true
    case ContinueStatement {}: true
    case ExpressionStatement {expression}: {
      match (expression) {
        case ThrowExpression {}: true
        case _: false
      }
    }
    case BlockStatement {body}: {
      if (body.length == 0) { false }
      else { branchDefinitelyExits(body[body.length - 1]) }
    }
    case IfStatement {consequent, alternate}: {
      if (alternate == null) { false }
      else { branchDefinitelyExits(consequent) && branchDefinitelyExits(alternate as Statement) }
    }
    case _: false
  }
};

/**
 * Remove null from a type. For unions, filters out NullType members.
 * Returns the narrowed type.
 */
let subtractNullFromType = (t: Type): Type => {
  match (t) {
    case UnionT as u: {
      let remaining = new Array<Type>();
      let types = u.types;
      var i = 0;
      while (i < types.length) {
        match (types[i]) {
          case NullType: {}
          case _: { remaining.push(types[i]); }
        }
        i = i + 1;
      }
      if (remaining.length == 0) { return new NeverType(); }
      if (remaining.length == 1) { return remaining[0]; }
      return new UnionT(remaining);
    }
    case NullType: { return new NeverType(); }
    case _: { return t; }
  }
};

/**
 * Subtract a specific type from a union type.
 * For example, subtractTypeFromUnion(Cat | Fish, Cat) => Fish.
 * For non-union types, returns never if equal, or the original type unchanged.
 */
let subtractTypeFromUnion = (original: Type, toRemove: Type): Type => {
  match (original) {
    case UnionT as u: {
      let remaining = new Array<Type>();
      let types = u.types;
      var i = 0;
      while (i < types.length) {
        if (!typesEqual(types[i], toRemove)) {
          remaining.push(types[i]);
        }
        i = i + 1;
      }
      if (remaining.length == 0) { return new NeverType(); }
      if (remaining.length == 1) { return remaining[0]; }
      return new UnionT(remaining);
    }
    case _: {
      if (typesEqual(original, toRemove)) { return new NeverType(); }
      return original;
    }
  }
};

/**
 * Extract is-expression narrowing from a condition like `x is T`.
 * Returns the SymbolInfo, the target type, and the original type.
 */
let extractIsNarrowing = (
  ctx: CheckerContext,
  condition: Expression
): (SymbolInfo | null, Type | null, Type | null) => {
  match (condition) {
    case IsExpression {expression, typeAnnotation}: {
      match (expression) {
        case Identifier {}: {
          let info = ctx.model.resolve(expression as Node);
          if (info == null) {
            return (null, null, null);
          }
          let si = info as SymbolInfo;
          let originalType = ctx.resolveIdentifier(expression as Node);
          if (originalType == null) {
            return (null, null, null);
          }
          let targetType = resolveTypeAnnotation(ctx, typeAnnotation);
          return (si, targetType, originalType as Type);
        }
        case _: { return (null, null, null); }
      }
    }
    case _: { return (null, null, null); }
  }
};

/**
 * Extract null-guard narrowing from a condition like `x == null` or `x != null`.
 * Returns the SymbolInfo and the narrowed type for the "after-exit" context.
 *
 * For `x == null` with definite exit: inverse narrowing removes null from x.
 * For `x != null` with definite exit: inverse narrowing narrows x to null.
 */
let extractNullGuardNarrowing = (
  ctx: CheckerContext,
  condition: Expression
): (SymbolInfo | null, Type | null, boolean) => {
  match (condition) {
    case BinaryExpression {operator, left, right}: {
      if (operator == "==" || operator == "!=") {
        // Check for `x == null` or `null == x`
        var target: Expression | null = null;
        match (right) {
          case NullLiteral {}: { target = left; }
          case _: {
            match (left) {
              case NullLiteral {}: { target = right; }
              case _: {}
            }
          }
        }
        if (target == null) {
          return (null, null, false);
        }

        let targetExpr = target as Expression;
        match (targetExpr) {
          case Identifier {name}: {
            let info = ctx.model.resolve(targetExpr as Node);
            if (info == null) {
              return (null, null, false);
            }
            let si = info as SymbolInfo;
            let originalType = ctx.resolveIdentifier(targetExpr as Node);
            if (originalType == null) {
              return (null, null, false);
            }
            let isEqualNull = operator == "==";
            return (si, originalType as Type, isEqualNull);
          }
          case _: {
            return (null, null, false);
          }
        }
      }
      return (null, null, false);
    }
    case _: { return (null, null, false); }
  }
};

/**
 * Check if a statement (or block) contains an assignment to a variable
 * identified by its SymbolInfo id. Used to detect patterns like:
 *   if (x == null) { x = value; }
 * for post-if narrowing.
 */
let bodyAssignsToVariable = (ctx: CheckerContext, stmt: Statement, targetId: SymbolId): boolean => {
  match (stmt) {
    case BlockStatement {body}: {
      for (let s in body) {
        if (bodyAssignsToVariable(ctx, s, targetId)) { return true; }
      }
      false
    }
    case ExpressionStatement {expression}: {
      match (expression) {
        case AssignmentExpression {left}: {
          match (left) {
            case Identifier: {
              let info = ctx.model.resolve(left);
              if (info != null && (info as SymbolInfo).id == targetId) {
                return true;
              }
              false
            }
            case _: false
          }
        }
        case _: false
      }
    }
    case _: false
  }
};

let checkStatement = (ctx: CheckerContext, stmt: Statement): void => {
  match (stmt) {
    case VariableDeclaration {kind, pattern, typeAnnotation, init, loc}: {
      checkVariableDeclaration(ctx, kind, pattern, typeAnnotation, init, loc);
    }
    case ExpressionStatement {expression}: {
      checkExpression(ctx, expression, null);
    }
    case BlockStatement {body}: {
      ctx.enterScope();
      var i = 0;
      while (i < body.length) {
        checkStatement(ctx, body[i]);
        i += 1;
      }
      ctx.exitScope();
    }
    case ReturnStatement {argument, loc}: {
      let expectedReturn = ctx.returnType;
      if (argument != null) {
        let argExpr = argument as Expression;
        let argType = checkExpression(ctx, argExpr, expectedReturn);
        if (expectedReturn != null) {
          let expected = expectedReturn as Type;
          if (expected is VoidType) {
            // No explicit return type - infer from return statements
            ctx.addInferredReturnType(argType);
          } else if (!isAssignableTo(ctx, argType, expected)) {
            ctx.error(
              "Type mismatch: cannot return '" + typeToString(argType) +
              "' from function expecting '" + typeToString(expected) + "'.",
              DiagnosticCode.TypeMismatch,
              loc
            );
          }
        } else {
          // No expected return type at all (shouldn't happen in a function, but collect anyway)
          ctx.addInferredReturnType(argType);
        }
      } else {
        // return; — function should return void.
        if (expectedReturn != null) {
          let expected = expectedReturn as Type;
          if (!(expected is VoidType)) {
            ctx.error(
              "Missing return value. Expected '" + typeToString(expected) + "'.",
              DiagnosticCode.TypeMismatch,
              loc
            );
          }
        }
      }
    }
    case IfStatement {test, consequent, alternate, loc}: {
      // Check condition.
      match (test) {
        case LetPatternCondition as lpc: {
          let initType = checkExpression(ctx, lpc.init, null);
          ctx.enterScope();
          checkPattern(ctx, lpc.pattern, initType);
          checkStatement(ctx, consequent);
          ctx.exitScope();
          if (alternate != null) {
            ctx.enterScope();
            checkStatement(ctx, alternate as Statement);
            ctx.exitScope();
          }
        }
        case _: {
          let testExpr = test as Expression;
          let testType = checkExpression(ctx, testExpr, null);
          validateConditionType(ctx, testType, testExpr);

          // Extract null-guard narrowing from the condition.
          let (guardInfo, guardOrigType, isEqualNull) = extractNullGuardNarrowing(ctx, testExpr);

          // Also try is-expression narrowing if no null-guard found.
          var isInfo: SymbolInfo | null = null;
          var isTargetType: Type | null = null;
          var isOrigType: Type | null = null;
          if (guardInfo == null) {
            let (info, target, orig) = extractIsNarrowing(ctx, testExpr);
            isInfo = info;
            isTargetType = target;
            isOrigType = orig;
          }

          // Check consequent with narrowing applied.
          // For `x == null`: consequent has x narrowed to null
          // For `x != null`: consequent has x narrowed to non-null
          // For `x is T`: consequent has x narrowed to T
          if (guardInfo != null) {
            let si = guardInfo as SymbolInfo;
            let origType = guardOrigType as Type;
            ctx.enterScope();
            if (isEqualNull) {
              ctx.narrowBinding(si, new NullType());
            } else {
              ctx.narrowBinding(si, subtractNullFromType(origType));
            }
            checkStatement(ctx, consequent);
            ctx.exitScope();
          } else if (isInfo != null) {
            let si = isInfo as SymbolInfo;
            ctx.enterScope();
            ctx.narrowBinding(si, isTargetType as Type);
            checkStatement(ctx, consequent);
            ctx.exitScope();
          } else {
            checkStatement(ctx, consequent);
          }

          // Check alternate with inverse narrowing applied.
          if (alternate != null) {
            if (guardInfo != null) {
              let si = guardInfo as SymbolInfo;
              let origType = guardOrigType as Type;
              ctx.enterScope();
              if (isEqualNull) {
                ctx.narrowBinding(si, subtractNullFromType(origType));
              } else {
                ctx.narrowBinding(si, new NullType());
              }
              checkStatement(ctx, alternate as Statement);
              ctx.exitScope();
            } else if (isInfo != null) {
              // `x is T` else branch: x is NOT T, subtract T from original type
              let si = isInfo as SymbolInfo;
              let narrowed = subtractTypeFromUnion(isOrigType as Type, isTargetType as Type);
              ctx.enterScope();
              ctx.narrowBinding(si, narrowed);
              checkStatement(ctx, alternate as Statement);
              ctx.exitScope();
            } else {
              checkStatement(ctx, alternate as Statement);
            }
          }

          // Narrowing past definite exits:
          // If the consequent always exits and there is no else branch,
          // the inverse narrowing holds for subsequent code.
          if (alternate == null && branchDefinitelyExits(consequent)) {
            if (guardInfo != null) {
              let si = guardInfo as SymbolInfo;
              let origType = guardOrigType as Type;
              if (isEqualNull) {
                // `if (x == null) { return; }` → x is non-null after
                ctx.narrowBinding(si, subtractNullFromType(origType));
              } else {
                // `if (x != null) { return; }` → x is null after
                ctx.narrowBinding(si, new NullType());
              }
            }
            if (isInfo != null) {
              // `if (x is T) { return; }` → x is NOT T after
              let si = isInfo as SymbolInfo;
              ctx.narrowBinding(si, subtractTypeFromUnion(isOrigType as Type, isTargetType as Type));
            }
          }

          // If the alternate always exits, the regular narrowing holds.
          if (alternate != null && branchDefinitelyExits(alternate as Statement)) {
            if (guardInfo != null) {
              let si = guardInfo as SymbolInfo;
              let origType = guardOrigType as Type;
              if (isEqualNull) {
                // `if (x == null) { ... } else { return; }` → x is null after
                ctx.narrowBinding(si, new NullType());
              } else {
                // `if (x != null) { ... } else { return; }` → x is non-null after
                ctx.narrowBinding(si, subtractNullFromType(origType));
              }
            }
            if (isInfo != null) {
              // `if (x is T) { ... } else { return; }` → x IS T after
              let si = isInfo as SymbolInfo;
              ctx.narrowBinding(si, isTargetType as Type);
            }
          }

          // Narrowing via assignment in null-guard body:
          // `if (x == null) { x = value; }` → x is non-null after
          // Both paths guarantee non-null: the non-null branch didn't enter,
          // and the null branch assigned a (presumably non-null) value.
          if (alternate == null && !branchDefinitelyExits(consequent)) {
            if (guardInfo != null && isEqualNull) {
              let si = guardInfo as SymbolInfo;
              let origType = guardOrigType as Type;
              if (bodyAssignsToVariable(ctx, consequent, si.id)) {
                ctx.narrowBinding(si, subtractNullFromType(origType));
              }
            }
          }
        }
      }
    }
    case WhileStatement {test, body, loc}: {
      match (test) {
        case LetPatternCondition as lpc: {
          let initType = checkExpression(ctx, lpc.init, null);
          ctx.enterLoop();
          ctx.enterScope();
          checkPattern(ctx, lpc.pattern, initType);
          checkStatement(ctx, body);
          ctx.exitScope();
          ctx.exitLoop();
        }
        case _: {
          let testExpr = test as Expression;
          let testType = checkExpression(ctx, testExpr, null);
          validateConditionType(ctx, testType, testExpr);
          ctx.enterLoop();
          checkStatement(ctx, body);
          ctx.exitLoop();
        }
      }
    }
    case ForStatement {init, test, update, body, loc}: {
      ctx.enterScope();
      if (init != null) {
        match (init as Node) {
          case VariableDeclaration as vd: {
            checkStatement(ctx, vd);
          }
          case _: {
            let initExpr = init as Expression;
            checkExpression(ctx, initExpr, null);
          }
        }
      }
      if (test != null) {
        let testExpr = test as Expression;
        let testType = checkExpression(ctx, testExpr, null);
        validateConditionType(ctx, testType, testExpr);
      }
      if (update != null) {
        let updateExpr = update as Expression;
        checkExpression(ctx, updateExpr, null);
      }
      ctx.enterLoop();
      checkStatement(ctx, body);
      ctx.exitLoop();
      ctx.exitScope();
    }
    case BreakStatement {loc}: {
      if (!ctx.inLoop()) {
        ctx.error("'break' outside of loop.", DiagnosticCode.BreakOutsideLoop, loc);
      }
    }
    case ContinueStatement {loc}: {
      if (!ctx.inLoop()) {
        ctx.error("'continue' outside of loop.", DiagnosticCode.ContinueOutsideLoop, loc);
      }
    }
    // Declarations that are handled during pre-pass or skipped for now.
    case ImportDeclaration {moduleSpecifier, imports}: {
      let deps = ctx.depExports;
      if (deps != null) {
        let depsMap = deps as HashMap<String, ModuleExports>;
        let specifier = moduleSpecifier.value;
        if (depsMap.has(specifier)) {
          let depMod = depsMap[specifier];

          // Look up the dependency's SemanticModel for resolved types.
          var depModel: SemanticModel | null = null;
          let models = ctx.depModels;
          if (models != null) {
            let modelsMap = models as HashMap<String, SemanticModel>;
            if (modelsMap.has(specifier)) {
              depModel = modelsMap[specifier];
            }
          }

          var impIdx = 0;
          while (impIdx < imports.length) {
            let spec = imports[impIdx];
            let importedName = spec.imported.name;
            let localName = spec.local.name;

            // Register type imports (classes, interfaces, etc.)
            let typeExport = depMod.getType(importedName);
            if (typeExport != null) {
              let si = typeExport as SymbolInfo;

              // Try to get the fully resolved type from the dependency's checker.
              // The export SymbolInfo has a different id than the local
              // declaration SymbolInfo, so we bridge through the declaration
              // node to find the local SymbolInfo used during checking.
              var resolvedType: Type | null = null;
              if (depModel != null) {
                let dm = depModel as SemanticModel;
                let declNode = si.declaration;
                if (declNode != null) {
                  let localSi = dm.resolveDeclaration(declNode as Node);
                  if (localSi != null) {
                    resolvedType = dm.getBindingType(localSi as SymbolInfo);
                  }
                }
              }

              if (resolvedType != null) {
                // Use the actual resolved type from the dependency.
                let rt = resolvedType as Type;
                ctx.declareTypeName(localName, rt);
                let localInfo = ctx.model.resolveDeclaration(spec);
                if (localInfo != null) {
                  ctx.declareBinding(localInfo as SymbolInfo, rt);
                }
              } else {
                // Fallback: create stub types from the declaration AST node.
                // For stdlib types, prefer the prelude type which has full
                // member definitions (fields, methods, constructors).
                let decl = si.declaration;
                if (decl != null) {
                  match (decl as Node) {
                    case ClassDeclaration {name}: {
                      let preludeType = ctx.resolveTypeName(name.name);
                      if (preludeType != null) {
                        let pt = preludeType as Type;
                        ctx.declareTypeName(localName, pt);
                        let localInfo = ctx.model.resolveDeclaration(spec);
                        if (localInfo != null) {
                          ctx.declareBinding(localInfo as SymbolInfo, pt);
                        }
                      } else {
                        let ct = new ClassType(ctx.freshTypeId(), name.name);
                        ctx.declareTypeName(localName, ct);
                        let localInfo = ctx.model.resolveDeclaration(spec);
                        if (localInfo != null) {
                          ctx.declareBinding(localInfo as SymbolInfo, ct);
                        }
                      }
                    }
                    case InterfaceDeclaration {name}: {
                      let it = new InterfaceType(ctx.freshTypeId(), name.name);
                      ctx.declareTypeName(localName, it);
                      let localInfo = ctx.model.resolveDeclaration(spec);
                      if (localInfo != null) {
                        ctx.declareBinding(localInfo as SymbolInfo, it);
                      }
                    }
                    case SealedVariant {name}: {
                      // Sealed variant used as a type (e.g., for pattern matching).
                      let ct = new ClassType(ctx.freshTypeId(), name.name);
                      ct.isCaseClass = true;
                      ctx.declareTypeName(localName, ct);
                      let localInfo = ctx.model.resolveDeclaration(spec);
                      if (localInfo != null) {
                        ctx.declareBinding(localInfo as SymbolInfo, ct);
                      }
                    }
                    case _: {
                      ctx.declareTypeName(localName, new UnknownType());
                    }
                  }
                } else {
                  ctx.declareTypeName(localName, new UnknownType());
                }
              }
            }

            // Register value imports (functions, variables).
            let valueExport = depMod.getValue(importedName);
            if (valueExport != null && typeExport == null) {
              // Pure value import (not also a type).
              let localInfo = ctx.model.resolveDeclaration(spec);
              if (localInfo != null) {
                var resolvedValType: Type | null = null;
                if (depModel != null) {
                  let dm = depModel as SemanticModel;
                  let valSi = valueExport as SymbolInfo;
                  let declNode = valSi.declaration;
                  if (declNode != null) {
                    let localSi = dm.resolveDeclaration(declNode as Node);
                    if (localSi != null) {
                      resolvedValType = dm.getBindingType(localSi as SymbolInfo);
                    }
                  }
                }
                if (resolvedValType != null) {
                  ctx.declareBinding(localInfo as SymbolInfo, resolvedValType as Type);
                } else {
                  ctx.declareBinding(localInfo as SymbolInfo, new UnknownType());
                }
              }
            }

            impIdx = impIdx + 1;
          }
        }
      }
    }
    case ExportAllDeclaration {}: {}
    case ExportFromDeclaration {}: {}
    case ClassDeclaration as cd: {
      registerClassDeclaration(ctx, cd);
      checkClassBodies(ctx, cd);
    }
    case InterfaceDeclaration as id: {
      checkInterfaceDeclaration(ctx, id);
    }
    case EnumDeclaration as ed: {
      checkEnumDeclaration(ctx, ed);
    }
    case MixinDeclaration as md: {
      checkMixinDeclaration(ctx, md);
    }
    case TypeAliasDeclaration {name}: {
      // Force materialization so errors inside constraints or the target type
      // are reported once (in their proper generic scope).
      ctx.resolveTypeName(name.name);
    }
    case DeclareFunction as df: {
      checkDeclareFunction(ctx, df);
    }
    case SymbolDeclaration as sd: {
      checkSymbolDeclaration(ctx, sd);
    }
    case ForInStatement {pattern, iterable, body, loc}: {
      let iterableType = checkExpression(ctx, iterable, null);
      let elementType = getElementType(ctx, iterableType, iterable);
      ctx.enterScope();
      ctx.enterLoop();
      bindPattern(ctx, pattern, elementType);
      checkStatement(ctx, body);
      ctx.exitLoop();
      ctx.exitScope();
    }
  }
};

let checkVariableDeclaration = (
  ctx: CheckerContext,
  kind: String,
  pattern: Pattern,
  typeAnnotation: TypeAnnotation | null,
  init: Expression,
  loc: SourceLocation | null
): void => {
  // Infer the type of the initializer.
  var expectedType: Type | null = null;
  if (typeAnnotation != null) {
    expectedType = resolveTypeAnnotation(ctx, typeAnnotation as TypeAnnotation);
  }

  let initType = checkExpression(ctx, init, expectedType);

  // For `var` bindings, widen literal types.
  var declType = initType;
  if (kind == "var" && typeAnnotation == null) {
    declType = widenType(initType);
  }

  // If an explicit type annotation is present, validate assignability.
  if (expectedType != null) {
    let expected = expectedType as Type;
    if (!isAssignableTo(ctx, initType, expected)) {
      ctx.error(
        "Type mismatch: '" + typeToString(initType) +
        "' is not assignable to '" + typeToString(expected) + "'.",
        DiagnosticCode.TypeMismatch,
        loc
      );
    }
    declType = expected;
  }

  // Bind the declared names in the pattern.
  bindPattern(ctx, pattern, declType);
};

/**
 * Bind names from a pattern, registering their types via the
 * DeclarationMap → SymbolInfo → SemanticModel.setBindingType path.
 */
let bindPattern = (ctx: CheckerContext, pattern: Pattern, t: Type): void => {
  match (pattern) {
    case IdentifierPattern as pat: {
      let info = ctx.model.resolveDeclaration(pat);
      if (info != null) {
        let si = info as SymbolInfo;
        if (si.declaration != null && (si.declaration as Node) != pat) {
          ctx.error(
            "Variable '" + pat.name + "' is already declared in this scope.",
            DiagnosticCode.DuplicateDeclaration,
            pat.loc
          );
        } else {
          ctx.declareBinding(si, t);
        }
      }
    }
    case RecordPattern {properties}: {
      // For record destructuring: { x, y } = record.
      match (t) {
        case RecordT {properties as recordProps, optionalProperties}: {
          var i = 0;
          while (i < properties.length) {
            let prop = properties[i];
            let propName = prop.name.name;
            if (recordProps.has(propName)) {
              // Check if the property is optional and requires a default value
              let isOptional = optionalProperties != null &&
                (optionalProperties as HashSet<String>).has(propName);
              let hasDefault = prop.value is AssignmentPattern;
              if (isOptional && !hasDefault) {
                ctx.error(
                  "Optional field '" + propName + "' requires a default value when destructuring.",
                  DiagnosticCode.TypeMismatch,
                  prop.loc
                );
              } else {
                let propType = recordProps[propName];
                bindPattern(ctx, prop.value as Pattern, propType);
              }
            } else {
              ctx.error(
                "Type '" + typeToString(t) + "' has no property '" + propName + "'.",
                DiagnosticCode.PropertyNotFound,
                prop.loc
              );
            }
            i += 1;
          }
        }
        case _: {
          // If not a record, just bind the property names as unknown.
          var i = 0;
          while (i < properties.length) {
            bindPattern(ctx, properties[i].value as Pattern, new UnknownType());
            i += 1;
          }
        }
      }
    }
    case TuplePattern {elements, loc}: {
      match (t) {
        case TupleT {elementTypes}: {
          if (elements.length > elementTypes.length) {
            ctx.error(
              "Tuple pattern has more elements than the tuple type.",
              DiagnosticCode.TypeMismatch,
              loc
            );
          }
          var i = 0;
          while (i < elements.length) {
            if (elements[i] != null) {
              let elem = elements[i] as Node;
              if (i < elementTypes.length) {
                bindPattern(ctx, elem as Pattern, elementTypes[i]);
              } else {
                bindPattern(ctx, elem as Pattern, new UnknownType());
              }
            }
            i += 1;
          }
        }
        case InlineTupleT {elementTypes}: {
          if (elements.length > elementTypes.length) {
            ctx.error(
              "Tuple pattern has more elements than the tuple type.",
              DiagnosticCode.TypeMismatch,
              loc
            );
          }
          var i = 0;
          while (i < elements.length) {
            if (elements[i] != null) {
              let elem = elements[i] as Node;
              if (i < elementTypes.length) {
                bindPattern(ctx, elem as Pattern, elementTypes[i]);
              } else {
                bindPattern(ctx, elem as Pattern, new UnknownType());
              }
            }
            i += 1;
          }
        }
        case _: {
          var i = 0;
          while (i < elements.length) {
            if (elements[i] != null) {
              bindPattern(ctx, (elements[i] as Node) as Pattern, new UnknownType());
            }
            i += 1;
          }
        }
      }
    }
    case AsPattern {pattern as inner, name}: {
      // `pattern as name` — bind both the inner pattern and the alias.
      bindPattern(ctx, inner as Pattern, t);
      // Narrow the alias to the matched type, not the scrutinee type.
      var narrowedType: Type = t;
      if (inner is ClassPattern) {
        let cp = inner as ClassPattern;
        let cls = ctx.resolveTypeName(cp.name.name);
        if (cls != null) {
          narrowedType = cls as Type;
        }
      } else if (inner is Identifier) {
        let ident = inner as Identifier;
        let cls = ctx.resolveTypeName(ident.name);
        if (cls != null) {
          narrowedType = cls as Type;
        }
      }
      let info = ctx.model.resolveDeclaration(name);
      if (info != null) {
        ctx.declareBinding(info as SymbolInfo, narrowedType);
      }
    }
    case AssignmentPattern {left, right}: {
      // `name = default` — default expression must be assignable to the
      // target binding type, then bind the left-hand pattern.
      let defaultType = checkExpression(ctx, right, t);
      if (!isAssignableTo(ctx, defaultType, t)) {
        ctx.error(
          "Type mismatch: '" + typeToString(defaultType) +
          "' is not assignable to '" + typeToString(t) + "'.",
          DiagnosticCode.TypeMismatch,
          pattern.loc
        );
      }
      bindPattern(ctx, left as Pattern, t);
    }
    case ClassPattern as cp: {
      // Look up the class type.
      let clsName = cp.name.name;
      let classType = ctx.resolveTypeName(clsName);
      if (classType == null) {
        ctx.error(
          "Unknown class '" + clsName + "' in pattern.",
          DiagnosticCode.SymbolNotFound,
          cp.loc
        );
        return;
      }
      // Bind property patterns with field types from the class.
      let props = cp.properties;
      var pi = 0;
      while (pi < props.length) {
        let prop = props[pi];
        let propName = prop.name.name;
        let propType = resolveClassFieldType(ctx, classType as Type, propName, prop.loc);
        bindPattern(ctx, prop.value as Pattern, propType);
        pi += 1;
      }
    }
    case LogicalPattern {operator, left, right}: {
      // For | (or) and & (and) patterns, bind variables from both sides.
      bindPattern(ctx, left as Pattern, t);
      bindPattern(ctx, right as Pattern, t);
    }
  }
};

/**
 * Check an expression and return its inferred type.
 * `expectedType` is a contextual type hint (may be null).
 */
/**
 * Check a branch node of an IfExpression (Expression or BlockStatement).
 */
let checkIfBranchNode = (ctx: CheckerContext, node: Node, expectedType: Type | null): Type => {
  if (node is BlockStatement) {
    let b = node as BlockStatement;
    ctx.enterScope();
    // Check all statements except the last
    var i = 0;
    while (i < b.body.length - 1) {
      checkStatement(ctx, b.body[i]);
      i += 1;
    }
    // The type of the block is the type of the last expression statement
    var resultType: Type = new VoidType();
    if (b.body.length > 0) {
      let lastStmt = b.body[b.body.length - 1];
      if (lastStmt is ExpressionStatement) {
        let es = lastStmt as ExpressionStatement;
        resultType = checkExpression(ctx, es.expression, expectedType);
      } else {
        checkStatement(ctx, lastStmt);
      }
    }
    ctx.exitScope();
    return resultType;
  }
  if (node is Expression) {
    return checkExpression(ctx, node as Expression, expectedType);
  }
  return new VoidType();
};

let checkExpression = (ctx: CheckerContext, expr: Expression, expectedType: Type | null): Type => {
  let t = checkExpressionInner(ctx, expr, expectedType);
  // Record the inferred type in the semantic model.
  ctx.model.setNodeType(expr, t);
  return t;
};

let checkExpressionInner = (ctx: CheckerContext, expr: Expression, expectedType: Type | null): Type => match (expr) {
  // --- Literals ---

  case NumberLiteral {raw, loc}: {
    // Check if the literal has a decimal point → float.
    var isFloat = false;
    var i = 0;
    while (i < raw.length) {
      if (raw.getByteAt(i) == 46) {
        isFloat = true;
      }
      i += 1;
    }

    if (isFloat) {
      // Float literal — default to f32; use context to pick f64.
      if (expectedType != null) {
        let expected = expectedType as Type;
        if (expected is F64Type) { return new F64Type(); }
        if (expected is F32Type) { return new F32Type(); }
        if (isNumericType(expected)) { return new F32Type(); }
      }
      new F32Type()
    } else {
      // Integer literal — default to i32; use context to pick other int types.
      if (expectedType != null) {
        let expected = expectedType as Type;
        if (isNumericType(expected)) { return expected; }
      }
      new I32Type()
    }
  }

  case StringLiteral {value, loc}: {
    // String literals have type String (the stdlib class).
    // For now, look up "String" in the type scope.
    let stringType = ctx.resolveTypeName("String");
    if (stringType != null) {
      return stringType as Type;
    }
    // String not in scope — prelude was not loaded correctly.
    ctx.error(
      "Built-in type 'String' is not available. Ensure the standard prelude is loaded.",
      DiagnosticCode.SymbolNotFound,
      loc
    );
    new UnknownType()
  }

  case BooleanLiteral {value, loc}: {
    // Boolean literals get literal types (true or false).
    new BoolLiteralType(value)
  }

  case NullLiteral {loc}: new NullType()

  // --- Identifiers ---

  case Identifier {name, loc}: {
    // The hole literal `_` has type `never`.
    if (name == "_") { return new NeverType(); }

    if (name == "__LOCATION__") {
      let stringType = ctx.resolveTypeName("String");
      if (stringType != null) {
        let uTypes = new Array<Type>();
        uTypes.push(stringType as Type);
        uTypes.push(new NullType());
        return createUnionType(uTypes);
      }
      return new UnknownType();
    }

    // Resolve through the scope pass's ReferenceMap → SymbolInfo → binding type.
    let resolved = ctx.resolveIdentifier(expr);
    if (resolved == null) {
      ctx.error(
        "Variable '" + name + "' not found.",
        DiagnosticCode.SymbolNotFound,
        loc
      );
      return new UnknownType();
    }
    resolved as Type
  }

  // --- Binary Expressions ---

  case BinaryExpression {operator, left, right, loc}: {
    checkBinaryExpression(ctx, operator, left, right, loc)
  }

  // --- Unary Expressions ---

  case UnaryExpression {operator, argument, loc}: {
    let argType = checkExpression(ctx, argument, null);

    if (operator == "-") {
      if (isNumericType(argType)) {
        return argType;
      }
      ctx.error(
        "Unary '-' requires a numeric type, got '" + typeToString(argType) + "'.",
        DiagnosticCode.InvalidOperator,
        loc
      );
      return new UnknownType();
    }
    if (operator == "!") {
      if (isBooleanLike(argType)) {
        return new BooleanType();
      }
      ctx.error(
        "Unary '!' requires a boolean type, got '" + typeToString(argType) + "'.",
        DiagnosticCode.InvalidOperator,
        loc
      );
      return new BooleanType();
    }
    new UnknownType()
  }

  // --- Assignment ---

  case AssignmentExpression {left, value, operator, loc}: {
    // Check for assignment to immutable let binding
    match (left) {
      case Identifier {name}: {
        let info = ctx.model.resolve(left);
        if (info != null) {
          let si = info as SymbolInfo;
          if (si.kind == "let") {
            ctx.error(
              "Cannot assign to immutable variable '" + name + "'.",
              DiagnosticCode.InvalidAssignment,
              loc
            );
            return new UnknownType();
          }
        }
      }
      case _: {}
    }

    // Check for read-only indexer assignment: arr[i] = x
    match (left) {
      case IndexExpression {object, index}: {
        let objectType = checkExpression(ctx, object, null);
        match (objectType) {
          case ClassType as ct: {
            // Check for setter []=
            if (!ct.methods.has("[]=")) {
              // Check if there's a getter only (read-only indexer)
              if (ct.methods.has("[]")) {
                ctx.error(
                  "Cannot assign to read-only indexer.",
                  DiagnosticCode.InvalidAssignment,
                  loc
                );
                return new UnknownType();
              }
            }
          }
          case _: {}
        }
      }
      case MemberExpression {object, property}: {
        let propName = property.name;
        // Handle private field assignment outside class
        if (propName.length > 0 && propName.sliceBytes(0, 1) == "#") {
          if (ctx.currentClass == null) {
            ctx.error(
              "Private field '" + propName + "' can only be accessed within a class.",
              DiagnosticCode.PrivateAccess,
              loc
            );
            return new UnknownType();
          }
        }
        // Check for read-only property assignment
        let objectType = checkExpression(ctx, object, null);
        match (objectType) {
          case ClassType as ct: {
            // Check if it's a field
            if (ct.fields.has(propName)) {
              // Check if field is mutable
              if (!ct.fieldMutability.has(propName) || !ct.fieldMutability[propName]) {
                ctx.error(
                  "Cannot assign to read-only property '" + propName + "'.",
                  DiagnosticCode.InvalidAssignment,
                  loc
                );
                return new UnknownType();
              }
            } else {
              // Check for setter method (set#propName)
              let setterName = "set#" + propName;
              if (!ct.methods.has(setterName)) {
                // Check if there's a getter only (read-only property)
                let getterName = "get#" + propName;
                if (ct.methods.has(getterName)) {
                  ctx.error(
                    "Cannot assign to read-only property '" + propName + "'.",
                    DiagnosticCode.InvalidAssignment,
                    loc
                  );
                  return new UnknownType();
                }
              }
            }
          }
          case _: {}
        }
      }
      case _: {}
    }

    // Null-coalescing assignment: x ??= value
    // Result type is the non-null part of left's type.
    // Narrows the binding to non-null afterward.
    if (operator != null && (operator as String) == "??") {
      let leftType = checkExpression(ctx, left, null);

      // Warn if LHS is not nullable (??= is a no-op).
      var leftIsNullable = false;
      var leftIsAlwaysNull = false;
      match (leftType) {
        case NullType: { leftIsNullable = true; leftIsAlwaysNull = true; }
        case UnionT as u: {
          let members = u.types;
          var ni = 0;
          while (ni < members.length) {
            if (members[ni] is NullType) { leftIsNullable = true; }
            ni += 1;
          }
        }
        case _: {}
      }
      if (!leftIsNullable) {
        ctx.warning(
          "Left operand of '??=' is not nullable and will always be returned.",
          DiagnosticCode.UnnecessaryNullish,
          loc
        );
        return leftType;
      }
      if (leftIsAlwaysNull) {
        ctx.warning(
          "Left operand of '??=' is always null and will never be returned.",
          DiagnosticCode.UnnecessaryNullish,
          loc
        );
      }

      let nonNullType = subtractNullFromType(leftType);
      let rightType = checkExpression(ctx, value, nonNullType);
      if (!isAssignableTo(ctx, rightType, nonNullType)) {
        ctx.error(
          "Type mismatch in '??=' assignment: '" + typeToString(rightType) +
          "' is not assignable to '" + typeToString(nonNullType) + "'.",
          DiagnosticCode.TypeMismatch,
          loc
        );
      }
      // Narrow the binding to non-null.
      match (left) {
        case Identifier: {
          let info = ctx.model.resolve(left);
          if (info != null) {
            ctx.narrowBinding(info as SymbolInfo, nonNullType);
          }
        }
        case _: {}
      }
      return nonNullType;
    }

    // For assignment, use the declared (binding) type of the LHS,
    // not the narrowed type. The RHS must be compatible with what the
    // variable was declared as, not what it was narrowed to.
    var leftType: Type = checkExpression(ctx, left, null);
    match (left) {
      case Identifier: {
        let info = ctx.model.resolve(left);
        if (info != null) {
          let bindingType = ctx.model.getBindingType(info as SymbolInfo);
          if (bindingType != null) {
            leftType = bindingType as Type;
          }
        }
      }
      case _: {}
    }
    let rightType = checkExpression(ctx, value, leftType);

    if (!isAssignableTo(ctx, rightType, leftType)) {
      ctx.error(
        "Type mismatch: '" + typeToString(rightType) +
        "' is not assignable to '" + typeToString(leftType) + "'.",
        DiagnosticCode.TypeMismatch,
        loc
      );
    }

    leftType
  }

  // --- Functions ---

  case FunctionExpression {typeParameters, params, returnType, body, loc}: {
    checkFunctionExpression(ctx, typeParameters, params, returnType, body, loc, expectedType)
  }

  case CallExpression {callee, args, typeArguments, optional, loc}: {
    checkCallExpression(ctx, callee, args, typeArguments, optional, loc)
  }

  // --- If Expression ---

  case IfExpression {test, consequent, alternate, loc}: {
    match (test) {
      case LetPatternCondition as lpc: {
        let initType = checkExpression(ctx, lpc.init, null);
        ctx.enterScope();
        checkPattern(ctx, lpc.pattern, initType);
        let consType = checkIfBranchNode(ctx, consequent, expectedType);
        ctx.exitScope();

        var altType: Type = new VoidType();
        if (alternate != null) {
          ctx.enterScope();
          altType = checkIfBranchNode(ctx, alternate as Node, expectedType);
          ctx.exitScope();
        }

        let branches = new Array<Type>();
        branches.push(consType);
        branches.push(altType);
        createUnionType(branches)
      }
      case _: {
        let testExpr = test as Expression;
        let testType = checkExpression(ctx, testExpr, null);
        validateConditionType(ctx, testType, testExpr);

        // Extract null-guard narrowing from the condition.
        let (guardInfo, guardOrigType, isEqualNull) = extractNullGuardNarrowing(ctx, testExpr);

        // Check consequent with narrowing applied.
        if (guardInfo != null) {
          let si = guardInfo as SymbolInfo;
          let origType = guardOrigType as Type;
          ctx.enterScope();
          if (isEqualNull) {
            ctx.narrowBinding(si, new NullType());
          } else {
            ctx.narrowBinding(si, subtractNullFromType(origType));
          }
        }
        let consType = checkIfBranchNode(ctx, consequent, expectedType);
        if (guardInfo != null) {
          ctx.exitScope();
        }

        // Check alternate with inverse narrowing applied.
        var altType: Type = new VoidType();
        if (alternate != null) {
          if (guardInfo != null) {
            let si = guardInfo as SymbolInfo;
            let origType = guardOrigType as Type;
            ctx.enterScope();
            if (isEqualNull) {
              ctx.narrowBinding(si, subtractNullFromType(origType));
            } else {
              ctx.narrowBinding(si, new NullType());
            }
          }
          altType = checkIfBranchNode(ctx, alternate as Node, expectedType);
          if (guardInfo != null) {
            ctx.exitScope();
          }
        }

        // Result type is the union of both branches.
        let branches = new Array<Type>();
        branches.push(consType);
        branches.push(altType);
        createUnionType(branches)
      }
    }
  }

  // --- TODO: Other expression types ---

  case MemberExpression {object, property, optional, loc}: {
    checkMemberExpression(ctx, object, property, optional, loc)
  }
  case IndexExpression {object, index, optional, loc}: {
    checkIndexExpression(ctx, object, index, optional, loc)
  }
  case ThisExpression {loc}: {
    let cc = ctx.currentClass;
    if (cc == null) {
      ctx.error("'this' used outside of a class.", DiagnosticCode.SymbolNotFound, loc);
      new UnknownType()
    } else {
      cc as Type
    }
  }
  case SuperExpression {loc}: {
    let cc = ctx.currentClass;
    if (cc == null) {
      ctx.error("'super' can only be used inside a class.", DiagnosticCode.SymbolNotFound, loc);
      new UnknownType()
    } else {
      let cls = cc as ClassType;
      let st = cls.superType;
      if (st == null) {
        ctx.error("Class '" + cls.name + "' does not have a superclass.", DiagnosticCode.SymbolNotFound, loc);
        new UnknownType()
      } else {
        st as Type
      }
    }
  }
  case NewExpression {callee, typeArguments, args, loc}: {
    checkNewExpression(ctx, callee, typeArguments, args, loc)
  }
  case AsExpression {expression, typeAnnotation, loc}: {
    checkExpression(ctx, expression, null);
    resolveTypeAnnotation(ctx, typeAnnotation)
  }
  case IsExpression {expression, typeAnnotation, loc}: {
    checkExpression(ctx, expression, null);
    resolveTypeAnnotation(ctx, typeAnnotation);
    new BooleanType()
  }
  case ArrayLiteral {elements, loc}: {
    if (elements.length == 0) {
      // Empty array — need contextual type or return unknown element type.
      if (expectedType != null) {
        match (expectedType as Type) {
          case ClassType as ct: {
            if ((isPreludeClassType(ctx, ct, "Array") || isPreludeClassType(ctx, ct, "FixedArray")) && ct.typeArguments != null) {
              return expectedType as Type;
            }
          }
          case _: {}
        }
      }
      new ArrayType(new UnknownType())
    } else {
      // Infer element type from first element.
      let firstType = checkExpression(ctx, elements[0], null);
      var i = 1;
      while (i < elements.length) {
        let elemType = checkExpression(ctx, elements[i], null);
        if (!isAssignableTo(ctx, elemType, firstType)) {
          ctx.error(
            "Array element type mismatch: '" + typeToString(elemType) + "' is not assignable to '" + typeToString(firstType) + "'.",
            DiagnosticCode.TypeMismatch,
            elements[i].loc
          );
        }
        i += 1;
      }
      new ArrayType(firstType)
    }
  }
  case RecordLiteral {properties, loc}: {
    let propTypes = new HashMap<String, Type>();
    var i = 0;
    while (i < properties.length) {
      match (properties[i]) {
        case PropertyAssignment {name, value}: {
          let valType = checkExpression(ctx, value, null);
          propTypes[name.name] = valType;
        }
        case SpreadElement {argument}: {
          // Spread: merge properties from the argument's record type.
          let spreadType = checkExpression(ctx, argument, null);
          match (spreadType) {
            case RecordT {properties as spreadProps}: {
              let keys = spreadProps.keys();
              while (let (true, key) = keys.next()) {
                propTypes[key] = spreadProps[key];
              }
            }
            case _: {}
          }
        }
        case _: {}
      }
      i += 1;
    }
    new RecordT(propTypes, null)
  }
  case TupleLiteral {elements, loc}: {
    // Check each element and collect their types.
    let elementTypes = new Array<Type>();
    var i = 0;
    while (i < elements.length) {
      let elemType = checkExpression(ctx, elements[i], null);
      elementTypes.push(elemType);
      i += 1;
    }
    new TupleT(elementTypes)
  }
  case MapLiteral {entries, loc}: {
    if (entries.length == 0) {
      ctx.error("Empty map literal requires type annotation. Use 'new HashMap<K, V>()' instead.", DiagnosticCode.TypeMismatch, loc);
      new UnknownType()
    } else {
      // Check all entries and unify key/value types.
      let firstKeyType = checkExpression(ctx, entries[0].key, null);
      let firstValType = checkExpression(ctx, entries[0].value, null);
      var ei = 1;
      while (ei < entries.length) {
        let kt = checkExpression(ctx, entries[ei].key, null);
        if (!isAssignableTo(ctx, kt, firstKeyType)) {
          ctx.error(
            "Map key type mismatch: expected '" + typeToString(firstKeyType) + "', got '" + typeToString(kt) + "'.",
            DiagnosticCode.TypeMismatch, entries[ei].key.loc
          );
        }
        let vt = checkExpression(ctx, entries[ei].value, null);
        if (!isAssignableTo(ctx, vt, firstValType)) {
          ctx.error(
            "Map value type mismatch: expected '" + typeToString(firstValType) + "', got '" + typeToString(vt) + "'.",
            DiagnosticCode.TypeMismatch, entries[ei].value.loc
          );
        }
        ei += 1;
      }
      // Return HashMap<K, V> if available, otherwise UnknownType.
      let hashMapType = ctx.resolveTypeName("HashMap");
      if (hashMapType != null) {
        match (hashMapType as Type) {
          case ClassType as hm: {
            let typeArgs = new Array<Type>();
            typeArgs.push(firstKeyType);
            typeArgs.push(firstValType);
            instantiateClassType(hm, typeArgs) as Type
          }
          case _: new UnknownType()
        }
      } else {
        new UnknownType()
      }
    }
  }
  case TemplateLiteral {loc}: {
    let stringType = ctx.resolveTypeName("String");
    if (stringType != null) { return stringType as Type; }
    ctx.error(
      "Built-in type 'String' is not available. Ensure the standard prelude is loaded.",
      DiagnosticCode.SymbolNotFound,
      loc
    );
    new UnknownType()
  }
  case TaggedTemplateExpression {tag, quasi, loc}: {
    // Check the interpolated expressions.
    var qi = 0;
    while (qi < quasi.expressions.length) {
      checkExpression(ctx, quasi.expressions[qi], null);
      qi += 1;
    }
    // Check the tag function and return its return type.
    let tagType = checkExpression(ctx, tag, null);
    match (tagType) {
      case FunctionType as ft: ft.returnType
      case _: {
        ctx.error(
          "Tagged template tag must be a function, got '" + typeToString(tagType) + "'.",
          DiagnosticCode.TypeMismatch, loc
        );
        new UnknownType()
      }
    }
  }
  case MatchExpression {discriminant, cases, loc}: {
    checkMatchExpr(ctx, discriminant, cases, loc, expectedType)
  }
  case ThrowExpression {argument, loc}: {
    checkExpression(ctx, argument, null);
    new NeverType()
  }
  case TryExpression {body, handler, finalizer, loc}: {
    let tryType = checkMatchCaseBody(ctx, body as Node, expectedType);
    var catchType: Type | null = null;
    if (handler != null) {
      let clause = handler as CatchClause;
      ctx.enterScope();
      if (clause.param != null) {
        let paramId = clause.param as Identifier;
        let info = ctx.model.resolveDeclaration(paramId);
        if (info != null) {
          ctx.declareBinding(info as SymbolInfo, new UnknownType());
        }
      }
      catchType = checkMatchCaseBody(ctx, clause.body as Node, expectedType);
      ctx.exitScope();
    }
    if (finalizer != null) {
      checkMatchCaseBody(ctx, finalizer as Node, null);
    }
    if (catchType != null) {
      let types = new Array<Type>();
      types.push(tryType);
      types.push(catchType as Type);
      createUnionType(types)
    } else {
      tryType
    }
  }
  case RangeExpression {start, end, loc}: {
    // Check start/end are i32.
    if (start != null) {
      let startType = checkExpression(ctx, start as Expression, null);
      if (!isAssignableTo(ctx, startType, new I32Type())) {
        ctx.error(
          "Range start must be i32, got '" + typeToString(startType) + "'.",
          DiagnosticCode.TypeMismatch, loc
        );
      }
    }
    if (end != null) {
      let endType = checkExpression(ctx, end as Expression, null);
      if (!isAssignableTo(ctx, endType, new I32Type())) {
        ctx.error(
          "Range end must be i32, got '" + typeToString(endType) + "'.",
          DiagnosticCode.TypeMismatch, loc
        );
      }
    }
    // Determine which range variant to return.
    let rangeTypeName = if (start != null && end != null) { "BoundedRange" }
      else if (start != null) { "FromRange" }
      else if (end != null) { "ToRange" }
      else { "FullRange" };
    let rangeType = ctx.resolveTypeName(rangeTypeName);
    if (rangeType != null) { rangeType as Type }
    else { new UnknownType() }
  }
  case PipelineExpression {left, right, loc}: {
    let leftType = checkExpression(ctx, left, null);
    ctx.pushPipelineValue(leftType);
    let resultType = checkExpression(ctx, right, null);
    ctx.popPipelineValue();
    resultType
  }
  case PipePlaceholder {loc}: {
    let pipeType = ctx.pipelineValueType;
    if (pipeType == null) {
      ctx.error("'$' can only be used inside a pipeline expression (|>).", DiagnosticCode.SymbolNotFound, loc);
      new UnknownType()
    } else {
      pipeType as Type
    }
  }
};

// ============================================================================
// Class & Interface Checking
// ============================================================================

/**
 * Register a class declaration's type identity, flags, superclass,
 * case-class params, member signatures (fields, methods, accessors),
 * and sealed variant types. Does NOT check method bodies, field
 * initializers, or accessor bodies — that happens in checkClassBodies.
 */
let registerClassDeclaration = (ctx: CheckerContext, cd: ClassDeclaration): void => {
  // Access Identifier.name directly. In Zena AST, ClassDeclaration.name is an Identifier
  // which has a .name: String field. Use cd.name.name directly.
  let className = cd.name.name;

  // Look up the pre-registered ClassType from the forward-declaration pass.
  // If not found (shouldn't happen), create one.
  var classType: ClassType = new ClassType(ctx.freshTypeId(), className);
  let preRegistered = ctx.resolveTypeName(className);
  if (preRegistered != null) {
    match (preRegistered as Type) {
      case ClassType as existing: { classType = existing; }
      case _: {}
    }
  }

  // Record the declaring file for cross-module goto-definition.
  classType.sourcePath = ctx.filePath;

  // Flags — ClassDeclaration is authoritative, overriding any
  // previously materialized flags (e.g., from SealedVariant).
  classType.isFinal = cd.isFinal;
  classType.isAbstract = cd.isAbstract;
  classType.isExtension = cd.isExtension;
  classType.isSealed = cd.isSealed;
  classType.isCaseClass = false;

  // Sealed classes are implicitly abstract (cannot be instantiated directly).
  if (cd.isSealed) {
    classType.isAbstract = true;
  }

  // Case class: implicitly final (unless sealed).
  if (cd.caseParams != null && !cd.isSealed) {
    classType.isFinal = true;
    classType.isCaseClass = true;
  }

  // Sealed classes: register forward variant names.
  if (cd.isSealed && cd.sealedVariants != null) {
    let variants = cd.sealedVariants as Array<SealedVariant>;
    var fvi = 0;
    while (fvi < variants.length) {
      let variant = variants[fvi];
      if (variant.params == null) {
        if (classType.forwardVariantNames != null) {
          (classType.forwardVariantNames as HashSet<String>).add(variant.name.name);
        } else {
          let set = new HashSet<String>();
          set.add(variant.name.name);
          classType.forwardVariantNames = set;
        }
      }
      fvi = fvi + 1;
    }
  }

  // Type parameters.
  ctx.enterScope();
  if (cd.typeParameters != null) {
    let tps = cd.typeParameters as Array<TypeParameter>;
    var tpi = 0;
    while (tpi < tps.length) {
      let tp = tps[tpi];
      var constraint: Type | null = null;
      if (tp.constraint != null) {
        constraint = resolveTypeAnnotation(ctx, tp.constraint as TypeAnnotation);
      }
      var defaultT: Type | null = null;
      if (tp.defaultType != null) {
        defaultT = resolveTypeAnnotation(ctx, tp.defaultType as TypeAnnotation);
      }
      let tpType = new TypeParameterType(tp.name, constraint, defaultT);
      ctx.declareTypeName(tp.name, tpType);

      if (classType.typeParameters == null) {
        classType.typeParameters = new Array<TypeParameterType>();
      }
      (classType.typeParameters as Array<TypeParameterType>).push(tpType);
      tpi = tpi + 1;
    }
  }

  // Resolve superclass.
  if (cd.superClass != null) {
    let superAnn = cd.superClass as TypeAnnotation;
    let superType = resolveTypeAnnotation(ctx, superAnn);
    match (superType) {
      case ClassType as st: {
        if (st.isFinal || st.isCaseClass) {
          ctx.error(
            "Cannot extend final class '" + st.name + "'." +
            if (st.isCaseClass) " Case classes are implicitly final." else "",
            DiagnosticCode.IncompatibleTypes,
            cd.loc
          );
        }
        // Sealed classes can only be extended by their declared variants.
        if (st.isSealed) {
          // Check if this class is a forward-declared variant
          var isForwardVariant = false;
          if (st.forwardVariantNames != null) {
            let fwdNames = st.forwardVariantNames as HashSet<String>;
            if (fwdNames.has(className)) {
              isForwardVariant = true;
            }
          }
          if (!isForwardVariant) {
            ctx.error(
              "cannot extend sealed class '" + st.name + "'. " +
              "Sealed classes can only be extended by their declared variants.",
              DiagnosticCode.IncompatibleTypes,
              cd.loc
            );
          }
        }
        classType.superType = st;
        // Inherit fields and methods from superclass.
        // Skip abstract fields - they need to be implemented, not inherited.
        let fieldKeys = st.fields.keys();
        while (let (true, key) = fieldKeys.next()) {
          // Check if this is an abstract field
          var isAbstractInSuper = false;
          if (st.abstractFields != null) {
            let stAbs = st.abstractFields as HashSet<String>;
            if (stAbs.has(key)) {
              isAbstractInSuper = true;
            }
          }
          if (!isAbstractInSuper) {
            classType.fields[key] = st.fields[key];
            if (st.fieldMutability.has(key)) {
              classType.fieldMutability[key] = st.fieldMutability[key];
            }
          }
        }
        let methodKeys = st.methods.keys();
        while (let (true, key) = methodKeys.next()) {
          classType.methods[key] = st.methods[key];
        }
        // Inherit abstract fields from superclass.
        if (st.abstractFields != null) {
          let stAbstract = st.abstractFields as HashSet<String>;
          let targetAbsFields = classType.abstractFields ??= new HashSet<String>();
          for (let absKey in stAbstract) {
            targetAbsFields.add(absKey);
          }
        }
        // Inherit abstract methods from superclass.
        if (st.abstractMethods != null) {
          let stAbstractMethods = st.abstractMethods as HashSet<String>;
          let targetAbsMethods = classType.abstractMethods ??= new HashSet<String>();
          for (let absMethodKey in stAbstractMethods) {
            targetAbsMethods.add(absMethodKey);
          }
        }
      }
      case _: {
        ctx.error(
          "Superclass must be a class type, got '" + typeToString(superType) + "'.",
          DiagnosticCode.IncompatibleTypes,
          cd.loc
        );
      }
    }
  }

  // Apply mixins
  if (cd.mixins != null) {
    let mixinAnns = cd.mixins as Array<TypeAnnotation>;
    var mi = 0;
    while (mi < mixinAnns.length) {
      let mixinAnn = mixinAnns[mi];
      let resolvedMixin = resolveTypeAnnotation(ctx, mixinAnn);
      
      match (resolvedMixin) {
        case MixinType as mt: {
          // Check 'on' constraint
          if (mt.onType != null) {
            var st: Type | null = null;
            if (cd.superClass != null && classType.superType != null) {
              st = classType.superType as Type;
            }
            if (st == null) {
              ctx.error(
                "Mixin '" + mt.name + "' requires superclass to extend '" + 
                (mt.onType as ClassType).name + "', but no superclass is defined.",
                DiagnosticCode.TypeMismatch,
                mixinAnn.loc
              );
            } else {
              if (!isAssignableTo(ctx, st, mt.onType as Type)) {
                ctx.error(
                  "Mixin '" + mt.name + "' requires superclass to extend '" + 
                  (mt.onType as ClassType).name + "'.",
                  DiagnosticCode.TypeMismatch,
                  mixinAnn.loc
                );
              }
            }
          }
          
          // Copy fields
          let fieldKeys = mt.fields.keys();
          while (let (true, key) = fieldKeys.next()) {
            classType.fields[key] = mt.fields[key];
            if (mt.fieldMutability.has(key)) {
              classType.fieldMutability[key] = mt.fieldMutability[key];
            }
          }
          
          // Copy methods
          let methodKeys = mt.methods.keys();
          while (let (true, key) = methodKeys.next()) {
            let mMethod = mt.methods[key];
            if (classType.methods.has(key)) {
              let existingMethod = classType.methods[key];
              if (!isAssignableTo(ctx, mMethod, existingMethod)) {
                ctx.error(
                  "Type mismatch in overridden method '" + key + "' is not compatible.",
                  DiagnosticCode.TypeMismatch,
                  mixinAnn.loc
                );
              }
            }
            classType.methods[key] = mMethod;
          }
        }
        case _: {
          if (!(resolvedMixin is UnknownType)) {
            ctx.error(
              "'" + typeToString(resolvedMixin) + "' is not a mixin.",
              DiagnosticCode.TypeMismatch,
              mixinAnn.loc
            );
          }
        }
      }
      mi += 1;
    }
  }

  // Process case class parameters → generate fields and constructor.
  if (cd.caseParams != null) {
    let caseParams = cd.caseParams as Array<CaseClassParam>;
    let ctorParamTypes = new Array<Type>();
    let ctorParamNames = new Array<String>();
    let ctorOptionalParams = new Array<boolean>();

    var cpi = 0;
    while (cpi < caseParams.length) {
      let cp = caseParams[cpi];
      let fieldName = cp.name.name;
      let fieldType = resolveTypeAnnotation(ctx, cp.typeAnnotation);

      // Check for duplicate fields (but allow implementing abstract fields).
      if (classType.fields.has(fieldName)) {
        ctx.error(
          "Duplicate field '" + fieldName + "' in class '" + className + "'.",
          DiagnosticCode.DuplicateField,
          cp.loc
        );
      }

      classType.fields[fieldName] = fieldType;
      let isMutable = cp.mutability != null && cp.mutability == "var";
      classType.fieldMutability[fieldName] = isMutable;

      // Case param may satisfy an inherited abstract field.
      if (classType.abstractFields != null) {
        let absFields = classType.abstractFields as HashSet<String>;
        if (absFields.has(fieldName)) {
          absFields.delete(fieldName);
        }
      }

      ctorParamTypes.push(fieldType);
      ctorParamNames.push(fieldName);
      ctorOptionalParams.push(cp.optional);
      cpi = cpi + 1;
    }

    // Auto-generate constructor type.
    let ctorType = new FunctionType(ctorParamTypes, ctorParamNames, classType);
    ctorType.optionalParameters = ctorOptionalParams;
    classType.constructorType = ctorType;
  }

  // Register the class type in both namespaces.
  ctx.declareTypeName(className, classType);

  // Also register in the value namespace (for `new ClassName` and as a binding).
  let classInfo = ctx.model.resolveDeclaration(cd);
  if (classInfo != null) {
    ctx.declareBinding(classInfo as SymbolInfo, classType);
  }

  // Enter class context for body checking.
  ctx.enterClass(classType);

  // === Pass 1: Register all field types and method signatures ===
  // This allows forward references between methods (e.g. this.#foo() calling
  // a private method defined later in the class body).
  // Track fields declared directly in this class body (not inherited).
  let ownFieldNames = new HashSet<String>();
  var bi = 0;
  while (bi < cd.body.length) {
    let member = cd.body[bi];
    match (member) {
      case FieldDefinition as fd: {
        let fieldName = match (fd.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        let fieldType = if (fd.typeAnnotation != null) {
          resolveTypeAnnotation(ctx, fd.typeAnnotation as TypeAnnotation)
        } else {
          new UnknownType() as Type
        };

        // Abstract fields can only appear in abstract or sealed classes.
        if (fd.isAbstract) {
          if (!cd.isAbstract && !cd.isSealed) {
            ctx.error(
              "Abstract field '" + fieldName + "' can only appear within an abstract or sealed class.",
              DiagnosticCode.IncompatibleTypes,
              fd.loc
            );
          }
          // Track abstract field.
          let absFields = classType.abstractFields ??= new HashSet<String>();
          absFields.add(fieldName);
        } else {
          // Concrete field may satisfy an inherited abstract field.
          if (classType.abstractFields != null) {
            let absFields = classType.abstractFields as HashSet<String>;
            if (absFields.has(fieldName)) {
              absFields.delete(fieldName);
            }
          }
        }

        // Optional fields cannot have primitive types (primitives are not nullable).
        if (fd.isOptional) {
          let isPrimitive = isNumericType(fieldType) || fieldType is BooleanType;
          if (isPrimitive) {
            ctx.error(
              "Optional field '" + fieldName + "' cannot have primitive type '" +
              typeToString(fieldType) + "'. Primitives are not nullable.",
              DiagnosticCode.IncompatibleTypes,
              fd.loc
            );
          }
        }

        if (ownFieldNames.has(fieldName)) {
          ctx.error(
            "Duplicate field '" + fieldName + "' in class '" + className + "'.",
            DiagnosticCode.DuplicateField,
            fd.loc
          );
        } else if (classType.fields.has(fieldName)) {
          // Field was inherited from superclass — check type compatibility.
          let inheritedType = classType.fields[fieldName];
          if (!isAssignableTo(ctx, fieldType, inheritedType)) {
            ctx.error(
              "Field '" + fieldName + "' in subclass '" + className +
              "' must be compatible with inherited field of type '" +
              typeToString(inheritedType) + "'.",
              DiagnosticCode.IncompatibleTypes,
              fd.loc
            );
          }
        }
        ownFieldNames.add(fieldName);

        classType.fields[fieldName] = fieldType;
        let isMutable = fd.mutability != null && fd.mutability == "var";
        classType.fieldMutability[fieldName] = isMutable;
      }
      case MethodDefinition as md: {
        let methodName = match (md.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };

        if (methodName == "<constructor>") {
          if (cd.caseParams != null && classType.constructorType != null) {
            ctx.error(
              "Duplicate constructor in case class '" + className +
              "'. Case classes auto-generate a constructor from their parameters.",
              DiagnosticCode.DuplicateMethod,
              md.loc
            );
          } else {
            let ctorType = checkMethodSignature(ctx, classType, md);
            ctorType.returnType = classType;
            classType.constructorType = ctorType;
          }
        } else {
          // Regular method.

          // Check for field/method name conflict.
          if (ownFieldNames.has(methodName)) {
            ctx.error(
              "Method '" + methodName + "' conflicts with field '" + methodName + "'.",
              DiagnosticCode.DuplicateDeclaration,
              md.loc
            );
          }

          // Check abstract method in concrete class.
          if (md.isAbstract && !cd.isAbstract && !cd.isSealed) {
            ctx.error(
              "Abstract method '" + methodName + "' can only appear within an abstract class.",
              DiagnosticCode.IncompatibleTypes,
              md.loc
            );
          }

          // Check final method override.
          if (classType.superType != null) {
            let superCt = classType.superType as ClassType;
            if (superCt.methods.has(methodName)) {
              let inheritedMethod = superCt.methods[methodName];
              if (inheritedMethod.isFinal) {
                ctx.error(
                  "Cannot override final method '" + methodName + "'.",
                  DiagnosticCode.IncompatibleTypes,
                  md.loc
                );
              }
            }
          }

          let methodType = checkMethodSignature(ctx, classType, md);
          classType.methods[methodName] = methodType;

          // Track abstract methods for checking in subclasses.
          trackAbstractMethod(ctx, classType, methodName, md.isAbstract);
        }
      }
      case AccessorDeclaration as acc: {
        let accName = match (acc.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        let accType = resolveTypeAnnotation(ctx, acc.typeAnnotation);

        // Getter creates get#accName method.
        if (acc.getter != null) {
          let getterName = "get#" + accName;
          // Check for final override.
          if (classType.superType != null) {
            let superCt = classType.superType as ClassType;
            if (superCt.methods.has(getterName)) {
              let superMethod = superCt.methods[getterName];
              if (superMethod.isFinal) {
                ctx.error(
                  "Cannot override final method '" + getterName + "'.",
                  DiagnosticCode.IncompatibleTypes,
                  acc.loc
                );
              }
            }
          }
          let getterType = new FunctionType(new Array<Type>(), null, accType);
          getterType.isFinal = acc.isFinal;
          classType.methods[getterName] = getterType;
        }

        // Setter creates a method set#accName with param type = accType.
        if (acc.setter != null) {
          let setterName = "set#" + accName;
          // Check for final override.
          if (classType.superType != null) {
            let superCt = classType.superType as ClassType;
            if (superCt.methods.has(setterName)) {
              let superMethod = superCt.methods[setterName];
              if (superMethod.isFinal) {
                ctx.error(
                  "Cannot override final method '" + setterName + "'.",
                  DiagnosticCode.IncompatibleTypes,
                  acc.loc
                );
              }
            }
          }
          let setterParams = new Array<Type>();
          setterParams.push(accType);
          let setterType = new FunctionType(setterParams, null, new VoidType());
          setterType.isFinal = acc.isFinal;
          classType.methods[setterName] = setterType;
        }
      }
      case MethodSignature as ms: {
        let methodName = (ms.name as Identifier).name;
        
        if (methodName == "new") {
          if (cd.caseParams != null && classType.constructorType != null) {
            ctx.error(
              "Duplicate constructor in case class '" + className +
              "'. Case classes auto-generate a constructor from their parameters.",
              DiagnosticCode.DuplicateMethod,
              ms.loc
            );
          } else {
            let paramTypes = new Array<Type>();
            let paramNames = new Array<String>();
            var pi = 0;
            while (pi < ms.params.length) {
              let param = ms.params[pi];
              let paramName = param.name.name;
              var paramType: Type = new UnknownType();
              if (param.isThisParam && classType.fields.has(paramName)) {
                paramType = classType.fields[paramName];
              } else if (param.typeAnnotation != null) {
                paramType = resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation);
              }
              paramTypes.push(paramType);
              paramNames.push(paramName);
              pi = pi + 1;
            }
            let ctorType = new FunctionType(paramTypes, paramNames, classType);
            classType.constructorType = ctorType;
          }
        } else {
          let paramTypes = new Array<Type>();
          var pi = 0;
          while (pi < ms.params.length) {
            let param = ms.params[pi];
            var paramType: Type = new UnknownType();
            if (param.typeAnnotation != null) {
              paramType = resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation);
            }
            paramTypes.push(paramType);
            pi = pi + 1;
          }
          var retType: Type = new VoidType();
          if (ms.returnType != null) {
            retType = resolveTypeAnnotation(ctx, ms.returnType as TypeAnnotation);
          }
          classType.methods[methodName] = new FunctionType(paramTypes, null, retType);
        }
      }
      case _: {}
    }
    bi = bi + 1;
  }

  // Handle sealed class variants.
  if (cd.isSealed && cd.sealedVariants != null) {
    let variants = cd.sealedVariants as Array<SealedVariant>;
    classType.sealedVariants = new Array<ClassType>();
    var vi = 0;
    while (vi < variants.length) {
      let variant = variants[vi];
      let variantName = variant.name.name;

      // Forward-declared variants (null params, like `case Circle, Rect`)
      // are defined as separate classes - skip creating inline types.
      if (variant.params != null) {
        // On-demand: resolveTypeName will materialize from the SealedVariant
        // declaration in scope analysis if this variant was referenced earlier.
        // If not, create a fresh ClassType.
        let existingType = ctx.resolveTypeName(variantName);
        var variantType: ClassType = new ClassType(ctx.freshTypeId(), variantName);
        if (existingType != null) {
          // Check scope analysis: if the name's declaration is a SealedVariant,
          // the existing type was forward-materialized from this variant — reuse.
          // If it's a ClassDeclaration or other node, it's a name conflict.
          var isForwardVariant = false;
          if (ctx.scopeResult != null) {
            let scopeInfo = (ctx.scopeResult as ScopeResult).rootScope.resolveType(variantName);
            if (scopeInfo != null && (scopeInfo as SymbolInfo).declaration is SealedVariant) {
              isForwardVariant = true;
            }
          }
          if (isForwardVariant && existingType is ClassType) {
            variantType = existingType as ClassType;
          } else {
            ctx.error(
              "Duplicate declaration of '" + variantName + "' as inline variant. " +
              "The name conflicts with an existing type.",
              DiagnosticCode.DuplicateDeclaration,
              variant.name.loc
            );
          }
        }
        variantType.superType = classType;
        variantType.isCaseClass = true;
        variantType.isFinal = true;

        // Inherit fields from parent.
        let parentFieldKeys = classType.fields.keys();
        while (let (true, key) = parentFieldKeys.next()) {
          variantType.fields[key] = classType.fields[key];
          if (classType.fieldMutability.has(key)) {
            variantType.fieldMutability[key] = classType.fieldMutability[key];
          }
        }

        // Process variant parameters as fields + constructor.
        let vParams = variant.params as Array<CaseClassParam>;
        let vCtorParams = new Array<Type>();
        let vCtorNames = new Array<String>();
        var vpi = 0;
        while (vpi < vParams.length) {
          let vp = vParams[vpi];
          let vpType = resolveTypeAnnotation(ctx, vp.typeAnnotation);
          variantType.fields[vp.name.name] = vpType;
          let isMut = vp.mutability != null && vp.mutability == "var";
          variantType.fieldMutability[vp.name.name] = isMut;
          vCtorParams.push(vpType);
          vCtorNames.push(vp.name.name);
          vpi = vpi + 1;
        }
        variantType.constructorType = new FunctionType(
          vCtorParams, vCtorNames, variantType
        );

        (classType.sealedVariants as Array<ClassType>).push(variantType);

        // Register variant in type and value namespaces (module scope
        // so the name is visible in match patterns outside the class).
        ctx.declareModuleTypeName(variant.name.name, variantType);
        // Also bind the variant type to its SymbolInfo so cross-module
        // import resolution can find the fully-typed ClassType.
        let variantInfo = ctx.model.resolveDeclaration(variant);
        if (variantInfo != null) {
          ctx.declareBinding(variantInfo as SymbolInfo, variantType);
        }
      } else {
        // Forward-declared variant or unit variant (no params).
        // Look up an existing class type (distributed variant pattern),
        // otherwise create an inline unit variant.
        match (ctx.resolveTypeName(variantName)) {
          case ClassType as ct: {
            // If this ClassType was forward-materialized on-demand from a
            // SealedVariant, it won't have superType/constructor yet.
            // Complete it now.
            if (ct.superType == null) {
              ct.superType = classType;
              // Only fully set up unit variants (not forward-declared ones
              // which have their own ClassDeclaration that handles fields).
              var isForwardVariant2 = false;
              if (classType.forwardVariantNames != null) {
                let fvn = classType.forwardVariantNames as HashSet<String>;
                if (fvn.has(variantName)) { isForwardVariant2 = true; }
              }
              if (!isForwardVariant2) {
                ct.isCaseClass = true;
                ct.isFinal = true;
                // Inherit fields from parent.
                let pfKeys = classType.fields.keys();
                while (let (true, pfk) = pfKeys.next()) {
                  ct.fields[pfk] = classType.fields[pfk];
                  if (classType.fieldMutability.has(pfk)) {
                    ct.fieldMutability[pfk] = classType.fieldMutability[pfk];
                  }
                }
                if (ct.constructorType == null) {
                  ct.constructorType = new FunctionType(
                    new Array<Type>(), new Array<String>(), ct
                  );
                }
              }
            }
            let sealedVars = classType.sealedVariants as Array<ClassType>;
            sealedVars.push(ct);
          }
          case _: {
            let unitType = new ClassType(ctx.freshTypeId(), variantName);
            unitType.superType = classType;
            unitType.isCaseClass = true;
            unitType.isFinal = true;

            // Inherit fields from parent.
            let parentFieldKeys2 = classType.fields.keys();
            while (let (true, key2) = parentFieldKeys2.next()) {
              unitType.fields[key2] = classType.fields[key2];
              if (classType.fieldMutability.has(key2)) {
                unitType.fieldMutability[key2] = classType.fieldMutability[key2];
              }
            }
            // Unit variant: zero-arg constructor.
            unitType.constructorType = new FunctionType(
              new Array<Type>(), new Array<String>(), unitType
            );

            (classType.sealedVariants as Array<ClassType>).push(unitType);
            ctx.declareModuleTypeName(variantName, unitType);
          }
        }
      }

      vi = vi + 1;
    }
  }

  ctx.exitClass();
  ctx.exitScope();
};

/**
 * Check class method bodies, field initializers, accessor bodies, interface
 * conformance, and abstract field/method implementation. Called in Phase 2
 * after all declaration signatures have been registered.
 */
let checkClassBodies = (ctx: CheckerContext, cd: ClassDeclaration): void => {
  let className = cd.name.name;

  // Look up the ClassType registered by registerClassDeclaration.
  var classType: ClassType = new ClassType(ctx.freshTypeId(), className);
  let resolved = ctx.resolveTypeName(className);
  if (resolved != null) {
    match (resolved as Type) {
      case ClassType as ct: { classType = ct; }
      case _: {}
    }
  }

  // Re-enter scope for type parameters so method bodies can reference them.
  ctx.enterScope();
  if (classType.typeParameters != null) {
    let tps = classType.typeParameters as Array<TypeParameterType>;
    var tpi = 0;
    while (tpi < tps.length) {
      ctx.declareTypeName(tps[tpi].name, tps[tpi]);
      tpi = tpi + 1;
    }
  }

  ctx.enterClass(classType);

  // Check method bodies and field initializers.
  // Collect field names in declaration order for forward-reference detection.
  let fieldOrder = new Array<String>();
  var foi = 0;
  while (foi < cd.body.length) {
    match (cd.body[foi]) {
      case FieldDefinition as fd: {
        let fn = match (fd.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        fieldOrder.push(fn);
      }
      case _: {}
    }
    foi = foi + 1;
  }

  var fieldIndex = 0;
  var bi = 0;
  while (bi < cd.body.length) {
    let member = cd.body[bi];
    match (member) {
      case FieldDefinition as fd: {
        if (fd.value != null) {
          let fieldName = match (fd.name) {
            case Identifier {name}: name
            case _: "<unknown>"
          };

          // Temporarily hide fields declared after this one so that
          // forward references in initializers (e.g. this.y when y comes
          // later) are caught as "property does not exist" errors.
          let hiddenFields = new HashMap<String, Type>();
          var hi = fieldIndex + 1;
          while (hi < fieldOrder.length) {
            let laterName = fieldOrder[hi];
            // Don't hide the current field (handles duplicate field names).
            if (laterName != fieldName && classType.fields.has(laterName)) {
              hiddenFields[laterName] = classType.fields[laterName];
              classType.fields.delete(laterName);
            }
            hi = hi + 1;
          }

          let fieldType = classType.fields[fieldName];
          let initType = checkExpression(ctx, fd.value as Expression, fieldType);

          // Restore hidden fields.
          let restoreKeys = hiddenFields.keys();
          while (let (true, key) = restoreKeys.next()) {
            classType.fields[key] = hiddenFields[key];
          }

          // Infer field type from initializer when no explicit annotation.
          if (fieldType is UnknownType && !(initType is UnknownType)) {
            classType.fields[fieldName] = initType;
          } else if (!isAssignableTo(ctx, initType, fieldType)) {
            ctx.error(
              "Type mismatch: field '" + fieldName + "' has type '" +
              typeToString(fieldType) + "' but initializer has type '" +
              typeToString(initType) + "'.",
              DiagnosticCode.TypeMismatch,
              fd.loc
            );
          }
        }
        fieldIndex = fieldIndex + 1;
      }
      case MethodDefinition as md: {
        if (md.body != null) {
          let methodName = match (md.name) {
            case Identifier {name}: name
            case _: "<unknown>"
          };
          if (methodName == "<constructor>") {
            if (classType.constructorType != null) {
              checkMethodBody(ctx, classType, classType.constructorType as FunctionType, md);
            }
            // Derived class constructors must call super().
            if (classType.superType != null && md.superInitializer == null && !classType.isCaseClass) {
              ctx.error(
                "Constructors in derived classes must call super().",
                DiagnosticCode.IncompatibleTypes,
                md.loc
              );
            }
          } else {
            if (classType.methods.has(methodName)) {
              checkMethodBody(ctx, classType, classType.methods[methodName], md);
            }
          }
        }
      }
      case AccessorDeclaration as acc: {
        let accName = match (acc.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        let accType = resolveTypeAnnotation(ctx, acc.typeAnnotation);

        // Check getter body.
        if (acc.getter != null) {
          let getterBlock = acc.getter as BlockStatement;
          ctx.enterScope();
          let prevReturnType = ctx.returnType;
          ctx.setReturnType(accType);
          var gi = 0;
          while (gi < getterBlock.body.length) {
            checkStatement(ctx, getterBlock.body[gi]);
            gi += 1;
          }
          ctx.setReturnType(prevReturnType);
          ctx.exitScope();
        }

        // Check setter body.
        if (acc.setter != null) {
          match (acc.setter as Node) {
            case SetterInfo as si: {
              ctx.enterScope();
              let paramInfo = ctx.model.resolveDeclaration(si.param);
              if (paramInfo != null) {
                ctx.declareBinding(paramInfo as SymbolInfo, accType);
              }
              var sbi = 0;
              while (sbi < si.body.body.length) {
                checkStatement(ctx, si.body.body[sbi]);
                sbi += 1;
              }
              ctx.exitScope();
            }
            case _: {}
          }
        }
      }
      case _: {}
    }
    bi = bi + 1;
  }

  // Check interface conformance.
  if (cd.implementsList != null) {
    let implList = cd.implementsList as Array<TypeAnnotation>;
    var ii = 0;
    while (ii < implList.length) {
      let ifaceAnn = implList[ii];
      let ifaceType = resolveTypeAnnotation(ctx, ifaceAnn);
      match (ifaceType) {
        case InterfaceType as iface: {
          classType.implementsList.push(iface);
          // Check all interface methods are implemented.
          let ifaceMethodKeys = iface.methods.keys();
          while (let (true, methodName) = ifaceMethodKeys.next()) {
            let ifaceMethod = iface.methods[methodName];
            if (classType.methods.has(methodName)) {
              // Check signature compatibility.
              let expectedMethodType = substituteTypeParams(iface.typeParameters, iface.typeArguments, ifaceMethod);
              let classMethod = classType.methods[methodName];
              if (!isAssignableTo(ctx, classMethod, expectedMethodType)) {
                ctx.error(
                  "Class '" + className + "' incorrectly implements interface '" + iface.name +
                  "': Method '" + methodName + "' is type '" + typeToString(classMethod) +
                  "' but expected '" + typeToString(expectedMethodType) + "'.",
                  DiagnosticCode.IncompatibleTypes,
                  cd.loc
                );
              }
            } else if (classType.fields.has(methodName)) {
              // A field can satisfy a getter/setter interface method.
            } else {
              ctx.error(
                "Class '" + className + "' incorrectly implements interface '" + iface.name +
                "': Method '" + methodName + "' is missing.",
                DiagnosticCode.IncompatibleTypes,
                cd.loc
              );
            }
          }
          // Check all interface fields are implemented.
          let ifaceFieldKeys = iface.fields.keys();
          while (let (true, fieldName) = ifaceFieldKeys.next()) {
            // Interface field requires at least a getter.
            let getterName = "get#" + fieldName;
            let hasField = classType.fields.has(fieldName);
            let hasGetter = classType.methods.has(getterName);
            if (!hasField && !hasGetter) {
              ctx.error(
                "Class '" + className + "' incorrectly implements interface '" + iface.name +
                "': Getter for '" + fieldName + "' is missing.",
                DiagnosticCode.IncompatibleTypes,
                cd.loc
              );
            }
          }
        }
        case _: {}
      }
      ii += 1;
    }
  }

  // Check for unimplemented abstract fields in non-abstract classes.
  if (!cd.isAbstract && !cd.isSealed) {
    if (classType.abstractFields != null) {
      let absFields = classType.abstractFields as HashSet<String>;
      for (let absName in absFields) {
        ctx.error(
          "Non-abstract class '" + className + "' does not implement abstract field '" + absName + "'.",
          DiagnosticCode.AbstractMethodNotImplemented,
          cd.loc
        );
      }
    }
    // Check for unimplemented abstract methods in non-abstract classes.
    if (classType.abstractMethods != null) {
      let absMethods = classType.abstractMethods as HashSet<String>;
      for (let absMethodName in absMethods) {
        ctx.error(
          "Non-abstract class '" + className + "' does not implement abstract method '" + absMethodName + "'.",
          DiagnosticCode.AbstractMethodNotImplemented,
          cd.loc
        );
      }
    }
  }

  ctx.exitClass();
  ctx.exitScope();
};

/**
 * Track an abstract method on a class type, or remove it if it's been implemented.
 */
let trackAbstractMethod = (ctx: CheckerContext, classType: ClassType, methodName: String, isAbstract: boolean) => {
  if (isAbstract) {
    let absMethods = classType.abstractMethods ??= new HashSet<String>();
    absMethods.add(methodName);
  } else {
    if (classType.abstractMethods != null) {
      let absMethods = classType.abstractMethods as HashSet<String>;
      if (absMethods.has(methodName)) {
        absMethods.delete(methodName);
      }
    }
  }
};

/**
 * Build a FunctionType for a method from its MethodDefinition.
 */
let checkMethodSignature = (
  ctx: CheckerContext,
  classType: ClassType,
  md: MethodDefinition
): FunctionType => {
  let paramTypes = new Array<Type>();
  let paramNames = new Array<String>();
  var hasOptionals = false;
  let optionals = new Array<boolean>();
  var hasInitializers = false;
  let initializers = new Array<Expression | null>();

  var i = 0;
  while (i < md.params.length) {
    let param = md.params[i];
    let paramName = param.name.name;
    var paramType: Type = new UnknownType();
    if (param.isThisParam && classType.fields.has(paramName)) {
      // this.-style param inherits type from the class field.
      paramType = classType.fields[paramName];
    } else if (param.typeAnnotation != null) {
      paramType = resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation);
    }

    // Track optional parameters and widen to T | null.
    let isOptional = param.optional || param.defaultValue != null;
    optionals.push(isOptional);
    if (param.defaultValue != null) { hasInitializers = true; }
    initializers.push(param.defaultValue);
    if (isOptional) {
      hasOptionals = true;
      // Only widen to T | null for ?-style optionals without a default value.
      // Params with default values keep their declared type.
      if (param.optional && param.defaultValue == null) {
        var alreadyNullable = false;
        match (paramType) {
          case NullType: { alreadyNullable = true; }
          case UnionT {types}: {
            var ui = 0;
            while (ui < types.length) {
              if (types[ui] is NullType) { alreadyNullable = true; }
              ui += 1;
            }
          }
          case _: {}
        }
        if (!alreadyNullable) {
          let unionTypes = new Array<Type>();
          unionTypes.push(paramType);
          unionTypes.push(new NullType());
          paramType = createUnionType(unionTypes);
        }
      }
    }

    paramTypes.push(paramType);
    paramNames.push(paramName);
    i += 1;
  }

  var retType: Type = new VoidType();
  if (md.returnType != null) {
    retType = resolveTypeAnnotation(ctx, md.returnType as TypeAnnotation);
  }

  let ft = new FunctionType(paramTypes, paramNames, retType);
  ft.isFinal = md.isFinal;
  ft.isAbstract = md.isAbstract;
  if (hasOptionals) {
    ft.optionalParameters = optionals;
  }
  if (hasInitializers) {
    ft.parameterInitializers = initializers;
  }
  return ft;
};

/**
 * Check a method body: push method scope, declare params, check body.
 */
let checkMethodBody = (
  ctx: CheckerContext,
  classType: ClassType,
  methodType: FunctionType,
  md: MethodDefinition
): void => {
  ctx.enterScope();

  // Declare parameters.
  var i = 0;
  while (i < md.params.length) {
    let param = md.params[i];
    let paramType = methodType.parameters[i];
    let paramInfo = ctx.model.resolveDeclaration(param);
    if (paramInfo != null) {
      ctx.declareBinding(paramInfo as SymbolInfo, paramType);
    }
    // For destructured params, also bind the pattern fields.
    if (param.pattern != null) {
      bindPattern(ctx, param.pattern as Pattern, paramType);
    }
    i += 1;
  }

  // Set expected return type.
  let prevReturnType = ctx.returnType;
  ctx.setReturnType(methodType.returnType);

  // Check body.
  match (md.body as Node) {
    case BlockStatement as block: {
      var j = 0;
      while (j < block.body.length) {
        checkStatement(ctx, block.body[j]);
        j = j + 1;
      }
    }
    case Expression as bodyExpr: {
      let bodyType = checkExpression(ctx, bodyExpr, methodType.returnType);
      if (!isAssignableTo(ctx, bodyType, methodType.returnType)) {
        ctx.error(
          "Type mismatch: method body returns '" + typeToString(bodyType) +
          "' but expects '" + typeToString(methodType.returnType) + "'.",
          DiagnosticCode.TypeMismatch,
          md.loc
        );
      }
    }
    case _: {}
  }

  ctx.setReturnType(prevReturnType);
  ctx.exitScope();
};

/**
 * Check an interface declaration: build an InterfaceType with method/field signatures.
 */
let checkInterfaceDeclaration = (ctx: CheckerContext, id: InterfaceDeclaration): void => {
  let ifaceName = id.name.name;

  // Look up the pre-registered InterfaceType from the forward-declaration pass.
  var ifaceType: InterfaceType = new InterfaceType(ctx.freshTypeId(), ifaceName);
  let preRegistered = ctx.resolveTypeName(ifaceName);
  if (preRegistered != null) {
    match (preRegistered as Type) {
      case InterfaceType as existing: { ifaceType = existing; }
      case _: {}
    }
  }

  // Type parameters.
  ctx.enterScope();
  if (id.typeParameters != null) {
    let tps = id.typeParameters as Array<TypeParameter>;
    var tpi = 0;
    while (tpi < tps.length) {
      let tp = tps[tpi];
      var constraint: Type | null = null;
      if (tp.constraint != null) {
        constraint = resolveTypeAnnotation(ctx, tp.constraint as TypeAnnotation);
      }
      let tpType = new TypeParameterType(tp.name, constraint, null);
      ctx.declareTypeName(tp.name, tpType);
      tpi = tpi + 1;
    }
  }

  // Resolve extends list.
  if (id.extendsList != null) {
    let extends_ = id.extendsList as Array<TypeAnnotation>;
    var ei = 0;
    while (ei < extends_.length) {
      let parentType = resolveTypeAnnotation(ctx, extends_[ei]);
      match (parentType) {
        case InterfaceType as pt: {
          ifaceType.extendsList.push(pt);
          // Inherit methods and fields.
          let methodKeys = pt.methods.keys();
          while (let (true, key) = methodKeys.next()) {
            ifaceType.methods[key] = pt.methods[key];
          }
          let fieldKeys = pt.fields.keys();
          while (let (true, key) = fieldKeys.next()) {
            ifaceType.fields[key] = pt.fields[key];
          }
        }
        case _: {}
      }
      ei = ei + 1;
    }
  }

  // Process body members.
  var bi = 0;
  while (bi < id.body.length) {
    let member = id.body[bi];
    match (member) {
      case MethodSignature as ms: {
        let paramTypes = new Array<Type>();
        var pi = 0;
        while (pi < ms.params.length) {
          let param = ms.params[pi];
          var paramType: Type = new UnknownType();
          if (param.typeAnnotation != null) {
            paramType = resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation);
          }
          paramTypes.push(paramType);
          pi = pi + 1;
        }
        var retType: Type = new VoidType();
        if (ms.returnType != null) {
          retType = resolveTypeAnnotation(ctx, ms.returnType as TypeAnnotation);
        }
        ifaceType.methods[(ms.name as Identifier).name] = new FunctionType(paramTypes, null, retType);
      }
      case PropertySignature as ps: {
        let propType = resolveTypeAnnotation(ctx, ps.typeAnnotation);
        ifaceType.fields[ps.name.name] = propType;
      }
      case FieldDefinition as fd: {
        let fieldName = match (fd.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        let fieldType = resolveTypeAnnotation(ctx, fd.typeAnnotation as TypeAnnotation);
        ifaceType.fields[fieldName] = fieldType;
        // Track mutability for setter requirement.
        if (fd.mutability != null && fd.mutability == "var") {
          ifaceType.fieldMutability[fieldName] = true;
        }
      }
      case AccessorSignature as as_: {
        let accType = resolveTypeAnnotation(ctx, as_.typeAnnotation);
        if (as_.hasGetter) {
          ifaceType.methods[as_.name.name] = new FunctionType(new Array<Type>(), null, accType);
        }
      }
      case _: {}
    }
    bi = bi + 1;
  }

  // Register interface in type namespace.
  ctx.declareTypeName(ifaceName, ifaceType);
  let ifaceInfo = ctx.model.resolveDeclaration(id);
  if (ifaceInfo != null) {
    ctx.declareBinding(ifaceInfo as SymbolInfo, ifaceType);
  }

  ctx.exitScope();
};

// ============================================================================
// Enum Declaration
// ============================================================================

let checkEnumDeclaration = (ctx: CheckerContext, ed: EnumDeclaration): void => {
  let name = ed.name.name;
  let members = ed.members;

  // Determine backing type: string or i32.
  var isStringEnum = false;
  var mi = 0;
  while (mi < members.length) {
    let member = members[mi];
    if (member.initializer != null) {
      if (member.initializer is StringLiteral) {
        isStringEnum = true;
      }
      // If NumberLiteral, stays as i32 (default).
      mi = members.length; // break
    }
    mi += 1;
  }

  // Validate members and collect values.
  var nextValue: i32 = 0;
  var vi = 0;
  while (vi < members.length) {
    let member = members[vi];
    if (member.initializer != null) {
      let initType = checkExpression(ctx, member.initializer as Expression, null);
      if (isStringEnum) {
        let stringType = ctx.resolveTypeName("String");
        if (stringType != null && !isAssignableTo(ctx, initType, stringType as Type)) {
          ctx.error(
            "Enum member initializer must be assignable to 'String'.",
            DiagnosticCode.TypeMismatch,
            member.loc
          );
        }
      } else {
        if (!isAssignableTo(ctx, initType, new I32Type())) {
          ctx.error(
            "Enum member initializer must be assignable to 'i32'.",
            DiagnosticCode.TypeMismatch,
            member.loc
          );
        }
      }
    } else {
      if (isStringEnum) {
        ctx.error(
          "String enum member '" + member.name.name + "' must have an initializer.",
          DiagnosticCode.TypeMismatch,
          member.loc
        );
      }
      nextValue += 1;
    }
    vi += 1;
  }

  // Create the enum type as a distinct type alias over the backing type.
  var backingType: Type = new I32Type();
  if (isStringEnum) {
    let st = ctx.resolveTypeName("String");
    if (st != null) { backingType = st as Type; }
    else {
      ctx.error(
        "Built-in type 'String' is not available. Ensure the standard prelude is loaded.",
        DiagnosticCode.SymbolNotFound,
        ed.name.loc
      );
      backingType = new UnknownType();
    }
  }
  let enumType = new TypeAliasType(name, null, backingType, true);

  // Register the enum in the type namespace.
  ctx.declareTypeName(name, enumType);

  // Create a record type for the value namespace (e.g., Color.Red).
  let fields = new HashMap<String, Type>();
  var fi = 0;
  while (fi < members.length) {
    fields[members[fi].name.name] = enumType;
    fi += 1;
  }
  let enumValueType = new RecordT(fields, null);

  // Register the enum value in the value namespace.
  let info = ctx.model.resolveDeclaration(ed);
  if (info != null) {
    ctx.declareBinding(info as SymbolInfo, enumValueType);
  }
};

// ============================================================================
// Mixin Declaration
// ============================================================================

let checkMixinDeclaration = (ctx: CheckerContext, md: MixinDeclaration): void => {
  let mixinName = md.name.name;

  // Look up pre-registered MixinType, or create one.
  var mixinType: MixinType = new MixinType(mixinName);
  let preRegistered = ctx.resolveTypeName(mixinName);
  if (preRegistered != null) {
    match (preRegistered as Type) {
      case MixinType as existing: { mixinType = existing; }
      case _: {}
    }
  }

  // Type parameters.
  ctx.enterScope();
  if (md.typeParameters != null) {
    let tps = md.typeParameters as Array<TypeParameter>;
    var resolvedTps = new Array<TypeParameterType>();
    var tpi = 0;
    while (tpi < tps.length) {
      let tp = tps[tpi];
      var constraint: Type | null = null;
      if (tp.constraint != null) {
        constraint = resolveTypeAnnotation(ctx, tp.constraint as TypeAnnotation);
      }
      let tpType = new TypeParameterType(tp.name, constraint, null);
      ctx.declareTypeName(tp.name, tpType);
      resolvedTps.push(tpType);
      tpi += 1;
    }
    mixinType.typeParameters = resolvedTps;
  }

  // Resolve 'on' type.
  if (md.on != null) {
    let onId = md.on as Identifier;
    let onResolved = ctx.resolveTypeName(onId.name);
    if (onResolved != null) {
      match (onResolved as Type) {
        case ClassType as onClass: {
          mixinType.onType = onClass;
        }
        case _: {
          ctx.error(
            "Mixin 'on' type must be a class, got '" + typeToString(onResolved as Type) + "'.",
            DiagnosticCode.TypeMismatch,
            md.loc
          );
        }
      }
    } else {
      ctx.error(
        "Type '" + onId.name + "' not found in 'on' clause.",
        DiagnosticCode.SymbolNotFound,
        md.loc
      );
    }
  }

  // Resolve composed mixins.
  if (md.mixins != null) {
    let mixinAnns = md.mixins as Array<TypeAnnotation>;
    var ci = 0;
    while (ci < mixinAnns.length) {
      let composedType = resolveTypeAnnotation(ctx, mixinAnns[ci]);
      match (composedType) {
        case MixinType as composedMixin: {
          // Copy fields and methods from composed mixin.
          let fieldKeys = composedMixin.fields.keys();
          while (let (true, key) = fieldKeys.next()) {
            mixinType.fields[key] = composedMixin.fields[key];
            if (composedMixin.fieldMutability.has(key)) {
              mixinType.fieldMutability[key] = composedMixin.fieldMutability[key];
            }
          }
          let methodKeys = composedMixin.methods.keys();
          while (let (true, key) = methodKeys.next()) {
            mixinType.methods[key] = composedMixin.methods[key];
          }
        }
        case _: {
          if (!(composedType is UnknownType)) {
            ctx.error(
              "'" + typeToString(composedType) + "' is not a mixin.",
              DiagnosticCode.TypeMismatch,
              md.loc
            );
          }
        }
      }
      ci += 1;
    }
  }

  // Process body members.
  var bi = 0;
  while (bi < md.body.length) {
    let member = md.body[bi];
    match (member) {
      case FieldDefinition as fd: {
        let fieldName = match (fd.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        let fieldType = resolveTypeAnnotation(ctx, fd.typeAnnotation);
        mixinType.fields[fieldName] = fieldType;
        let isMutable = fd.mutability != null && fd.mutability == "var";
        mixinType.fieldMutability[fieldName] = isMutable;

        // Check initializer if present.
        if (fd.value != null) {
          let initType = checkExpression(ctx, fd.value as Expression, fieldType);
          if (!isAssignableTo(ctx, initType, fieldType)) {
            ctx.error(
              "Type mismatch: field '" + fieldName + "' has type '" +
              typeToString(fieldType) + "' but initializer has type '" +
              typeToString(initType) + "'.",
              DiagnosticCode.TypeMismatch,
              fd.loc
            );
          }
        }
      }
      case MethodDefinition as methDef: {
        let methodName = match (methDef.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };

        // Reject constructors in mixins.
        if (methodName == "<constructor>") {
          ctx.error(
            "Mixins cannot define constructors.",
            DiagnosticCode.IncompatibleTypes,
            methDef.loc
          );
        } else {
          // Build FunctionType from annotations.
          let paramTypes = new Array<Type>();
          let paramNames = new Array<String>();
          var mpi = 0;
          while (mpi < methDef.params.length) {
            let param = methDef.params[mpi];
            var paramType: Type = new UnknownType();
            if (param.typeAnnotation != null) {
              paramType = resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation);
            }
            paramTypes.push(paramType);
            paramNames.push(param.name.name);
            mpi += 1;
          }
          var retType: Type = new VoidType();
          if (methDef.returnType != null) {
            retType = resolveTypeAnnotation(ctx, methDef.returnType as TypeAnnotation);
          }
          let ft = new FunctionType(paramTypes, paramNames, retType);
          ft.isFinal = methDef.isFinal;
          ft.isAbstract = methDef.isAbstract;
          mixinType.methods[methodName] = ft;
        }
      }
      case AccessorDeclaration as acc: {
        let accType = resolveTypeAnnotation(ctx, acc.typeAnnotation);
        let accName = match (acc.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        mixinType.fields[accName] = accType;
        if (acc.getter != null) {
          mixinType.methods[accName] = new FunctionType(new Array<Type>(), null, accType);
        }
      }
      case _: {}
    }
    bi += 1;
  }

  // 2. Check bodies
  // Create a synthetic ClassType for "this" inside the mixin
  let thisType = new ClassType(ctx.freshTypeId(), mixinName + "_This");
  
  if (mixinType.onType != null) {
    thisType.superType = mixinType.onType;
    let onClass = mixinType.onType as ClassType;
    let onKeys = onClass.fields.keys();
    while (let (true, k) = onKeys.next()) {
      if (!k.startsWith("#") && !thisType.fields.has(k)) {
        thisType.fields[k] = onClass.fields[k];
        if (onClass.fieldMutability.has(k)) {
          thisType.fieldMutability[k] = onClass.fieldMutability[k];
        }
      }
    }
    let onMethods = onClass.methods.keys();
    while (let (true, k) = onMethods.next()) {
      if (!thisType.methods.has(k)) {
        thisType.methods[k] = onClass.methods[k];
      }
    }
  }

  // Add mixin own members
  let mKeys = mixinType.fields.keys();
  while (let (true, k) = mKeys.next()) {
    thisType.fields[k] = mixinType.fields[k];
    if (mixinType.fieldMutability.has(k)) {
      thisType.fieldMutability[k] = mixinType.fieldMutability[k];
    }
  }
  let mmKeys = mixinType.methods.keys();
  while (let (true, k) = mmKeys.next()) {
    thisType.methods[k] = mixinType.methods[k];
  }

  ctx.enterClass(thisType);

  var bmi = 0;
  while (bmi < md.body.length) {
    let member = md.body[bmi];
    match (member) {
      case MethodDefinition as methDef: {
        let methodName = match (methDef.name) {
          case Identifier {name}: name
          case _: "<unknown>"
        };
        if (methodName != "<constructor>" && methDef.body != null && mixinType.methods.has(methodName)) {
           checkMethodBody(ctx, thisType, mixinType.methods[methodName], methDef);
        }
      }
      case _: {}
    }
    bmi += 1;
  }

  ctx.exitClass();

  // Register mixin type.
  ctx.declareTypeName(mixinName, mixinType);
  let info = ctx.model.resolveDeclaration(md);
  if (info != null) {
    ctx.declareBinding(info as SymbolInfo, mixinType);
  }

  ctx.exitScope();
};

// ============================================================================
// Declare Function (External Declarations)
// ============================================================================

let checkDeclareFunction = (ctx: CheckerContext, df: DeclareFunction): void => {
  // Resolve from annotations (type params, params, return type).
  // DeclareFunction always has full annotations — no body to check.
  ctx.enterScope();

  // Type parameters.
  var resolvedTypeParams: Array<TypeParameterType> | null = null;
  if (df.typeParameters != null) {
    let tps = df.typeParameters as Array<TypeParameter>;
    resolvedTypeParams = new Array<TypeParameterType>();
    var tpi = 0;
    while (tpi < tps.length) {
      let tp = tps[tpi];
      var constraint: Type | null = null;
      if (tp.constraint != null) {
        constraint = resolveTypeAnnotation(ctx, tp.constraint as TypeAnnotation);
      }
      let tpType = new TypeParameterType(tp.name, constraint, null);
      ctx.declareTypeName(tp.name, tpType);
      (resolvedTypeParams as Array<TypeParameterType>).push(tpType);
      tpi += 1;
    }
  }

  // Parameter types.
  let paramTypes = new Array<Type>();
  let paramNames = new Array<String>();
  var pi = 0;
  while (pi < df.params.length) {
    let param = df.params[pi];
    paramNames.push(param.name.name);
    if (param.typeAnnotation != null) {
      paramTypes.push(resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation));
    } else {
      paramTypes.push(new UnknownType());
    }
    pi += 1;
  }

  // Return type.
  let retType = resolveTypeAnnotation(ctx, df.returnType);

  ctx.exitScope();

  // Build function type.
  let funcType = new FunctionType(paramTypes, paramNames, retType);
  if (resolvedTypeParams != null) {
    funcType.typeParameters = resolvedTypeParams;
  }

  // Declare in value namespace.
  let info = ctx.model.resolveDeclaration(df);
  if (info != null) {
    ctx.declareBinding(info as SymbolInfo, funcType);
  }
};

// ============================================================================
// Symbol Declaration
// ============================================================================

let checkSymbolDeclaration = (ctx: CheckerContext, sd: SymbolDeclaration): void => {
  let name = sd.name.name;

  let symbolType = new SymbolType(ctx.freshTypeId(), name);

  // Declare in value namespace.
  let info = ctx.model.resolveDeclaration(sd);
  if (info != null) {
    ctx.declareBinding(info as SymbolInfo, symbolType);
  }
};

// ============================================================================
// New Expression
// ============================================================================

let checkNewExpression = (
  ctx: CheckerContext,
  callee: Identifier,
  typeArguments: Array<TypeAnnotation> | null,
  args: Array<Expression>,
  loc: SourceLocation | null
): Type => {
  let className = callee.name;

  // Resolve the class from the type namespace.
  var resolved = ctx.resolveTypeName(className);
  if (resolved == null) {
    // Try value namespace (might be imported as a value binding).
    let valueResolved = ctx.resolveIdentifier(callee);
    if (valueResolved != null) {
      match (valueResolved as Type) {
        case ClassType as ct: { resolved = ct; }
        case _: {}
      }
    }
  }

  if (resolved == null) {
    ctx.error(
      "Class '" + className + "' not found.",
      DiagnosticCode.SymbolNotFound,
      loc
    );
    return new UnknownType();
  }

  match (resolved as Type) {
    case ClassType as ct: {
      // Cannot instantiate abstract classes.
      if (ct.isAbstract) {
        ctx.error(
          "Cannot instantiate abstract class '" + ct.name + "'.",
          DiagnosticCode.CannotInstantiateAbstractClass,
          loc
        );
      }

      // Instantiate generic class (infers type arguments if not explicit).
      let instantiated = instantiateGenericClass(ctx, ct, typeArguments, args, loc);

      // Resolve constructor.
      let ctorType = instantiated.constructorType;
      if (ctorType == null) {
        // No explicit constructor — must have zero args.
        if (args.length > 0) {
          ctx.error(
            `Class '${instantiated.name}' has no constructor, but ${args.length} arguments were provided.`,
            DiagnosticCode.ArgumentCountMismatch,
            loc
          );
        }
        return instantiated;
      }

      let ctor = ctorType as FunctionType;

      // Fill in missing arguments with default values
      if (ctor.parameterInitializers != null) {
        var a = args.length;
        while (a < ctor.parameters.length) {
          let init = (ctor.parameterInitializers as Array<Expression | null>)[a];
          if (init != null) {
            let initializer = init as Expression;
            match (initializer) {
              case Identifier {name}: {
                if (name == "__LOCATION__") {
                  if (ctx.emitLocations) {
                    let locStr = if (loc != null) {
                      `${ctx.filePath}:${(loc as SourceLocation).line}`
                    } else {
                      `${ctx.filePath}:0`
                    };
                    args.push(new StringLiteral(locStr, loc));
                  } else {
                    args.push(new NullLiteral(loc));
                  }
                } else {
                  args.push(initializer);
                }
              }
              case _: { args.push(initializer); }
            }
          } else {
            // Optional but no default? Inject null.
            args.push(new NullLiteral(loc));
          }
          a += 1;
        }
      }

      // Check argument count (accounting for optional parameters).
      let expectedCount = ctor.parameters.length;
      var requiredCount = expectedCount;
      if (ctor.optionalParameters != null) {
        let optionals = ctor.optionalParameters as Array<boolean>;
        requiredCount = 0;
        var oi = 0;
        while (oi < optionals.length) {
          if (!optionals[oi]) { requiredCount = requiredCount + 1; }
          oi += 1;
        }
      }
      if (args.length < requiredCount || args.length > expectedCount) {
        let expectedMsg = if (requiredCount == expectedCount) {
          `${expectedCount}`
        } else {
          `${requiredCount}-${expectedCount}`
        };
        ctx.error(
          `Expected ${expectedMsg} arguments, got ${args.length}.`,
          DiagnosticCode.ArgumentCountMismatch,
          loc
        );
      }

      // Check argument types with substituted parameter types.
      var ai = 0;
      while (ai < args.length && ai < expectedCount) {
        let paramType = ctor.parameters[ai];
        // Substitute type parameters with type arguments.
        let expectedParamType = substituteTypeParams(
          instantiated.typeParameters, instantiated.typeArguments, paramType
        );
        // Args were already checked during inference; just validate here.
        let argType = checkExpression(ctx, args[ai], expectedParamType);
        if (!isAssignableTo(ctx, argType, expectedParamType)) {
          ctx.error(
            "Type mismatch: argument '" + typeToString(argType) +
            "' is not assignable to parameter '" +
            typeToString(expectedParamType) + "'.",
            DiagnosticCode.TypeMismatch,
            loc
          );
        }
        ai = ai + 1;
      }

      return instantiated;
    }
    case _: {
      ctx.error(
        "'" + className + "' is not a class.",
        DiagnosticCode.NotCallable,
        loc
      );
      return new UnknownType();
    }
  }
};

// ============================================================================
// Member Expression
// ============================================================================

let checkMemberExpression = (
  ctx: CheckerContext,
  object: Expression,
  property: Identifier,
  optional: boolean,
  loc: SourceLocation | null
): Type => {
  let objectType = checkExpression(ctx, object, null);
  let propName = property.name;

  // Check for private field access outside class
  if (propName.length > 0 && propName.sliceBytes(0, 1) == "#") {
    if (ctx.currentClass == null) {
      ctx.error(
        "Private field '" + propName + "' can only be accessed within a class.",
        DiagnosticCode.PrivateAccess,
        loc
      );
      return new UnknownType();
    }
  }

  // Unwrap union types for optional chaining.
  var baseType_: Type = objectType;
  var isNullable = false;
  match (objectType) {
    case UnionT {types}: {
      // If the union includes null, strip it for the member check.
      let nonNull = new Array<Type>();
      var ui = 0;
      while (ui < types.length) {
        if (types[ui] is NullType) {
          isNullable = true;
        } else {
          nonNull.push(types[ui]);
        }
        ui = ui + 1;
      }
      if (nonNull.length == 1) {
        baseType_ = nonNull[0];
      } else if (nonNull.length > 1) {
        baseType_ = new UnionT(nonNull);
      }
    }
    case NullType: { isNullable = true; }
    case _: {}
  }

  let resultType = resolveMemberType(ctx, baseType_, propName, loc);

  // If the original type was nullable and this is optional chaining,
  // wrap the result in a union with null.
  if (isNullable && optional) {
    let types = new Array<Type>();
    types.push(resultType);
    types.push(new NullType());
    return createUnionType(types);
  }

  return resultType;
};

/**
 * Look up a member (field or method) on a type.
 */
let resolveMemberType = (
  ctx: CheckerContext,
  objectType: Type,
  propName: String,
  loc: SourceLocation | null
): Type => {
  match (objectType) {
    case ClassType as ct: {
      // Check fields first.
      if (ct.fields.has(propName)) {
        let fieldType = ct.fields[propName];
        // Substitute type parameters if this is an instantiated generic class.
        return substituteTypeParams(ct.typeParameters, ct.typeArguments, fieldType);
      }
      // Check methods.
      if (ct.methods.has(propName)) {
        let methodType = ct.methods[propName];
        return substituteTypeParams(ct.typeParameters, ct.typeArguments, methodType);
      }
      // Check for getter method (get#propName)
      let getterName = "get#" + propName;
      if (ct.methods.has(getterName)) {
        let getterType = ct.methods[getterName];
        // Return the return type of the getter
        return substituteTypeParams(ct.typeParameters, ct.typeArguments, getterType.returnType);
      }
      ctx.error(
        "Property '" + propName + "' does not exist on type '" + ct.name + "'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case InterfaceType as it: {
      if (it.fields.has(propName)) {
        return it.fields[propName];
      }
      if (it.methods.has(propName)) {
        return it.methods[propName];
      }
      // Check for getter method
      let getterName = "get#" + propName;
      if (it.methods.has(getterName)) {
        let getterType = it.methods[getterName];
        return getterType.returnType;
      }
      ctx.error(
        "Property '" + propName + "' does not exist on interface '" + it.name + "'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case RecordT {properties}: {
      if (properties.has(propName)) {
        return properties[propName];
      }
      ctx.error(
        "Property '" + propName + "' does not exist on record type.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case ArrayType {elementType}: {
      // ArrayType is produced by array literals [1, 2, 3].
      // Delegate to FixedArray<T> prelude type with T = elementType.
      let faType = ctx.resolveTypeName("FixedArray");
      if (faType != null) {
        match (faType as Type) {
          case ClassType as faCt: {
            // Build type arguments [elementType] for substitution.
            let typeArgs = new Array<Type>();
            typeArgs.push(elementType);
            // Check getter first.
            let getterName = "get#" + propName;
            if (faCt.methods.has(getterName)) {
              let getterType = faCt.methods[getterName];
              return substituteTypeParams(faCt.typeParameters, typeArgs, getterType.returnType);
            }
            if (faCt.methods.has(propName)) {
              let methodType = faCt.methods[propName];
              return substituteTypeParams(faCt.typeParameters, typeArgs, methodType);
            }
            if (faCt.fields.has(propName)) {
              let fieldType = faCt.fields[propName];
              return substituteTypeParams(faCt.typeParameters, typeArgs, fieldType);
            }
          }
          case _: {}
        }
      }
      ctx.error(
        "Property '" + propName + "' does not exist on type 'Array<" + typeToString(elementType) + ">'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case TypeParameterType {name as tname, constraint}: {
      if (constraint != null) {
        return resolveMemberType(ctx, constraint as Type, propName, loc);
      }
      ctx.error(
        "Property '" + propName + "' does not exist on type '" + tname + "'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case UnknownType: { return new UnknownType(); }
    case _: {
      ctx.error(
        "Property access not supported on type '" + typeToString(objectType) + "'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
  }
};

let checkIndexExpression = (
  ctx: CheckerContext,
  object: Expression,
  index: Expression,
  optional: boolean,
  loc: SourceLocation | null
): Type => {
  let objectType = checkExpression(ctx, object, null);

  // Handle optional chaining on nullable object.
  var baseType_: Type = objectType;
  var isNullable = false;
  match (objectType) {
    case UnionT {types}: {
      let nonNull = new Array<Type>();
      var ui = 0;
      while (ui < types.length) {
        if (types[ui] is NullType) {
          isNullable = true;
        } else {
          nonNull.push(types[ui]);
        }
        ui = ui + 1;
      }
      if (nonNull.length == 1) {
        baseType_ = nonNull[0];
      } else if (nonNull.length > 1) {
        baseType_ = new UnionT(nonNull);
      }
    }
    case NullType: { isNullable = true; }
    case _: {}
  }

  let resultType = resolveIndexType(ctx, baseType_, index, loc);

  if (isNullable && optional) {
    let types = new Array<Type>();
    types.push(resultType);
    types.push(new NullType());
    return createUnionType(types);
  }

  return resultType;
};

/**
 * Resolve the result type of an index operation.
 */
let resolveIndexType = (
  ctx: CheckerContext,
  objectType: Type,
  index: Expression,
  loc: SourceLocation | null
): Type => {
  // Check the index.
  let indexType = checkExpression(ctx, index, null);

  match (objectType) {
    case ArrayType {elementType}: {
      // Array indexing — index must be i32.
      if (!isIntegerType(indexType)) {
        ctx.error(
          "Array index must be an integer, got '" + typeToString(indexType) + "'.",
          DiagnosticCode.TypeMismatch,
          loc
        );
      }
      return elementType;
    }
    case TupleT {elementTypes}: {
      // Tuple indexing — return specific element type for literal index.
      match (index) {
        case NumberLiteral {raw}: {
          while (let (true, idx) = parseI32(raw)) {
            if (idx >= 0 && idx < elementTypes.length) {
              return elementTypes[idx];
            }
            break;
          }
          ctx.error(
            `Tuple index out of bounds: ${raw} (tuple has ${elementTypes.length} elements).`,
            DiagnosticCode.IndexOutOfBounds,
            loc
          );
          return new UnknownType();
        }
        case _: {
          // Non-literal index — return union of all element types.
          return createUnionType(elementTypes);
        }
      }
    }
    case ClassType as ct: {
      // Check for operator [] method.
      if (ct.methods.has("[]")) {
        let opMethod = ct.methods["[]"];
        // The return type is the element type.
        return substituteTypeParams(ct.typeParameters, ct.typeArguments, opMethod.returnType);
      }
      ctx.error(
        "Type '" + ct.name + "' does not support indexing (no 'operator []' method).",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case UnknownType: { return new UnknownType(); }
    case _: {
      ctx.error(
        "Index access not supported on type '" + typeToString(objectType) + "'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
  }
};

let checkBinaryExpression = (
  ctx: CheckerContext,
  operator: String,
  left: Expression,
  right: Expression,
  loc: SourceLocation | null
): Type => {
  // For && and ||, handle short-circuit evaluation and narrowing.
  if (operator == "&&") {
    let leftType = checkExpression(ctx, left, null);
    // Extract null-guard narrowing from the left side and apply to right.
    let (guardInfo, guardOrigType, isEqualNull) = extractNullGuardNarrowing(ctx, left);
    var rightType: Type = new UnknownType();
    if (guardInfo != null) {
      let si = guardInfo as SymbolInfo;
      let origType = guardOrigType as Type;
      ctx.enterScope();
      if (isEqualNull) {
        ctx.narrowBinding(si, new NullType());
      } else {
        ctx.narrowBinding(si, subtractNullFromType(origType));
      }
      rightType = checkExpression(ctx, right, null);
      ctx.exitScope();
    } else {
      rightType = checkExpression(ctx, right, null);
    }
    // && returns the type of the right operand (if left is truthy).
    return rightType;
  }
  if (operator == "||") {
    let leftType = checkExpression(ctx, left, null);
    let rightType = checkExpression(ctx, right, null);
    // || returns union of both types.
    let types = new Array<Type>();
    types.push(leftType);
    types.push(rightType);
    return createUnionType(types);
  }

  // Arithmetic operators: +, -, *, /, %
  if (operator == "+" || operator == "-" || operator == "*" ||
      operator == "/" || operator == "%") {
    // Check right first for contextual typing.
    let rightType = checkExpression(ctx, right, null);
    // Use right's type to give context to the left.
    var contextualType: Type | null = null;
    if (isNumericType(rightType)) { contextualType = rightType; }
    let leftType = checkExpression(ctx, left, contextualType);

    // If left is numeric and right was checked without context, re-check
    // right with left's type as context.
    if (isNumericType(leftType) && !isNumericType(rightType)) {
      // Right wasn't numeric — error.
      ctx.error(
        "Type mismatch: cannot apply operator '" + operator + "' to " +
        typeToString(leftType) + " and " + typeToString(rightType),
        DiagnosticCode.InvalidOperator,
        loc
      );
      return new UnknownType();
    }

    if (!isNumericType(leftType)) {
      // Check for operator overloading on class types (e.g., String.+).
      match (leftType) {
        case ClassType as ct: {
          if (ct.methods.has(operator)) {
            let method = ct.methods[operator];
            if (method.parameters.length != 1) {
              ctx.error(
                "Operator '" + operator + "' must take exactly one argument.",
                DiagnosticCode.ArgumentCountMismatch,
                loc
              );
              return new UnknownType();
            }
            if (!isAssignableTo(ctx, rightType, method.parameters[0])) {
              ctx.error(
                "Type mismatch in operator '" + operator + "': expected '" +
                typeToString(method.parameters[0]) + "', got '" + typeToString(rightType) + "'.",
                DiagnosticCode.TypeMismatch,
                loc
              );
              return new UnknownType();
            }
            return method.returnType;
          }
        }
        case _: {}
      }
      ctx.error(
        "Type mismatch: cannot apply operator '" + operator + "' to " +
        typeToString(leftType) + " and " + typeToString(rightType),
        DiagnosticCode.InvalidOperator,
        loc
      );
      return new UnknownType();
    }

    let promoted = promoteNumeric(leftType, rightType);
    if (promoted == null) {
      ctx.error(
        "Type mismatch: cannot apply operator '" + operator + "' to " +
        typeToString(leftType) + " and " + typeToString(rightType),
        DiagnosticCode.InvalidOperator,
        loc
      );
      return new UnknownType();
    }
    // Division always returns a float type.
    if (operator == "/") {
      if (promoted is F64Type || promoted is I64Type || promoted is U64Type) {
        return new F64Type();
      }
      return new F32Type();
    }
    return promoted as Type;
  }

  // Comparison operators: <, <=, >, >=
  if (operator == "<" || operator == "<=" || operator == ">" || operator == ">=") {
    let rightType = checkExpression(ctx, right, null);
    var contextualType: Type | null = null;
    if (isNumericType(rightType)) { contextualType = rightType; }
    let leftType = checkExpression(ctx, left, contextualType);

    if (!isNumericType(leftType) || !isNumericType(rightType)) {
      ctx.error(
        "Type mismatch: cannot apply operator '" + operator + "' to " +
        typeToString(leftType) + " and " + typeToString(rightType),
        DiagnosticCode.InvalidOperator,
        loc
      );
    } else {
      // Reject mixed signedness (e.g., u32 < i32)
      let promoted = promoteNumeric(leftType, rightType);
      if (promoted == null) {
        ctx.error(
          "Type mismatch: cannot apply operator '" + operator + "' to " +
          typeToString(leftType) + " and " + typeToString(rightType),
          DiagnosticCode.InvalidOperator,
          loc
        );
      }
    }
    return new BooleanType();
  }

  // Equality operators: ==, !=, ===, !==
  if (operator == "==" || operator == "!=" || operator == "===" || operator == "!==") {
    let leftType = checkExpression(ctx, left, null);
    let rightType = checkExpression(ctx, right, leftType);
    // Validate that types are comparable:
    // - Both boolean: always allowed
    // - Both numeric: always allowed
    // - Both class or interface: always allowed (reference equality)
    // - Otherwise: at least one direction must be assignable
    let typesMatch = (leftType is BooleanType && rightType is BooleanType) ||
      (leftType is BoolLiteralType && (rightType is BooleanType || rightType is BoolLiteralType)) ||
      (rightType is BoolLiteralType && (leftType is BooleanType || leftType is BoolLiteralType)) ||
      (isNumericType(leftType) && isNumericType(rightType)) ||
      (leftType is ClassType && rightType is ClassType) ||
      (leftType is InterfaceType && rightType is InterfaceType) ||
      leftType is NullType || rightType is NullType ||
      leftType is UnknownType || rightType is UnknownType ||
      isAssignableTo(ctx, leftType, rightType) ||
      isAssignableTo(ctx, rightType, leftType);
    if (!typesMatch) {
      ctx.error(
        "Type mismatch: cannot apply operator '" + operator + "' to '" +
        typeToString(leftType) + "' and '" + typeToString(rightType) + "'.",
        DiagnosticCode.TypeMismatch,
        loc
      );
    }
    return new BooleanType();
  }

  // Bitwise operators: &, |, ^, <<, >>
  if (operator == "&" || operator == "|" || operator == "^" ||
      operator == "<<" || operator == ">>") {
    let leftType = checkExpression(ctx, left, null);
    let rightType = checkExpression(ctx, right, leftType);

    if (!isIntegerType(leftType) || !isIntegerType(rightType)) {
      ctx.error(
        "Operator '" + operator + "' cannot be applied to type '" +
        typeToString(leftType) + "' and '" + typeToString(rightType) + "'.",
        DiagnosticCode.InvalidOperator,
        loc
      );
    }

    let promoted = promoteNumeric(leftType, rightType);
    if (promoted != null) { return promoted as Type; }
    return leftType;
  }

  // Null coalescing operator: ??
  // Returns the left operand if not null, otherwise the right operand.
  // Type is the union of (non-null left type) and right type, or just right type
  // if left is definitely nullable.
  if (operator == "??") {
    let leftType = checkExpression(ctx, left, null);
    let rightType = checkExpression(ctx, right, null);

    // Extract non-null part of left type.
    // For T | null, result is T | rightType (simplified to rightType if T = rightType).
    match (leftType) {
      case UnionT as u: {
        // Filter out null from union members.
        let nonNullMembers = new Array<Type>();
        let members = u.types;
        var i = 0;
        while (i < members.length) {
          match (members[i]) {
            case NullType: {}
            case _: { nonNullMembers.push(members[i]); }
          }
          i += 1;
        }
        // Result type: union of non-null left members with right type.
        nonNullMembers.push(rightType);
        return createUnionType(nonNullMembers);
      }
      case NullType: {
        // Left is just null, result is right type.
        ctx.warning(
          "Left operand of '??' is always null and will never be returned.",
          DiagnosticCode.UnnecessaryNullish,
          loc
        );
        return rightType;
      }
      case _: {
        // Left is not nullable, ?? is redundant but valid. Return left type.
        ctx.warning(
          "Left operand of '??' is not nullable and will always be returned.",
          DiagnosticCode.UnnecessaryNullish,
          loc
        );
        return leftType;
      }
    }
  }

  ctx.error(
    "Unknown operator '" + operator + "'.",
    DiagnosticCode.InvalidOperator,
    loc
  );
  return new UnknownType();
};

/**
 * Collect all concrete (non-sealed) leaf variants of a sealed class type,
 * recursing into sub-sealed variants (sum of sums).
 */
let collectLeafVariants = (ct: ClassType): Array<ClassType> => {
  let result = new Array<ClassType>();
  if (ct.sealedVariants == null) { return result; }
  let variants = ct.sealedVariants as Array<ClassType>;
  var i = 0;
  while (i < variants.length) {
    let v = variants[i];
    if (v.isSealed && v.sealedVariants != null) {
      // Recurse: this variant is itself sealed
      let leaves = collectLeafVariants(v);
      var li = 0;
      while (li < leaves.length) {
        result.push(leaves[li]);
        li += 1;
      }
    } else {
      result.push(v);
    }
    i += 1;
  }
  return result;
};

/**
 * Returns true if a type has a finite, enumerable set of values that can be
 * fully covered by match patterns (sealed classes, booleans, literal types).
 */
let isFiniteType = (t: Type): boolean => {
  match (t) {
    case BooleanType: true
    case BoolLiteralType: true
    case StringLiteralType: true
    case NullType: true
    case ClassType as ct: ct.isSealed
    case UnionT {types}: {
      var allFinite = true;
      var i = 0;
      while (i < types.length) {
        if (!isFiniteType(types[i])) { allFinite = false; }
        i += 1;
      }
      allFinite
    }
    case _: false
  }
};

/**
 * Subtract a pattern from a type, returning the remaining uncovered type.
 * Returns NeverType when the pattern fully covers the type.
 */
let subtractPatternFromType = (ctx: CheckerContext, t: Type, pattern: Node): Type => {
  // Wildcard or variable pattern covers everything.
  match (pattern) {
    case IdentifierPattern {name}: {
      if (name == "_") {
        return new NeverType();
      }
      // Check if this identifier names a sealed variant (unit variant pattern).
      let resolved = ctx.resolveTypeName(name);
      if (resolved != null) {
        match (resolved as Type) {
          case ClassType as patClass: {
            return subtractClassFromType(ctx, t, patClass);
          }
          case _: {}
        }
      }
      // Regular variable binding — covers everything.
      return new NeverType();
    }
    case Identifier {name}: {
      // Plain identifier in match pattern (e.g., case _, case Red).
      if (name == "_") {
        return new NeverType();
      }
      // Check if this identifier names a sealed variant (unit variant pattern).
      let resolved = ctx.resolveTypeName(name);
      if (resolved != null) {
        match (resolved as Type) {
          case ClassType as patClass: {
            return subtractClassFromType(ctx, t, patClass);
          }
          case _: {}
        }
      }
      // Regular variable binding — covers everything.
      return new NeverType();
    }
    case ClassPattern as cp: {
      let clsName = cp.name.name;
      let resolved = ctx.resolveTypeName(clsName);
      if (resolved != null) {
        match (resolved as Type) {
          case ClassType as patClass: {
            return subtractClassFromType(ctx, t, patClass);
          }
          case _: {}
        }
      }
      return t;
    }
    case AsPattern as ap: {
      return subtractPatternFromType(ctx, t, ap.pattern);
    }
    case BooleanLiteral {value}: {
      // Subtract the specific boolean literal from the remaining type.
      let lit: Type = new BoolLiteralType(value);
      match (t) {
        case BooleanType: {
          // BooleanType = true | false. Subtracting one literal leaves the other.
          if (value) {
            return new BoolLiteralType(false);
          } else {
            return new BoolLiteralType(true);
          }
        }
        case _: {
          return subtractTypeFromUnion(t, lit);
        }
      }
    }
    case StringLiteral {value}: {
      // Subtract the specific string literal from the remaining type.
      let lit: Type = new StringLiteralType(value);
      return subtractTypeFromUnion(t, lit);
    }
    case NumberLiteral {}: {
      // Number literal patterns: no subtraction (no numeric literal types yet).
      return t;
    }
    case _: {
      // Literal patterns, etc. — don't subtract from sealed types for now.
      return t;
    }
  }
};

/**
 * Subtract a class type (from a pattern) from the scrutinee type.
 * Handles sealed class variant tracking and transitive hierarchies.
 */
let subtractClassFromType = (ctx: CheckerContext, t: Type, patClass: ClassType): Type => {
  match (t) {
    case ClassType as scrutClass: {
      // If the pattern class IS the scrutinee class (or a supertype), covers it.
      if (scrutClass.id == patClass.id) {
        return new NeverType();
      }
      // If the scrutinee is a sealed class, subtract the variant from its set.
      if (scrutClass.isSealed && scrutClass.sealedVariants != null) {
        let variants = scrutClass.sealedVariants as Array<ClassType>;
        let remaining = new Array<ClassType>();
        var i = 0;
        while (i < variants.length) {
          let v = variants[i];
          if (v.id == patClass.id) {
            // Directly matched — don't add to remaining.
          } else if (v.isSealed && v.sealedVariants != null) {
            // Variant is itself sealed — recurse into its sub-variants.
            let subResult = subtractClassFromType(ctx, v, patClass);
            match (subResult) {
              case NeverType: {
                // Fully covered — don't add to remaining.
              }
              case ClassType as remainingVariant: {
                remaining.push(remainingVariant);
              }
              case _: {
                remaining.push(v);
              }
            }
          } else {
            // Check if patClass is a subtype of this variant.
            var isSubtype = false;
            var current: ClassType | null = patClass.superType;
            while (current != null) {
              let cur = current as ClassType;
              if (cur.id == v.id) {
                isSubtype = true;
                break;
              }
              current = cur.superType;
            }
            if (!isSubtype) {
              remaining.push(v);
            }
          }
          i += 1;
        }
        if (remaining.length == 0) {
          return new NeverType();
        }
        // Return a synthetic sealed type with remaining variants.
        let remainingType = new ClassType(scrutClass.id, scrutClass.name);
        remainingType.isSealed = true;
        remainingType.isAbstract = true;
        remainingType.superType = scrutClass.superType;
        remainingType.sealedVariants = remaining;
        return remainingType;
      }
    }
    case _: {}
  }
  return t;
};

/**
 * Look up a field type on a class or interface type for pattern destructuring.
 * Returns UnknownType if the field is not found.
 */
let resolveClassFieldType = (
  ctx: CheckerContext,
  classType: Type,
  propName: String,
  loc: SourceLocation | null
): Type => {
  match (classType) {
    case ClassType as ct: {
      if (ct.fields.has(propName)) {
        return substituteTypeParams(ct.typeParameters, ct.typeArguments, ct.fields[propName]);
      }
      // Check for getter.
      let getterName = "get#" + propName;
      if (ct.methods.has(getterName)) {
        let getter = ct.methods[getterName];
        return substituteTypeParams(ct.typeParameters, ct.typeArguments, getter.returnType);
      }
      // Walk superclass.
      if (ct.superType != null) {
        return resolveClassFieldType(ctx, ct.superType as Type, propName, loc);
      }
      ctx.error(
        "Property '" + propName + "' does not exist on type '" + ct.name + "'.",
        DiagnosticCode.PropertyNotFound,
        loc
      );
      return new UnknownType();
    }
    case _: {
      return new UnknownType();
    }
  }
};

/**
 * Check a match expression: discriminant against patterns, return union of case body types.
 * Also checks exhaustiveness for sealed class discriminants.
 */
let checkMatchExpr = (
  ctx: CheckerContext,
  discriminant: Expression,
  cases: Array<MatchCase>,
  loc: SourceLocation | null,
  expectedType: Type | null
): Type => {
  // Check the discriminant expression.
  let scrutineeType = checkExpression(ctx, discriminant, null);

  // Track remaining type for exhaustiveness checking.
  var remainingType: Type = scrutineeType;

  // Collect result types from each case.
  let resultTypes = new Array<Type>();

  var i = 0;
  while (i < cases.length) {
    let matchCase = cases[i];

    // Check for unreachable case: if remaining type is Never, nothing can reach this case.
    if (remainingType is NeverType) {
      ctx.error(
        "Unreachable case.",
        DiagnosticCode.TypeMismatch,
        matchCase.loc
      );
    }

    // Enter a new scope for pattern bindings.
    ctx.enterScope();

    // Check the pattern and bind variables.
    checkPattern(ctx, matchCase.pattern, scrutineeType);

    // Update remaining type (only if no guard — guards prevent exhaustiveness).
    if (matchCase.guard == null) {
      remainingType = subtractPatternFromType(ctx, remainingType, matchCase.pattern);
    }

    // Check the guard if present.
    if (matchCase.guard != null) {
      let guardType = checkExpression(ctx, matchCase.guard as Expression, null);
      if (!isBooleanLike(guardType)) {
        ctx.error(
          "Match guard must be a boolean expression.",
          DiagnosticCode.TypeMismatch,
          matchCase.loc
        );
      }
    }

    // Check the body and collect its type.
    let bodyType = checkMatchCaseBody(ctx, matchCase.body, expectedType);
    resultTypes.push(bodyType);

    ctx.exitScope();
    i += 1;
  }

  // Check exhaustiveness: if the scrutinee is a finite type (sealed class,
  // boolean, literal union, etc.) and remainingType is not Never, report error.
  if (isFiniteType(scrutineeType) && !(remainingType is NeverType)) {
    ctx.error(
      "Non-exhaustive match. Not all cases are covered.",
      DiagnosticCode.TypeMismatch,
      loc
    );
  }

  // Result is union of all case body types.
  if (resultTypes.length == 0) {
    return new NeverType();
  }
  if (resultTypes.length == 1) {
    return resultTypes[0];
  }
  return createUnionType(resultTypes);
};

/**
 * Check the body of a match case (expression or block) and return its type.
 */
let checkMatchCaseBody = (ctx: CheckerContext, body: Node, expectedType: Type | null): Type => {
  match (body) {
    case BlockStatement as block: {
      // Execute statements; need to track return type.
      let stmts = block.body;
      var lastType: Type = new VoidType();
      var si = 0;
      while (si < stmts.length) {
        let isLast = si == stmts.length - 1;
        let et = if (isLast) { expectedType } else { null };
        // For ExpressionStatement/ReturnStatement, we need to extract the type
        // from the expression. Use checkStatement for all other types.
        match (stmts[si]) {
          case ExpressionStatement {expression}: {
            lastType = checkExpression(ctx, expression, et);
          }
          case ReturnStatement {argument}: {
            if (argument != null) {
              lastType = checkExpression(ctx, argument as Expression, et);
            } else {
              lastType = new VoidType();
            }
          }
          case _: {
            checkStatement(ctx, stmts[si]);
            lastType = new VoidType();
          }
        }
        si = si + 1;
      }
      return lastType;
    }
    case _: {
      // Expression body.
      return checkExpression(ctx, body as Expression, expectedType);
    }
  }
};

/**
 * Check a pattern against an expected type and bind pattern variables.
 * Uses bindPattern for identifier bindings through the DeclarationMap → SymbolInfo path.
 */
let checkPattern = (ctx: CheckerContext, pattern: Node, expectedType: Type): void => {
  match (pattern) {
    case IdentifierPattern as pat: {
      if (pat.name != "_") {
        // Use the same binding mechanism as variable declarations.
        let info = ctx.model.resolveDeclaration(pat);
        if (info != null) {
          ctx.declareBinding(info as SymbolInfo, expectedType);
        } else {
          // Fallback: register in type scope.
          ctx.declareTypeName(pat.name, expectedType);
        }
      }
    }
    case ClassPattern as cp: {
      // Look up the class type.
      let clsName = cp.name.name;
      let classType = ctx.resolveTypeName(clsName);
      if (classType == null) {
        ctx.error(
          "Unknown class '" + clsName + "' in pattern.",
          DiagnosticCode.SymbolNotFound,
          cp.loc
        );
        return;
      }
      // Resolve field types from the class.
      let props = cp.properties;
      var pi = 0;
      while (pi < props.length) {
        let prop = props[pi];
        let propName = prop.name.name;
        let propType = resolveClassFieldType(ctx, classType as Type, propName, prop.loc);
        checkPattern(ctx, prop.value, propType);
        pi = pi + 1;
      }
    }
    case RecordPattern {properties, loc}: {
      var pi = 0;
      while (pi < properties.length) {
        let prop = properties[pi];
        let propName = prop.name.name;
        var propType: Type = new UnknownType();
        match (expectedType) {
          case RecordT {properties as recordProps}: {
            if (recordProps.has(propName)) {
              propType = recordProps[propName];
            }
          }
          case _: {}
        }
        checkPattern(ctx, prop.value, propType);
        pi = pi + 1;
      }
    }
    case TuplePattern {elements}: {
      match (expectedType) {
        case TupleT {elementTypes}: {
          var i = 0;
          while (i < elements.length) {
            if (elements[i] != null) {
              let elem = elements[i] as Node;
              if (i < elementTypes.length) {
                checkPattern(ctx, elem, elementTypes[i]);
              } else {
                checkPattern(ctx, elem, new UnknownType());
              }
            }
            i = i + 1;
          }
        }
        case InlineTupleT {elementTypes}: {
          var i = 0;
          while (i < elements.length) {
            if (elements[i] != null) {
              let elem = elements[i] as Node;
              if (i < elementTypes.length) {
                checkPattern(ctx, elem, elementTypes[i]);
              } else {
                checkPattern(ctx, elem, new UnknownType());
              }
            }
            i = i + 1;
          }
        }
        case _: {
          var i = 0;
          while (i < elements.length) {
            if (elements[i] != null) {
              checkPattern(ctx, (elements[i] as Node), new UnknownType());
            }
            i = i + 1;
          }
        }
      }
    }
    case AsPattern as ap: {
      checkPattern(ctx, ap.pattern, expectedType);
      // Narrow the alias to the matched type, not the scrutinee type.
      var narrowedType: Type = expectedType;
      if (ap.pattern is ClassPattern) {
        let cp = ap.pattern as ClassPattern;
        let cls = ctx.resolveTypeName(cp.name.name);
        if (cls != null) {
          narrowedType = cls as Type;
        }
      } else if (ap.pattern is Identifier) {
        let ident = ap.pattern as Identifier;
        let cls = ctx.resolveTypeName(ident.name);
        if (cls != null) {
          narrowedType = cls as Type;
        }
      }
      let info = ctx.model.resolveDeclaration(ap.name);
      if (info != null) {
        ctx.declareBinding(info as SymbolInfo, narrowedType);
      } else {
        ctx.declareTypeName(ap.name.name, narrowedType);
      }
    }
    case LogicalPattern {operator, left, right, loc}: {
      checkPattern(ctx, left, expectedType);
      checkPattern(ctx, right, expectedType);
    }
    case Identifier as ident: {
      // Match-context patterns produce Identifier nodes (not IdentifierPattern).
      if (ident.name != "_") {
        // Check if this identifier refers to a sealed variant (unit variant pattern).
        // If so, skip binding — it's a type match, not a variable binding.
        let resolvedType = ctx.resolveTypeName(ident.name);
        var isVariant = false;
        if (resolvedType != null) {
          match (resolvedType as Type) {
            case ClassType: { isVariant = true; }
            case _: {}
          }
        }
        if (!isVariant) {
          let info = ctx.model.resolveDeclaration(ident);
          if (info != null) {
            ctx.declareBinding(info as SymbolInfo, expectedType);
          } else {
            ctx.declareTypeName(ident.name, expectedType);
          }
        }
      }
    }
    case _: {
      // Literal patterns, wildcard, etc. - no bindings needed.
    }
  }
};

let checkFunctionExpression = (
  ctx: CheckerContext,
  typeParameters: Array<TypeParameter> | null,
  params: Array<Parameter>,
  returnTypeAnn: TypeAnnotation | null,
  body: Node,
  loc: SourceLocation | null,
  expectedType: Type | null
): Type => {
  ctx.enterScope();

  // Register type parameters in the type scope.
  var resolvedTypeParams: Array<TypeParameterType> | null = null;
  if (typeParameters != null) {
    let tps = typeParameters as Array<TypeParameter>;
    if (tps.length > 0) {
      let tpTypes = new Array<TypeParameterType>();
      var tpi = 0;
      while (tpi < tps.length) {
        let tp = tps[tpi];
        var constraint: Type | null = null;
        if (tp.constraint != null) {
          constraint = resolveTypeAnnotation(ctx, tp.constraint as TypeAnnotation);
        }
        let tpType = new TypeParameterType(tp.name, constraint, null);
        ctx.declareTypeName(tp.name, tpType);
        tpTypes.push(tpType);
        tpi += 1;
      }
      resolvedTypeParams = tpTypes;
    }
  }

  // Resolve parameter types.
  let paramTypes = new Array<Type>();
  let paramNames = new Array<String>();

  // If there's a contextual function type, use it for parameter inference.
  var contextualFn: FunctionType | null = null;
  if (expectedType != null) {
    match (expectedType as Type) {
      case FunctionType as ft: { contextualFn = ft; }
      case _: {}
    }
  }

  var i = 0;
  var hasOptionals = false;
  let optionals = new Array<boolean>();
  var hasInitializers = false;
  let initializers = new Array<Expression | null>();
  while (i < params.length) {
    let param = params[i];
    let paramName = param.name.name;
    paramNames.push(paramName);

    var paramType: Type = new UnknownType();
    if (param.typeAnnotation != null) {
      paramType = resolveTypeAnnotation(ctx, param.typeAnnotation as TypeAnnotation);
    } else if (contextualFn != null) {
      let cfn = contextualFn as FunctionType;
      if (i < cfn.parameters.length) {
        paramType = cfn.parameters[i];
      }
    } else {
      // No annotation and no contextual type — report an error.
      ctx.error(
        "Parameter '" + paramName + "' has no type annotation and cannot be inferred from context.",
        DiagnosticCode.TypeMismatch,
        loc
      );
    }

    // Optional parameters have their type widened to T | null
    let isOptional = param.optional || param.defaultValue != null;
    optionals.push(isOptional);
    if (param.defaultValue != null) { hasInitializers = true; }
    initializers.push(param.defaultValue);
    if (isOptional) {
      hasOptionals = true;
      // Only widen to T | null for ?-style optionals without a default value.
      // Params with default values keep their declared type.
      if (param.optional && param.defaultValue == null) {
        var alreadyNullable = false;
        match (paramType) {
          case NullType: { alreadyNullable = true; }
          case UnionT {types}: {
            var ui = 0;
            while (ui < types.length) {
              if (types[ui] is NullType) { alreadyNullable = true; }
              ui += 1;
            }
          }
          case _: {}
        }
        if (!alreadyNullable) {
          let unionTypes = new Array<Type>();
          unionTypes.push(paramType);
          unionTypes.push(new NullType());
          paramType = createUnionType(unionTypes);
        }
      }
    }

    paramTypes.push(paramType);
    // Store the parameter's type via its SymbolInfo (from the DeclarationMap).
    let paramInfo = ctx.model.resolveDeclaration(param);
    if (paramInfo != null) {
      ctx.declareBinding(paramInfo as SymbolInfo, paramType);
    }
    // For destructured params, also bind the pattern fields.
    if (param.pattern != null) {
      bindPattern(ctx, param.pattern as Pattern, paramType);
    }
    i += 1;
  }

  // Resolve return type annotation.
  var retType: Type = new VoidType();
  var needsInference = false;
  if (returnTypeAnn != null) {
    retType = resolveTypeAnnotation(ctx, returnTypeAnn as TypeAnnotation);
  } else if (contextualFn != null) {
    retType = (contextualFn as FunctionType).returnType;
  } else {
    // No explicit return type - will infer from return statements
    needsInference = true;
  }

  // Set expected return type for return statements.
  // Save and reset inferred return types for this function.
  let prevReturnType = ctx.returnType;
  let prevInferredReturns = ctx.inferredReturnTypes;
  ctx.setReturnType(retType);
  ctx.setInferredReturnTypes(new Array<Type>());

  // Check the body.
  match (body) {
    case BlockStatement as block: {
      var j = 0;
      while (j < block.body.length) {
        checkStatement(ctx, block.body[j]);
        j = j + 1;
      }
      // After checking block body, infer return type from collected types.
      if (needsInference) {
        let inferred = ctx.inferredReturnTypes;
        if (inferred.length == 0) {
          retType = new VoidType();
        } else if (inferred.length == 1) {
          retType = inferred[0];
        } else {
          // Multiple return types - create union (or use first as approximation)
          // For now, just use the first type as a simple heuristic
          retType = inferred[0];
        }
      }
    }
    case Expression as bodyExpr: {
      let bodyType = checkExpression(ctx, bodyExpr, retType);
      // Expression body: validate return type if annotated or contextual.
      if (returnTypeAnn != null || contextualFn != null) {
        if (!isAssignableTo(ctx, bodyType, retType)) {
          ctx.error(
            "Type mismatch: expression body returns '" + typeToString(bodyType) +
            "' but function expects '" + typeToString(retType) + "'.",
            DiagnosticCode.TypeMismatch,
            loc
          );
        }
      } else {
        // Infer return type from expression body.
        retType = bodyType;
      }
    }
    case _: {}
  }

  ctx.setReturnType(prevReturnType);
  ctx.setInferredReturnTypes(prevInferredReturns);
  ctx.exitScope();

  let fnType = new FunctionType(paramTypes, paramNames, retType);
  fnType.typeParameters = resolvedTypeParams;
  if (hasOptionals) {
    fnType.optionalParameters = optionals;
  }
  if (hasInitializers) {
    fnType.parameterInitializers = initializers;
  }
  return fnType;
};

let checkCallExpression = (
  ctx: CheckerContext,
  callee: Expression,
  args: Array<Expression>,
  typeArguments: Array<TypeAnnotation> | null,
  optional: boolean,
  loc: SourceLocation | null
): Type => {
  let calleeType = checkExpression(ctx, callee, null);

  // Handle optional chaining on nullable callee.
  var baseCalleeType: Type = calleeType;
  var isNullable = false;
  match (calleeType) {
    case UnionT {types}: {
      let nonNull = new Array<Type>();
      var ui = 0;
      while (ui < types.length) {
        if (types[ui] is NullType) {
          isNullable = true;
        } else {
          nonNull.push(types[ui]);
        }
        ui = ui + 1;
      }
      if (nonNull.length == 1) {
        baseCalleeType = nonNull[0];
      } else if (nonNull.length > 1) {
        baseCalleeType = new UnionT(nonNull);
      }
    }
    case NullType: { isNullable = true; }
    case _: {}
  }

  // If optional and not nullable, proceed normally.
  // If optional and nullable, wrap result in union with null.
  let resultType = checkCallExpressionInner(ctx, baseCalleeType, args, typeArguments, loc);

  if (isNullable && optional) {
    let types = new Array<Type>();
    types.push(resultType);
    types.push(new NullType());
    return createUnionType(types);
  }

  return resultType;
};

let checkCallExpressionInner = (
  ctx: CheckerContext,
  calleeType: Type,
  args: Array<Expression>,
  typeArguments: Array<TypeAnnotation> | null,
  loc: SourceLocation | null
): Type => {
  match (calleeType) {
    case FunctionType as ft: {
      // Handle generic function calls.
      var effectiveFt = ft;
      if (ft.typeParameters != null) {
        let typeParams = ft.typeParameters as Array<TypeParameterType>;
        if (typeParams.length > 0) {
          if (typeArguments != null) {
            // Explicit type arguments provided.
            let explicit = typeArguments as Array<TypeAnnotation>;
            let typeArgs = new Array<Type>();
            var ti = 0;
            while (ti < explicit.length) {
              typeArgs.push(resolveTypeAnnotation(ctx, explicit[ti]));
              ti += 1;
            }
            // Substitute type parameters in params and return type.
            let subParams = new Array<Type>();
            var si = 0;
            while (si < ft.parameters.length) {
              subParams.push(substituteTypeParams(ft.typeParameters, typeArgs, ft.parameters[si]));
              si += 1;
            }
            let subRet = substituteTypeParams(ft.typeParameters, typeArgs, ft.returnType);
            effectiveFt = new FunctionType(subParams, ft.parameterNames, subRet);
          } else {
            // Infer type arguments from argument types.
            let inferred = new HashMap<String, Type>();
            var ai = 0;
            while (ai < args.length && ai < ft.parameters.length) {
              let argType = checkExpression(ctx, args[ai], null);
              inferTypeArg(ft.parameters[ai], argType, inferred);
              ai += 1;
            }
            // Build type args array from inferred map.
            let typeArgs = new Array<Type>();
            var pi = 0;
            while (pi < typeParams.length) {
              let paramName = typeParams[pi].name;
              if (inferred.has(paramName)) {
                typeArgs.push(inferred[paramName]);
              } else {
                typeArgs.push(new UnknownType());
              }
              pi += 1;
            }
            // Substitute type parameters in params and return type.
            let subParams = new Array<Type>();
            var si = 0;
            while (si < ft.parameters.length) {
              subParams.push(substituteTypeParams(ft.typeParameters, typeArgs, ft.parameters[si]));
              si += 1;
            }
            let subRet = substituteTypeParams(ft.typeParameters, typeArgs, ft.returnType);
            effectiveFt = new FunctionType(subParams, ft.parameterNames, subRet);
          }
        }
      }

      // Fill in missing arguments with default values
      if (effectiveFt.parameterInitializers != null) {
        var a = args.length;
        while (a < effectiveFt.parameters.length) {
          let init = (effectiveFt.parameterInitializers as Array<Expression | null>)[a];
          if (init != null) {
            let initializer = init as Expression;
            match (initializer) {
              case Identifier {name}: {
                if (name == "__LOCATION__") {
                  if (ctx.emitLocations) {
                    let locStr = if (loc != null) {
                      `${ctx.filePath}:${(loc as SourceLocation).line}`
                    } else {
                      `${ctx.filePath}:0`
                    };
                    args.push(new StringLiteral(locStr, loc));
                  } else {
                    args.push(new NullLiteral(loc));
                  }
                } else {
                  args.push(initializer);
                }
              }
              case _: { args.push(initializer); }
            }
          } else {
            // Optional but no default? Inject null.
            args.push(new NullLiteral(loc));
          }
          a += 1;
        }
      }

      // Check argument count.
      let expectedCount = effectiveFt.parameters.length;
      let actualCount = args.length;

      // Count required parameters (not optional).
      var requiredCount = expectedCount;
      if (effectiveFt.optionalParameters != null) {
        let optionals = effectiveFt.optionalParameters as Array<boolean>;
        requiredCount = 0;
        var i = 0;
        while (i < optionals.length) {
          if (!optionals[i]) { requiredCount = requiredCount + 1; }
          i += 1;
        }
      }

      if (actualCount < requiredCount || actualCount > expectedCount) {
        // Show range for optional parameters, single count otherwise
        let expectedMsg = if (requiredCount == expectedCount) {
          `${expectedCount}`
        } else {
          `${requiredCount}-${expectedCount}`
        };
        ctx.error(
          `Expected ${expectedMsg} arguments, got ${actualCount}.`,
          DiagnosticCode.ArgumentCountMismatch,
          loc
        );
      }

      // Check argument types.
      var j = 0;
      while (j < actualCount && j < expectedCount) {
        let expectedParamType = effectiveFt.parameters[j];
        let argType = checkExpression(ctx, args[j], expectedParamType);
        if (!isAssignableTo(ctx, argType, expectedParamType)) {
          ctx.error(
            "Type mismatch: argument '" + typeToString(argType) +
            "' is not assignable to parameter '" + typeToString(expectedParamType) + "'.",
            DiagnosticCode.TypeMismatch,
            loc
          );
        }
        j = j + 1;
      }

      return effectiveFt.returnType;
    }
    case UnknownType: { return new UnknownType(); }
    case _: {
      ctx.error(
        "Type '" + typeToString(calleeType) + "' is not callable.",
        DiagnosticCode.NotCallable,
        loc
      );
      return new UnknownType();
    }
  }
};

/**
 * Validate that a condition expression has a boolean-compatible type.
 */
let validateConditionType = (ctx: CheckerContext, t: Type, expr: Expression): void => {
  if (!isBooleanLike(t)) {
    ctx.error(
      "Condition must be a boolean type, got '" + typeToString(t) + "'.",
      DiagnosticCode.TypeMismatch,
      expr.loc
    );
  }
};
