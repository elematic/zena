// Abstract Syntax Tree (AST) types for the Zena language
// Ported from packages/compiler/src/lib/ast.ts

import { Array } from 'zena:array';

// ============================================================================
// Source Location
// ============================================================================

export class SourceLocation(
  /** 1-based line number */
  line: i32,
  /** 1-based column number */
  column: i32,
  /** 0-based start index (inclusive) */
  start: i32,
  /** 0-based end index (exclusive) */
  end: i32)

// ============================================================================
// Base Node - Sealed Hierarchy
// ============================================================================

export sealed class Node {
  // Sub-hierarchies
  case Expression, Statement, Pattern, TypeAnnotation

  // Direct case classes
  case Module
  case TemplateElement, PropertyAssignment, SpreadElement, MapEntry
  case BindingProperty, MatchCase, LetPatternCondition
  case TypeParameter, Parameter
  case CaseClassParam, SealedVariant
  case FieldDefinition, MethodDefinition, AccessorDeclaration, SetterInfo
  case FieldInitializer, SuperInitializer
  case MethodSignature, AccessorSignature
  case EnumMember, CatchClause
  case PropertySignature

  abstract loc?: SourceLocation;
}

// ============================================================================
// Module
// ============================================================================

export class Module(
  body: Array<Statement>,
  path: String,
  source: String,
  loc?: SourceLocation) extends Node

// ============================================================================
// Expressions
// ============================================================================

export sealed class Expression extends Node {
  // Identifiers & Literals
  case Identifier(name: String, loc?: SourceLocation)
  case NumberLiteral(raw: String, loc?: SourceLocation)
  case StringLiteral(value: String, loc?: SourceLocation)
  case BooleanLiteral(value: boolean, loc?: SourceLocation)
  case NullLiteral(loc?: SourceLocation)

  // Templates
  case TemplateLiteral(
    quasis: Array<TemplateElement>,
    expressions: Array<Expression>,
    loc?: SourceLocation)
  case TaggedTemplateExpression(
    tag: Expression,
    quasi: TemplateLiteral,
    loc?: SourceLocation)

  // Operators
  case BinaryExpression(
    operator: String,
    left: Expression,
    right: Expression,
    loc?: SourceLocation)
  case UnaryExpression(
    operator: String,
    argument: Expression,
    prefix: boolean,
    loc?: SourceLocation)
  case AssignmentExpression(
    left: Expression,
    value: Expression,
    loc?: SourceLocation)
  case AsExpression(
    expression: Expression,
    typeAnnotation: TypeAnnotation,
    loc?: SourceLocation)
  case IsExpression(
    expression: Expression,
    typeAnnotation: TypeAnnotation,
    loc?: SourceLocation)
  case RangeExpression(
    start: Expression | null,
    end: Expression | null,
    loc?: SourceLocation)
  case PipelineExpression(
    left: Expression,
    right: Expression,
    loc?: SourceLocation)
  case PipePlaceholder(loc?: SourceLocation)

  // Functions & Calls
  case FunctionExpression(
    typeParameters: Array<TypeParameter> | null,
    params: Array<Parameter>,
    returnType: TypeAnnotation | null,
    body: Node,
    loc?: SourceLocation)
  case CallExpression(
    callee: Expression,
    args: Array<Expression>,
    typeArguments: Array<TypeAnnotation> | null,
    optional: boolean,
    loc?: SourceLocation)

  // Member Access
  case MemberExpression(
    object: Expression,
    property: Identifier,
    optional: boolean,
    loc?: SourceLocation)
  case IndexExpression(
    object: Expression,
    index: Expression,
    optional: boolean,
    loc?: SourceLocation)
  case ThisExpression(loc?: SourceLocation)
  case SuperExpression(loc?: SourceLocation)
  case NewExpression(
    callee: Identifier,
    typeArguments: Array<TypeAnnotation> | null,
    args: Array<Expression>,
    loc?: SourceLocation)

  // Collection Literals
  case ArrayLiteral(elements: Array<Expression>, loc?: SourceLocation)
  case RecordLiteral(properties: Array<Node>, loc?: SourceLocation)
  case MapLiteral(entries: Array<MapEntry>, loc?: SourceLocation)
  case TupleLiteral(elements: Array<Expression>, loc?: SourceLocation)

  // Control Flow Expressions
  case MatchExpression(
    discriminant: Expression,
    cases: Array<MatchCase>,
    loc?: SourceLocation)
  case IfExpression(
    test: Expression,
    consequent: Node,
    alternate: Node,
    loc?: SourceLocation)

  // Error Handling Expressions
  case ThrowExpression(argument: Expression, loc?: SourceLocation)
  case TryExpression(
    body: BlockStatement,
    handler: CatchClause | null,
    finalizer: BlockStatement | null,
    loc?: SourceLocation)
}

// ============================================================================
// Statements
// ============================================================================

export sealed class Statement extends Node {
  case VariableDeclaration(
    kind: String,
    pattern: Pattern,
    typeAnnotation: TypeAnnotation | null,
    init: Expression,
    exported: boolean,
    loc?: SourceLocation)
  case ExpressionStatement(expression: Expression, loc?: SourceLocation)
  case BlockStatement(body: Array<Statement>, loc?: SourceLocation)
  case ReturnStatement(argument: Expression | null, loc?: SourceLocation)
  case BreakStatement(loc?: SourceLocation)
  case ContinueStatement(loc?: SourceLocation)
  case IfStatement(
    test: Node,
    consequent: Statement,
    alternate: Statement | null,
    loc?: SourceLocation)
  case WhileStatement(test: Node, body: Statement, loc?: SourceLocation)
  case ForStatement(
    init: Node | null,
    test: Expression | null,
    update: Expression | null,
    body: Statement,
    loc?: SourceLocation)
  case ForInStatement(
    pattern: Pattern,
    iterable: Expression,
    body: Statement,
    loc?: SourceLocation)
  case ClassDeclaration(
    name: Identifier,
    typeParameters: Array<TypeParameter> | null,
    caseParams: Array<CaseClassParam> | null,
    superClass: TypeAnnotation | null,
    mixins: Array<TypeAnnotation> | null,
    implementsList: Array<TypeAnnotation> | null,
    body: Array<Node>,
    exported: boolean,
    isFinal: boolean,
    isAbstract: boolean,
    isExtension: boolean,
    isSealed: boolean,
    sealedVariants: Array<SealedVariant> | null,
    onType: TypeAnnotation | null,
    loc?: SourceLocation)
  case InterfaceDeclaration(
    name: Identifier,
    typeParameters: Array<TypeParameter> | null,
    extendsList: Array<TypeAnnotation> | null,
    body: Array<Node>,
    exported: boolean,
    loc?: SourceLocation)
  case EnumDeclaration(
    name: Identifier,
    members: Array<EnumMember>,
    exported: boolean,
    loc?: SourceLocation)
  case MixinDeclaration(
    name: Identifier,
    typeParameters: Array<TypeParameter> | null,
    on: Identifier | null,
    mixins: Array<TypeAnnotation> | null,
    body: Array<Node>,
    exported: boolean,
    loc?: SourceLocation)
  case TypeAliasDeclaration(
    name: Identifier,
    typeParameters: Array<TypeParameter> | null,
    typeAnnotation: TypeAnnotation,
    exported: boolean,
    isDistinct: boolean,
    loc?: SourceLocation)
}

// ============================================================================
// Patterns
// ============================================================================

export sealed class Pattern extends Node {
  case IdentifierPattern(name: String, loc?: SourceLocation)
  case RecordPattern(properties: Array<BindingProperty>, loc?: SourceLocation)
  case TuplePattern(elements: Array<Node | null>, loc?: SourceLocation)
  case AsPattern(pattern: Node, name: Identifier, loc?: SourceLocation)
  case ClassPattern(
    name: Identifier,
    properties: Array<BindingProperty>,
    loc?: SourceLocation)
  case LogicalPattern(
    operator: String,
    left: Node,
    right: Node,
    loc?: SourceLocation)
  case AssignmentPattern(
    left: Node,
    right: Expression,
    loc?: SourceLocation)
}

// ============================================================================
// Type Annotations
// ============================================================================

export sealed class TypeAnnotation extends Node {
  case NamedTypeAnnotation(
    name: String,
    typeArguments: Array<TypeAnnotation> | null,
    loc?: SourceLocation)
  case UnionTypeAnnotation(
    types: Array<TypeAnnotation>,
    loc?: SourceLocation)
  case FunctionTypeAnnotation(
    paramNames: Array<String>,
    params: Array<TypeAnnotation>,
    returnType: TypeAnnotation,
    loc?: SourceLocation)
  case LiteralTypeAnnotation(
    value: Node,
    loc?: SourceLocation)
  case RecordTypeAnnotation(
    properties: Array<PropertySignature>,
    loc?: SourceLocation)
  case TupleTypeAnnotation(
    elementTypes: Array<TypeAnnotation>,
    loc?: SourceLocation)
  case InlineTupleTypeAnnotation(
    elementTypes: Array<TypeAnnotation>,
    loc?: SourceLocation)
  case ThisTypeAnnotation(
    loc?: SourceLocation)
}

// ============================================================================
// Template Elements
// ============================================================================

export class TemplateElement(
  cooked: String,
  raw: String,
  tail: boolean,
  loc?: SourceLocation) extends Node

// ============================================================================
// Record & Map Entries
// ============================================================================

export class PropertyAssignment(
  name: Identifier,
  value: Expression,
  loc?: SourceLocation) extends Node

export class SpreadElement(
  argument: Expression,
  loc?: SourceLocation) extends Node

export class MapEntry(
  key: Expression,
  value: Expression,
  loc?: SourceLocation) extends Node

// ============================================================================
// Pattern Helpers
// ============================================================================

export class BindingProperty(
  name: Identifier,
  value: Node,
  loc?: SourceLocation) extends Node

// ============================================================================
// Match Expression Helpers
// ============================================================================

export class MatchCase(
  pattern: Node,
  guard: Expression | null,
  body: Node,
  loc?: SourceLocation) extends Node

// ============================================================================
// Control Flow Helpers
// ============================================================================

export class LetPatternCondition(
  pattern: Pattern,
  init: Expression,
  loc?: SourceLocation) extends Node

// ============================================================================
// Type Parameters
// ============================================================================

export class TypeParameter(
  name: String,
  constraint: TypeAnnotation | null,
  defaultType: TypeAnnotation | null,
  loc?: SourceLocation) extends Node

// ============================================================================
// Parameters
// ============================================================================

export class Parameter(
  name: Identifier,
  typeAnnotation: TypeAnnotation | null,
  optional: boolean,
  defaultValue: Expression | null,
  isThisParam: boolean,
  loc?: SourceLocation) extends Node

// ============================================================================
// Case Class & Sealed Variant Helpers
// ============================================================================

export class CaseClassParam(
  name: Identifier,
  typeAnnotation: TypeAnnotation,
  mutability: String | null,
  optional: boolean,
  loc?: SourceLocation) extends Node

export class SealedVariant(
  name: Identifier,
  params: Array<CaseClassParam> | null,
  loc?: SourceLocation) extends Node

// ============================================================================
// Class Members
// ============================================================================

export class FieldDefinition(
  name: Identifier,
  typeAnnotation: TypeAnnotation,
  value: Expression | null,
  isFinal: boolean,
  isAbstract: boolean,
  isOptional: boolean,
  mutability: String | null,
  loc?: SourceLocation) extends Node

export class MethodDefinition(
  name: Identifier,
  typeParameters: Array<TypeParameter> | null,
  params: Array<Parameter>,
  returnType: TypeAnnotation | null,
  body: Node | null,
  initializerList: Array<Node> | null,
  superInitializer: Node | null,
  isFinal: boolean,
  isAbstract: boolean,
  isStatic: boolean,
  loc?: SourceLocation) extends Node

// ============================================================================
// Accessors
// ============================================================================

export class AccessorDeclaration(
  name: Identifier,
  typeAnnotation: TypeAnnotation,
  getter: BlockStatement | null,
  setter: Node | null,
  isFinal: boolean,
  isStatic: boolean,
  loc?: SourceLocation) extends Node

export class SetterInfo(
  param: Identifier,
  body: BlockStatement,
  loc?: SourceLocation) extends Node

// ============================================================================
// Initializer List Entries
// ============================================================================

export class FieldInitializer(
  field: Identifier,
  value: Expression,
  loc?: SourceLocation) extends Node

export class SuperInitializer(
  args: Array<Expression>,
  loc?: SourceLocation) extends Node

// ============================================================================
// Interface Members
// ============================================================================

export class MethodSignature(
  name: Identifier,
  typeParameters: Array<TypeParameter> | null,
  params: Array<Parameter>,
  returnType: TypeAnnotation | null,
  loc?: SourceLocation) extends Node

export class AccessorSignature(
  name: Identifier,
  typeAnnotation: TypeAnnotation,
  hasGetter: boolean,
  hasSetter: boolean,
  loc?: SourceLocation) extends Node

// ============================================================================
// Enum Members
// ============================================================================

export class EnumMember(
  name: Identifier,
  initializer: Expression | null,
  loc?: SourceLocation) extends Node

// ============================================================================
// Error Handling Helpers
// ============================================================================

export class CatchClause(
  param: Identifier | null,
  body: BlockStatement,
  loc?: SourceLocation) extends Node

// ============================================================================
// Property Signatures (for Record Type Annotations)
// ============================================================================

export class PropertySignature(
  name: Identifier,
  typeAnnotation: TypeAnnotation,
  optional: boolean,
  loc?: SourceLocation) extends Node
