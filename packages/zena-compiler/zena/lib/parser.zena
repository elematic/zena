// Parser for the Zena programming language
// Ported from packages/compiler/src/lib/parser.ts
// Self-hosted compiler implementation

import { Array } from 'zena:array';
import { Error } from 'zena:error';
import { StringReader } from 'zena:string-reader';
import { Token, TokenType, tokenize } from './tokenizer.zena';
import { 
  SourceLocation,
  Node,
  Module,
  Statement,
  Expression,
  Pattern,
  TypeAnnotation,
  Identifier,
  IdentifierPattern,
  NumberLiteral,
  StringLiteral,
  BooleanLiteral,
  NullLiteral,
  BinaryExpression,
  UnaryExpression,
  AssignmentExpression,
  VariableDeclaration,
  ExpressionStatement,
  BlockStatement,
  ReturnStatement,
  BreakStatement,
  ContinueStatement,
  IfStatement,
  WhileStatement,
  ForStatement,
  ForInStatement,
  LetPatternCondition,
  NamedTypeAnnotation,
  UnionTypeAnnotation,
  FunctionTypeAnnotation,
  LiteralTypeAnnotation,
  RecordTypeAnnotation,
  TupleTypeAnnotation,
  InlineTupleTypeAnnotation,
  ThisTypeAnnotation,
  PropertySignature,
  TypeParameter,
  Parameter,
  FunctionExpression,
  CallExpression,
  MemberExpression,
  IndexExpression,
  ThisExpression,
  ArrayLiteral,
  PropertyAssignment,
  SpreadElement,
  RecordLiteral,
  MapEntry,
  MapLiteral,
  TupleLiteral,
  RecordPattern,
  BindingProperty,
  TuplePattern,
  AsPattern,
  ClassPattern,
  LogicalPattern,
  AssignmentPattern,
  MatchExpression,
  MatchCase,
  IfExpression,
  CaseClassParam,
  ClassDeclaration,
  FieldDefinition,
  MethodDefinition,
  AccessorDeclaration,
  SetterInfo,
  SuperExpression,
  FieldInitializer,
  SuperInitializer,
  InterfaceDeclaration,
  MixinDeclaration,
  MethodSignature,
  AccessorSignature,
  TemplateElement,
  TemplateLiteral,
  TaggedTemplateExpression,
  AsExpression,
  IsExpression,
  RangeExpression,
  PipelineExpression,
  PipePlaceholder,
  NewExpression,
  ThrowExpression,
  TryExpression,
  CatchClause,
  EnumDeclaration,
  EnumMember,
  SealedVariant,
  TypeAliasDeclaration,
  ImportDeclaration,
  ImportSpecifier,
  ExportAllDeclaration,
  Decorator,
  DeclareFunction,
  SymbolDeclaration,
  SymbolPropertyName
} from './ast.zena';

// ============================================================================
// Parser
// ============================================================================

export class Parser {
  #tokens: Array<Token>;
  var #current: i32;
  var #extraGreaters: i32;
  #source: String;
  #path: String;
  
  new(source: String, path: String)
    : #source = source, #path = path, #tokens = tokenize(source), #current = 0, #extraGreaters = 0
  { }
  
  // ==========================================================================
  // Main Entry Point
  // ==========================================================================
  
  parse(): Module {
    let body = new Array<Statement>(16);
    
    // Parse imports at the top of the file
    while (this.#check(TokenType.Import) || this.#check(TokenType.From)) {
      if (this.#check(TokenType.From) && this.#peek2().kind != TokenType.String) {
        break;
      }
      body.push(this.#parseImportDeclaration());
    }
    
    while (!this.#isAtEnd()) {
      let stmt = this.#parseStatement();
      body.push(stmt);
    }
    
    return new Module(body, this.#path, this.#source, null);
  }
  
  // ==========================================================================
  // Import Parsing
  // ==========================================================================
  
  #parseImportDeclaration(): ImportDeclaration {
    let startToken = this.#peek();
    if (this.#match(TokenType.Import)) {
      let imports = this.#parseImportSpecifiers();
      this.#consume(TokenType.From, "Expected 'from'");
      let moduleSpecifier = this.#parseStringLiteralNode();
      this.#consume(TokenType.Semi, "Expected ';'");
      return new ImportDeclaration(moduleSpecifier, imports, this.#makeLocation(startToken));
    }
    
    if (this.#match(TokenType.From)) {
      let moduleSpecifier = this.#parseStringLiteralNode();
      this.#consume(TokenType.Import, "Expected 'import'");
      let imports = this.#parseImportSpecifiers();
      this.#consume(TokenType.Semi, "Expected ';'");
      return new ImportDeclaration(moduleSpecifier, imports, this.#makeLocation(startToken));
    }
    
    throw new Error('Expected import declaration.');
  }
  
  #parseImportSpecifiers(): Array<ImportSpecifier> {
    this.#consume(TokenType.LBrace, "Expected '{'");
    let imports = new Array<ImportSpecifier>(4);
    if (!this.#check(TokenType.RBrace)) {
      let imported = this.#parseIdentifier();
      var local = imported;
      if (this.#match(TokenType.As)) {
        local = this.#parseIdentifier();
      }
      imports.push(new ImportSpecifier(imported, local, null));
      while (this.#match(TokenType.Comma)) {
        let imported2 = this.#parseIdentifier();
        var local2 = imported2;
        if (this.#match(TokenType.As)) {
          local2 = this.#parseIdentifier();
        }
        imports.push(new ImportSpecifier(imported2, local2, null));
      }
    }
    this.#consume(TokenType.RBrace, "Expected '}'");
    return imports;
  }
  
  #parseStringLiteralNode(): StringLiteral {
    let token = this.#consume(TokenType.String, "Expected string literal");
    return new StringLiteral(token.value, null);
  }
  
  // ==========================================================================
  // Token Navigation
  // ==========================================================================
  
  #peek(): Token {
    return this.#tokens[this.#current];
  }
  
  #peek2(): Token {
    return this.#tokens[this.#current + 1];
  }
  
  #previous(): Token {
    return this.#tokens[this.#current - 1];
  }
  
  #isAtEnd(): boolean {
    return this.#peek().kind == TokenType.EOF;
  }
  
  #check(type: TokenType): boolean {
    if (this.#isAtEnd()) {
      return false;
    }
    return this.#peek().kind == type;
  }
  
  #advance(): Token {
    if (!this.#isAtEnd()) {
      this.#current = this.#current + 1;
    }
    return this.#previous();
  }
  
  #match(type: TokenType): boolean {
    if (this.#check(type)) {
      this.#advance();
      return true;
    }
    return false;
  }
  
  #consume(type: TokenType, message: String): Token {
    if (this.#check(type)) {
      return this.#advance();
    }
    // TODO: Better error handling
    throw new Error(message);
  }
  
  #makeLocation(startToken: Token): SourceLocation {
    let endToken = this.#previous();
    return new SourceLocation(
      startToken.line,
      startToken.column,
      startToken.start,
      endToken.end
    );
  }
  
  // ==========================================================================
  // Statement Parsing
  // ==========================================================================
  
  #parseStatement(): Statement {
    let startToken = this.#peek();
    
    // Decorated statement: @decorator ... declare function ...
    if (this.#check(TokenType.At)) {
      let decorators = new Array<Decorator>(2);
      while (this.#check(TokenType.At)) {
        decorators.push(this.#parseDecorator());
      }
      var decExported = false;
      if (this.#match(TokenType.Export)) {
        decExported = true;
      }
      if (this.#match(TokenType.Declare)) {
        return this.#parseDeclareFunction(decorators, decExported, startToken);
      }
      throw new Error("Expected 'declare' after decorator");
    }
    
    // Export prefix
    var exported = false;
    if (this.#match(TokenType.Export)) {
      // export * from '...';
      if (this.#match(TokenType.Star)) {
        this.#consume(TokenType.From, "Expected 'from' after '*'");
        let moduleSpecifier = this.#parseStringLiteralNode();
        this.#consume(TokenType.Semi, "Expected ';' after export declaration");
        return new ExportAllDeclaration(moduleSpecifier, this.#makeLocation(startToken));
      }
      exported = true;
    }
    
    // Reject late imports
    if (this.#check(TokenType.Import)) {
      throw new Error('Imports must appear at the top of the file.');
    }
    if (this.#check(TokenType.From) && this.#peek2().kind == TokenType.String) {
      throw new Error('Imports must appear at the top of the file.');
    }
    
    // Declare function (without decorators)
    if (this.#check(TokenType.Declare) && this.#peek2().kind == TokenType.Function) {
      this.#advance(); // consume 'declare'
      return this.#parseDeclareFunction(new Array<Decorator>(0), exported, startToken);
    }
    
    // Variable declarations
    if (this.#match(TokenType.Let)) {
      return this.#parseVariableDeclaration('let', exported, startToken);
    }
    if (this.#match(TokenType.Var)) {
      return this.#parseVariableDeclaration('var', exported, startToken);
    }
    
    // Sealed class declarations
    if (this.#check(TokenType.Sealed)) {
      return this.#parseSealedClassEntry(exported, startToken);
    }
    
    // Class declarations
    if (this.#check(TokenType.Class) || this.#check(TokenType.Final) || this.#check(TokenType.Abstract) || this.#check(TokenType.Extension)) {
      return this.#parseClassDeclarationEntry(exported, startToken);
    }
    
    // Interface declarations
    if (this.#match(TokenType.Interface)) {
      return this.#parseInterfaceDeclaration(exported, startToken);
    }
    
    // Mixin declarations
    if (this.#match(TokenType.Mixin)) {
      return this.#parseMixinDeclaration(exported, startToken);
    }
    
    // Enum declarations
    if (this.#match(TokenType.Enum)) {
      return this.#parseEnumDeclaration(exported, startToken);
    }
    
    // Type alias declarations: type X = Y; or distinct type X = Y;
    if (this.#check(TokenType.Type)) {
      return this.#parseTypeAliasDeclaration(exported, false, startToken);
    }
    if (this.#check(TokenType.Distinct)) {
      this.#advance(); // consume 'distinct'
      return this.#parseTypeAliasDeclaration(exported, true, startToken);
    }
    
    // Symbol declarations
    if (this.#check(TokenType.Symbol) && this.#peek2().kind == TokenType.Identifier) {
      this.#advance(); // consume 'symbol'
      return this.#parseSymbolDeclaration(exported, startToken);
    }
    
    // Control flow
    if (this.#match(TokenType.Return)) {
      return this.#parseReturnStatement(startToken);
    }
    if (this.#match(TokenType.Break)) {
      this.#consume(TokenType.Semi, "Expected ';' after break");
      return new BreakStatement(this.#makeLocation(startToken));
    }
    if (this.#match(TokenType.Continue)) {
      this.#consume(TokenType.Semi, "Expected ';' after continue");
      return new ContinueStatement(this.#makeLocation(startToken));
    }
    if (this.#match(TokenType.If)) {
      return this.#parseIfStatement(startToken);
    }
    if (this.#match(TokenType.While)) {
      return this.#parseWhileStatement(startToken);
    }
    if (this.#match(TokenType.For)) {
      return this.#parseForStatement(startToken);
    }
    
    // Block statement
    if (this.#match(TokenType.LBrace)) {
      return this.#parseBlockStatement(startToken);
    }
    
    // Expression statement
    return this.#parseExpressionStatement();
  }
  
  #parseVariableDeclaration(kind: String, exported: boolean, startToken: Token): VariableDeclaration {
    // Parse pattern (for now just identifier)
    let pattern = this.#parsePattern();
    
    // Optional type annotation
    var typeAnnotation: TypeAnnotation | null = null;
    if (this.#match(TokenType.Colon)) {
      typeAnnotation = this.#parseTypeAnnotation();
    }
    
    // Initializer
    this.#consume(TokenType.Equals, "Expected '=' after variable name");
    let init = this.#parseExpression();
    
    this.#consume(TokenType.Semi, "Expected ';' after variable declaration");
    
    return new VariableDeclaration(kind, pattern, typeAnnotation, init, exported, this.#makeLocation(startToken));
  }
  
  #parseReturnStatement(startToken: Token): ReturnStatement {
    var argument: Expression | null = null;
    
    if (!this.#check(TokenType.Semi)) {
      argument = this.#parseExpression();
    }
    
    this.#consume(TokenType.Semi, "Expected ';' after return statement");
    
    return new ReturnStatement(argument, this.#makeLocation(startToken));
  }
  
  #parseIfStatement(startToken: Token): IfStatement {
    this.#consume(TokenType.LParen, "Expected '(' after 'if'");
    let test = this.#parseCondition();
    this.#consume(TokenType.RParen, "Expected ')' after condition");
    
    let consequent = this.#parseStatement();
    
    var alternate: Statement | null = null;
    if (this.#match(TokenType.Else)) {
      alternate = this.#parseStatement();
    }
    
    return new IfStatement(test, consequent, alternate, this.#makeLocation(startToken));
  }
  
  #parseWhileStatement(startToken: Token): WhileStatement {
    this.#consume(TokenType.LParen, "Expected '(' after 'while'");
    let test = this.#parseCondition();
    this.#consume(TokenType.RParen, "Expected ')' after condition");
    
    let body = this.#parseStatement();
    
    return new WhileStatement(test, body, this.#makeLocation(startToken));
  }
  
  #parseCondition(): Node {
    if (this.#match(TokenType.Let)) {
      return this.#parseLetPatternCondition();
    }
    return this.#parseExpression();
  }
  
  #parseLetPatternCondition(): LetPatternCondition {
    let startToken = this.#previous();
    let pattern = this.#parsePattern();
    this.#consume(TokenType.Equals, "Expected '=' after pattern in let condition");
    let init = this.#parseExpression();
    return new LetPatternCondition(pattern, init, this.#makeLocation(startToken));
  }
  
  #parseForStatement(startToken: Token): Statement {
    this.#consume(TokenType.LParen, "Expected '(' after 'for'");
    
    if (this.#match(TokenType.Let)) {
      // Could be for-in or C-style with let declaration
      let pattern = this.#parsePattern();
      
      if (this.#match(TokenType.In)) {
        // for-in loop
        let iterable = this.#parseExpression();
        this.#consume(TokenType.RParen, "Expected ')' after for-in iterable");
        let body = this.#parseStatement();
        return new ForInStatement(pattern, iterable, body, this.#makeLocation(startToken));
      }
      
      // C-style for with let declaration
      this.#consume(TokenType.Equals, "Expected '=' or 'in' after pattern in for statement");
      let initExpr = this.#parseExpression();
      let init = new VariableDeclaration('let', pattern, null, initExpr, false, this.#makeLocation(startToken));
      return this.#parseCStyleFor(startToken, init);
    }
    
    if (this.#match(TokenType.Var)) {
      // C-style for with var declaration
      let varStart = this.#previous();
      let pattern = this.#parsePattern();
      
      var typeAnnotation: TypeAnnotation | null = null;
      if (this.#match(TokenType.Colon)) {
        typeAnnotation = this.#parseTypeAnnotation();
      }
      
      this.#consume(TokenType.Equals, "Expected '=' after variable name");
      let initExpr = this.#parseExpression();
      let init = new VariableDeclaration('var', pattern, typeAnnotation, initExpr, false, this.#makeLocation(varStart));
      return this.#parseCStyleFor(startToken, init);
    }
    
    // Parse init as expression, or empty
    var init: Node | null = null;
    if (!this.#check(TokenType.Semi)) {
      init = this.#parseExpression();
    }
    
    return this.#parseCStyleFor(startToken, init);
  }
  
  #parseCStyleFor(startToken: Token, init: Node | null): ForStatement {
    this.#consume(TokenType.Semi, "Expected ';' after for initializer");
    
    var test: Expression | null = null;
    if (!this.#check(TokenType.Semi)) {
      test = this.#parseExpression();
    }
    this.#consume(TokenType.Semi, "Expected ';' after for condition");
    
    var update: Expression | null = null;
    if (!this.#check(TokenType.RParen)) {
      update = this.#parseExpression();
    }
    this.#consume(TokenType.RParen, "Expected ')' after for clauses");
    
    let body = this.#parseStatement();
    
    return new ForStatement(init, test, update, body, this.#makeLocation(startToken));
  }
  
  #parseBlockStatement(startToken: Token): BlockStatement {
    let body = new Array<Statement>(8);
    
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      body.push(this.#parseStatement());
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after block");
    
    return new BlockStatement(body, this.#makeLocation(startToken));
  }
  
  #parseBlockAsExpression(startToken: Token): BlockStatement {
    let body = new Array<Statement>(8);
    
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      // Check for keywords that definitely start statements
      if (this.#check(TokenType.Let) || this.#check(TokenType.Var) || this.#check(TokenType.Return) || this.#check(TokenType.While) || this.#check(TokenType.If) || this.#check(TokenType.For) || this.#check(TokenType.Break) || this.#check(TokenType.Continue) || this.#check(TokenType.Class)) {
        body.push(this.#parseStatement());
        continue;
      }
      
      // If we're at a semicolon, parse the statement
      if (this.#check(TokenType.Semi)) {
        body.push(this.#parseStatement());
        continue;
      }
      
      // Try to parse as expression
      let expr = this.#parseExpression();
      
      // If next token is '}', this is the trailing expression (no semicolon needed)
      if (this.#check(TokenType.RBrace)) {
        body.push(new ExpressionStatement(expr, expr.loc));
        break;
      }
      
      // Otherwise, we expect a semicolon (it's a regular expression statement)
      this.#consume(TokenType.Semi, "Expected ';' after expression");
      body.push(new ExpressionStatement(expr, expr.loc));
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after block");
    
    return new BlockStatement(body, this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // Match Expression
  // ==========================================================================
  
  #parseMatchExpression(startToken: Token): MatchExpression {
    this.#consume(TokenType.LParen, "Expected '(' after 'match'");
    let discriminant = this.#parseExpression();
    this.#consume(TokenType.RParen, "Expected ')' after match discriminant");
    this.#consume(TokenType.LBrace, "Expected '{' before match cases");
    
    let cases = new Array<MatchCase>(4);
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      cases.push(this.#parseMatchCase());
    }
    this.#consume(TokenType.RBrace, "Expected '}' after match cases");
    
    return new MatchExpression(discriminant, cases, this.#makeLocation(startToken));
  }
  
  #parseMatchCase(): MatchCase {
    this.#consume(TokenType.Case, "Expected 'case'");
    let startToken = this.#previous();
    let pattern = this.#parseMatchPattern();
    
    var guard: Expression | null = null;
    if (this.#match(TokenType.If)) {
      guard = this.#parseExpression();
    }
    
    this.#consume(TokenType.Colon, "Expected ':' after case pattern");
    
    return if (this.#match(TokenType.LBrace)) {
      let body: Node = this.#parseBlockAsExpression(this.#previous());
      new MatchCase(pattern, guard, body, this.#makeLocation(startToken))
    } else {
      let body: Node = this.#parseExpression();
      new MatchCase(pattern, guard, body, this.#makeLocation(startToken))
    };
  }
  
  #parseMatchPattern(): Node {
    return this.#parseLogicalOrPattern();
  }
  
  #parseLogicalOrPattern(): Node {
    var left = this.#parseLogicalAndPattern();
    while (this.#match(TokenType.Pipe)) {
      let right = this.#parseLogicalAndPattern();
      left = new LogicalPattern('||', left, right, null);
    }
    return left;
  }
  
  #parseLogicalAndPattern(): Node {
    var left = this.#parseAsPattern();
    while (this.#match(TokenType.Ampersand)) {
      let right = this.#parseAsPattern();
      left = new LogicalPattern('&&', left, right, null);
    }
    return left;
  }
  
  #parseAsPattern(): Node {
    let pattern = this.#parsePrimaryPattern();
    if (this.#match(TokenType.As)) {
      let name = this.#parseIdentifier();
      return new AsPattern(pattern, name, null);
    }
    return pattern;
  }
  
  #parsePrimaryPattern(): Node {
    let startToken = this.#peek();
    
    // Number literal pattern
    if (this.#match(TokenType.Number)) {
      let token = this.#previous();
      return new NumberLiteral(token.value, this.#makeLocation(startToken));
    }
    
    // String literal pattern
    if (this.#match(TokenType.String)) {
      let token = this.#previous();
      return new StringLiteral(token.value, this.#makeLocation(startToken));
    }
    
    // Boolean literal patterns
    if (this.#match(TokenType.True)) {
      return new BooleanLiteral(true, this.#makeLocation(startToken));
    }
    if (this.#match(TokenType.False)) {
      return new BooleanLiteral(false, this.#makeLocation(startToken));
    }
    
    // Null literal pattern
    if (this.#match(TokenType.Null)) {
      return new NullLiteral(this.#makeLocation(startToken));
    }
    
    // Record pattern: { a, b }
    if (this.#match(TokenType.LBrace)) {
      return this.#parseRecordPattern(startToken, true);
    }
    
    // Tuple pattern: (a, b)
    if (this.#match(TokenType.LParen)) {
      return this.#parseMatchTuplePattern(startToken);
    }
    
    // Identifier, wildcard, class pattern, or member expression pattern
    if (this.#isIdentifier()) {
      let ident = this.#parseIdentifier();
      
      // Class pattern: ClassName { ... }
      if (this.#check(TokenType.LBrace)) {
        this.#advance();
        let properties = new Array<BindingProperty>(4);
        while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
          let propStart = this.#peek();
          let name = this.#parseIdentifier();
          var value: Node = new IdentifierPattern(name.name, name.loc);
          if (this.#match(TokenType.Colon)) {
            value = this.#parseMatchPattern();
          }
          properties.push(new BindingProperty(name, value, this.#makeLocation(propStart)));
          if (!this.#check(TokenType.RBrace)) {
            this.#consume(TokenType.Comma, "Expected ',' after property");
          }
        }
        this.#consume(TokenType.RBrace, "Expected '}' after class pattern");
        return new ClassPattern(ident, properties, this.#makeLocation(startToken));
      }
      
      // Member expression pattern: Enum.Member or A.B.C
      if (this.#check(TokenType.Dot)) {
        var obj: Expression = ident;
        while (this.#match(TokenType.Dot)) {
          let prop = this.#parseIdentifier();
          obj = new MemberExpression(obj, prop, false, this.#makeLocation(startToken));
        }
        return obj;
      }
      
      // Plain identifier or wildcard
      return ident;
    }
    
    throw new Error("Unexpected token in pattern");
  }
  
  #parseMatchTuplePattern(startToken: Token): TuplePattern {
    let elements = new Array<Node | null>(4);
    
    if (!this.#check(TokenType.RParen)) {
      elements.push(this.#parseMatchPattern());
      while (this.#match(TokenType.Comma)) {
        elements.push(this.#parseMatchPattern());
      }
    }
    
    this.#consume(TokenType.RParen, "Expected ')' after tuple pattern");
    return new TuplePattern(elements, this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // If Expression
  // ==========================================================================
  
  #parseIfExpression(startToken: Token): IfExpression {
    this.#consume(TokenType.LParen, "Expected '(' after 'if'");
    let test = this.#parseExpression();
    this.#consume(TokenType.RParen, "Expected ')' after if condition");
    
    var consequent: Node = if (this.#match(TokenType.LBrace)) {
      let b: Node = this.#parseBlockAsExpression(this.#previous());
      b
    } else {
      let e: Node = this.#parseExpression();
      e
    };
    
    this.#consume(TokenType.Else, "Expected 'else' after consequent in if expression");
    
    var alternate: Node = if (this.#match(TokenType.LBrace)) {
      let b: Node = this.#parseBlockAsExpression(this.#previous());
      b
    } else if (this.#check(TokenType.If)) {
      this.#advance();
      let e: Node = this.#parseIfExpression(this.#previous());
      e
    } else {
      let e: Node = this.#parseExpression();
      e
    };
    
    return new IfExpression(test, consequent, alternate, this.#makeLocation(startToken));
  }
  
  #parseTryExpression(startToken: Token): TryExpression {
    this.#consume(TokenType.LBrace, "Expected '{' after 'try'");
    let body = this.#parseBlockAsExpression(this.#previous());
    
    var handler: CatchClause | null = null;
    var finalizer: BlockStatement | null = null;
    
    if (this.#match(TokenType.Catch)) {
      let catchToken = this.#previous();
      var param: Identifier | null = null;
      
      if (this.#match(TokenType.LParen)) {
        param = this.#parseIdentifier();
        this.#consume(TokenType.RParen, "Expected ')' after catch parameter");
      }
      
      this.#consume(TokenType.LBrace, "Expected '{' after catch");
      let catchBody = this.#parseBlockAsExpression(this.#previous());
      
      handler = new CatchClause(param, catchBody, this.#makeLocation(catchToken));
    }
    
    if (this.#match(TokenType.Finally)) {
      this.#consume(TokenType.LBrace, "Expected '{' after 'finally'");
      finalizer = this.#parseBlockAsExpression(this.#previous());
    }
    
    if (handler == null && finalizer == null) {
      throw new Error("Expected 'catch' or 'finally' after try block");
    }
    
    return new TryExpression(body, handler, finalizer, this.#makeLocation(startToken));
  }
  
  #parseExpressionStatement(): ExpressionStatement {
    let startToken = this.#peek();
    let expr = this.#parseExpression();
    if (this.#isBlockEndedExpression(expr)) {
      if (this.#check(TokenType.Semi)) {
        this.#advance();
      }
    } else {
      this.#consume(TokenType.Semi, "Expected ';' after expression");
    }
    return new ExpressionStatement(expr, this.#makeLocation(startToken));
  }
  
  #isBlockEndedExpression(expr: Expression): boolean {
    if (expr is MatchExpression) { return true; }
    if (expr is TryExpression) { return true; }
    if (expr is IfExpression) {
      let ifExpr = expr as IfExpression;
      if (ifExpr.alternate is BlockStatement) { return true; }
      if (ifExpr.alternate is IfExpression) {
        return this.#isBlockEndedExpression(ifExpr.alternate as Expression);
      }
      return false;
    }
    return false;
  }
  
  // ==========================================================================
  // Pattern Parsing
  // ==========================================================================
  
  #parsePattern(): Pattern {
    let startToken = this.#peek();
    
    // Record pattern: { a, b }
    if (this.#match(TokenType.LBrace)) {
      return this.#parseRecordPattern(startToken, false);
    }
    
    // Tuple pattern: [a, b]
    if (this.#match(TokenType.LBracket)) {
      return this.#parseTuplePattern(startToken);
    }
    
    // Tuple pattern with parens: (a, b)
    if (this.#match(TokenType.LParen)) {
      return this.#parseParenTuplePattern(startToken);
    }
    
    // Identifier pattern (most common case)
    return this.#parseIdentifierPattern();
  }
  
  #parseIdentifierPattern(): IdentifierPattern {
    let startToken = this.#peek();
    if (this.#isIdentifier()) {
      let token = this.#advance();
      return new IdentifierPattern(token.value, this.#makeLocation(startToken));
    }
    throw new Error("Expected identifier");
  }
  
  #parseRecordPattern(startToken: Token, matchContext: boolean): RecordPattern {
    let properties = new Array<BindingProperty>(4);
    
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      let propStart = this.#peek();
      let name = this.#parseIdentifier();
      
      // Shorthand: { x } means { x: x }
      var value: Node = new IdentifierPattern(name.name, name.loc);
      if (this.#match(TokenType.Colon)) {
        value = if (matchContext) {
          let m: Node = this.#parseMatchPattern();
          m
        } else {
          let p: Node = this.#parsePattern();
          p
        };
      } else if (this.#match(TokenType.As)) {
        // Rename: { x as y }
        let newName = this.#parseIdentifier();
        value = new IdentifierPattern(newName.name, newName.loc);
      }
      
      // Default value: { x = 1 }
      if (this.#match(TokenType.Equals)) {
        let defaultValue = this.#parseExpression();
        value = new AssignmentPattern(value, defaultValue, this.#makeLocation(propStart));
      }
      
      properties.push(new BindingProperty(name, value, this.#makeLocation(propStart)));
      
      if (!this.#check(TokenType.RBrace)) {
        this.#consume(TokenType.Comma, "Expected ',' after property");
      }
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after record pattern");
    return new RecordPattern(properties, this.#makeLocation(startToken));
  }
  
  #parseTuplePattern(startToken: Token): TuplePattern {
    let elements = new Array<Node | null>(4);
    
    while (!this.#check(TokenType.RBracket) && !this.#isAtEnd()) {
      // TODO: Support holes in tuple patterns (null elements)
      elements.push(this.#parsePattern());
      
      if (!this.#check(TokenType.RBracket)) {
        this.#consume(TokenType.Comma, "Expected ',' in tuple pattern");
      }
    }
    
    this.#consume(TokenType.RBracket, "Expected ']' after tuple pattern");
    return new TuplePattern(elements, this.#makeLocation(startToken));
  }
  
  #parseParenTuplePattern(startToken: Token): TuplePattern {
    let elements = new Array<Node | null>(4);
    
    if (!this.#check(TokenType.RParen)) {
      elements.push(this.#parseMatchPattern());
      while (this.#match(TokenType.Comma)) {
        elements.push(this.#parseMatchPattern());
      }
    }
    
    this.#consume(TokenType.RParen, "Expected ')' after tuple pattern");
    return new TuplePattern(elements, this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // Expression Parsing (Precedence Climbing)
  // ==========================================================================
  
  #parseExpression(): Expression {
    return this.#parseAssignment();
  }
  
  #parseAssignment(): Expression {
    let expr = this.#parsePipeline();
    
    if (this.#match(TokenType.Equals)) {
      let startToken = this.#previous();
      let value = this.#parseAssignment();
      return new AssignmentExpression(expr, value, this.#makeLocation(startToken));
    }
    
    return expr;
  }
  
  #parsePipeline(): Expression {
    var expr = this.#parseLogicalOr();
    
    while (this.#match(TokenType.PipeGreater)) {
      let startToken = this.#previous();
      let right = this.#parseLogicalOr();
      expr = new PipelineExpression(expr, right, this.#makeLocation(startToken));
    }
    
    return expr;
  }
  
  #parseLogicalOr(): Expression {
    var expr = this.#parseLogicalAnd();
    
    while (this.#check(TokenType.PipePipe) || this.#check(TokenType.QuestionQuestion)) {
      let op = this.#advance();
      let right = this.#parseLogicalAnd();
      let opStr = op.value;
      expr = new BinaryExpression(opStr, expr, right, this.#makeLocation(op));
    }
    
    return expr;
  }
  
  #parseLogicalAnd(): Expression {
    var expr = this.#parseBitwiseOr();
    
    while (this.#match(TokenType.AmpersandAmpersand)) {
      let startToken = this.#previous();
      let right = this.#parseBitwiseOr();
      expr = new BinaryExpression('&&', expr, right, this.#makeLocation(startToken));
    }
    
    return expr;
  }
  
  #parseBitwiseOr(): Expression {
    var expr = this.#parseBitwiseXor();
    
    while (this.#match(TokenType.Pipe)) {
      let startToken = this.#previous();
      let right = this.#parseBitwiseXor();
      expr = new BinaryExpression('|', expr, right, this.#makeLocation(startToken));
    }
    
    return expr;
  }
  
  #parseBitwiseXor(): Expression {
    var expr = this.#parseBitwiseAnd();
    
    while (this.#match(TokenType.Caret)) {
      let startToken = this.#previous();
      let right = this.#parseBitwiseAnd();
      expr = new BinaryExpression('^', expr, right, this.#makeLocation(startToken));
    }
    
    return expr;
  }
  
  #parseBitwiseAnd(): Expression {
    var expr = this.#parseEquality();
    
    while (this.#match(TokenType.Ampersand)) {
      let startToken = this.#previous();
      let right = this.#parseEquality();
      expr = new BinaryExpression('&', expr, right, this.#makeLocation(startToken));
    }
    
    return expr;
  }
  
  #parseEquality(): Expression {
    var expr = this.#parseComparison();
    
    while (this.#check(TokenType.EqualsEquals) || this.#check(TokenType.BangEquals) ||
           this.#check(TokenType.EqualsEqualsEquals) || this.#check(TokenType.BangEqualsEquals)) {
      let op = this.#advance();
      let right = this.#parseComparison();
      let opStr = op.value;
      expr = new BinaryExpression(opStr, expr, right, this.#makeLocation(op));
    }
    
    return expr;
  }
  
  #parseComparison(): Expression {
    var expr = this.#parseShift();
    
    while (this.#check(TokenType.Less) || this.#check(TokenType.LessEquals) ||
           this.#check(TokenType.Greater) || this.#check(TokenType.GreaterEquals)) {
      let op = this.#advance();
      let right = this.#parseShift();
      let opStr = op.value;
      expr = new BinaryExpression(opStr, expr, right, this.#makeLocation(op));
    }
    
    return expr;
  }
  
  #parseShift(): Expression {
    var expr = this.#parseRange();
    
    while (this.#check(TokenType.LessLess) || this.#check(TokenType.GreaterGreater) ||
           this.#check(TokenType.GreaterGreaterGreater)) {
      let op = this.#advance();
      let right = this.#parseRange();
      let opStr = op.value;
      expr = new BinaryExpression(opStr, expr, right, this.#makeLocation(op));
    }
    
    return expr;
  }
  
  #parseRange(): Expression {
    let startToken = this.#peek();
    
    // Handle prefix range: ..end or ..
    if (this.#match(TokenType.DotDot)) {
      if (this.#check(TokenType.Comma) || this.#check(TokenType.Semi) ||
          this.#check(TokenType.RParen) || this.#check(TokenType.RBracket) ||
          this.#check(TokenType.RBrace)) {
        // .. with no end -> FullRange
        return new RangeExpression(null, null, this.#makeLocation(startToken));
      } else {
        // ..end -> ToRange
        let end = this.#parseAs();
        return new RangeExpression(null, end, this.#makeLocation(startToken));
      }
    }
    
    var left = this.#parseAs();
    
    // Handle postfix range: start.. or bounded range: start..end
    if (this.#match(TokenType.DotDot)) {
      if (this.#check(TokenType.Comma) || this.#check(TokenType.Semi) ||
          this.#check(TokenType.RParen) || this.#check(TokenType.RBracket) ||
          this.#check(TokenType.RBrace)) {
        // start.. with no end -> FromRange
        return new RangeExpression(left, null, this.#makeLocation(startToken));
      } else {
        // start..end -> BoundedRange
        let end = this.#parseAs();
        return new RangeExpression(left, end, this.#makeLocation(startToken));
      }
    }
    
    return left;
  }
  
  #parseAs(): Expression {
    var expr = this.#parseTerm();
    
    while (this.#check(TokenType.As) || this.#check(TokenType.Is)) {
      let op = this.#advance();
      let typeAnnotation = this.#parseTypeAnnotation();
      if (op.kind == TokenType.As) {
        expr = new AsExpression(expr, typeAnnotation, this.#makeLocation(op));
      } else {
        expr = new IsExpression(expr, typeAnnotation, this.#makeLocation(op));
      }
    }
    
    return expr;
  }
  
  #parseTerm(): Expression {
    var expr = this.#parseFactor();
    
    while (this.#check(TokenType.Plus) || this.#check(TokenType.Minus)) {
      let op = this.#advance();
      let right = this.#parseFactor();
      let opStr = op.value;
      expr = new BinaryExpression(opStr, expr, right, this.#makeLocation(op));
    }
    
    return expr;
  }
  
  #parseFactor(): Expression {
    var expr = this.#parseUnary();
    
    while (this.#check(TokenType.Star) || this.#check(TokenType.Slash) || this.#check(TokenType.Percent)) {
      let op = this.#advance();
      let right = this.#parseUnary();
      let opStr = op.value;
      expr = new BinaryExpression(opStr, expr, right, this.#makeLocation(op));
    }
    
    return expr;
  }
  
  #parseUnary(): Expression {
    if (this.#check(TokenType.Bang) || this.#check(TokenType.Minus)) {
      let op = this.#advance();
      let argument = this.#parseUnary();
      let opStr = op.value;
      return new UnaryExpression(opStr, argument, true, this.#makeLocation(op));
    }
    
    if (this.#check(TokenType.Throw)) {
      let next = this.#peek2().kind;
      if (next != TokenType.RParen
        && next != TokenType.RBrace
        && next != TokenType.RBracket
        && next != TokenType.Comma
        && next != TokenType.Semi
        && next != TokenType.EOF
        && next != TokenType.Dot) {
        let startToken = this.#advance();
        let argument = this.#parseExpression();
        return new ThrowExpression(argument, this.#makeLocation(startToken));
      }
    }
    
    return this.#parseCall();
  }
  
  #parseCall(): Expression {
    var expr = this.#parsePrimary();
    
    while (true) {
      if (this.#match(TokenType.LParen)) {
        expr = this.#finishCall(expr, false);
      } else if (this.#match(TokenType.Dot)) {
        let name = this.#parseIdentifier();
        expr = new MemberExpression(expr, name, false, null);
      } else if (this.#match(TokenType.LBracket)) {
        let index = this.#parseExpression();
        this.#consume(TokenType.RBracket, "Expected ']' after index");
        expr = new IndexExpression(expr, index, false, null);
      } else if (this.#match(TokenType.QuestionDot)) {
        let name = this.#parseIdentifier();
        expr = new MemberExpression(expr, name, true, null);
      } else if (this.#match(TokenType.QuestionLBracket)) {
        let index = this.#parseExpression();
        this.#consume(TokenType.RBracket, "Expected ']' after index");
        expr = new IndexExpression(expr, index, true, null);
      } else if (this.#match(TokenType.QuestionLParen)) {
        expr = this.#finishCall(expr, true);
      } else if (this.#check(TokenType.NoSubstitutionTemplate) || this.#check(TokenType.TemplateHead)) {
        let tagStartToken = this.#peek();
        let quasi = this.#parsePrimary();
        expr = new TaggedTemplateExpression(expr, quasi as TemplateLiteral, this.#makeLocation(tagStartToken));
      } else {
        break;
      }
    }
    
    return expr;
  }
  
  #finishCall(callee: Expression, optional: boolean): CallExpression {
    let startToken = this.#previous();
    let args = new Array<Expression>(4);
    
    if (!this.#check(TokenType.RParen)) {
      args.push(this.#parseExpression());
      while (this.#match(TokenType.Comma)) {
        args.push(this.#parseExpression());
      }
    }
    
    this.#consume(TokenType.RParen, "Expected ')' after arguments");
    
    return new CallExpression(callee, args, null, optional, this.#makeLocation(startToken));
  }
  
  #parsePrimary(): Expression {
    let startToken = this.#peek();
    
    // Boolean literals
    if (this.#match(TokenType.True)) {
      return new BooleanLiteral(true, this.#makeLocation(startToken));
    }
    if (this.#match(TokenType.False)) {
      return new BooleanLiteral(false, this.#makeLocation(startToken));
    }
    
    // Null literal
    if (this.#match(TokenType.Null)) {
      return new NullLiteral(this.#makeLocation(startToken));
    }
    
    // Number literal
    if (this.#match(TokenType.Number)) {
      let token = this.#previous();
      return new NumberLiteral(token.value, this.#makeLocation(startToken));
    }
    
    // String literal
    if (this.#match(TokenType.String)) {
      let token = this.#previous();
      return new StringLiteral(token.value, this.#makeLocation(startToken));
    }
    
    // Template literal (no substitution)
    if (this.#match(TokenType.NoSubstitutionTemplate)) {
      let token = this.#previous();
      let quasis = new Array<TemplateElement>(1);
      var raw = token.rawValue;
      if (raw == null) {
        raw = token.value;
      }
      quasis.push(new TemplateElement(token.value, raw as String, true, this.#makeLocation(token)));
      let expressions = new Array<Expression>(0);
      return new TemplateLiteral(quasis, expressions, this.#makeLocation(startToken));
    }
    
    // Template literal (with substitutions)
    if (this.#match(TokenType.TemplateHead)) {
      return this.#parseTemplateLiteral(startToken);
    }
    
    // This expression
    if (this.#match(TokenType.This)) {
      return new ThisExpression(this.#makeLocation(startToken));
    }
    
    // Super expression
    if (this.#match(TokenType.Super)) {
      return new SuperExpression(this.#makeLocation(startToken));
    }
    
    // Match expression: match (expr) { case ...: ... }
    if (this.#check(TokenType.Match) && this.#peek2().kind == TokenType.LParen) {
      this.#advance();
      return this.#parseMatchExpression(startToken);
    }
    
    // If expression: if (cond) expr else expr
    if (this.#match(TokenType.If)) {
      return this.#parseIfExpression(startToken);
    }
    
    // Try expression: try { ... } catch (e) { ... } finally { ... }
    if (this.#match(TokenType.Try)) {
      return this.#parseTryExpression(startToken);
    }
    
    // Generic arrow function: <T>(x: T) => x
    if (this.#check(TokenType.Less) && this.#isGenericArrowFunction()) {
      this.#advance(); // consume '<'
      let typeParams = this.#parseTypeParameterList();
      this.#consume(TokenType.LParen, "Expected '(' after type parameters");
      return this.#parseArrowFunction(startToken, typeParams);
    }
    
    // Parenthesized expression, tuple, or arrow function
    if (this.#match(TokenType.LParen)) {
      // Check for arrow function: (params) =>
      if (this.#isArrowFunction()) {
        return this.#parseArrowFunction(startToken, null);
      }
      
      // Parse first expression
      let first = this.#parseExpression();
      
      // If comma follows, it's a tuple literal
      if (this.#match(TokenType.Comma)) {
        let elements = new Array<Expression>(4);
        elements.push(first);
        elements.push(this.#parseExpression());
        while (this.#match(TokenType.Comma)) {
          elements.push(this.#parseExpression());
        }
        this.#consume(TokenType.RParen, "Expected ')' after tuple");
        return new TupleLiteral(elements, this.#makeLocation(startToken));
      }
      
      // Single expression: grouping
      this.#consume(TokenType.RParen, "Expected ')' after expression");
      return first;
    }
    
    // Array literal
    if (this.#match(TokenType.LBracket)) {
      return this.#parseArrayLiteral(startToken);
    }
    
    // Record or map literal
    if (this.#match(TokenType.LBrace)) {
      return this.#parseRecordOrMapLiteral(startToken);
    }
    
    // Pipeline placeholder ($)
    if (this.#isIdentifier() && this.#peek().value == '$') {
      let token = this.#advance();
      return new PipePlaceholder(this.#makeLocation(token));
    }
    
    // New expression
    if (this.#match(TokenType.New)) {
      let callee = this.#parseIdentifier();
      var typeArguments: Array<TypeAnnotation> | null = null;
      if (this.#match(TokenType.Less)) {
        let args = new Array<TypeAnnotation>(4);
        args.push(this.#parseTypeAnnotation());
        while (this.#match(TokenType.Comma)) {
          args.push(this.#parseTypeAnnotation());
        }
        this.#consume(TokenType.Greater, "Expected '>' after type arguments");
        typeArguments = args;
      }
      this.#consume(TokenType.LParen, "Expected '(' after class name");
      let args = new Array<Expression>(4);
      if (!this.#check(TokenType.RParen)) {
        args.push(this.#parseExpression());
        while (this.#match(TokenType.Comma)) {
          args.push(this.#parseExpression());
        }
      }
      this.#consume(TokenType.RParen, "Expected ')' after arguments");
      return new NewExpression(callee, typeArguments, args, this.#makeLocation(startToken));
    }
    
    // Identifier (including contextual keywords)
    if (this.#isIdentifier()) {
      return this.#parseIdentifier();
    }
    
    throw new Error("Unexpected token in expression");
  }
  
  #parseTemplateLiteral(startToken: Token): TemplateLiteral {
    let headToken = this.#previous();
    let quasis = new Array<TemplateElement>(4);
    let expressions = new Array<Expression>(4);
    
    // Add the head quasi
    var headRaw = headToken.rawValue;
    if (headRaw == null) {
      headRaw = headToken.value;
    }
    quasis.push(new TemplateElement(headToken.value, headRaw as String, false, this.#makeLocation(headToken)));
    
    // Parse expression
    expressions.push(this.#parseExpression());
    
    // Parse middle parts and tail
    while (this.#match(TokenType.TemplateMiddle)) {
      let midToken = this.#previous();
      var midRaw = midToken.rawValue;
      if (midRaw == null) {
        midRaw = midToken.value;
      }
      quasis.push(new TemplateElement(midToken.value, midRaw as String, false, this.#makeLocation(midToken)));
      expressions.push(this.#parseExpression());
    }
    
    // Expect tail
    this.#consume(TokenType.TemplateTail, "Expected template tail after expression");
    let tailToken = this.#previous();
    var tailRaw = tailToken.rawValue;
    if (tailRaw == null) {
      tailRaw = tailToken.value;
    }
    quasis.push(new TemplateElement(tailToken.value, tailRaw as String, true, this.#makeLocation(tailToken)));
    
    return new TemplateLiteral(quasis, expressions, this.#makeLocation(startToken));
  }
  
  #parseNumber(raw: String): f64 {
    // Simple number parsing for integers and floats
    let reader = new StringReader(raw);
    var result: f64 = 0.0 as f64;
    var negative = false;
    
    // Handle negative sign
    if (!reader.isAtEnd && reader.peekByte() == 45) { // '-'
      negative = true;
      reader.advanceByte();
    }
    
    // Handle hex literals
    if (!reader.isAtEnd && reader.peekByte() == 48) { // '0'
      let next = reader.peekByteAt(1);
      if (next == 120 || next == 88) { // 'x' or 'X'
        reader.advanceByte(); // skip '0'
        reader.advanceByte(); // skip 'x'
        while (!reader.isAtEnd) {
          let hb = reader.peekByte();
          if (hb >= 48 && hb <= 57) { // '0'-'9'
            result = result * (16.0 as f64) + ((hb - 48) as f64);
            reader.advanceByte();
          } else if (hb >= 97 && hb <= 102) { // 'a'-'f'
            result = result * (16.0 as f64) + ((hb - 87) as f64);
            reader.advanceByte();
          } else if (hb >= 65 && hb <= 70) { // 'A'-'F'
            result = result * (16.0 as f64) + ((hb - 55) as f64);
            reader.advanceByte();
          } else {
            break;
          }
        }
        if (negative) { result = (0.0 as f64) - result; }
        return result;
      }
    }
    
    // Integer part
    while (!reader.isAtEnd) {
      let ib = reader.peekByte();
      if (ib >= 48 && ib <= 57) { // '0'-'9'
        result = result * (10.0 as f64) + ((ib - 48) as f64);
        reader.advanceByte();
      } else {
        break;
      }
    }
    
    // Fractional part
    if (!reader.isAtEnd && reader.peekByte() == 46) { // '.'
      reader.advanceByte();
      var fracDiv: f64 = 10.0 as f64;
      while (!reader.isAtEnd) {
        let fb = reader.peekByte();
        if (fb >= 48 && fb <= 57) {
          result = result + ((fb - 48) as f64) / fracDiv;
          fracDiv = fracDiv * (10.0 as f64);
          reader.advanceByte();
        } else {
          break;
        }
      }
    }
    
    // Exponent part (e or E)
    if (!reader.isAtEnd) {
      let ec = reader.peekByte();
      if (ec == 101 || ec == 69) { // 'e' or 'E'
        reader.advanceByte();
        var expNeg = false;
        var expVal = 0;
        
        if (!reader.isAtEnd) {
          let sign = reader.peekByte();
          if (sign == 45) { // '-'
            expNeg = true;
            reader.advanceByte();
          } else if (sign == 43) { // '+'
            reader.advanceByte();
          }
        }
        
        while (!reader.isAtEnd) {
          let eb = reader.peekByte();
          if (eb >= 48 && eb <= 57) {
            expVal = expVal * 10 + (eb - 48);
            reader.advanceByte();
          } else {
            break;
          }
        }
        
        // Apply exponent
        var exp: f64 = 1.0 as f64;
        var j = 0;
        while (j < expVal) {
          exp = exp * (10.0 as f64);
          j = j + 1;
        }
        if (expNeg) {
          result = result / exp;
        } else {
          result = result * exp;
        }
      }
    }
    
    if (negative) { result = (0.0 as f64) - result; }
    return result;
  }
  
  #isArrowFunction(): boolean {
    // Look ahead to determine if this is an arrow function
    // Handles: () => or (identifier) => or (identifier: type) => or (...): ReturnType =>
    
    var depth = 1;
    var i = 0;
    
    // Find matching )
    while (depth > 0) {
      let token = this.#tokens[this.#current + i];
      if (token.kind == TokenType.EOF) {
        return false;
      }
      if (token.kind == TokenType.LParen) {
        depth = depth + 1;
      } else if (token.kind == TokenType.RParen) {
        depth = depth - 1;
      }
      i = i + 1;
    }
    
    // Check if next token after ) is => or : (return type annotation)
    let nextToken = this.#tokens[this.#current + i];
    if (nextToken.kind == TokenType.Arrow) {
      return true;
    }
    if (nextToken.kind == TokenType.Colon) {
      // Could be return type annotation: (...): Type =>
      // Skip past the type to find =>
      i = i + 1;
      while (true) {
        let t = this.#tokens[this.#current + i];
        if (t.kind == TokenType.EOF) { return false; }
        if (t.kind == TokenType.Arrow) { return true; }
        if (t.kind == TokenType.LBrace || t.kind == TokenType.Semi) { return false; }
        // Handle nested < > for generic types
        if (t.kind == TokenType.Less) {
          var depth2 = 1;
          i = i + 1;
          while (depth2 > 0) {
            let t2 = this.#tokens[this.#current + i];
            if (t2.kind == TokenType.EOF) { return false; }
            if (t2.kind == TokenType.Less) { depth2 = depth2 + 1; }
            if (t2.kind == TokenType.Greater) { depth2 = depth2 - 1; }
            i = i + 1;
          }
        } else {
          i = i + 1;
        }
      }
    }
    return false;
  }
  
  #isGenericArrowFunction(): boolean {
    // Check if <...> is followed by (
    var depth = 1;
    var i = 1; // skip the <
    
    while (depth > 0) {
      let token = this.#tokens[this.#current + i];
      if (token.kind == TokenType.EOF) { return false; }
      if (token.kind == TokenType.Less) { depth = depth + 1; }
      else if (token.kind == TokenType.Greater) { depth = depth - 1; }
      i = i + 1;
    }
    
    // After > should be (
    let nextToken = this.#tokens[this.#current + i];
    return nextToken.kind == TokenType.LParen;
  }
  
  #parseTypeParameterList(): Array<TypeParameter> {
    let params = new Array<TypeParameter>(4);
    
    let startToken = this.#peek();
    let name = this.#advance().value;
    
    var constraint: TypeAnnotation | null = null;
    if (this.#match(TokenType.Extends)) {
      constraint = this.#parseTypeAnnotation();
    }
    
    var defaultType: TypeAnnotation | null = null;
    if (this.#match(TokenType.Equals)) {
      defaultType = this.#parseTypeAnnotation();
    }
    
    params.push(new TypeParameter(name, constraint, defaultType, this.#makeLocation(startToken)));
    
    while (this.#match(TokenType.Comma)) {
      let tpStart = this.#peek();
      let tpName = this.#advance().value;
      
      var tpConstraint: TypeAnnotation | null = null;
      if (this.#match(TokenType.Extends)) {
        tpConstraint = this.#parseTypeAnnotation();
      }
      
      var tpDefault: TypeAnnotation | null = null;
      if (this.#match(TokenType.Equals)) {
        tpDefault = this.#parseTypeAnnotation();
      }
      
      params.push(new TypeParameter(tpName, tpConstraint, tpDefault, this.#makeLocation(tpStart)));
    }
    
    this.#consume(TokenType.Greater, "Expected '>' after type parameters");
    return params;
  }
  
  #parseArrowFunction(startToken: Token, typeParameters: Array<TypeParameter> | null): FunctionExpression {
    // We're after the '('
    let params = this.#parseParameters();
    
    this.#consume(TokenType.RParen, "Expected ')' after parameters");
    
    // Optional return type
    var returnType: TypeAnnotation | null = null;
    if (this.#match(TokenType.Colon)) {
      returnType = this.#parseTypeAnnotation();
    }
    
    this.#consume(TokenType.Arrow, "Expected '=>' after parameters");
    
    // Body: expression or block
    if (this.#check(TokenType.LBrace)) {
      let blockStart = this.#advance();
      let body = this.#parseBlockStatement(blockStart);
      return new FunctionExpression(typeParameters, params, returnType, body, this.#makeLocation(startToken));
    } else {
      let body = this.#parseExpression();
      return new FunctionExpression(typeParameters, params, returnType, body, this.#makeLocation(startToken));
    }
  }
  
  #parseParameters(): Array<Parameter> {
    let params = new Array<Parameter>(4);
    
    if (!this.#check(TokenType.RParen)) {
      params.push(this.#parseParameter());
      while (this.#match(TokenType.Comma)) {
        params.push(this.#parseParameter());
      }
    }
    
    return params;
  }
  
  #parseParameter(): Parameter {
    let startToken = this.#peek();
    
    // Check for this.field constructor parameter
    var isThisParam = false;
    if (this.#check(TokenType.This) && this.#peek2().kind == TokenType.Dot) {
      this.#advance(); // consume 'this'
      this.#advance(); // consume '.'
      isThisParam = true;
    }
    
    let name = this.#parseIdentifier();
    
    // Check for optional parameter
    var optional = this.#match(TokenType.Question);
    
    // Type annotation (optional for this.field params)
    var typeAnnotation: TypeAnnotation | null = null;
    if (this.#match(TokenType.Colon)) {
      typeAnnotation = this.#parseTypeAnnotation();
    }
    
    // Default value
    var defaultValue: Expression | null = null;
    if (this.#match(TokenType.Equals)) {
      defaultValue = this.#parseExpression();
      optional = true;
    }
    
    return new Parameter(name, typeAnnotation, optional, defaultValue, isThisParam, this.#makeLocation(startToken));
  }
  
  #parseArrayLiteral(startToken: Token): ArrayLiteral {
    let elements = new Array<Expression>(8);
    
    while (!this.#check(TokenType.RBracket) && !this.#isAtEnd()) {
      elements.push(this.#parseExpression());
      if (!this.#check(TokenType.RBracket)) {
        this.#consume(TokenType.Comma, "Expected ',' after array element");
      }
    }
    
    this.#consume(TokenType.RBracket, "Expected ']' after array");
    
    return new ArrayLiteral(elements, this.#makeLocation(startToken));
  }
  
  #parseRecordOrMapLiteral(startToken: Token): Expression {
    // Empty: {} → empty record
    if (this.#check(TokenType.RBrace)) {
      this.#advance();
      return new RecordLiteral(
        new Array<Node>(0),
        this.#makeLocation(startToken)
      );
    }
    
    // Spread element: definitely a record
    if (this.#check(TokenType.DotDotDot)) {
      let properties = new Array<Node>(4);
      return this.#parseRecordProperties(startToken, properties);
    }
    
    // Parse the first expression to determine record vs map
    let firstExpr = this.#parseExpression();
    
    // If followed by =>, it's a map literal
    if (this.#match(TokenType.Arrow)) {
      let firstValue = this.#parseExpression();
      let entries = new Array<MapEntry>(4);
      entries.push(new MapEntry(firstExpr, firstValue, this.#makeLocation(startToken)));
      
      while (this.#match(TokenType.Comma)) {
        if (this.#check(TokenType.RBrace)) {
          break; // trailing comma
        }
        let entryStart = this.#peek();
        let key = this.#parseExpression();
        this.#consume(TokenType.Arrow, "Expected '=>' in map entry");
        let value = this.#parseExpression();
        entries.push(new MapEntry(key, value, this.#makeLocation(entryStart)));
      }
      
      this.#consume(TokenType.RBrace, "Expected '}' after map literal");
      return new MapLiteral(entries, this.#makeLocation(startToken));
    }
    
    // Otherwise it's a record — first expression must be an identifier
    let name = firstExpr as Identifier;
    var value: Expression = name;
    if (this.#match(TokenType.Colon)) {
      value = this.#parseExpression();
    }
    
    let properties = new Array<Node>(4);
    properties.push(new PropertyAssignment(name, value, this.#makeLocation(startToken)));
    return this.#parseRecordProperties(startToken, properties);
  }
  
  #parseRecordProperties(startToken: Token, properties: Array<Node>): RecordLiteral {
    while (this.#match(TokenType.Comma) || this.#check(TokenType.DotDotDot)) {
      if (this.#check(TokenType.RBrace)) {
        break; // trailing comma
      }
      if (this.#match(TokenType.DotDotDot)) {
        let spreadStart = this.#previous();
        let argument = this.#parseExpression();
        properties.push(new SpreadElement(argument, this.#makeLocation(spreadStart)));
      } else {
        let propStart = this.#peek();
        let propName = this.#parseIdentifier();
        var propValue: Expression = propName;
        if (this.#match(TokenType.Colon)) {
          propValue = this.#parseExpression();
        }
        properties.push(new PropertyAssignment(propName, propValue, this.#makeLocation(propStart)));
      }
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after record");
    return new RecordLiteral(properties, this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // Type Annotation Parsing
  // ==========================================================================
  
  #parseTypeAnnotation(): TypeAnnotation {
    let startToken = this.#peek();
    var type = this.#parsePrimaryType();
    
    // Check for union type: T | U
    if (this.#check(TokenType.Pipe)) {
      let types = new Array<TypeAnnotation>(4);
      types.push(type);
      
      while (this.#match(TokenType.Pipe)) {
        types.push(this.#parsePrimaryType());
      }
      
      return new UnionTypeAnnotation(types, this.#makeLocation(startToken));
    }
    
    return type;
  }
  
  #parsePrimaryType(): TypeAnnotation {
    let startToken = this.#peek();
    
    // this type
    if (this.#check(TokenType.This)) {
      this.#advance();
      return new ThisTypeAnnotation(this.#makeLocation(startToken));
    }
    
    // Boolean literal types: true / false
    if (this.#check(TokenType.True)) {
      this.#advance();
      return new LiteralTypeAnnotation(new BooleanLiteral(true, this.#makeLocation(startToken)), this.#makeLocation(startToken));
    }
    if (this.#check(TokenType.False)) {
      this.#advance();
      return new LiteralTypeAnnotation(new BooleanLiteral(false, this.#makeLocation(startToken)), this.#makeLocation(startToken));
    }
    
    // Null type
    if (this.#check(TokenType.Null)) {
      this.#advance();
      return new NamedTypeAnnotation('null', null, this.#makeLocation(startToken));
    }
    
    // Number literal type
    if (this.#check(TokenType.Number)) {
      let token = this.#advance();
      return new LiteralTypeAnnotation(new NumberLiteral(token.value, this.#makeLocation(startToken)), this.#makeLocation(startToken));
    }
    
    // String literal type
    if (this.#check(TokenType.String)) {
      let token = this.#advance();
      return new LiteralTypeAnnotation(new StringLiteral(token.value, this.#makeLocation(startToken)), this.#makeLocation(startToken));
    }
    
    // inline tuple type: inline (T1, T2)
    if (this.#check(TokenType.Inline)) {
      this.#advance();
      this.#consume(TokenType.LParen, "Expected '(' after 'inline'");
      let elementTypes = new Array<TypeAnnotation>(4);
      elementTypes.push(this.#parseTypeAnnotation());
      while (this.#match(TokenType.Comma)) {
        elementTypes.push(this.#parseTypeAnnotation());
      }
      this.#consume(TokenType.RParen, "Expected ')' after inline tuple type elements");
      return new InlineTupleTypeAnnotation(elementTypes, this.#makeLocation(startToken));
    }
    
    // Parenthesized: function type or tuple type
    if (this.#check(TokenType.LParen)) {
      return this.#parseFunctionOrTupleType(startToken);
    }
    
    // Record type: { x: i32, y: i32 }
    if (this.#check(TokenType.LBrace)) {
      return this.#parseRecordType(startToken);
    }
    
    // Named type or primitive
    if (this.#isIdentifier()) {
      let name = this.#advance().value;
      
      // Check for type arguments: Type<T>
      var typeArgs: Array<TypeAnnotation> | null = null;
      if (this.#match(TokenType.Less)) {
        let args = new Array<TypeAnnotation>(4);
        args.push(this.#parseTypeAnnotation());
        while (this.#match(TokenType.Comma)) {
          args.push(this.#parseTypeAnnotation());
        }
        this.#consumeGreater("Expected '>' after type arguments");
        typeArgs = args;
      }
      
      return new NamedTypeAnnotation(name, typeArgs, this.#makeLocation(startToken));
    }
    
    throw new Error("Expected type annotation");
  }
  
  #parseFunctionOrTupleType(startToken: Token): TypeAnnotation {
    this.#advance(); // consume '('
    
    // Empty parens: () => ReturnType (function type with no params)
    if (this.#check(TokenType.RParen)) {
      this.#advance(); // consume ')'
      // Must be followed by '=>' for function type
      this.#consume(TokenType.Arrow, "Expected '=>' after '()'");
      let returnType = this.#parseTypeAnnotation();
      return new FunctionTypeAnnotation(
        new Array<String>(0),
        new Array<TypeAnnotation>(0),
        returnType,
        this.#makeLocation(startToken));
    }
    
    // Try to determine if this is a function type or tuple type
    // Function type has named params: (name: Type, ...) => ReturnType
    // Tuple type has just types: (Type1, Type2)
    // Heuristic: if we see Identifier followed by ':', it's a function type
    if (this.#isIdentifier() && this.#peek2().kind == TokenType.Colon) {
      // Function type
      let paramNames = new Array<String>(4);
      let params = new Array<TypeAnnotation>(4);
      
      // Parse first param
      let paramName = this.#advance().value;
      this.#consume(TokenType.Colon, "Expected ':' after parameter name");
      let paramType = this.#parseTypeAnnotation();
      paramNames.push(paramName);
      params.push(paramType);
      
      // Parse remaining params
      while (this.#match(TokenType.Comma)) {
        let nextName = this.#advance().value;
        this.#consume(TokenType.Colon, "Expected ':' after parameter name");
        let nextType = this.#parseTypeAnnotation();
        paramNames.push(nextName);
        params.push(nextType);
      }
      
      this.#consume(TokenType.RParen, "Expected ')' after function type parameters");
      this.#consume(TokenType.Arrow, "Expected '=>' after function type parameters");
      let returnType = this.#parseTypeAnnotation();
      
      return new FunctionTypeAnnotation(paramNames, params, returnType, this.#makeLocation(startToken));
    }
    
    // Tuple type: (Type1, Type2)
    let elementTypes = new Array<TypeAnnotation>(4);
    elementTypes.push(this.#parseTypeAnnotation());
    while (this.#match(TokenType.Comma)) {
      elementTypes.push(this.#parseTypeAnnotation());
    }
    this.#consume(TokenType.RParen, "Expected ')' after tuple type elements");
    
    return new TupleTypeAnnotation(elementTypes, this.#makeLocation(startToken));
  }
  
  #parseRecordType(startToken: Token): TypeAnnotation {
    this.#advance(); // consume '{'
    let properties = new Array<PropertySignature>(4);
    
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      let propStartToken = this.#peek();
      let propName = this.#parseIdentifier();
      
      // Check for optional: name?:
      var optional = false;
      if (this.#match(TokenType.Question)) {
        optional = true;
      }
      
      this.#consume(TokenType.Colon, "Expected ':' after property name in record type");
      let propType = this.#parseTypeAnnotation();
      
      properties.push(new PropertySignature(propName, propType, optional, this.#makeLocation(propStartToken)));
      
      if (!this.#check(TokenType.RBrace)) {
        this.#consume(TokenType.Comma, "Expected ',' between record type properties");
      }
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after record type");
    return new RecordTypeAnnotation(properties, this.#makeLocation(startToken));
  }
  
  /**
   * Consume a '>' token in type context. Handles '>>' and '>>>' by consuming
   * one '>' and leaving the rest for subsequent parsing via #extraGreaters.
   */
  #consumeGreater(message: String): Token {
    // Check if we have a pending '>' from a previous '>>' split
    if (this.#extraGreaters > 0) {
      this.#extraGreaters = this.#extraGreaters - 1;
      return this.#previous();
    }
    
    if (this.#check(TokenType.Greater)) {
      return this.#advance();
    }
    
    if (this.#check(TokenType.GreaterGreater)) {
      // '>>' in type context: consume as one '>' and mark one pending
      this.#extraGreaters = this.#extraGreaters + 1;
      return this.#advance();
    }
    
    if (this.#check(TokenType.GreaterGreaterGreater)) {
      // '>>>' in type context: consume as one '>' and mark two pending
      this.#extraGreaters = this.#extraGreaters + 2;
      return this.#advance();
    }
    
    throw new Error(message);
  }
  
  // ==========================================================================
  // Helper Methods
  // ==========================================================================
  
  #isIdentifier(): boolean {
    let t = this.#peek().kind;
    return t == TokenType.Identifier
      || t == TokenType.From
      || t == TokenType.Type
      || t == TokenType.As
      || t == TokenType.Is
      || t == TokenType.On
      || t == TokenType.Abstract
      || t == TokenType.Declare
      || t == TokenType.Mixin
      || t == TokenType.Operator
      || t == TokenType.Static
      || t == TokenType.Extension
      || t == TokenType.Distinct
      || t == TokenType.Final
      || t == TokenType.Extends
      || t == TokenType.Implements
      || t == TokenType.With
      || t == TokenType.Case
      || t == TokenType.Match
      || t == TokenType.Throw
      || t == TokenType.Sealed;
  }

  #parseIdentifier(): Identifier {
    let startToken = this.#peek();
    if (this.#isIdentifier()) {
      let token = this.#advance();
      return new Identifier(token.value, this.#makeLocation(startToken));
    }
    throw new Error("Expected identifier");
  }
  
  // ==========================================================================
  // Class Declarations
  // ==========================================================================
  
  #parseClassDeclarationEntry(exported: boolean, startToken: Token): ClassDeclaration {
    var isFinal = false;
    var isAbstract = false;
    var isExtension = false;
    
    if (this.#match(TokenType.Final)) {
      isFinal = true;
      // final extension class
      if (this.#check(TokenType.Extension)) {
        isExtension = true;
        this.#advance();
      }
    } else if (this.#match(TokenType.Abstract)) {
      isAbstract = true;
    } else if (this.#match(TokenType.Extension)) {
      isExtension = true;
    }
    
    this.#consume(TokenType.Class, "Expected 'class'");
    return this.#parseClassDeclaration(exported, isFinal, isAbstract, isExtension, false, startToken);
  }
  
  #parseSealedClassEntry(exported: boolean, startToken: Token): ClassDeclaration {
    this.#consume(TokenType.Sealed, "Expected 'sealed'");
    // sealed abstract class ...
    let isAbstract = this.#match(TokenType.Abstract);
    this.#consume(TokenType.Class, "Expected 'class' after 'sealed'");
    return this.#parseClassDeclaration(exported, false, isAbstract, false, true, startToken);
  }
  
  #parseClassDeclaration(exported: boolean, isFinal: boolean, isAbstract: boolean, isExtension: boolean, isSealed: boolean, startToken: Token): ClassDeclaration {
    let name = this.#parseIdentifier();
    
    // Type parameters: class Foo<T, U>
    var typeParameters: Array<TypeParameter> | null = null;
    if (this.#match(TokenType.Less)) {
      typeParameters = this.#parseTypeParameterList();
    }
    
    // Extension class: on TargetType
    var onType: TypeAnnotation | null = null;
    if (isExtension) {
      this.#consume(TokenType.On, "Expected 'on' after extension class name");
      onType = this.#parseTypeAnnotation();
    }
    
    // Case class parameters: class Point(x: f64, y: f64)
    var caseParams: Array<CaseClassParam> | null = null;
    if (!isExtension && this.#match(TokenType.LParen)) {
      let cps = new Array<CaseClassParam>(4);
      if (!this.#check(TokenType.RParen)) {
        cps.push(this.#parseCaseClassParam());
        while (this.#match(TokenType.Comma)) {
          cps.push(this.#parseCaseClassParam());
        }
      }
      this.#consume(TokenType.RParen, "Expected ')' after case class parameters");
      caseParams = cps;
    }
    
    // Extends clause
    var superClass: TypeAnnotation | null = null;
    if (this.#match(TokenType.Extends)) {
      if (isExtension) {
        throw new Error("Extension classes cannot use 'extends'");
      }
      superClass = this.#parseTypeAnnotation();
    }
    
    // With clause (mixins)
    var mixins: Array<TypeAnnotation> | null = null;
    if (this.#match(TokenType.With)) {
      let ms = new Array<TypeAnnotation>(4);
      ms.push(this.#parseTypeAnnotation());
      while (this.#match(TokenType.Comma)) {
        ms.push(this.#parseTypeAnnotation());
      }
      mixins = ms;
    }
    
    // Implements clause
    var implementsList: Array<TypeAnnotation> | null = null;
    if (this.#match(TokenType.Implements)) {
      let impls = new Array<TypeAnnotation>(4);
      impls.push(this.#parseTypeAnnotation());
      while (this.#match(TokenType.Comma)) {
        impls.push(this.#parseTypeAnnotation());
      }
      implementsList = impls;
    }
    
    // Body is optional for case classes
    let body = new Array<Node>(8);
    let sealedVariants = new Array<SealedVariant>(4);
    if (this.#match(TokenType.LBrace)) {
      while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
        if (isSealed && this.#check(TokenType.Case)) {
          this.#parseSealedVariants(sealedVariants);
        } else {
          body.push(this.#parseClassMember());
        }
      }
      this.#consume(TokenType.RBrace, "Expected '}' after class body");
    } else if (caseParams == null) {
      this.#consume(TokenType.LBrace, "Expected '{' before class body");
    }
    
    return new ClassDeclaration(
      name, typeParameters, caseParams, superClass, mixins, implementsList,
      body, exported, isFinal, isAbstract, isExtension, isSealed,
      if (sealedVariants.length > 0) { sealedVariants } else { null },
      onType, this.#makeLocation(startToken)
    );
  }
  
  #parseCaseClassParam(): CaseClassParam {
    let paramStart = this.#peek();
    var mutability: String | null = null;
    if (this.#match(TokenType.Var)) {
      mutability = 'var';
    } else if (this.#match(TokenType.Let)) {
      mutability = 'let';
    }
    let paramName = this.#parseIdentifier();
    let optional = this.#match(TokenType.Question);
    this.#consume(TokenType.Colon, "Expected ':' after case class parameter name");
    let typeAnnotation = this.#parseTypeAnnotation();
    return new CaseClassParam(paramName, typeAnnotation, mutability, optional, this.#makeLocation(paramStart));
  }
  
  #parseSealedVariants(variants: Array<SealedVariant>): void {
    this.#consume(TokenType.Case, "Expected 'case' for sealed variant");
    // Parse comma-separated variants: case A, B, C(x: i32)
    variants.push(this.#parseSealedVariant());
    while (this.#match(TokenType.Comma)) {
      variants.push(this.#parseSealedVariant());
    }
  }
  
  #parseSealedVariant(): SealedVariant {
    let variantStart = this.#peek();
    let variantName = this.#parseIdentifier();
    var params: Array<CaseClassParam> | null = null;
    if (this.#match(TokenType.LParen)) {
      let ps = new Array<CaseClassParam>(4);
      if (!this.#check(TokenType.RParen)) {
        ps.push(this.#parseCaseClassParam());
        while (this.#match(TokenType.Comma)) {
          ps.push(this.#parseCaseClassParam());
        }
      }
      this.#consume(TokenType.RParen, "Expected ')' after sealed variant parameters");
      params = ps;
    }
    return new SealedVariant(variantName, params, this.#makeLocation(variantStart));
  }
  
  #parseClassMember(): Node {
    let startToken = this.#peek();
    
    // Parse decorators
    let decorators = new Array<Decorator>(2);
    while (this.#check(TokenType.At)) {
      decorators.push(this.#parseDecorator());
    }
    
    // Check for member-level modifiers
    var isFinal = false;
    var isAbstract = false;
    
    if (this.#check(TokenType.Final) && this.#peek2().kind != TokenType.Colon) {
      isFinal = true;
      this.#advance();
    } else if (this.#check(TokenType.Abstract) && this.#peek2().kind != TokenType.Colon) {
      isAbstract = true;
      this.#advance();
    }
    
    // Check for field mutability prefix
    var mutability: String | null = null;
    if (this.#check(TokenType.Let) && this.#peek2().kind != TokenType.Colon && this.#peek2().kind != TokenType.LParen) {
      this.#advance();
      mutability = 'let';
    } else if (this.#check(TokenType.Var) && this.#peek2().kind != TokenType.Colon && this.#peek2().kind != TokenType.LParen) {
      this.#advance();
      mutability = 'var';
    }
    
    // Constructor: new(...)
    if (this.#check(TokenType.New)) {
      this.#advance();
      return this.#parseMethodBody(new Identifier('<constructor>', this.#makeLocation(startToken)), null, isFinal, isAbstract, false, decorators, startToken);
    }
    
    // Operator method: operator ==(other), operator [](index), operator +(other)
    if (this.#check(TokenType.Operator)) {
      this.#advance();
      var opName = "";
      if (this.#match(TokenType.LBracket)) {
        // operator [] or operator []=
        this.#consume(TokenType.RBracket, "Expected ']' after operator '['");
        if (this.#match(TokenType.Equals)) {
          opName = "[]=";
        } else {
          opName = "[]";
        }
      } else {
        // operator ==, operator +, etc.
        let opToken = this.#advance();
        opName = opToken.value;
        // Check for == (two consecutive = tokens)
        if (opName == "=" && this.#check(TokenType.Equals)) {
          this.#advance();
          opName = "==";
        }
      }
      let operatorName = new Identifier(opName, this.#makeLocation(startToken));
      return this.#parseMethodBody(operatorName, null, isFinal, isAbstract, false, decorators, startToken);
    }
    
    // Private field/method: #name
    if (this.#check(TokenType.Hash)) {
      this.#advance();
      let privateName = this.#parseIdentifier();
      let hashName = new Identifier("#" + privateName.name, this.#makeLocation(startToken));
      
      // Private method: #name(params) { ... }
      if (this.#check(TokenType.LParen)) {
        return this.#parseMethodBody(hashName, null, isFinal, isAbstract, false, decorators, startToken);
      }
      
      // Private field: #name: Type; or #name?: Type;
      let isOptional = this.#match(TokenType.Question);
      this.#consume(TokenType.Colon, "Expected ':' after private field name");
      let typeAnnotation = this.#parseTypeAnnotation();
      var value: Expression | null = null;
      if (this.#match(TokenType.Equals)) {
        value = this.#parseExpression();
      }
      this.#consume(TokenType.Semi, "Expected ';' after field declaration");
      return new FieldDefinition(hashName, typeAnnotation, value, isFinal, false, isOptional, false, false, mutability, decorators, this.#makeLocation(startToken));
    }
    
    // Static symbol declaration: static symbol name;
    if (this.#check(TokenType.Static) && this.#peek2().kind == TokenType.Symbol) {
      this.#advance(); // consume 'static'
      this.#advance(); // consume 'symbol'
      let symName = this.#parseIdentifier();
      this.#consume(TokenType.Semi, "Expected ';' after symbol declaration");
      return new FieldDefinition(symName, new NamedTypeAnnotation('symbol', null, symName.loc), null, true, false, false, true, false, null, decorators, this.#makeLocation(startToken));
    }
    
    // Symbol-keyed member: :symbolName
    if (this.#check(TokenType.Colon) && this.#peek2().kind == TokenType.Identifier) {
      this.#advance(); // consume ':'
      let symStart = this.#previous();
      var symbolExpr: Expression = this.#parseIdentifier();
      while (this.#match(TokenType.Dot)) {
        let prop = this.#parseIdentifier();
        symbolExpr = new MemberExpression(symbolExpr, prop, false, this.#makeLocation(symStart));
      }
      let symPropName = new SymbolPropertyName(symbolExpr, this.#makeLocation(symStart));
      
      // Symbol-keyed method: :name(params) { ... }
      if (this.#check(TokenType.LParen)) {
        return this.#parseMethodBody(symPropName, null, isFinal, isAbstract, false, decorators, startToken);
      }
      
      // Symbol-keyed field: :name: Type;
      this.#consume(TokenType.Colon, "Expected ':' after symbol field name");
      let symTypeAnnotation = this.#parseTypeAnnotation();
      
      // Check for accessor block
      if (this.#check(TokenType.LBrace)) {
        return this.#parseAccessorBlock(symPropName, symTypeAnnotation, isFinal, decorators, startToken);
      }
      
      var symFieldValue: Expression | null = null;
      if (this.#match(TokenType.Equals)) {
        symFieldValue = this.#parseExpression();
      }
      this.#consume(TokenType.Semi, "Expected ';' after field declaration");
      return new FieldDefinition(symPropName, symTypeAnnotation, symFieldValue, isFinal, false, false, false, false, mutability, decorators, this.#makeLocation(startToken));
    }
    
    let name = this.#parseIdentifier();
    
    // Generic method: name<T>(params) { ... }
    if (this.#check(TokenType.Less) && this.#isGenericMethodStart()) {
      this.#advance(); // consume '<'
      let typeParams = this.#parseTypeParameterList();
      return this.#parseMethodBody(name, typeParams, isFinal, isAbstract, false, decorators, startToken);
    }
    
    // Method: name(params) { ... }
    if (this.#check(TokenType.LParen)) {
      return this.#parseMethodBody(name, null, isFinal, isAbstract, false, decorators, startToken);
    }
    
    // Abstract field: abstract name: Type; or abstract name?: Type;
    if (isAbstract) {
      let isOptional = this.#match(TokenType.Question);
      this.#consume(TokenType.Colon, "Expected ':' after abstract field name.");
      let typeAnnotation = this.#parseTypeAnnotation();
      this.#consume(TokenType.Semi, "Expected ';' after abstract field declaration.");
      return new FieldDefinition(name, typeAnnotation, null, false, true, isOptional, false, false, mutability, decorators, this.#makeLocation(startToken));
    }
    
    // Field: name: Type; or name?: Type; -OR- Accessor: name: Type { get { } set(v) { } }
    let isOptional = this.#match(TokenType.Question);
    this.#consume(TokenType.Colon, "Expected ':' after field name");
    let typeAnnotation = this.#parseTypeAnnotation();
    
    // Check for accessor block
    if (this.#check(TokenType.LBrace)) {
      return this.#parseAccessorBlock(name, typeAnnotation, isFinal, decorators, startToken);
    }
    
    var fieldValue: Expression | null = null;
    if (this.#match(TokenType.Equals)) {
      fieldValue = this.#parseExpression();
    }
    
    this.#consume(TokenType.Semi, "Expected ';' after field declaration");
    return new FieldDefinition(name, typeAnnotation, fieldValue, isFinal, false, isOptional, false, false, mutability, decorators, this.#makeLocation(startToken));
  }
  
  // Check if < starts a generic method (vs a comparison expression)
  #isGenericMethodStart(): boolean {
    // Save position and try to parse type parameter list
    let saved = this.#current;
    var depth = 1;
    this.#advance(); // skip past '<' (already consumed by caller check)
    while (depth > 0 && !this.#isAtEnd()) {
      if (this.#check(TokenType.Less)) {
        depth = depth + 1;
      } else if (this.#check(TokenType.Greater)) {
        depth = depth - 1;
      }
      if (depth > 0) {
        this.#advance();
      }
    }
    // After matching '>', check if next token is '('
    var result = false;
    if (depth == 0) {
      this.#advance(); // skip '>'
      result = this.#check(TokenType.LParen);
    }
    this.#current = saved;
    return result;
  }
  
  #parseAccessorBlock(name: Node, typeAnnotation: TypeAnnotation, isFinal: boolean, decorators: Array<Decorator>, startToken: Token): AccessorDeclaration {
    this.#consume(TokenType.LBrace, "Expected '{' for accessor block");
    
    var getter: BlockStatement | null = null;
    var setter: Node | null = null;
    
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      let keyword = this.#peek();
      if (keyword.value == "get") {
        if (getter != null) {
          throw new Error("Duplicate getter");
        }
        this.#advance();
        let blockStart = this.#peek();
        this.#consume(TokenType.LBrace, "Expected '{' after get");
        getter = this.#parseBlockStatement(blockStart);
      } else if (keyword.value == "set") {
        if (setter != null) {
          throw new Error("Duplicate setter");
        }
        this.#advance();
        this.#consume(TokenType.LParen, "Expected '(' after set");
        let param = this.#parseIdentifier();
        this.#consume(TokenType.RParen, "Expected ')' after setter parameter");
        let blockStart = this.#peek();
        this.#consume(TokenType.LBrace, "Expected '{' after setter parameter");
        let body = this.#parseBlockStatement(blockStart);
        setter = new SetterInfo(param, body, this.#makeLocation(keyword));
      } else {
        throw new Error("Expected 'get' or 'set' in accessor block");
      }
    }
    
    if (getter == null && setter == null) {
      throw new Error("Accessor must have at least a getter or a setter");
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after accessor block");
    return new AccessorDeclaration(name, typeAnnotation, getter, setter, isFinal, false, decorators, this.#makeLocation(startToken));
  }
  
  #parseMethodBody(name: Node, typeParameters: Array<TypeParameter> | null, isFinal: boolean, isAbstract: boolean, isStatic: boolean, decorators: Array<Decorator>, startToken: Token): MethodDefinition {
    this.#consume(TokenType.LParen, "Expected '(' after method name");
    let params = this.#parseParameters();
    this.#consume(TokenType.RParen, "Expected ')' after parameters");
    
    // Synthesize FieldInitializer entries for this.field params
    let thisInits = new Array<Node>(4);
    var i = 0;
    while (i < params.length) {
      let p = params[i];
      if (p.isThisParam) {
        thisInits.push(new FieldInitializer(
          new Identifier(p.name.name, p.name.loc),
          new Identifier(p.name.name, p.name.loc),
          p.loc
        ));
      }
      i = i + 1;
    }
    
    var returnType: TypeAnnotation | null = null;
    if (this.#match(TokenType.Colon)) {
      // Check for initializer list (: field = value, ...) vs return type
      // If this is a constructor, the colon starts an initializer list
      let isConstructor = match (name) {
        case Identifier { name }: name == "<constructor>"
        case _: false
      };
      if (isConstructor) {
        // Parse initializer list
        let initList = new Array<Node>(4);
        var superInit: Node | null = null;
        
        // First entry
        if (this.#check(TokenType.Super)) {
          superInit = this.#parseSuperInitializer();
        } else {
          initList.push(this.#parseFieldInitializer());
        }
        
        while (this.#match(TokenType.Comma)) {
          if (this.#check(TokenType.Super)) {
            superInit = this.#parseSuperInitializer();
          } else {
            initList.push(this.#parseFieldInitializer());
          }
        }
        
        // Prepend this.field initializers before explicit ones
        let combined = new Array<Node>(thisInits.length + initList.length);
        var j = 0;
        while (j < thisInits.length) {
          combined.push(thisInits[j]);
          j = j + 1;
        }
        j = 0;
        while (j < initList.length) {
          combined.push(initList[j]);
          j = j + 1;
        }
        
        // Body: either { } or ;
        var body: Node | null = null;
        if (this.#check(TokenType.LBrace)) {
          let blockStart = this.#advance();
          body = this.#parseBlockStatement(blockStart);
        } else if (this.#match(TokenType.Semi)) {
          body = new BlockStatement(new Array<Statement>(0), this.#makeLocation(startToken));
        }
        
        var initListResult: Array<Node> | null = null;
        if (combined.length > 0) {
          initListResult = combined;
        }
        
        return new MethodDefinition(name, typeParameters, params, null, body, initListResult, superInit, isFinal, isAbstract, isStatic, false, decorators, this.#makeLocation(startToken));
      } else {
        returnType = this.#parseTypeAnnotation();
      }
    }
    
    // Method body
    var body: Node | null = null;
    if (this.#check(TokenType.LBrace)) {
      let blockStart = this.#advance();
      body = this.#parseBlockStatement(blockStart);
    } else if (this.#match(TokenType.Semi)) {
      // Abstract method or semicolon body — treated as empty block
      if (!isAbstract) {
        body = new BlockStatement(new Array<Statement>(0), this.#makeLocation(startToken));
      }
    }
    
    // If we have this.field params but no explicit initializer list
    var thisInitResult: Array<Node> | null = null;
    if (thisInits.length > 0) {
      thisInitResult = thisInits;
    }
    
    return new MethodDefinition(name, typeParameters, params, returnType, body, thisInitResult, null, isFinal, isAbstract, isStatic, false, decorators, this.#makeLocation(startToken));
  }
  
  #parseFieldInitializer(): FieldInitializer {
    let initStart = this.#peek();
    // Handle #private field names
    var fieldName: Identifier = if (this.#check(TokenType.Hash)) {
      this.#advance();
      let privName = this.#parseIdentifier();
      new Identifier("#" + privName.name, this.#makeLocation(initStart))
    } else {
      this.#parseIdentifier()
    };
    this.#consume(TokenType.Equals, "Expected '=' in initializer");
    let value = this.#parseExpression();
    return new FieldInitializer(fieldName, value, this.#makeLocation(initStart));
  }
  
  #parseSuperInitializer(): SuperInitializer {
    let superStart = this.#peek();
    this.#consume(TokenType.Super, "Expected 'super'");
    this.#consume(TokenType.LParen, "Expected '(' after super");
    let args = new Array<Expression>(4);
    if (!this.#check(TokenType.RParen)) {
      args.push(this.#parseExpression());
      while (this.#match(TokenType.Comma)) {
        args.push(this.#parseExpression());
      }
    }
    this.#consume(TokenType.RParen, "Expected ')' after super arguments");
    return new SuperInitializer(args, this.#makeLocation(superStart));
  }
  
  // ==========================================================================
  // Decorators
  // ==========================================================================
  
  #parseDecorator(): Decorator {
    let startToken = this.#peek();
    this.#consume(TokenType.At, "Expected '@'");
    let name = this.#parseIdentifier().name;
    let args = new Array<StringLiteral>(2);
    if (this.#match(TokenType.LParen)) {
      if (!this.#check(TokenType.RParen)) {
        let arg = this.#parseExpression();
        match (arg) {
          case StringLiteral {}: {
            args.push(arg as StringLiteral);
          }
          case _: {
            throw new Error('Decorator arguments must be string literals');
          }
        }
        while (this.#match(TokenType.Comma)) {
          let nextArg = this.#parseExpression();
          match (nextArg) {
            case StringLiteral {}: {
              args.push(nextArg as StringLiteral);
            }
            case _: {
              throw new Error('Decorator arguments must be string literals');
            }
          }
        }
      }
      this.#consume(TokenType.RParen, "Expected ')' after decorator arguments");
    }
    return new Decorator(name, args, this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // Declare Function
  // ==========================================================================
  
  #parseDeclareFunction(decorators: Array<Decorator>, exported: boolean, startToken: Token): DeclareFunction {
    this.#consume(TokenType.Function, "Expected 'function' after 'declare'");
    let name = this.#parseIdentifier();
    
    // Optional type parameters
    var typeParameters: Array<TypeParameter> | null = null;
    if (this.#check(TokenType.Less)) {
      this.#advance();
      typeParameters = this.#parseTypeParameterList();
    }
    
    this.#consume(TokenType.LParen, "Expected '(' after function name");
    let params = this.#parseParameters();
    this.#consume(TokenType.RParen, "Expected ')' after parameters");
    
    this.#consume(TokenType.Colon, "Expected ':' for return type");
    let returnType = this.#parseTypeAnnotation();
    
    this.#consume(TokenType.Semi, "Expected ';' after function declaration");
    
    // Extract @external module/name from decorators
    var externalModule: String | null = null;
    var externalName: String | null = null;
    var i = 0;
    while (i < decorators.length) {
      let d = decorators[i];
      if (d.name == "external") {
        if (d.args.length != 2) {
          throw new Error("@external expects 2 arguments");
        }
        externalModule = d.args[0].value;
        externalName = d.args[1].value;
      }
      i = i + 1;
    }
    
    return new DeclareFunction(name, typeParameters, params, returnType, externalModule, externalName, exported, decorators, this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // Interface Declarations
  // ==========================================================================
  
  #parseInterfaceDeclaration(exported: boolean, startToken: Token): InterfaceDeclaration {
    let name = this.#parseIdentifier();
    
    // Type parameters: interface Foo<T>
    var typeParameters: Array<TypeParameter> | null = null;
    if (this.#match(TokenType.Less)) {
      typeParameters = this.#parseTypeParameterList();
    }
    
    // Extends clause: interface Foo extends Bar, Baz
    var extendsList: Array<TypeAnnotation> | null = null;
    if (this.#match(TokenType.Extends)) {
      let exts = new Array<TypeAnnotation>(4);
      exts.push(this.#parseTypeAnnotation());
      while (this.#match(TokenType.Comma)) {
        exts.push(this.#parseTypeAnnotation());
      }
      extendsList = exts;
    }
    
    this.#consume(TokenType.LBrace, "Expected '{' before interface body");
    
    let body = new Array<Node>(8);
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      body.push(this.#parseInterfaceMember());
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after interface body");
    
    return new InterfaceDeclaration(name, typeParameters, extendsList, body, exported, this.#makeLocation(startToken));
  }
  
  #parseInterfaceMember(): Node {
    let startToken = this.#peek();
    
    // Static symbol declaration: static symbol name;
    if (this.#check(TokenType.Static) && this.#peek2().kind == TokenType.Symbol) {
      this.#advance(); // consume 'static'
      this.#advance(); // consume 'symbol'
      let symName = this.#parseIdentifier();
      this.#consume(TokenType.Semi, "Expected ';' after symbol declaration");
      return new SymbolDeclaration(symName, false, this.#makeLocation(startToken));
    }
    
    // Check for `var` modifier on interface fields
    var mutableField = false;
    if (this.#check(TokenType.Var)) {
      mutableField = true;
      this.#advance();
    }
    
    let name = this.#parseIdentifier();
    
    // Type parameters for methods
    var typeParameters: Array<TypeParameter> | null = null;
    if (this.#match(TokenType.Less)) {
      typeParameters = this.#parseTypeParameterList();
    }
    
    // Method: name(params): ReturnType;
    if (this.#match(TokenType.LParen)) {
      if (mutableField) {
        throw new Error("'var' modifier is not allowed on methods.");
      }
      let params = this.#parseParameters();
      this.#consume(TokenType.RParen, "Expected ')' after parameters");
      
      var returnType: TypeAnnotation | null = null;
      if (this.#match(TokenType.Colon)) {
        returnType = this.#parseTypeAnnotation();
      }
      
      this.#consume(TokenType.Semi, "Expected ';' after method signature");
      
      return new MethodSignature(name, typeParameters, params, returnType, this.#makeLocation(startToken));
    }
    
    if (typeParameters != null) {
      throw new Error("Fields cannot have type parameters.");
    }
    
    // Field: name: Type; or name?: Type;  or  Accessor: name: Type { get; set; }
    let isOptional = this.#match(TokenType.Question);
    this.#consume(TokenType.Colon, "Expected ':' after field name");
    let typeAnnotation = this.#parseTypeAnnotation();
    
    // Check for accessor signature: { get; set; }
    if (this.#match(TokenType.LBrace)) {
      if (mutableField) {
        throw new Error("'var' modifier is not allowed on accessor signatures.");
      }
      var hasGetter = false;
      var hasSetter = false;
      
      while (!this.#match(TokenType.RBrace)) {
        let id = this.#parseIdentifier();
        if (id.name == "get") {
          hasGetter = true;
        } else if (id.name == "set") {
          hasSetter = true;
        } else {
          throw new Error("Expected 'get' or 'set' in accessor signature, got '" + id.name + "'");
        }
        this.#consume(TokenType.Semi, "Expected ';' after accessor specifier");
      }
      
      return new AccessorSignature(name, typeAnnotation, hasGetter, hasSetter, this.#makeLocation(startToken));
    }
    
    this.#consume(TokenType.Semi, "Expected ';' after field declaration");
    
    return new FieldDefinition(name, typeAnnotation, null, false, false, isOptional, false, false, if (mutableField) { "var" } else { null }, new Array<Decorator>(0), this.#makeLocation(startToken));
  }
  
  // ==========================================================================
  // Mixin Declarations
  // ==========================================================================
  
  #parseMixinDeclaration(exported: boolean, startToken: Token): MixinDeclaration {
    let name = this.#parseIdentifier();
    
    // Type parameters: mixin Foo<T>
    var typeParameters: Array<TypeParameter> | null = null;
    if (this.#match(TokenType.Less)) {
      typeParameters = this.#parseTypeParameterList();
    }
    
    // On clause: mixin Foo on Bar
    var on: Identifier | null = null;
    if (this.#match(TokenType.On)) {
      on = this.#parseIdentifier();
    }
    
    // With clause: mixin Foo with A, B
    var mixins: Array<TypeAnnotation> | null = null;
    if (this.#match(TokenType.With)) {
      let ms = new Array<TypeAnnotation>(4);
      ms.push(this.#parseTypeAnnotation());
      while (this.#match(TokenType.Comma)) {
        ms.push(this.#parseTypeAnnotation());
      }
      mixins = ms;
    }
    
    this.#consume(TokenType.LBrace, "Expected '{' before mixin body");
    
    let body = new Array<Node>(8);
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      body.push(this.#parseClassMember());
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after mixin body");
    
    return new MixinDeclaration(name, typeParameters, on, mixins, body, exported, this.#makeLocation(startToken));
  }
  
  #parseEnumDeclaration(exported: boolean, startToken: Token): EnumDeclaration {
    let name = this.#parseIdentifier();
    this.#consume(TokenType.LBrace, "Expected '{' after enum name");
    
    let members = new Array<EnumMember>(8);
    while (!this.#check(TokenType.RBrace) && !this.#isAtEnd()) {
      let memberStartToken = this.#peek();
      let memberName = this.#parseIdentifier();
      var initializer: Expression | null = null;
      if (this.#match(TokenType.Equals)) {
        initializer = this.#parseExpression();
      }
      members.push(new EnumMember(memberName, initializer, this.#makeLocation(memberStartToken)));
      if (!this.#check(TokenType.RBrace)) {
        this.#consume(TokenType.Comma, "Expected ',' after enum member");
      }
    }
    
    this.#consume(TokenType.RBrace, "Expected '}' after enum body");
    
    return new EnumDeclaration(name, members, exported, this.#makeLocation(startToken));
  }
  
  #parseSymbolDeclaration(exported: boolean, startToken: Token): SymbolDeclaration {
    let name = this.#parseIdentifier();
    this.#consume(TokenType.Semi, "Expected ';' after symbol declaration");
    return new SymbolDeclaration(name, exported, this.#makeLocation(startToken));
  }
  
  #parseTypeAliasDeclaration(exported: boolean, isDistinct: boolean, startToken: Token): TypeAliasDeclaration {
    this.#consume(TokenType.Type, "Expected 'type' keyword");
    let name = this.#parseIdentifier();
    
    // Optional type parameters
    var typeParameters: Array<TypeParameter> | null = null;
    if (this.#match(TokenType.Less)) {
      typeParameters = this.#parseTypeParameterList();
    }
    
    this.#consume(TokenType.Equals, "Expected '=' after type alias name");
    let typeAnnotation = this.#parseTypeAnnotation();
    this.#consume(TokenType.Semi, "Expected ';' after type alias declaration");
    
    return new TypeAliasDeclaration(name, typeParameters, typeAnnotation, exported, isDistinct, this.#makeLocation(startToken));
  }
}

// ============================================================================
// Convenience function
// ============================================================================

export let parse = (source: String, path: String): Module => {
  let parser = new Parser(source, path);
  return parser.parse();
};
