// Hello World test for the self-hosted Zena compiler
// Tests that the basic test infrastructure is working

import { suite, test, TestContext } from 'zena:test';
import { equal, isTrue } from 'zena:assert';

let tests = suite('Hello World', (): void => {
  test('1 + 1 equals 2', (ctx: TestContext): void => {
    equal(1 + 1, 2);
  });

  test('string comparison works', (ctx: TestContext): void => {
    equal('hello', 'hello');
  });

  test('boolean assertions work', (ctx: TestContext): void => {
    isTrue(true);
    isTrue(1 < 2);
  });

  suite('nested suite', (): void => {
    test('nested test works', (ctx: TestContext): void => {
      equal(42, 42);
    });
  });
});

// Entry point - returns number of failed tests (0 = success)
export let main = (): i32 => {
  let result = tests.run();
  return result.failed;
};
