/**
 * Checker API tests — validates the programmatic API surface of the checker.
 *
 * These tests verify that:
 * 1. checkModule() can be called and returns a CheckResult
 * 2. The SemanticModel contains expected type information
 * 3. Diagnostics are collected for invalid code
 * 4. The checker integrates with scope analysis correctly
 *
 * Behavioral correctness (does the checker accept/reject the right code?) is
 * tested via portable tests in tests/language/semantics/. This file focuses on
 * the API contract.
 */

import { suite, test, TestContext } from 'zena:test';
import { equal, isTrue, isFalse } from 'zena:assert';
import { Array } from 'zena:array';
import { parse } from '../lib/parser.zena';
import { ScopeBuilder, ScopeResult, SymbolInfo } from '../lib/scope.zena';
import { checkModule, CheckResult } from '../lib/checker.zena';
import { SemanticModel } from '../lib/semantic-model.zena';
import { Diagnostic, DiagnosticSeverity, SourceSpan } from '../lib/diagnostics.zena';
import {
  Type, I32Type, F64Type, BooleanType, VoidType, NullType, NeverType,
  BoolLiteralType, ClassType, FunctionType, UnionType, TupleType,
  typeToString
} from '../lib/types.zena';
import {
  Module, Statement, VariableDeclaration, ExpressionStatement,
  IdentifierPattern, Identifier, Node
} from '../lib/ast.zena';

// ============================================================================
// Helpers
// ============================================================================

/**
 * Parse, scope-analyse, and type-check a source string.
 */
let check = (source: String): CheckResult => {
  let ast = parse(source, "<test>");
  let scopeBuilder = new ScopeBuilder("<test>");
  let scopeResult = scopeBuilder.build(ast);
  return checkModule(ast, scopeResult, null);
};

/**
 * Assert that checking produces no errors.
 */
let checkOk = (source: String): CheckResult => {
  let result = check(source);
  let errors = errorDiagnostics(result.diagnostics);
  if (errors.length > 0) {
    var msg = "Expected no errors, got:\n";
    var i = 0;
    while (i < errors.length) {
      msg = msg + "  - " + errors[i].message + "\n";
      i += 1;
    }
    throw new Error(msg);
  }
  return result;
};

/**
 * Assert that checking produces at least one error matching the pattern.
 */
let checkError = (source: String, pattern: String): void => {
  let result = check(source);
  let errors = errorDiagnostics(result.diagnostics);
  var found = false;
  var i = 0;
  while (i < errors.length) {
    if (contains(errors[i].message, pattern)) {
      found = true;
      break;
    }
    i += 1;
  }
  if (!found) {
    var msg = "Expected error containing '" + pattern + "', got:\n";
    if (errors.length == 0) {
      msg = msg + "  (none)\n";
    } else {
      var j = 0;
      while (j < errors.length) {
        msg = msg + "  - " + errors[j].message + "\n";
        j += 1;
      }
    }
    throw new Error(msg);
  }
};

/**
 * Filter diagnostics to only error severity.
 */
let errorDiagnostics = (diags: Array<Diagnostic>): Array<Diagnostic> => {
  let errors = new Array<Diagnostic>(4);
  var i = 0;
  while (i < diags.length) {
    match (diags[i].severity) {
      case DiagnosticSeverity.Error: errors.push(diags[i])
      case _: {}
    }
    i += 1;
  }
  return errors;
};

/**
 * Substring check (no builtins yet).
 */
let contains = (s: String, sub: String): boolean => {
  if (sub.length > s.length) { return false; }
  var i = 0;
  while (i <= s.length - sub.length) {
    if (s.sliceBytes(i, i + sub.length) == sub) {
      return true;
    }
    i += 1;
  }
  return false;
};

// ============================================================================
// Tests
// ============================================================================

export let tests = suite('Checker API', (): void => {

  // ==========================================================================
  // Basic API surface
  // ==========================================================================

  suite('checkModule returns a CheckResult', (): void => {

    test('valid source produces CheckResult with no errors', (ctx: TestContext): void => {
      let result = checkOk("let x = 42;");
      // CheckResult has a model and diagnostics
      isTrue(result.diagnostics.length == 0);
    });

    test('invalid source produces diagnostics', (ctx: TestContext): void => {
      let result = check("let x: i32 = true;");
      let errors = errorDiagnostics(result.diagnostics);
      isTrue(errors.length > 0);
    });

    test('checkModule works without scope result', (ctx: TestContext): void => {
      let ast = parse("let x = 1;", "<test>");
      // Pass null for scopeResult — checker should still work
      let result = checkModule(ast, null, null);
      // It might have warnings about unresolved names, but shouldn't crash
      isTrue(result.model != null);
    });

    test('multiple statements checked', (ctx: TestContext): void => {
      let result = checkOk(
        "let x = 1;\nlet y = 2;\nlet z = x;"
      );
      isTrue(result.diagnostics.length == 0);
    });
  });

  // ==========================================================================
  // SemanticModel: node types
  // ==========================================================================

  suite('SemanticModel records node types', (): void => {

    test('integer literal has i32 type', (ctx: TestContext): void => {
      let source = "let x = 42;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      // Navigate AST: body[0] is VariableDeclaration, its init is NumberLiteral
      let decl = ast.body[0] as VariableDeclaration;
      let initType = result.model.getNodeType(decl.init);
      isTrue(initType != null);
      equal(typeToString(initType as Type), "i32");
    });

    test('string literal has String type', (ctx: TestContext): void => {
      let source = "let x = 'hello';";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let decl = ast.body[0] as VariableDeclaration;
      let initType = result.model.getNodeType(decl.init);
      isTrue(initType != null);
      equal(typeToString(initType as Type), "String");
    });

    test('boolean literal has literal type', (ctx: TestContext): void => {
      let source = "let x = true;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let decl = ast.body[0] as VariableDeclaration;
      let initType = result.model.getNodeType(decl.init);
      isTrue(initType != null);
      equal(typeToString(initType as Type), "true");
    });

    test('binary expression has inferred type', (ctx: TestContext): void => {
      let source = "let x = 1 + 2;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let decl = ast.body[0] as VariableDeclaration;
      let initType = result.model.getNodeType(decl.init);
      isTrue(initType != null);
      equal(typeToString(initType as Type), "i32");
    });

    test('function expression has function type', (ctx: TestContext): void => {
      let source = "let f = (x: i32): i32 => x;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let decl = ast.body[0] as VariableDeclaration;
      let initType = result.model.getNodeType(decl.init);
      isTrue(initType != null);
      let typeStr = typeToString(initType as Type);
      // Should be something like "(x: i32) => i32"
      isTrue(contains(typeStr, "i32"));
    });
  });

  // ==========================================================================
  // SemanticModel: binding types
  // ==========================================================================

  suite('SemanticModel records binding types', (): void => {

    test('let binding has correct type via scope lookup', (ctx: TestContext): void => {
      let source = "let x = 42;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      // Look up x in scope, then get its binding type
      let info = scopeResult.rootScope.resolveValue("x");
      isTrue(info != null);
      let bindingType = result.model.getBindingType(info as SymbolInfo);
      isTrue(bindingType != null);
      equal(typeToString(bindingType as Type), "i32");
    });

    test('annotated binding has annotation type', (ctx: TestContext): void => {
      let source = "let x: i32 = 42;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let info = scopeResult.rootScope.resolveValue("x");
      isTrue(info != null);
      let bindingType = result.model.getBindingType(info as SymbolInfo);
      isTrue(bindingType != null);
      equal(typeToString(bindingType as Type), "i32");
    });

    test('var binding widens literal type', (ctx: TestContext): void => {
      let source = "var x = true;";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let info = scopeResult.rootScope.resolveValue("x");
      isTrue(info != null);
      let bindingType = result.model.getBindingType(info as SymbolInfo);
      isTrue(bindingType != null);
      // var should widen true → boolean
      equal(typeToString(bindingType as Type), "boolean");
    });
  });

  // ==========================================================================
  // Diagnostics
  // ==========================================================================

  suite('diagnostics', (): void => {

    test('type mismatch produces error', (ctx: TestContext): void => {
      checkError("let x: i32 = true;", "Type mismatch");
    });

    test('undeclared variable produces error', (ctx: TestContext): void => {
      checkError("let x = y;", "not found");
    });

    test('error has location info', (ctx: TestContext): void => {
      let result = check("let x: i32 = true;");
      let errors = errorDiagnostics(result.diagnostics);
      isTrue(errors.length > 0);
      isTrue(errors[0].location != null);
    });

    test('multiple errors collected', (ctx: TestContext): void => {
      let result = check("let x: i32 = true;\nlet y: String = 42;");
      let errors = errorDiagnostics(result.diagnostics);
      isTrue(errors.length >= 2);
    });

    test('valid code produces zero errors', (ctx: TestContext): void => {
      let result = check("let x = 1;\nlet y = x + 2;");
      let errors = errorDiagnostics(result.diagnostics);
      equal(errors.length, 0);
    });
  });

  // ==========================================================================
  // Class declarations
  // ==========================================================================

  suite('class type creation', (): void => {

    test('class creates a ClassType', (ctx: TestContext): void => {
      let source = "class Point {\n  x: i32;\n  y: i32;\n  new(this.x, this.y);\n}";
      let ast = parse(source, "<test>");
      let scopeBuilder = new ScopeBuilder("<test>");
      let scopeResult = scopeBuilder.build(ast);
      let result = checkModule(ast, scopeResult, null);

      let errors = errorDiagnostics(result.diagnostics);
      equal(errors.length, 0);

      // Point should be resolvable as a type
      let info = scopeResult.rootScope.resolveType("Point");
      isTrue(info != null);
    });

    test('class instantiation works', (ctx: TestContext): void => {
      let result = checkOk(
        "class Point {\n  x: i32;\n  y: i32;\n  new(this.x, this.y);\n}\nlet p = new Point(1, 2);"
      );
      isTrue(result.diagnostics.length == 0);
    });

    test('sealed class with variants', (ctx: TestContext): void => {
      let result = checkOk(
        "sealed class Shape {\n  case Circle(radius: f64)\n  case Rect(width: f64, height: f64)\n}"
      );
      isTrue(result.diagnostics.length == 0);
    });

    test('case class creates type', (ctx: TestContext): void => {
      let result = checkOk(
        "class Pair(first: i32, second: String)"
      );
      isTrue(result.diagnostics.length == 0);
    });
  });

  // ==========================================================================
  // Integration: scope + checker pipeline
  // ==========================================================================

  suite('scope integration', (): void => {

    test('identifier resolves through scope', (ctx: TestContext): void => {
      let result = checkOk("let x = 1;\nlet y = x;");
      isTrue(result.diagnostics.length == 0);
    });

    test('function parameter types resolve', (ctx: TestContext): void => {
      let result = checkOk(
        "let add = (a: i32, b: i32): i32 => a + b;\nlet r = add(1, 2);"
      );
      isTrue(result.diagnostics.length == 0);
    });

    test('class members resolve from scope', (ctx: TestContext): void => {
      let result = checkOk(
        "class Foo {\n  value: i32;\n  new(this.value);\n  getValue(): i32 { return this.value; }\n}\nlet f = new Foo(42);\nlet v = f.getValue();"
      );
      isTrue(result.diagnostics.length == 0);
    });

    test('block scope isolates variables', (ctx: TestContext): void => {
      // The inner x should not conflict with the outer x
      let result = checkOk(
        "let x = 1;\n{\n  let x = 2;\n}"
      );
      isTrue(result.diagnostics.length == 0);
    });
  });

  // ==========================================================================
  // Type checking: patterns and match
  // ==========================================================================

  suite('pattern matching', (): void => {

    test('exhaustive match on sealed class passes', (ctx: TestContext): void => {
      let result = checkOk(
        "sealed class Shape {\n  case Circle(radius: f64)\n  case Rect(w: f64, h: f64)\n}\nlet describe = (s: Shape): String => match (s) {\n  case Circle {}: 'circle'\n  case Rect {}: 'rect'\n};"
      );
      isTrue(result.diagnostics.length == 0);
    });

    test('non-exhaustive match produces error', (ctx: TestContext): void => {
      checkError(
        "sealed class Shape {\n  case Circle(radius: f64)\n  case Rect(w: f64, h: f64)\n}\nlet describe = (s: Shape): String => match (s) {\n  case Circle {}: 'circle'\n};",
        "Non-exhaustive"
      );
    });
  });

  // ==========================================================================
  // Private fields
  // ==========================================================================

  suite('private fields', (): void => {

    test('private field read in own class', (ctx: TestContext): void => {
      checkOk(
        "class Counter {\n  #count: i32 = 0;\n  getCount(): i32 { return this.#count; }\n}"
      );
    });

    test('private field write in own class', (ctx: TestContext): void => {
      checkOk(
        "class Counter {\n  var #count: i32 = 0;\n  increment(): void { this.#count += 1; }\n}"
      );
    });

    test('private field outside class is error', (ctx: TestContext): void => {
      checkError(
        "class Foo {\n  #secret: i32 = 0;\n}\nlet f = new Foo();\nlet x = f.#secret;",
        "Private field"
      );
    });

    test('private method in own class', (ctx: TestContext): void => {
      checkOk(
        "class Builder {\n  #helper(): i32 { return 42; }\n  build(): i32 { return this.#helper(); }\n}"
      );
    });

    test('private field with initializer expression', (ctx: TestContext): void => {
      // Scope.zena pattern: #values = new HashMap<String, SymbolInfo>()
      checkOk(
        "class Container {\n  #items: Array<i32> = [1, 2, 3];\n  count(): i32 { return this.#items.length; }\n}"
      );
    });

    test('private field member access chain', (ctx: TestContext): void => {
      // Pattern: this.#values.has(name)
      checkOk(
        "class Wrapper {\n  #text: String = 'hello';\n  len(): i32 { return this.#text.length; }\n}"
      );
    });

    test('forward reference to private method', (ctx: TestContext): void => {
      // build() calls #helper() which is defined later in the class body
      checkOk(
        "class Builder {\n  build(): i32 { return this.#process(); }\n  #process(): i32 { return 42; }\n}"
      );
    });

    test('cross-class forward reference', (ctx: TestContext): void => {
      // Class A's method calls class B's method — B is declared AFTER A.
      // The two-phase checker registers all member signatures before checking bodies.
      checkOk(
        "class A {\n  getValue(): i32 {\n    let b = new B(42);\n    return b.getDouble();\n  }\n}\nclass B {\n  value: i32;\n  new(this.value);\n  getDouble(): i32 { return this.value * 2; }\n}"
      );
    });
  });

  // ==========================================================================
  // Generic type members
  // ==========================================================================

  suite('generic type members', (): void => {

    test('array literal length', (ctx: TestContext): void => {
      checkOk(
        "let arr = [1, 2, 3];\nlet n: i32 = arr.length;"
      );
    });

    test('array push method', (ctx: TestContext): void => {
      checkOk(
        "import { Array } from 'zena:array';\nlet arr = new Array<i32>();\narr.push(42);"
      );
    });
  });

  // ==========================================================================
  // Null comparison operators
  // ==========================================================================

  suite('null comparison', (): void => {

    test('nullable field compared to null with !=', (ctx: TestContext): void => {
      checkOk(
        "class Foo {\n  x: i32 | null;\n  new(this.x);\n}\nlet f = new Foo(null);\nlet b = f.x != null;"
      );
    });

    test('nullable field compared to null with ==', (ctx: TestContext): void => {
      checkOk(
        "class Foo {\n  x: i32 | null;\n  new(this.x);\n}\nlet f = new Foo(null);\nlet b = f.x == null;"
      );
    });

    test('nullable class type compared to null', (ctx: TestContext): void => {
      checkOk(
        "class Point { x: f64; new(this.x); }\nlet p: Point | null = null;\nlet b = p != null;"
      );
    });

    test('class field compared to null', (ctx: TestContext): void => {
      checkOk(
        "class Loc { line: i32; new(this.line); }\nclass Foo {\n  loc: Loc | null;\n  new(this.loc);\n}\nlet f = new Foo(null);\nlet b = f.loc != null;"
      );
    });
  });

  // ==========================================================================
  // HashMap member access
  // ==========================================================================

  suite('HashMap members', (): void => {

    test('HashMap index access', (ctx: TestContext): void => {
      checkOk(
        "import { HashMap } from 'zena:map';\nlet m = new HashMap<String, i32>();\nm[\"x\"] = 42;"
      );
    });

    test('HashMap get method', (ctx: TestContext): void => {
      checkOk(
        "import { HashMap } from 'zena:map';\nlet m = new HashMap<String, i32>();\nlet v = m.get(\"x\");"
      );
    });

    test('HashMap has method', (ctx: TestContext): void => {
      checkOk(
        "import { HashMap } from 'zena:map';\nlet m = new HashMap<String, i32>();\nlet b = m.has(\"x\");"
      );
    });

    test('HashMap field with get and return', (ctx: TestContext): void => {
      // Class with HashMap field — get method return type must substitute V
      checkOk(
        "import { HashMap } from 'zena:map';\nclass Store {\n  #data = new HashMap<String, i32>();\n  lookup(key: String): i32 {\n    let (val, found) = this.#data.get(key);\n    if (found) { return val; }\n    return 0;\n  }\n}"
      );
    });

    test('HashMap index access substitutes V', (ctx: TestContext): void => {
      // Index access on HashMap field must substitute type args
      checkOk(
        "import { HashMap } from 'zena:map';\nclass Cache {\n  #map = new HashMap<String, i32>();\n  getValue(key: String): i32 {\n    return this.#map[key];\n  }\n}"
      );
    });
  });

  // ==========================================================================
  // Match pattern narrowing
  // ==========================================================================

  suite('match pattern narrowing', (): void => {

    test('as pattern narrows to class type', (ctx: TestContext): void => {
      checkOk(
        "sealed class Shape {\n  case Circle(radius: f64)\n  case Rect(w: f64, h: f64)\n}\nlet c = new Circle(3.14);\nlet r: f64 = c.radius;"
      );
    });

    test('as pattern with identifier narrows to class type', (ctx: TestContext): void => {
      // `case Circle as c:` where Circle is an Identifier (no {})
      checkOk(
        "sealed class Shape {\n  case Circle(radius: f64)\n  case Rect(w: f64, h: f64)\n}\nlet area = (s: Shape): f64 => match (s) {\n  case Circle as c: c.radius\n  case Rect as r: r.w * r.h\n};"
      );
    });

    test('as pattern with distributed variant narrows', (ctx: TestContext): void => {
      // Distributed variant (standalone class extends sealed)
      checkOk(
        "sealed class Node {\n  case Leaf, Branch\n}\nclass Leaf(value: i32) extends Node\nclass Branch(left: Node, right: Node) extends Node\nlet eval = (n: Node): i32 => match (n) {\n  case Leaf as l: l.value\n  case Branch as b: eval(b.left) + eval(b.right)\n};"
      );
    });
  });

  suite('null check narrowing', (): void => {

    test('if != null narrows in then branch', (ctx: TestContext): void => {
      checkOk(
        "class Foo {\n  x: i32;\n  new(this.x);\n}\nlet foo: Foo | null = null;\nif (foo != null) {\n  let y: Foo = foo;\n}"
      );
    });

    test('if == null narrows in else branch', (ctx: TestContext): void => {
      checkOk(
        "class Foo {\n  x: i32;\n  new(this.x);\n}\nlet foo: Foo | null = null;\nif (foo == null) {\n  let y: i32 = 0;\n} else {\n  let y: Foo = foo;\n}"
      );
    });

    test('if == null early return narrows after', (ctx: TestContext): void => {
      checkOk(
        "class Foo {\n  x: i32;\n  new(this.x);\n}\nlet f = (foo: Foo | null): i32 => {\n  if (foo == null) { return 0; }\n  let y: Foo = foo;\n  return y.x;\n};"
      );
    });

    test('null narrowing with method call argument', (ctx: TestContext): void => {
      // Pattern from scope.zena: if (info == null) { ... } else { record(expr, info); }
      checkOk(
        "class Info {\n  x: i32;\n  new(this.x);\n}\nlet record = (info: Info): void => {};\nlet lookup = (): Info | null => null;\nlet test = (): void => {\n  let info = lookup();\n  if (info == null) {\n    let x = 0;\n  } else {\n    record(info);\n  }\n};"
      );
    });

    test('null narrowing with != null and method call', (ctx: TestContext): void => {
      // Pattern from scope.zena: if (info != null) { record(ann, info); }
      checkOk(
        "class Info {\n  x: i32;\n  new(this.x);\n}\nlet record = (info: Info): void => {};\nlet lookup = (): Info | null => null;\nlet test = (): void => {\n  let info = lookup();\n  if (info != null) {\n    record(info);\n  }\n};"
      );
    });

    test('null narrowing inside match case with method call', (ctx: TestContext): void => {
      // Exact pattern from scope.zena: inside match arm, if == null, else calls method
      checkOk(
        "class Info {\n  x: i32;\n  new(this.x);\n}\nclass Ref {\n  record(a: i32, info: Info): void {}\n}\nclass Foo {\n  #ref: Ref;\n  new() : #ref = new Ref();\n  test(input: String | null): void {\n    let info: Info | null = null;\n    if (info == null) {\n      let x = 0;\n    } else {\n      this.#ref.record(42, info);\n    }\n  }\n}"
      );
    });

    test('null narrowing inside match case body', (ctx: TestContext): void => {
      // info inferred from function returning T | null, inside match arm
      // FIRST: without match - should pass
      checkOk(
        "class Info {\n  x: i32;\n  new(this.x);\n}\nlet record = (info: Info): void => {};\nlet lookup = (s: String): Info | null => null;\nlet process = (s: String): void => {\n  let info = lookup(s);\n  if (info == null) {\n    let x = 0;\n  } else {\n    record(info);\n  }\n};"
      );
    });

    test('null narrowing inside match case body with match', (ctx: TestContext): void => {
      // SAME but inside match - should also pass
      checkOk(
        "class Info {\n  x: i32;\n  new(this.x);\n}\nlet record = (info: Info): void => {};\nlet lookup = (s: String): Info | null => null;\nsealed class Tag {\n  case A(name: String)\n  case B\n}\nlet process = (expr: Tag): void => {\n  match (expr) {\n    case A {name}: {\n      let info = lookup(name);\n      if (info == null) {\n        let x = 0;\n      } else {\n        record(info);\n      }\n    }\n    case _: {}\n  }\n};"
      );
    });

    test('null narrowing inside match - no destructuring', (ctx: TestContext): void => {
      // Same but without destructuring in match pattern
      checkOk(
        "sealed class Tag {\n  case A\n  case B\n}\nlet f = (): i32 | null => null;\nlet process = (expr: Tag): void => {\n  match (expr) {\n    case A: {\n      let info = f();\n      if (info == null) {\n        let x = 0;\n      } else {\n        let y: i32 = info;\n      }\n    }\n    case B: {}\n  }\n};"
      );
    });

    test('rejects nullable to non-nullable assignment', (ctx: TestContext): void => {
      checkError(
        "class Foo {\n  x: i32;\n  new(this.x);\n}\nlet foo: Foo | null = null;\nlet y: Foo = foo;",
        "not assignable"
      );
    });

    test('narrowing allows non-null assignment in if body', (ctx: TestContext): void => {
      // With narrowing, foo should be Foo (not Foo | null) inside the if body
      checkOk(
        "class Foo {\n  x: i32;\n  new(this.x);\n}\nlet foo: Foo | null = null;\nif (foo != null) {\n  let y: Foo = foo;\n}"
      );
    });
  });
});
