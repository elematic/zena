// Portable tests — auto-discovers .zena files under tests/language/
//   syntax/    → parsed AST JSON compared against .ast.json snapshots
//   semantics/ → parsed, scope-analysed, type-checked; @error directives validated
// Requires WASI (run with wasmtime via npm run test:wasmtime)

import { suite, test, TestContext } from 'zena:test';
import { equal, isTrue, isFalse } from 'zena:assert';
import { jsonEqual } from 'zena:assert';
import { readFile, listDir, exists, DirEntry, FileType } from 'zena:fs';
import { parseJson, JsonValue, JsonOptions } from 'zena:json';
import { Array } from 'zena:array';
import { parse } from '../lib/parser.zena';
import { nodeToJson } from '../lib/ast-json.zena';
import { ExpressionStatement } from '../lib/ast.zena';
import { ScopeBuilder } from '../lib/scope.zena';
import { checkModule, CheckResult } from '../lib/checker.zena';
import { Diagnostic, DiagnosticSeverity, formatDiagnostic } from '../lib/diagnostics.zena';

// ============================================================================
// Skip list — tests that the self-hosted parser cannot yet match
// ============================================================================

type SkipEntry = { path: String, reason: String };

let skipList = [
  {
    path: "classes/case-classes/exported.zena",
    reason: "snapshot is full Module (no @target: statement directive)"
  }
];

// ============================================================================
// String helpers (Zena has no endsWith/startsWith builtins yet)
// ============================================================================

let startsWith = (s: String, prefix: String): boolean => {
  if (prefix.length > s.length) {
    return false;
  }
  return s.sliceBytes(0, prefix.length) == prefix;
};

let endsWith = (s: String, suffix: String): boolean => {
  if (suffix.length > s.length) {
    return false;
  }
  return s.sliceBytes(s.length - suffix.length, s.length) == suffix;
};

let contains = (s: String, sub: String): boolean => {
  if (sub.length > s.length) {
    return false;
  }
  var i = 0;
  while (i <= s.length - sub.length) {
    if (s.sliceBytes(i, i + sub.length) == sub) {
      return true;
    }
    i += 1;
  }
  return false;
};

// Returns true if the source has any // @error: directive
let hasErrorDirective = (source: String): boolean => {
  return contains(source, "// @error:");
};


// ============================================================================
// Directive parsing
// ============================================================================

// Returns "statement", "module", or "expression" based on // @target: directive
let parseTarget = (source: String): String => {
  // Scan first few lines for // @target: ...
  // Simple approach: look for the prefix in the source
  let prefix = "// @target: ";
  var i = 0;
  while (i < source.length) {
    // Check if this position starts with prefix
    if (i + prefix.length <= source.length) {
      if (source.sliceBytes(i, i + prefix.length) == prefix) {
        // Found it — extract value until newline
        let start = i + prefix.length;
        var end = start;
        while (end < source.length) {
          // Check for newline (byte 10)
          if (source.sliceBytes(end, end + 1) == "\n") {
            break;
          }
          end += 1;
        }
        // Trim trailing whitespace
        var trimEnd = end;
        while (trimEnd > start) {
          let ch = source.sliceBytes(trimEnd - 1, trimEnd);
          if (ch == " " || ch == "\r") {
            trimEnd -= 1;
          } else {
            break;
          }
        }
        return source.sliceBytes(start, trimEnd);
      }
    }
    // Advance to next line
    while (i < source.length) {
      let ch = source.sliceBytes(i, i + 1);
      i += 1;
      if (ch == "\n") {
        break;
      }
    }
  }
  return "module";
};

// ============================================================================
// Test discovery
// ============================================================================

let isSkipped = (relPath: String, skips: FixedArray<SkipEntry>): String | null => {
  var i = 0;
  while (i < skips.length) {
    // Match exact path OR prefix (for directory patterns like "optional-chaining/")
    if (skips[i].path == relPath || startsWith(relPath, skips[i].path)) {
      return skips[i].reason;
    }
    i += 1;
  }
  return null;
};

// Discovers and registers tests for all .zena files in a directory (recursively).
// dirPath: filesystem path (e.g., "tests/language/syntax")
// relPrefix: relative path from the syntax root for skip list matching (e.g., "")
let discoverTests = (dirPath: String, relPrefix: String, skips: FixedArray<SkipEntry>): void => {
  let entries = listDir(dirPath);
  
  // Collect subdirectories and files separately for ordered processing
  let subdirs = new Array<DirEntry>(4);
  let files = new Array<DirEntry>(8);
  
  var i = 0;
  while (i < entries.length) {
    let entry = entries[i];
    if (entry.fileType == FileType.Directory) {
      // Skip . and .. to prevent infinite recursion
      if (entry.name != "." && entry.name != "..") {
        subdirs.push(entry);
      }
    } else if (entry.fileType == FileType.RegularFile) {
      if (entry.name.endsWith(".zena")) {
        files.push(entry);
      }
    }
    i += 1;
  }
  
  // Register tests for .zena files that have a corresponding .ast.json
  var fi = 0;
  while (fi < files.length) {
    let fileName = files[fi].name;
    let filePath = dirPath + "/" + fileName;
    
    // Build relative path for skip list matching
    let relPath = if (relPrefix.length > 0) {
      relPrefix + "/" + fileName
    } else {
      fileName
    };
    
    // Build snapshot path: replace .zena with .ast.json
    let snapshotPath = filePath.sliceBytes(0, filePath.length - 5) + ".ast.json";
    
    // Read source to check for @error directives
    let source = readFile(filePath);
    let isErrorTest = hasErrorDirective(source);

    // Test if snapshot exists (positive test) or @error directive present (error test)
    if (exists(snapshotPath) || isErrorTest) {
      let reason = isSkipped(relPath, skips);
      if (reason != null) {
        // Skip — test is in skip list
        // (zena:test doesn't have test.skip yet, so we just don't register it)
      } else {
        // Capture values for closure
        let capturedFilePath = filePath;
        let capturedSnapshotPath = snapshotPath;
        let capturedFileName = fileName;
        let capturedIsErrorTest = isErrorTest;
        let capturedSource = source;

        test(capturedFileName, (ctx: TestContext): void => {
          if (capturedIsErrorTest) {
            // Error test: parser should throw
            let threw = try {
              parse(capturedSource, capturedFileName);
              false
            } catch (e) {
              true
            };
            if (!threw) {
              throw new Error("Expected parse error (has @error directive) but parsing succeeded: " + capturedFilePath);
            }
          } else {
            // Positive test: compare AST against snapshot
            let expectedSnapshot = readFile(capturedSnapshotPath);
            let expected = parseJson(expectedSnapshot, { allowComments: false, trackLocations: true });
            let mod = parse(capturedSource, capturedFileName);
          
            // Determine target from directives
            let target = parseTarget(capturedSource);
          
            var actual = nodeToJson(mod);
            if (target == "statement") {
              actual = nodeToJson(mod.body[0]);
            } else {
              if (target == "expression") {
                let stmt = mod.body[0] as ExpressionStatement;
                actual = nodeToJson(stmt.expression);
              } else {}
            }
          
            jsonEqual(actual, expected, capturedFilePath);
          }
        });
      }
    }
    fi += 1;
  }
  
  // Recurse into subdirectories, each wrapped in a suite
  var si = 0;
  while (si < subdirs.length) {
    let subName = subdirs[si].name;
    let subPath = dirPath + "/" + subName;
    let subRel = if (relPrefix.length > 0) {
      relPrefix + "/" + subName
    } else {
      subName
    };
    
    // Capture for closure
    let capturedSubPath = subPath;
    let capturedSubRel = subRel;
    let capturedSkips = skips;
    
    suite(subName, (): void => {
      discoverTests(capturedSubPath, capturedSubRel, capturedSkips);
    });
    si += 1;
  }
};

// ============================================================================
// Semantic test infrastructure
// ============================================================================

type ExpectedError = { line: i32, pattern: String };

/**
 * Extract // @error: <pattern> directives from source, returning
 * the line number (1-based) and the pattern string for each.
 */
let parseExpectedErrors = (source: String): Array<ExpectedError> => {
  let errors = new Array<ExpectedError>(4);
  let marker = "// @error: ";
  var pos = 0;
  var lineNum = 1;

  while (pos < source.length) {
    // Find end of current line.
    var eol = pos;
    while (eol < source.length && source.sliceBytes(eol, eol + 1) != "\n") {
      eol += 1;
    }

    // Check if this line contains the marker.
    let line = source.sliceBytes(pos, eol);
    var mi = 0;
    var found = false;
    while (mi <= line.length - marker.length) {
      if (line.sliceBytes(mi, mi + marker.length) == marker) {
        // Extract the pattern (rest of line after marker, trimmed).
        var patEnd = line.length;
        while (patEnd > mi + marker.length) {
          let ch = line.sliceBytes(patEnd - 1, patEnd);
          if (ch == " " || ch == "\r") {
            patEnd -= 1;
          } else {
            break;
          }
        }
        let pattern = line.sliceBytes(mi + marker.length, patEnd);
        errors.push({ line: lineNum, pattern: pattern });
        found = true;
        break;
      }
      mi += 1;
    }

    // Advance past newline.
    if (eol < source.length) {
      pos = eol + 1;
    } else {
      pos = eol;
    }
    lineNum += 1;
  }

  return errors;
};

/**
 * Check if a diagnostic message contains a pattern string (case-sensitive).
 */
let messageContains = (message: String, pattern: String): boolean => {
  if (pattern.length > message.length) {
    return false;
  }
  var i = 0;
  while (i <= message.length - pattern.length) {
    if (message.sliceBytes(i, i + pattern.length) == pattern) {
      return true;
    }
    i += 1;
  }
  return false;
};

/**
 * Run a semantic check test: parse → scope → check, then match diagnostics.
 */
let runSemanticCheck = (source: String, filePath: String): void => {
  let expectedErrors = parseExpectedErrors(source);

  // Parse.
  let ast = parse(source, filePath);

  // Scope analysis.
  let scopeBuilder = new ScopeBuilder(filePath);
  let scopeResult = scopeBuilder.build(ast);

  // Type check.
  let result = checkModule(ast, scopeResult, null);
  let diagnostics = result.diagnostics;

  // Collect only errors (not warnings).
  let errors = new Array<Diagnostic>(4);
  var ei = 0;
  while (ei < diagnostics.length) {
    match (diagnostics[ei].severity) {
      case DiagnosticSeverity.Error: {
        errors.push(diagnostics[ei]);
      }
      case _: {}
    }
    ei += 1;
  }

  // Match expected errors against actual diagnostics.
  var xi = 0;
  while (xi < expectedErrors.length) {
    let expected = expectedErrors[xi];
    var matched = false;
    var di = 0;
    while (di < errors.length) {
      if (messageContains(errors[di].message, expected.pattern)) {
        matched = true;
        break;
      }
      di += 1;
    }
    if (!matched) {
      var actualStr = "(none)";
      if (errors.length > 0) {
        actualStr = "";
        var ai = 0;
        while (ai < errors.length) {
          if (ai > 0) { actualStr = actualStr + "\n"; }
          actualStr = actualStr + formatDiagnostic(errors[ai], source);
          ai += 1;
        }
      }
      throw new Error(
        `Expected error matching '${expected.pattern}' on line ${expected.line} but found none.\nActual errors:\n${actualStr}\nFile: ${filePath}`
      );
    }
    xi += 1;
  }

  // If no expected errors, fail on any unexpected errors.
  if (expectedErrors.length == 0 && errors.length > 0) {
    var errStr = "";
    var ui = 0;
    while (ui < errors.length) {
      if (ui > 0) { errStr = errStr + "\n"; }
      errStr = errStr + formatDiagnostic(errors[ui], source);
      ui += 1;
    }
    throw new Error(
      "Unexpected errors:\n" + errStr + "\nFile: " + filePath
    );
  }
};

/**
 * Discovers and registers semantic tests for all .zena files in a directory.
 */
let discoverSemanticTests = (dirPath: String, relPrefix: String, skips: FixedArray<SkipEntry>): void => {
  let entries = listDir(dirPath);

  let subdirs = new Array<DirEntry>(4);
  let files = new Array<DirEntry>(8);

  var i = 0;
  while (i < entries.length) {
    let entry = entries[i];
    if (entry.fileType == FileType.Directory) {
      if (entry.name != "." && entry.name != "..") {
        subdirs.push(entry);
      }
    } else if (entry.fileType == FileType.RegularFile) {
      if (entry.name.endsWith(".zena")) {
        files.push(entry);
      }
    }
    i += 1;
  }

  var fi = 0;
  while (fi < files.length) {
    let fileName = files[fi].name;
    let filePath = dirPath + "/" + fileName;
    let relPath = if (relPrefix.length > 0) {
      relPrefix + "/" + fileName
    } else {
      fileName
    };

    let reason = isSkipped(relPath, skips);
    // console.log(`Test: ${relPath} skipped: ${reason != null}`);
    if (reason == null) {
      let capturedFilePath = filePath;
      let capturedFileName = fileName;

      test(capturedFileName, (ctx: TestContext): void => {
        let source = readFile(capturedFilePath);
        runSemanticCheck(source, capturedFilePath);
      });
    }
    fi += 1;
  }

  var si = 0;
  while (si < subdirs.length) {
    let subName = subdirs[si].name;
    let subPath = dirPath + "/" + subName;
    let subRel = if (relPrefix.length > 0) {
      relPrefix + "/" + subName
    } else {
      subName
    };

    let capturedSubPath = subPath;
    let capturedSubRel = subRel;
    let capturedSkips = skips;

    suite(subName, (): void => {
      discoverSemanticTests(capturedSubPath, capturedSubRel, capturedSkips);
    });
    si += 1;
  }
};

// ============================================================================
// Main test registration
// ============================================================================

// Skip list for semantic tests
let semanticSkipList: FixedArray<SkipEntry> = [
  // unannotated params get different error message (not critical, but skip for now)
  {path: "predeclare-no-param-annotations", reason: "unannotated param error message differs"}
];

export let tests = suite('Portable Tests', (): void => {
  suite('Syntax', (): void => {
    discoverTests("tests/language/syntax", "", skipList);
  });
  // Re-enabling to debug the null reference error
  suite('Semantics', (): void => {
    discoverSemanticTests("tests/language/semantics", "", semanticSkipList);
  });
});
