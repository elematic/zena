/**
 * Portable tests — auto-discovers .zena files under tests/language/
 *   syntax/    → parsed AST JSON compared against .ast.json snapshots
 *   semantics/ → parsed, scope-analysed, type-checked; @error directives validated
 *
 * Requires WASI (run with wasmtime via npm run test:wasmtime)
 */

import { suite, test, TestContext } from 'zena:test';
import { equal, isTrue, isFalse } from 'zena:assert';
import { jsonEqual } from 'zena:assert';
import { readFile, listDir, exists, DirEntry, FileType } from 'zena:fs';
import { parseJson, JsonValue, JsonOptions } from 'zena:json';
import { Array } from 'zena:array';
import { StringReader } from 'zena:string-reader';
import { parse } from '../lib/parser.zena';
import { nodeToJson } from '../lib/ast-json.zena';
import { ExpressionStatement } from '../lib/ast.zena';
import { ScopeBuilder } from '../lib/scope.zena';
import { checkModule, CheckResult } from '../lib/checker.zena';
import { Diagnostic, DiagnosticSeverity, formatDiagnostic } from '../lib/diagnostics.zena';

// ============================================================================
// Skip list — tests that the self-hosted parser cannot yet match
// ============================================================================

type SkipEntry = { path: String, reason: String };

let skippedTests = [
  // syntax skips
  { path: "syntax/classes/case-classes/exported.zena", reason: "snapshot is full Module (no @target: statement directive)" },
  // semantics skips
  { path: "semantics/destructuring/tuple/inline-never-union", reason: "inline tuple union returns not yet supported" },
  { path: "semantics/classes/fields/field-init-required.zena", reason: "field init check not implemented" },
  { path: "semantics/interfaces/var-field-needs-setter.zena", reason: "var field setter check not implemented" },
  { path: "semantics/control-flow/for/for-in-iterator.zena", reason: "HashMap.keys() not resolved in self-hosted checker" },
  { path: "semantics/control-flow/for/for-in-destructure-map.zena", reason: "HashMap iteration not resolved in self-hosted checker" }
];

// Returns true if the source has any // @error: directive
let hasErrorDirective = (directives: Array<Directive>): boolean => {
  for (let directive in directives) {
    if (directive.name == "error") {
      return true;
    }
  }
  return false;
};

// ============================================================================
// Directive parsing
// ============================================================================

type Directive = { name: String, line: i32, value: String };

// Parses all // @name: value directives from a file
let parseDirectives = (source: String): Array<Directive> => {
  let results = new Array<Directive>(4);
  let marker = "// @";
  if (!source.contains(marker)) {
    return results;
  }

  var lineNum = 1;
  let r = new StringReader(source);
  while (!r.isAtEnd) {
    let lineStart = r.mark();
    while (!r.isAtEnd && r.peekByte() != 10) { // 10 = '\n'
      r.advanceByte();
    }
    let line = r.sliceFrom(lineStart);

    if (line.contains(marker)) {
      var mi = 0;
      while (mi <= line.length - marker.length) {
        if (line.sliceBytes(mi, mi + marker.length) == marker) {
          var colonIndex = mi + marker.length;
          var foundColon = false;
          while (colonIndex < line.length) {
            if (line.getByteAt(colonIndex) == 58) { // ':'
              foundColon = true;
              break;
            }
            colonIndex += 1;
          }

          if (foundColon) {
            let name = line.sliceBytes(mi + marker.length, colonIndex);
            var valStart = colonIndex + 1;
            while (valStart < line.length) {
              let b = line.getByteAt(valStart);
              if (b == 32 || b == 9) { // space or \t
                valStart += 1;
              } else {
                break;
              }
            }
            var valEnd = line.length;
            while (valEnd > valStart) {
              let b = line.getByteAt(valEnd - 1);
              if (b == 32 || b == 13) { // space or \r
                valEnd -= 1;
              } else {
                break;
              }
            }
            let value = line.sliceBytes(valStart, valEnd);
            results.push({ name: name, line: lineNum, value: value });
          }
          break;
        }
        mi += 1;
      }
    }

    if (r.peekByte() == 10) {
      r.advanceByte();
    }
    lineNum += 1;
  }

  return results;
};

// Determine target from directives
let getTarget = (directives: Array<Directive>): String => {
  for (let directive in directives) {
    if (directive.name == "target") {
      return directive.value;
    }
  }
  return "module";
};

/**
 * Run a semantic test: parse → scope → check, then match diagnostics.
 */
let runSemanticTest = (
    source: String,
    filePath: String,
    directives: Array<Directive>): void => {
  let expectedErrors = new Array<Directive>(4);
  let expectedWarnings = new Array<Directive>(4);
  for (let directive in directives) {
    if (directive.name == "error") {
      expectedErrors.push(directive);
    } else if (directive.name == "warning") {
      expectedWarnings.push(directive);
    }
  }

  // Parse.
  let ast = parse(source, filePath);

  // Scope analysis.
  let scopeBuilder = new ScopeBuilder(filePath);
  let scopeResult = scopeBuilder.build(ast);

  // Type check.
  let result = checkModule(ast, scopeResult, null);
  let diagnostics = result.diagnostics;

  // Collect only errors (not warnings).
  let errors = new Array<Diagnostic>(4);
  for (let diagnostic in diagnostics) {
    match (diagnostic.severity) {
      case DiagnosticSeverity.Error: {
        errors.push(diagnostic);
      }
      case _: {}
    }
  }

  // Match expected errors against actual diagnostics.
  for (let expected in expectedErrors) {
    var matched = false;
    for (let error in errors) {
      if (error.message.contains(expected.value)) {
        matched = true;
        break;
      }
    }
    if (!matched) {
      var actualStr = "(none)";
      if (errors.length > 0) {
        actualStr = "";
        var ai = 0;
        while (ai < errors.length) {
          if (ai > 0) { actualStr = actualStr + "\n"; }
          actualStr = actualStr + formatDiagnostic(errors[ai], source);
          ai += 1;
        }
      }
      throw new Error(
        `Expected error matching '${expected.value}' on line ${expected.line} but found none.\nActual errors:\n${actualStr}\nFile: ${filePath}`
      );
    }
  }

  // If no expected errors, fail on any unexpected errors.
  if (expectedErrors.length == 0 && errors.length > 0) {
    var errStr = "";
    for (var i = 0; i < errors.length; i += 1) {
      if (i > 0) {
        errStr = errStr + "\n";
      }
      errStr = errStr + formatDiagnostic(errors[i], source);
    }
    throw new Error(
      "Unexpected errors:\n" + errStr + "\nFile: " + filePath
    );
  }

  // Match expected warnings against actual diagnostics.
  let warnings = new Array<Diagnostic>(4);
  for (let diagnostic in diagnostics) {
    match (diagnostic.severity) {
      case DiagnosticSeverity.Warning: {
        warnings.push(diagnostic);
      }
      case _: {}
    }
  }

  for (let expected in expectedWarnings) {
    var warningMatched = false;
    for (let warning in warnings) {
      if (warning.message.contains(expected.value)) {
        warningMatched = true;
        break;
      }
    }
    if (!warningMatched) {
      var actualWarnStr = "(none)";
      if (warnings.length > 0) {
        actualWarnStr = "";
        for (var i = 0; i < warnings.length; i += 1) {
          if (i > 0) {
            actualWarnStr = actualWarnStr + "\n";
          }
          actualWarnStr = actualWarnStr + formatDiagnostic(warnings[i], source);
        }
      }
      throw new Error(
        `Expected warning matching '${expected.value}' on line ${expected.line} but found none.\nActual warnings:\n${actualWarnStr}\nFile: ${filePath}`
      );
    }
  }
};

let runSyntaxTest = (
    source: String,
    filePath: String,
    directives: Array<Directive>,
    isErrorTest: boolean,
    snapshotPath: String,
    fileName: String): void => {
  if (isErrorTest) {
    // Error test: parser should throw
    let threw = try {
      parse(source, fileName);
      false
    } catch (e) {
      true
    };
    if (!threw) {
      throw new Error("Expected parse error (has @error directive) but parsing succeeded: " + filePath);
    }
  } else {
    // Positive test: compare AST against snapshot
    let expectedSnapshot = readFile(snapshotPath);
    let expected = parseJson(expectedSnapshot, { allowComments: false, trackLocations: true });
    let mod = parse(source, fileName);
    
    let actual = match (getTarget(directives)) {
      case "statement": {
        nodeToJson(mod.body[0]);
      }
      case "expression": {
        let stmt = mod.body[0] as ExpressionStatement;
        nodeToJson(stmt.expression);
      }
      case _: {
        nodeToJson(mod)
      }
    };
  
    jsonEqual(actual, expected, filePath);
  }
};

let isSkipped = (relPath: String): String | null => {
  for (let skip in skippedTests) {
    // Match exact path OR prefix (for directory patterns like "optional-chaining/")
    if (relPath.startsWith(skip.path)) {
      return skip.reason;
    }
  }
  return null;
};

// Discovers and registers tests for all .zena files in a directory (recursively).
// dirPath: filesystem path (e.g., "tests/language/syntax")
// relPrefix: relative path from the syntax root for skip list matching (e.g., "")
let runTests = (dirPath: String, relPrefix: String): void => {
  let entries = listDir(dirPath);
  
  // Collect subdirectories and files separately for ordered processing
  let subdirs = new Array<DirEntry>(4);
  let files = new Array<DirEntry>(8);
  
  for (let entry in entries) {
    if (entry.fileType == FileType.Directory) {
      // Skip . and .. to prevent infinite recursion
      if (entry.name != "." && entry.name != "..") {
        subdirs.push(entry);
      }
    } else if (entry.fileType == FileType.RegularFile) {
      if (entry.name.endsWith(".zena")) {
        files.push(entry);
      }
    }
  }
  
  // Register tests for .zena files that have a corresponding .ast.json
  for (let file in files) {
    let fileName = file.name;
    let filePath = dirPath + "/" + fileName;
    
    // Build relative path for skip list matching
    let relPath = if (relPrefix.length > 0) {
      relPrefix + "/" + fileName
    } else {
      fileName
    };
    
    // Build snapshot path: replace .zena with .ast.json
    let snapshotPath = filePath.sliceBytes(0, filePath.length - 5) + ".ast.json";
    
    // Read source to check for @error directives
    let source = readFile(filePath);
    let directives = parseDirectives(source);
    let isErrorTest = hasErrorDirective(directives);

    let isSyntax = relPath.startsWith("syntax/");
    let isSemantic = relPath.startsWith("semantics/");

    // Test if snapshot exists (positive test) or @error directive present (error test)
    if (isSemantic || exists(snapshotPath) || isErrorTest) {
      let reason = isSkipped(relPath);
      if (reason != null) {
        // Skip — test is in skip list
        // (zena:test doesn't have test.skip yet, so we just don't register it)
      } else {
        test(fileName, (ctx: TestContext): void => {
          if (isSyntax) {
            runSyntaxTest(source, filePath, directives, isErrorTest, snapshotPath, fileName);
          } else {
            runSemanticTest(source, filePath, directives);
          }
        });
      }
    }
  }
  
  // Recurse into subdirectories, each wrapped in a suite
  for (let subdir in subdirs) {
    let subName = subdir.name;
    let subPath = dirPath + "/" + subName;
    let subRel = if (relPrefix.length > 0) {
      relPrefix + "/" + subName
    } else {
      subName
    };
    
    suite(subName, (): void => {
      runTests(subPath, subRel);
    });
  }
};

export let tests = suite('Portable Tests', (): void => {
  runTests("tests/language", "");
});
