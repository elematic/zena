// Portable syntax tests — auto-discovers .zena files under tests/language/syntax/
// and compares parsed AST JSON against .ast.json snapshots.
// Requires WASI (run with wasmtime via npm run test:wasmtime)

import { suite, test, TestContext, SuiteResult } from 'zena:test';
import { jsonEqual } from 'zena:assert';
import { readFile, listDir, exists, DirEntry, FileType } from 'zena:fs';
import { parseJson, JsonValue, JsonOptions } from 'zena:json';
import { console } from 'zena:console';
import { parse } from '../lib/parser.zena';
import { nodeToJson } from '../lib/ast-json.zena';
import { ExpressionStatement } from '../lib/ast.zena';

// ============================================================================
// Skip list — tests that the self-hosted parser cannot yet match
// ============================================================================

type SkipEntry = { path: string, reason: string };

let skipList = [
  {
    path: "classes/case-classes/generic.zena",
    reason: "self-hosted parser uses NamedTypeAnnotation for type params, TS uses TypeParameter"
  },
  {
    path: "classes/case-classes/exported.zena",
    reason: "snapshot is full Module (no @target: statement directive)"
  }
];

// ============================================================================
// String helpers (Zena has no endsWith/startsWith builtins yet)
// ============================================================================

let endsWith = (s: string, suffix: string): boolean => {
  if (suffix.length > s.length) {
    return false;
  }
  return s.sliceBytes(s.length - suffix.length, s.length) == suffix;
};


// ============================================================================
// Directive parsing
// ============================================================================

// Returns "statement", "module", or "expression" based on // @target: directive
let parseTarget = (source: string): string => {
  // Scan first few lines for // @target: ...
  // Simple approach: look for the prefix in the source
  let prefix = "// @target: ";
  var i = 0;
  while (i < source.length) {
    // Check if this position starts with prefix
    if (i + prefix.length <= source.length) {
      if (source.sliceBytes(i, i + prefix.length) == prefix) {
        // Found it — extract value until newline
        let start = i + prefix.length;
        var end = start;
        while (end < source.length) {
          // Check for newline (byte 10)
          if (source.sliceBytes(end, end + 1) == "\n") {
            break;
          }
          end = end + 1;
        }
        // Trim trailing whitespace
        var trimEnd = end;
        while (trimEnd > start) {
          let ch = source.sliceBytes(trimEnd - 1, trimEnd);
          if (ch == " " || ch == "\r") {
            trimEnd = trimEnd - 1;
          } else {
            break;
          }
        }
        return source.sliceBytes(start, trimEnd);
      }
    }
    // Advance to next line
    while (i < source.length) {
      let ch = source.sliceBytes(i, i + 1);
      i = i + 1;
      if (ch == "\n") {
        break;
      }
    }
  }
  return "module";
};

// ============================================================================
// Test discovery
// ============================================================================

let isSkipped = (relPath: string, skips: FixedArray<SkipEntry>): string | null => {
  var i = 0;
  while (i < skips.length) {
    if (skips[i].path == relPath) {
      return skips[i].reason;
    }
    i = i + 1;
  }
  return null;
};

// Discovers and registers tests for all .zena files in a directory (recursively).
// dirPath: filesystem path (e.g., "tests/language/syntax")
// relPrefix: relative path from the syntax root for skip list matching (e.g., "")
let discoverTests = (dirPath: string, relPrefix: string, skips: FixedArray<SkipEntry>): void => {
  let entries = listDir(dirPath);
  
  // Collect subdirectories and files separately for ordered processing
  let subdirs = new Array<DirEntry>(4);
  let files = new Array<DirEntry>(8);
  
  var i = 0;
  while (i < entries.length) {
    let entry = entries[i];
    if (entry.fileType == FileType.Directory) {
      // Skip . and .. to prevent infinite recursion
      if (entry.name != "." && entry.name != "..") {
        subdirs.push(entry);
      }
    } else if (entry.fileType == FileType.RegularFile) {
      if (entry.name.endsWith(".zena")) {
        files.push(entry);
      }
    }
    i = i + 1;
  }
  
  // Register tests for .zena files that have a corresponding .ast.json
  var fi = 0;
  while (fi < files.length) {
    let fileName = files[fi].name;
    let filePath = dirPath + "/" + fileName;
    
    // Build relative path for skip list matching
    let relPath = if (relPrefix.length > 0) {
      relPrefix + "/" + fileName
    } else {
      fileName
    };
    
    // Build snapshot path: replace .zena with .ast.json
    let snapshotPath = filePath.sliceBytes(0, filePath.length - 5) + ".ast.json";
    
    // Only test if snapshot exists
    if (exists(snapshotPath)) {
      let reason = isSkipped(relPath, skips);
      if (reason != null) {
        // Skip — test is in skip list
        // (zena:test doesn't have test.skip yet, so we just don't register it)
      } else {
        // Capture values for closure
        let capturedFilePath = filePath;
        let capturedSnapshotPath = snapshotPath;
        let capturedFileName = fileName;

        test(capturedFileName, (ctx: TestContext): void => {
          let source = readFile(capturedFilePath);
          let expectedSnapshot = readFile(capturedSnapshotPath);
          let expected = parseJson(expectedSnapshot, { allowComments: false, trackLocations: true });
          let mod = parse(source, capturedFileName);
          
          // Determine target from directives
          let target = parseTarget(source);
          
          var actual = nodeToJson(mod);
          if (target == "statement") {
            actual = nodeToJson(mod.body[0]);
          } else {
            if (target == "expression") {
              let stmt = mod.body[0] as ExpressionStatement;
              actual = nodeToJson(stmt.expression);
            } else {}
          }
          
          jsonEqual(actual, expected, capturedFilePath);
        });
      }
    }
    fi = fi + 1;
  }
  
  // Recurse into subdirectories, each wrapped in a suite
  var si = 0;
  while (si < subdirs.length) {
    let subName = subdirs[si].name;
    let subPath = dirPath + "/" + subName;
    let subRel = if (relPrefix.length > 0) {
      relPrefix + "/" + subName
    } else {
      subName
    };
    
    // Capture for closure
    let capturedSubPath = subPath;
    let capturedSubRel = subRel;
    let capturedSkips = skips;
    
    suite(subName, (): void => {
      discoverTests(capturedSubPath, capturedSubRel, capturedSkips);
    });
    si = si + 1;
  }
};

// ============================================================================
// Result reporting
// ============================================================================

let printFailures = (result: SuiteResult, prefix: string): void => {
  var i = 0;
  while (i < result.tests.length) {
    let t = result.tests[i];
    if (!t.passed) {
      let label = if (prefix.length > 0) { prefix + " > " + t.name } else { t.name };
      console.error("  FAIL: " + label);
      if (t.error != null) {
        console.error("    " + t.error);
      }
    }
    i = i + 1;
  }
  var j = 0;
  while (j < result.suites.length) {
    let sub = result.suites[j];
    let subPrefix = if (prefix.length > 0) { prefix + " > " + sub.name } else { sub.name };
    printFailures(sub, subPrefix);
    j = j + 1;
  }
};

// ============================================================================
// Main test registration
// ============================================================================

let tests = suite('Portable Syntax Tests', (): void => {
  discoverTests("tests/language/syntax", "", skipList);
});

// Entry point — returns number of failed tests (0 = success)
export let main = (): i32 => {
  let result = tests.run();
  if (result.failed > 0) {
    console.error("");
    console.error("Failed tests:");
    printFailures(result, "");
    console.error("");
  }
  return result.failed;
};
