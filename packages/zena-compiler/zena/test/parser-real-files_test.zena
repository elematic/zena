// Test that the self-hosted parser can parse real Zena source files.
// This catches unsupported syntax that the parser doesn't handle yet.

import { suite, test, TestContext } from 'zena:test';
import { isTrue } from 'zena:assert';
import { readFile } from 'zena:fs';
import { Error } from 'zena:error';
import { parse } from '../lib/parser.zena';
import { console } from 'zena:console';

let parseFile = (path: String): boolean => {
  let source = readFile(path);
  let mod = try {
    parse(source, path);
    true
  } catch (e) {
    console.log("Parse error: " + (e as Error).message);
    false
  };
  return mod;
};

export let tests = suite('Parser: Real Files', (): void => {

  test('parses ast-json.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/zena-compiler/zena/lib/ast-json.zena'));
  });

  test('parses parser.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/zena-compiler/zena/lib/parser.zena'));
  });

  test('parses tokenizer.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/zena-compiler/zena/lib/tokenizer.zena'));
  });

  test('parses ast.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/zena-compiler/zena/lib/ast.zena'));
  });

  test('parses scope.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/zena-compiler/zena/lib/scope.zena'));
  });

  test('parses checker.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/zena-compiler/zena/lib/checker.zena'));
  });

  test('parses map.zena', (ctx: TestContext): void => {
    isTrue(parseFile('packages/stdlib/zena/map.zena'));
  });
});
