/**
 * Shared test utilities for the self-hosted compiler test suite.
 */

import { Array } from 'zena:array';
import { HashMap } from 'zena:map';
import { CompilerHost } from '../lib/library-loader.zena';
import { PackageConfig } from '../lib/module-resolver.zena';
import {
  createCompiler, Compiler, CompilerOptions
} from '../lib/compiler.zena';
import { Diagnostic, DiagnosticSeverity } from '../lib/diagnostics.zena';

/**
 * In-memory CompilerHost backed by a HashMap.
 *
 * Tests call `addFile` to register virtual files, then pass
 * the host to `makeCompiler` or `createCompiler`.
 */
export class MockHost implements CompilerHost {
  #files = new HashMap<String, String>();

  addFile(path: String, content: String): void {
    this.#files[path] = content;
  }

  readFile(path: String): String {
    return this.#files.getOr(path, '');
  }
}

/**
 * Create a Compiler with minimal stdlib stubs.
 *
 * Registers empty `zena:string` and `zena:array` modules so that
 * test files don't need to worry about stdlib resolution.
 */
export let makeCompiler = (host: MockHost): Compiler => {
  host.addFile("zena:string", "export class String {}");
  host.addFile("zena:array", "export class Array {}");

  let packages = new HashMap<String, PackageConfig>();
  let options = new CompilerOptions("host", "/stdlib", packages, null);
  return createCompiler(host, options);
};

/**
 * Filter an array of diagnostics down to errors only.
 */
export let errorDiagnostics = (diags: Array<Diagnostic>): Array<Diagnostic> => {
  let errors = new Array<Diagnostic>(4);
  // TODO: add a .filter method to Array to simplify this
  for (let diagnostic in diags) {
    if (diagnostic.severity == DiagnosticSeverity.Error) {
      errors.push(diagnostic);
    }
  }
  return errors;
};
