import { suite, test, TestContext } from 'zena:test';
import { equal, isTrue, isFalse } from 'zena:assert';
import { Array } from 'zena:array';
import { parse, Parser } from '../lib/parser.zena';
import { 
  Module, 
  Statement, 
  Expression,
  Comment,
  VariableDeclaration,
  Identifier,
  IdentifierPattern,
  NumberLiteral,
  StringLiteral,
  BooleanLiteral,
  BinaryExpression,
  ExpressionStatement
} from '../lib/ast.zena';

// ============================================================================
// Tests
// ============================================================================

export let tests = suite('Parser', (): void => {

  // ==========================================================================
  // Variable Declarations
  // ==========================================================================

  suite('Variable Declarations', (): void => {
    test('should parse let declaration', (ctx: TestContext): void => {
      let source = 'let x = 1;';
      let mod = parse(source, 'test.zena');
      
      equal(mod.body.length, 1);
      
      let decl = mod.body[0] as VariableDeclaration;
      equal(decl.kind, 'let');
      isFalse(decl.exported);
      
      let pattern = decl.pattern as IdentifierPattern;
      equal(pattern.name, 'x');
      
      let init = decl.init as NumberLiteral;
      equal(init.raw, '1');
    });

    test('should parse var declaration', (ctx: TestContext): void => {
      let source = 'var y = 42;';
      let mod = parse(source, 'test.zena');
      
      equal(mod.body.length, 1);
      
      let decl = mod.body[0] as VariableDeclaration;
      equal(decl.kind, 'var');
      
      let pattern = decl.pattern as IdentifierPattern;
      equal(pattern.name, 'y');
      
      let init = decl.init as NumberLiteral;
      equal(init.raw, '42');
    });

    test('should parse exported let declaration', (ctx: TestContext): void => {
      let source = 'export let z = 0;';
      let mod = parse(source, 'test.zena');
      
      let decl = mod.body[0] as VariableDeclaration;
      isTrue(decl.exported);
      equal(decl.kind, 'let');
      
      let pattern = decl.pattern as IdentifierPattern;
      equal(pattern.name, 'z');
    });
  });

  // ==========================================================================
  // Expressions
  // ==========================================================================

  suite('Expressions', (): void => {
    test('should parse binary expression', (ctx: TestContext): void => {
      let source = 'x + 1;';
      let mod = parse(source, 'test.zena');
      
      equal(mod.body.length, 1);
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BinaryExpression;
      equal(expr.operator, '+');
      
      let left = expr.left as Identifier;
      equal(left.name, 'x');
      
      let right = expr.right as NumberLiteral;
      equal(right.raw, '1');
    });

    test('should parse subtraction', (ctx: TestContext): void => {
      let source = 'a - b;';
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BinaryExpression;
      
      equal(expr.operator, '-');
    });

    test('should parse multiplication', (ctx: TestContext): void => {
      let source = 'a * b;';
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BinaryExpression;
      
      equal(expr.operator, '*');
    });

    test('should parse division', (ctx: TestContext): void => {
      let source = 'a / b;';
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BinaryExpression;
      
      equal(expr.operator, '/');
    });

    test('should respect operator precedence', (ctx: TestContext): void => {
      let source = 'a + b * c;';
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BinaryExpression;
      
      // Should be a + (b * c), so outer is +
      equal(expr.operator, '+');
      
      // Left should be identifier a
      let left = expr.left as Identifier;
      equal(left.name, 'a');
      
      // Right should be b * c
      let right = expr.right as BinaryExpression;
      equal(right.operator, '*');
    });
  });

  // ==========================================================================
  // Literals
  // ==========================================================================

  suite('Literals', (): void => {
    test('should parse boolean true', (ctx: TestContext): void => {
      let source = 'true;';
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BooleanLiteral;
      
      isTrue(expr.value);
    });

    test('should parse boolean false', (ctx: TestContext): void => {
      let source = 'false;';
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as BooleanLiteral;
      
      isFalse(expr.value);
    });

    test('should parse string literal', (ctx: TestContext): void => {
      let source = "'hello';";
      let mod = parse(source, 'test.zena');
      
      let stmt = mod.body[0] as ExpressionStatement;
      let expr = stmt.expression as StringLiteral;
      
      equal(expr.value, 'hello');
    });
  });

  // ==========================================================================
  // Comment Collection via Parser
  // ==========================================================================

  suite('Comments', (): void => {
    test('should collect comments on module', (ctx: TestContext): void => {
      let source = '// a comment\nlet x = 1;';
      let mod = parse(source, 'test.zena');

      equal(mod.comments.length, 1);
      equal(mod.comments[0].value, ' a comment');
      equal(mod.comments[0].isBlock, false);
    });

    test('should collect block comments on module', (ctx: TestContext): void => {
      let source = '/* block */\nlet x = 1;';
      let mod = parse(source, 'test.zena');

      equal(mod.comments.length, 1);
      equal(mod.comments[0].value, ' block ');
      equal(mod.comments[0].isBlock, true);
    });

    test('should collect multiple comments', (ctx: TestContext): void => {
      let source = '// first\n// second\nlet x = 1;';
      let mod = parse(source, 'test.zena');

      equal(mod.comments.length, 2);
      equal(mod.comments[0].value, ' first');
      equal(mod.comments[1].value, ' second');
    });

    test('should have empty comments when none present', (ctx: TestContext): void => {
      let source = 'let x = 1;';
      let mod = parse(source, 'test.zena');

      equal(mod.comments.length, 0);
    });

    test('should preserve comment positions', (ctx: TestContext): void => {
      let source = 'let a = 1;\n// between\nlet b = 2;';
      let mod = parse(source, 'test.zena');

      equal(mod.comments.length, 1);
      equal(mod.comments[0].value, ' between');
      equal(mod.comments[0].line, 2);
      equal(mod.comments[0].start, 11);
    });
  });
});


