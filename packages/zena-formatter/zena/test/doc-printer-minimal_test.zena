// Minimal doc printer test

import { suite, test, TestContext } from 'zena:test';
import { equal } from 'zena:assert';
import { Doc, text, concat, group, line, softline, hardline } from '../lib/doc.zena';
import { printDocToString, PrintOptions } from '../lib/doc-printer.zena';
import { Array } from 'zena:array';

let print = (doc: Doc, width: i32): String => {
  let opts = new PrintOptions(width);
  return printDocToString(doc, opts);
};

let print80 = (doc: Doc): String => print(doc, 80);

let tests = suite('doc-printer-minimal', () => {
  test('prints plain text', (t: TestContext) => {
    equal(print80(text('hello')), 'hello');
  });

  test('concat test', (t: TestContext) => {
    let arr = new Array<Doc>();
    arr.push(text('hello'));
    arr.push(text('world'));
    let doc = concat(arr);
    equal(print80(doc), 'helloworld');
  });
});

export let main = (): i32 => {
  let result = tests.run();
  return result.failed;
};
