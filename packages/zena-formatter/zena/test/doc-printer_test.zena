// Doc printer unit tests — tests the line-breaking algorithm in isolation
// without going through the parser. Constructs Doc IR directly and
// verifies string output.

import { suite, test, TestContext } from 'zena:test';
import { equal } from 'zena:assert';
import { Array } from 'zena:array';
import { console } from 'zena:console';
import {
  Doc,
  text,
  concat,
  group,
  groupBreak,
  indent,
  dedent,
  join,
  line,
  softline,
  hardline,
  literalline,
  ifBreak,
  fill,
  lineSuffix,
  breakParent,
  trim
} from '../lib/doc.zena';
import { printDocToString, PrintOptions } from '../lib/doc-printer.zena';

// Helper: print a doc with a given width
let print = (doc: Doc, width: i32): String => {
  let opts = new PrintOptions(width);
  return printDocToString(doc, opts);
};

// Helper: print a doc with default 80-col width
let print80 = (doc: Doc): String => print(doc, 80);

// Debug helper: check and log
let check = (name: String, actual: String, expected: String): void => {
  if (actual != expected) {
    console.log('FAIL: ' + name);
    console.log('  actual:   [' + actual + ']');
    console.log('  expected: [' + expected + ']');
  }
  equal(actual, expected, name);
};

let tests = suite('doc-printer', () => {

  // ========================================================================
  // Basic text
  // ========================================================================

  suite('text', () => {
    test('prints plain text', (t: TestContext) => {
      check('prints plain text', print80(text('hello')), 'hello');
    });

    test('concatenates text docs', (t: TestContext) => {
      let doc = concat([text('hello'), text(' '), text('world')]);
      check('concatenates text docs', print80(doc), 'hello world');
    });
  });

  // ========================================================================
  // Groups and line breaking
  // ========================================================================

  suite('group', () => {
    test('group fits on one line', (t: TestContext) => {
      let doc = group(concat([text('a'), text(', '), text('b'), text(', '), text('c')]));
      check('group fits on one line', print80(doc), 'a, b, c');
    });

    test('group with line stays flat when it fits', (t: TestContext) => {
      let doc = group(concat([text('a'), text(','), line, text('b'), text(','), line, text('c')]));
      check('group line stays flat', print80(doc), 'a, b, c');
    });

    test('group with line breaks when too wide', (t: TestContext) => {
      let doc = group(concat([text('a'), text(','), line, text('b'), text(','), line, text('c')]));
      check('group line breaks too wide', print(doc, 5), 'a,\nb,\nc');
    });

    test('shouldBreak forces group to break', (t: TestContext) => {
      let doc = groupBreak(concat([text('a'), text(','), line, text('b')]));
      check('shouldBreak forces break', print80(doc), 'a,\nb');
    });
  });

  // ========================================================================
  // Softline
  // ========================================================================

  suite('softline', () => {
    test('softline is empty when flat', (t: TestContext) => {
      let doc = group(concat([text('a'), softline, text('b')]));
      check('softline flat', print80(doc), 'ab');
    });

    test('softline is newline when broken', (t: TestContext) => {
      let doc = group(concat([text('a'), softline, text('b')]));
      check('softline newline', print(doc, 1), 'a\nb');
    });
  });

  // ========================================================================
  // Hardline
  // ========================================================================

  suite('hardline', () => {
    test('hardline always breaks', (t: TestContext) => {
      let doc = concat([text('a'), hardline, text('b')]);
      check('hardline always breaks', print80(doc), 'a\nb');
    });
  });

  // ========================================================================
  // Indent
  // ========================================================================

  suite('indent', () => {
    test('indent adds spaces after line break', (t: TestContext) => {
      let doc = indent(concat([text('a'), hardline, text('b')]));
      check('indent adds spaces', print80(doc), 'a\n  b');
    });

    test('nested indent adds more spaces', (t: TestContext) => {
      let doc = indent(indent(concat([text('a'), hardline, text('b')])));
      check('nested indent', print80(doc), 'a\n    b');
    });

    test('indent inside group adds spaces when broken', (t: TestContext) => {
      let doc = group(concat([
        text('{'),
        indent(concat([line, text('a'), line, text('b')])),
        line,
        text('}')
      ]));
      check('indent in group', print(doc, 5), '{\n  a\n  b\n}');
    });
  });

  // ========================================================================
  // IfBreak
  // ========================================================================

  suite('ifBreak', () => {
    test('ifBreak uses flat contents when group fits', (t: TestContext) => {
      let doc = group(concat([text('('), ifBreak(text('BREAK'), text('flat')), text(')')]));
      check('ifBreak flat', print80(doc), '(flat)');
    });

    test('ifBreak uses break contents when group breaks', (t: TestContext) => {
      let doc = group(concat([
        text('('),
        ifBreak(text('BREAK'), text('flat')),
        line,
        text('long_text_here'),
        text(')')
      ]));
      check('ifBreak broken', print(doc, 10), '(BREAK\nlong_text_here)');
    });
  });

  // ========================================================================
  // Join
  // ========================================================================

  suite('join', () => {
    test('join with separator', (t: TestContext) => {
      let doc = join(text(', '), [text('a'), text('b'), text('c')]);
      check('join separator', print80(doc), 'a, b, c');
    });

    test('join single item', (t: TestContext) => {
      let doc = join(text(', '), [text('a')]);
      check('join single', print80(doc), 'a');
    });

    test('join empty', (t: TestContext) => {
      let items = new Array<Doc>();
      let doc = join(text(', '), items);
      check('join empty', print80(doc), '');
    });
  });

  // ========================================================================
  // Fill
  // ========================================================================

  suite('fill', () => {
    test('fill prints all parts when fits', (t: TestContext) => {
      let doc = fill([text('word1'), text(' '), text('word2'), text(' '), text('word3')]);
      check('fill parts', print80(doc), 'word1 word2 word3');
    });

    test('fill keeps everything flat when it fits', (t: TestContext) => {
      let doc = fill([text('a'), line, text('b'), line, text('c')]);
      check('fill flat', print80(doc), 'a b c');
    });

    test('fill wraps greedily at line width', (t: TestContext) => {
      let doc = fill([text('aaa'), line, text('bbb'), line, text('ccc'), line, text('ddd')]);
      // Width 10: "aaa bbb" fits (7), "aaa bbb ccc" doesn't (11)
      // → break after bbb, then "ccc ddd" fits (7)
      check('fill wraps', print(doc, 10), 'aaa bbb\nccc ddd');
    });

    test('fill breaks every line when very narrow', (t: TestContext) => {
      let doc = fill([text('aaa'), line, text('bbb'), line, text('ccc')]);
      // Width 5: "aaa bbb" doesn't fit → break after each
      check('fill narrow', print(doc, 5), 'aaa\nbbb\nccc');
    });

    test('fill with indent', (t: TestContext) => {
      let doc = indent(fill([text('aaa'), line, text('bbb'), line, text('ccc'), line, text('ddd')]));
      // Width 10: "aaa bbb" fits (7), "aaa bbb ccc" doesn't (11)
      // After break, pos=2 (indent): "ccc ddd" fits (7+2=9 < 10)
      check('fill indent', print(doc, 10), 'aaa bbb\n  ccc ddd');
    });

    test('fill single item', (t: TestContext) => {
      let doc = fill([text('hello')]);
      check('fill single', print80(doc), 'hello');
    });

    test('fill empty', (t: TestContext) => {
      let doc = fill(new Array<Doc>());
      check('fill empty', print80(doc), '');
    });
  });

  // ========================================================================
  // LineSuffix
  // ========================================================================

  suite('lineSuffix', () => {
    test('lineSuffix flushes before newline', (t: TestContext) => {
      let doc = concat([text('code'), lineSuffix(text(' // comment')), hardline]);
      check('lineSuffix flushes', print80(doc), 'code // comment\n');
    });
  });

  // ========================================================================
  // Real-world patterns
  // ========================================================================

  suite('patterns', () => {
    test('argument list stays flat when short', (t: TestContext) => {
      let argList = join(concat([text(','), line]), [text('a'), text('b')]);
      let doc = group(concat([
        text('fn('),
        indent(concat([softline, argList])),
        softline,
        text(')'),
        text(';')
      ]));
      check('arg list flat', print80(doc), 'fn(a, b);');
    });

    test('argument list breaks when long', (t: TestContext) => {
      let argList = join(concat([text(','), line]), [text('longArgName1'), text('longArgName2'), text('longArgName3')]);
      let doc = group(concat([
        text('fn('),
        indent(concat([softline, argList])),
        softline,
        text(')'),
        text(';')
      ]));
      check('arg list breaks', print(doc, 25), 'fn(\n  longArgName1,\n  longArgName2,\n  longArgName3\n);');
    });

    test('block statement formatting', (t: TestContext) => {
      let stmts = concat([text('a;'), hardline, text('b;')]);
      let doc = concat([
        text('{'),
        indent(concat([hardline, stmts])),
        hardline,
        text('}')
      ]);
      check('block stmt', print80(doc), '{\n  a;\n  b;\n}');
    });
  });

  // ========================================================================
  // propagateBreaks
  //
  // These are NOT ports of Prettier tests — they're hand-written tests for
  // our propagateBreaks implementation. The current printer doesn't emit
  // breakParent yet, so these verify the algorithm at the IR level.
  // See formatter_test.zena for source→output tests that exercise
  // hardline propagation through real Zena code.
  // ========================================================================

  suite('propagateBreaks', () => {
    test('breakParent forces enclosing group to break', (t: TestContext) => {
      let doc = group(concat([text('a'), text(','), line, text('b'), breakParent]));
      // Without propagateBreaks this fits on one line: "a, b"
      // With propagateBreaks the group is forced to break
      check('breakParent breaks group', print80(doc), 'a,\nb');
    });

    test('hardline forces enclosing group to break', (t: TestContext) => {
      let doc = group(concat([text('a'), line, text('b'), hardline, text('c')]));
      // hardline forces the group to break, so line becomes newline too
      check('hardline breaks group', print80(doc), 'a\nb\nc');
    });

    test('breakParent propagates through nested groups', (t: TestContext) => {
      let inner = group(concat([breakParent, text('x')]));
      let outer = group(concat([text('a'), line, inner]));
      // breakParent breaks inner, which propagates to outer
      check('breakParent propagates', print80(outer), 'a\nx');
    });

    test('hardline in nested group breaks all ancestors', (t: TestContext) => {
      let inner = group(concat([text('x'), hardline, text('y')]));
      let outer = group(concat([
        text('{'),
        indent(concat([line, inner])),
        line,
        text('}')
      ]));
      // hardline breaks inner → propagates to outer
      check('hardline propagates', print80(outer), '{\n  x\n  y\n}');
    });

    test('groups without breakParent remain unaffected', (t: TestContext) => {
      let doc = group(concat([text('a'), text(','), line, text('b')]));
      check('no breakParent stays flat', print80(doc), 'a, b');
    });
  });

  // ========================================================================
  // fits with restCmds — group considers rest of line
  // ========================================================================

  suite('restCmds', () => {
    test('group considers rest of line in fits check', (t: TestContext) => {
      // Group alone = "a b" = 3 chars, fits at width 10.
      // But rest of line has "XXXXXXXXXXX" (11 chars), total 14 > 10.
      // With restCmds scan, group correctly breaks.
      let inner = group(concat([text('a'), line, text('b')]));
      let doc = concat([inner, text('XXXXXXXXXXX')]);
      check('restCmds basic', print(doc, 10), 'a\nbXXXXXXXXXXX');
    });

    test('nested group considers rest of line', (t: TestContext) => {
      // Inner group "aaa bbb" = 7 chars. Outer has inner + " cccccccccc" (11).
      // Width 15: outer breaks (18 > 15). Inner with restCmds also breaks (18 > 15).
      let inner = group(concat([text('aaa'), line, text('bbb')]));
      let outer = group(concat([inner, text(' cccccccccc')]));
      check('restCmds nested', print(outer, 15), 'aaa\nbbb cccccccccc');
    });

    test('group fits when rest of line is short', (t: TestContext) => {
      // Group "a b" = 3 chars + rest "XX" = 2 chars, total 5 < 10. Stays flat.
      let inner = group(concat([text('a'), line, text('b')]));
      let doc = concat([inner, text('XX')]);
      check('restCmds fits', print(doc, 10), 'a bXX');
    });
  });
});

// Entry point
export let main = (): i32 => {
  let result = tests.run();
  return result.failed;
};
