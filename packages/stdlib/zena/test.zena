import { String } from 'zena:string';
import { Error } from 'zena:error';
import { Array } from 'zena:growable-array';
import { StringBuilder } from 'zena:string-builder';

// Test context passed to each test function
export class TestContext {
  name: String;

  new(name: String) : name = name;
}

// Result of a single test execution
export class TestResult {
  name: String;
  passed: boolean;
  error: String | null;

  new(name: String, passed: boolean, error: String | null)
    : name = name, passed = passed, error = error;
}

// Result of running a suite
export class SuiteResult {
  name: String;
  tests: Array<TestResult>;
  suites: Array<SuiteResult>;
  var passed: i32;
  var failed: i32;

  new(name: String)
    : name = name, tests = new Array<TestResult>(), suites = new Array<SuiteResult>(), passed = 0, failed = 0;

  addTestResult(result: TestResult): void {
    this.tests.push(result);
    if (result.passed) {
      this.passed = this.passed + 1;
    } else {
      this.failed = this.failed + 1;
    }
  }

  addSuiteResult(result: SuiteResult): void {
    this.suites.push(result);
    this.passed = this.passed + result.passed;
    this.failed = this.failed + result.failed;
  }
}

// A single test case
class TestCase {
  name: String;
  fn: (ctx: TestContext) => void;
  only: boolean;
  skip: boolean;

  new(name: String, fn: (ctx: TestContext) => void, only: boolean, skip: boolean)
    : name = name, fn = fn, only = only, skip = skip;

  run(): TestResult {
    let ctx = new TestContext(this.name);
    let result = try {
      this.fn(ctx);
      new TestResult(this.name, true, null)
    } catch (e) {
      new TestResult(this.name, false, e.message)
    };
    return result;
  }
}

// A test suite containing tests and nested suites
export class Suite {
  name: String;
  tests: Array<TestCase>;
  suites: Array<Suite>;
  var hasOnly: boolean;

  new(name: String)
    : name = name, tests = new Array<TestCase>(), suites = new Array<Suite>(), hasOnly = false;

  // Run all tests in this suite and return structured results
  run(): SuiteResult {
    let result = new SuiteResult(this.name);
    
    // Check if any test has .only
    let runOnlyTests = this.hasOnly;
    
    // Run tests
    var i: i32 = 0;
    while (i < this.tests.length) {
      let testCase = this.tests[i];
      // Skip tests that are explicitly skipped
      if (testCase.skip) {
        i = i + 1;
        continue;
      }
      // Skip non-only tests if we have .only tests
      let shouldRun = !runOnlyTests || testCase.only;
      if (shouldRun) {
        let testResult = testCase.run();
        result.addTestResult(testResult);
      }
      i = i + 1;
    }
    
    // Run nested suites
    var j: i32 = 0;
    while (j < this.suites.length) {
      let nestedSuite = this.suites[j];
      let suiteResult = nestedSuite.run();
      result.addSuiteResult(suiteResult);
      j = j + 1;
    }
    
    return result;
  }
}

// Current suite for nested test/suite registration
var currentSuite: Suite | null = null;

// Register a test in the current suite
export let test = (name: String, fn: (ctx: TestContext) => void): void => {
  if (currentSuite !== null) {
    currentSuite.tests.push(new TestCase(name, fn, false, false));
  }
};

// Register a test that will be the only one to run (for debugging)
export let testOnly = (name: String, fn: (ctx: TestContext) => void): void => {
  if (currentSuite !== null) {
    currentSuite.tests.push(new TestCase(name, fn, true, false));
    currentSuite.hasOnly = true;
  }
};

// Register a test that will be skipped
export let testSkip = (name: String, fn: (ctx: TestContext) => void): void => {
  if (currentSuite !== null) {
    currentSuite.tests.push(new TestCase(name, fn, false, true));
  }
};

// Create a test suite
export let suite = (name: String, fn: () => void): Suite => {
  let parentSuite = currentSuite;
  let newSuite = new Suite(name);
  if (parentSuite !== null) {
    parentSuite.suites.push(newSuite);
  }
  currentSuite = newSuite;
  fn();
  // Propagate hasOnly up to parent suite
  if (newSuite.hasOnly) {
    if (parentSuite !== null) {
      parentSuite.hasOnly = true;
    }
  }
  currentSuite = parentSuite;
  return newSuite;
};

// ============================================================================
// Reporting
// ============================================================================

// Format a duration in milliseconds for display
let formatDuration = (ms: i32): String => {
  if (ms < 1000) {
    return `${ms}ms`;
  }
  let secs = ms / 1000;
  let remainder = ms % 1000;
  return `${secs}.${remainder}s`;
};

// Build an indentation string (2 spaces per level)
let indent = (level: i32): String => {
  let sb = new StringBuilder(level * 2);
  var i: i32 = 0;
  while (i < level) {
    sb.append('  ');
    i = i + 1;
  }
  return sb.toString();
};

// Report a suite result tree to a write function (spec reporter style).
// The write function is called once per line of output.
let reportSuite = (result: SuiteResult, write: (s: String) => void, level: i32): void => {
  let prefix = indent(level);

  // Print suite header
  if (level > 0) {
    write(`${prefix}▶ ${result.name}`);
  }

  // Print test results
  let testPrefix = indent(level + 1);
  var i: i32 = 0;
  while (i < result.tests.length) {
    let t = result.tests[i];
    if (t.passed) {
      write(`${testPrefix}✔ ${t.name}`);
    } else {
      write(`${testPrefix}✖ ${t.name}`);
      if (t.error !== null) {
        write(`${testPrefix}    ${t.error}`);
      }
    }
    i = i + 1;
  }

  // Print nested suites
  var j: i32 = 0;
  while (j < result.suites.length) {
    reportSuite(result.suites[j], write, level + 1);
    j = j + 1;
  }
};

// Run a suite, print results, and return the number of failures.
// This is the standard entry point for test runners.
//
// Usage in a test wrapper:
//   import { tests } from './my_test.zena';
//   import { runAndReport } from 'zena:test';
//   export let main = (): i32 => runAndReport(tests, console.log);
export let runAndReport = (s: Suite, write: (s: String) => void): i32 => {
  let result = s.run();

  // Print suite name as header
  let icon = if (result.failed > 0) '✖' else '✔';
  write(`${icon} ${result.name}`);

  // Print test tree
  reportSuite(result, write, 0);

  // Print summary
  let total = result.passed + result.failed;
  write('');
  if (result.failed == 0) {
    write(`✓ ${result.passed} of ${total} test(s) passed`);
  } else {
    write(`✗ ${result.failed} failed, ${result.passed} passed of ${total} test(s)`);
  }

  return result.failed;
};
