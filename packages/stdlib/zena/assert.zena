import { Error } from 'zena:error';
import { JsonValue, JsonObject, JsonArray, SourceLocation } from 'zena:json';
import { Box } from 'zena:box';
import { Array } from 'zena:growable-array';
import { StringBuilder } from 'zena:string-builder';

export class AssertionError extends Error {
  op: String;
  loc: String | null;

  new(message: String, this.op: String, this.loc: String | null = null)
    : super(if (loc != null) { (loc as String) + ": " + message } else { message });
}

export let equal = <T>(actual: T, expected: T, message: String = 'Values not equal', loc: String | null = __LOCATION__): void => {
  if (actual != expected) {
    throw new AssertionError(message, '==', loc);
  }
};

export let notEqual = <T>(actual: T, expected: T, message: String = 'Values should not be equal', loc: String | null = __LOCATION__): void => {
  if (actual == expected) {
    throw new AssertionError(message, '!=', loc);
  }
};

export let same = <T>(actual: T, expected: T, message: String = 'References not identical', loc: String | null = __LOCATION__): void => {
  if (actual !== expected) {
    throw new AssertionError(message, '===', loc);
  }
};

export let notSame = <T>(actual: T, expected: T, message: String = 'References should not be identical', loc: String | null = __LOCATION__): void => {
  if (actual === expected) {
    throw new AssertionError(message, '!==', loc);
  }
};

export let isNull = <T extends anyref>(value: T | null, message: String = 'Expected null', loc: String | null = __LOCATION__): void => {
  if (value !== null) {
    throw new AssertionError(message, 'isNull', loc);
  }
};

export let isNotNull = <T extends anyref>(value: T | null, message: String = 'Expected non-null value', loc: String | null = __LOCATION__): void => {
  if (value === null) {
    throw new AssertionError(message, 'isNotNull', loc);
  }
};

export let isTrue = (value: boolean, message: String = 'Expected true', loc: String | null = __LOCATION__): void => {
  if (value !== true) {
    throw new AssertionError(message, 'isTrue', loc);
  }
};

export let isFalse = (value: boolean, message: String = 'Expected false', loc: String | null = __LOCATION__): void => {
  if (value !== false) {
    throw new AssertionError(message, 'isFalse', loc);
  }
};

// Comparison assertions
export let greater = <T>(actual: T, expected: T, message: String = 'Expected actual > expected', loc: String | null = __LOCATION__): void => {
  if (actual <= expected) {
    throw new AssertionError(message, '>', loc);
  }
};

export let greaterOrEqual = <T>(actual: T, expected: T, message: String = 'Expected actual >= expected', loc: String | null = __LOCATION__): void => {
  if (actual < expected) {
    throw new AssertionError(message, '>=', loc);
  }
};

export let less = <T>(actual: T, expected: T, message: String = 'Expected actual < expected', loc: String | null = __LOCATION__): void => {
  if (actual >= expected) {
    throw new AssertionError(message, '<', loc);
  }
};

export let lessOrEqual = <T>(actual: T, expected: T, message: String = 'Expected actual <= expected', loc: String | null = __LOCATION__): void => {
  if (actual > expected) {
    throw new AssertionError(message, '<=', loc);
  }
};

// Exception assertions
export let throws = (fn: () => void, message: String = 'Expected function to throw', loc: String | null = __LOCATION__): void => {
  try {
    fn();
  } catch (e) {
    return;
  }
  throw new AssertionError(message, 'throws', loc);
};

export let doesNotThrow = (fn: () => void, message: String = 'Expected function not to throw', loc: String | null = __LOCATION__): void => {
  try {
    fn();
  } catch (e) {
    throw new AssertionError(message, 'doesNotThrow', loc);
  }
};

export let fail = (message: String = 'Test failed', loc: String | null = __LOCATION__): never => {
  throw new AssertionError(message, 'fail', loc);
};

// ============================================================================
// Structural JSON comparison
// ============================================================================

// Describe the JSON type of a value for error messages.
let describeJsonType = (value: JsonValue): String => {
  if (value == null) { return 'null'; }
  if (value is JsonObject) { return 'object'; }
  if (value is JsonArray) { return 'array'; }
  if (value is String) { return 'string'; }
  if (value is Box<f64>) { return 'number'; }
  if (value is Box<boolean>) { return 'boolean'; }
  return 'unknown';
};

// Short string representation of a JSON value for error messages.
let describeJsonValue = (value: JsonValue): String => {
  if (value == null) { return 'null'; }
  if (value is String) {
    let s = value as String;
    if (s.length > 50) {
      return '"' + s.sliceBytes(0, 47) + '..."';
    }
    return '"' + s + '"';
  }
  if (value is Box<f64>) {
    let sb = new StringBuilder();
    sb.appendF64((value as Box<f64>).value);
    return sb.toString();
  }
  if (value is Box<boolean>) {
    return if ((value as Box<boolean>).value) { 'true' } else { 'false' };
  }
  if (value is JsonObject) {
    let obj = value as JsonObject;
    let sb = new StringBuilder();
    sb.append('{');
    var count = 0;
    obj.forEach((key: String, v: any) => {
      if (count >= 5) { return; }
      if (count > 0) { sb.append(', '); }
      sb.append(key);
      count += 1;
    });
    if (obj.size > 5) { sb.append(', ...'); }
    sb.append('}');
    return sb.toString();
  }
  if (value is JsonArray) {
    let sb = new StringBuilder();
    sb.append('[...] (');
    sb.appendI32((value as JsonArray).length);
    sb.append(' elements)');
    return sb.toString();
  }
  return 'unknown';
};

// Format a single diff entry with path, source location, and expected/actual.
let formatJsonDiff = (path: String, loc: SourceLocation | null, expected: String, actual: String): String => {
  let sb = new StringBuilder();
  sb.append('  at ');
  sb.append(path);
  if (loc != null) {
    let l = loc as SourceLocation;
    sb.append(' (line ');
    sb.appendI32(l.line);
    sb.append(')');
  }
  sb.append(':\n    expected: ');
  sb.append(expected);
  sb.append('\n    actual:   ');
  sb.append(actual);
  return sb.toString();
};

// Format an array index as a string, e.g. "[3]"
let indexStr = (i: i32): String => {
  let sb = new StringBuilder();
  sb.append('[');
  sb.appendI32(i);
  sb.append(']');
  return sb.toString();
};

// Recursively collect structural differences between two JSON values.
// Stops after maxDiffs differences have been found.
let collectJsonDiffs = (
  actual: JsonValue,
  expected: JsonValue,
  path: String,
  loc: SourceLocation | null,
  diffs: Array<String>,
  maxDiffs: i32
): void => {
  if (diffs.length >= maxDiffs) { return; }

  // Both null — equal
  if (actual == null && expected == null) { return; }

  // Null mismatch
  if (expected == null) {
    diffs.push(formatJsonDiff(path, loc, 'null', describeJsonValue(actual)));
    return;
  }
  if (actual == null) {
    diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), 'null'));
    return;
  }

  // Object comparison
  if (expected is JsonObject) {
    if (!(actual is JsonObject)) {
      diffs.push(formatJsonDiff(path, loc, 'object', describeJsonType(actual)));
      return;
    }
    let expectedObj = expected as JsonObject;
    let actualObj = actual as JsonObject;

    // Missing keys (in expected but not actual)
    expectedObj.forEach((key: String, value: JsonValue) => {
      if (diffs.length >= maxDiffs) { return; }
      if (!actualObj.has(key)) {
        let keyLoc = expectedObj.locationOf(key);
        diffs.push(formatJsonDiff(path + '.' + key, keyLoc, describeJsonValue(value), 'missing'));
      }
    });

    // Extra keys (in actual but not expected)
    actualObj.forEach((key: String, value: JsonValue) => {
      if (diffs.length >= maxDiffs) { return; }
      if (!expectedObj.has(key)) {
        diffs.push(formatJsonDiff(path + '.' + key, null, 'missing', describeJsonValue(value)));
      }
    });

    // Recurse on shared keys
    expectedObj.forEach((key: String, value: JsonValue) => {
      if (diffs.length >= maxDiffs) { return; }
      if (actualObj.has(key)) {
        let keyLoc = expectedObj.locationOf(key);
        collectJsonDiffs(actualObj[key], value, path + '.' + key, keyLoc, diffs, maxDiffs);
      }
    });
    return;
  }

  // Array comparison
  if (expected is JsonArray) {
    if (!(actual is JsonArray)) {
      diffs.push(formatJsonDiff(path, loc, 'array', describeJsonType(actual)));
      return;
    }
    let expectedArr = expected as JsonArray;
    let actualArr = actual as JsonArray;

    if (expectedArr.length != actualArr.length && diffs.length < maxDiffs) {
      let sb = new StringBuilder();
      sb.append('array length ');
      sb.appendI32(expectedArr.length);
      let sb2 = new StringBuilder();
      sb2.append('array length ');
      sb2.appendI32(actualArr.length);
      diffs.push(formatJsonDiff(path, loc, sb.toString(), sb2.toString()));
    }

    let minLen = if (expectedArr.length < actualArr.length) { expectedArr.length } else { actualArr.length };
    var i = 0;
    while (i < minLen && diffs.length < maxDiffs) {
      let elemLoc = expectedArr.locationOf(i);
      collectJsonDiffs(actualArr[i], expectedArr[i], path + indexStr(i), elemLoc, diffs, maxDiffs);
      i += 1;
    }
    return;
  }

  // String comparison
  if (expected is String) {
    if (!(actual is String)) {
      diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), describeJsonType(actual)));
      return;
    }
    if ((actual as String) != (expected as String)) {
      diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), describeJsonValue(actual)));
    }
    return;
  }

  // Number comparison
  if (expected is Box<f64>) {
    if (!(actual is Box<f64>)) {
      diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), describeJsonType(actual)));
      return;
    }
    let expectedNum = (expected as Box<f64>).value;
    let actualNum = (actual as Box<f64>).value;
    if (expectedNum != actualNum) {
      diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), describeJsonValue(actual)));
    }
    return;
  }

  // Boolean comparison
  if (expected is Box<boolean>) {
    if (!(actual is Box<boolean>)) {
      diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), describeJsonType(actual)));
      return;
    }
    let expectedBool = (expected as Box<boolean>).value;
    let actualBool = (actual as Box<boolean>).value;
    if (expectedBool != actualBool) {
      diffs.push(formatJsonDiff(path, loc, describeJsonValue(expected), describeJsonValue(actual)));
    }
    return;
  }
};

// Assert that two JSON values are structurally equal.
// Reports up to 10 differences with JSON paths and source locations (if available
// on the expected value, e.g. when parsed with parseJson).
export let jsonEqual = (actual: JsonValue, expected: JsonValue, message: String = 'JSON mismatch', loc: String | null = __LOCATION__): void => {
  let diffs = new Array<String>(8);
  collectJsonDiffs(actual, expected, '$', null, diffs, 10);
  if (diffs.length > 0) {
    let sb = new StringBuilder();
    sb.append(message);
    sb.append(' (');
    sb.appendI32(diffs.length);
    sb.append(' difference');
    if (diffs.length > 1) { sb.append('s'); }
    sb.append('):\n');
    var i = 0;
    while (i < diffs.length) {
      sb.append(diffs[i]);
      sb.append('\n');
      i += 1;
    }
    throw new AssertionError(sb.toString(), 'jsonEqual', loc);
  }
};
