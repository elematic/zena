// String stdlib tests using zena:test
import {suite, test, TestContext} from 'zena:test';
import {equal} from 'zena:assert';

export let tests = suite('String', (): void => {
  suite('startsWith', (): void => {
    test('returns true for matching prefix', (ctx: TestContext): void => {
      equal("hello world".startsWith("hello"), true);
    });

    test('returns true for empty prefix', (ctx: TestContext): void => {
      equal("hello".startsWith(""), true);
    });

    test('returns false for non-matching prefix', (ctx: TestContext): void => {
      equal("hello world".startsWith("world"), false);
    });

    test('returns false when prefix is longer than string', (ctx: TestContext): void => {
      equal("hi".startsWith("hello"), false);
    });

    test('returns true when prefix equals string', (ctx: TestContext): void => {
      equal("hello".startsWith("hello"), true);
    });

    test('returns true for single character prefix', (ctx: TestContext): void => {
      equal("abc".startsWith("a"), true);
    });

    test('returns false for single character non-match', (ctx: TestContext): void => {
      equal("abc".startsWith("b"), false);
    });

    test('empty string starts with empty string', (ctx: TestContext): void => {
      equal("".startsWith(""), true);
    });

    test('empty string does not start with non-empty', (ctx: TestContext): void => {
      equal("".startsWith("a"), false);
    });
  });

  suite('endsWith', (): void => {
    test('returns true for matching suffix', (ctx: TestContext): void => {
      equal("hello world".endsWith("world"), true);
    });

    test('returns true for empty suffix', (ctx: TestContext): void => {
      equal("hello".endsWith(""), true);
    });

    test('returns false for non-matching suffix', (ctx: TestContext): void => {
      equal("hello world".endsWith("hello"), false);
    });

    test('returns false when suffix is longer than string', (ctx: TestContext): void => {
      equal("hi".endsWith("hello"), false);
    });

    test('returns true when suffix equals string', (ctx: TestContext): void => {
      equal("hello".endsWith("hello"), true);
    });

    test('returns true for single character suffix', (ctx: TestContext): void => {
      equal("abc".endsWith("c"), true);
    });

    test('returns false for single character non-match', (ctx: TestContext): void => {
      equal("abc".endsWith("b"), false);
    });

    test('empty string ends with empty string', (ctx: TestContext): void => {
      equal("".endsWith(""), true);
    });

    test('empty string does not end with non-empty', (ctx: TestContext): void => {
      equal("".endsWith("a"), false);
    });
  });
});
