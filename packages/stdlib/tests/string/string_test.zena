import {suite, test, TestContext} from 'zena:test';
import {equal} from 'zena:assert';

export let tests = suite('String', () => {
  suite('startsWith', () => {
    test('returns true for matching prefix', () => {
      equal("hello world".startsWith("hello"), true);
    });

    test('returns true for empty prefix', () => {
      equal("hello".startsWith(""), true);
    });

    test('returns false for non-matching prefix', () => {
      equal("hello world".startsWith("world"), false);
    });

    test('returns false when prefix is longer than string', () => {
      equal("hi".startsWith("hello"), false);
    });

    test('returns true when prefix equals string', () => {
      equal("hello".startsWith("hello"), true);
    });

    test('returns true for single character prefix', () => {
      equal("abc".startsWith("a"), true);
    });

    test('returns false for single character non-match', () => {
      equal("abc".startsWith("b"), false);
    });

    test('empty string starts with empty string', () => {
      equal("".startsWith(""), true);
    });

    test('empty string does not start with non-empty', () => {
      equal("".startsWith("a"), false);
    });
  });

  suite('endsWith', () => {
    test('returns true for matching suffix', () => {
      equal("hello world".endsWith("world"), true);
    });

    test('returns true for empty suffix', () => {
      equal("hello".endsWith(""), true);
    });

    test('returns false for non-matching suffix', () => {
      equal("hello world".endsWith("hello"), false);
    });

    test('returns false when suffix is longer than string', () => {
      equal("hi".endsWith("hello"), false);
    });

    test('returns true when suffix equals string', () => {
      equal("hello".endsWith("hello"), true);
    });

    test('returns true for single character suffix', () => {
      equal("abc".endsWith("c"), true);
    });

    test('returns false for single character non-match', () => {
      equal("abc".endsWith("b"), false);
    });

    test('empty string ends with empty string', () => {
      equal("".endsWith(""), true);
    });

    test('empty string does not end with non-empty', () => {
      equal("".endsWith("a"), false);
    });
  });

  suite('contains', () => {
    test('returns true for empty substring', () => {
      equal("hello".contains(""), true);
    });

    test('returns true for matching suffix', () => {
      equal("hello world".contains("world"), true);
    });

    test('returns true for matching prefix', () => {
      equal("hello world".contains("hello"), true);
    });

    test('returns true for matching substring', () => {
      equal("hello world".contains("ll"), true);
    });

    test('returns false when substring is longer than string', () => {
      equal("hi".contains("hello"), false);
    });

    test('returns true when substring equals string', () => {
      equal("hello".contains("hello"), true);
    });

    test('returns true for single character suffix', () => {
      equal("abc".contains("c"), true);
    });

    test('returns true for single character substring', () => {
      equal("abc".contains("b"), true);
    });

    test('returns false for non-matching substring with matching ends', () => {
      equal("abcde".contains("bxd"), false);
    });

    test('empty string contains empty string', () => {
      equal("".contains(""), true);
    });

    test('empty string does not contain non-empty', () => {
      equal("".contains("a"), false);
    });
  });

  suite('+', () => {
    test('concatenates two strings', () => {
      equal("hello " + "world", "hello world");
    });

    test('concatenates empty string with non-empty', () => {
      equal("" + "hello", "hello");
      equal("hello" + "", "hello");
    });

    test('concatenates multiple strings', () => {
      equal("a" + "b" + "c", "abc");
    });
  });
});
